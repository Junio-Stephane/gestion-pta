                            Annuler
                        </button>
                        <button type="button" class="btnG btn-successG" id="btnConfirmerChangementDirection">
                            <i class="bi bi-check-circle me-2"></i>
                            Changer la direction
                        </button>
                    </div>
                </div>
            </div>
        </div>
    `;

    document.body.insertAdjacentHTML('beforeend', modalHtml);

    const modalElement = document.getElementById('directionInactiveModal');
    
    // Ajouter l'écouteur pour le reset quand le modal est fermé
    modalElement.addEventListener('hidden.bs.modal', function() {
        const select2Instance = $(this).find('#nouvelleDirection');
        if (select2Instance.length && $.fn.select2) {
            select2Instance.select2('destroy');
        }
        
        const form = document.getElementById('changerDirectionForm');
        if (form) form.reset();
        
        // Nettoyer le modal du DOM après fermeture
        setTimeout(() => {
            if (document.body.contains(this)) {
                this.remove();
            }
        }, 300);
    });
    
    // Charger les directions actives
    this.chargerDirectionsActivesPourSelect().then(() => {
        this.configurerEvenementsModalDirection(modalElement, service);
    });

    // Afficher le modal
    const modal = new bootstrap.Modal(modalElement);
    modal.show();
}

async chargerDirectionsActivesPourSelect() {
    try {
        const response = await fetch('/admin/services/api/directions-actives');
        const data = await response.json();
        
        if (data.success) {
            const modalElement = document.getElementById('directionInactiveModal');
            
            // Attendre que le modal soit dans le DOM
            setTimeout(() => {
                const select = document.getElementById('nouvelleDirection');
                if (select && modalElement) {
                    // Initialiser Select2
                    $(select).select2({
                        theme: 'bootstrap-5',
                        width: '100%',
                        placeholder: 'Sélectionnez une direction active',
                        allowClear: false,
                        dropdownParent: $(modalElement), // Important pour le modal
                        language: {
                            noResults: () => "Aucune direction active trouvée",
                            searching: () => "Recherche en cours..."
                        }
                    });
                    
                    // Vider et remplir les options
                    $(select).empty();
                    $(select).append('<option value=""></option>');
                    
                    data.directions.forEach(direction => {
                        const optionText = `${direction.nomDirection} (${direction.CodeDirection})`;
                        const option = new Option(optionText, direction.CodeDirection, false, false);
                        $(select).append(option);
                    });
                    
                    $(select).trigger('change.select2');
                }
            }, 100); // Petit délai pour s'assurer que le DOM est prêt
        }
    } catch (error) {
        console.error('Erreur chargement directions actives:', error);
    }
}

    configurerEvenementsModalDirection(modalElement, service) {
        const btnConfirmer = document.getElementById('btnConfirmerChangementDirection');
        const form = document.getElementById('changerDirectionForm');
        const selectDirection = document.getElementById('nouvelleDirection');

        if (btnConfirmer) {
            btnConfirmer.onclick = () => {
                this.confirmerChangementDirection(service);
            };
        }

        if (selectDirection) {
            selectDirection.addEventListener('change', () => {
                // Effacer les erreurs quand l'utilisateur sélectionne une direction
                this.clearFieldError('nouvelleDirection');
            });
        }

        if (form) {
            form.addEventListener('submit', (e) => {
                e.preventDefault();
                this.confirmerChangementDirection(service);
            });
        }
    }

    async confirmerChangementDirection(service) {
        const selectDirection = document.getElementById('nouvelleDirection');
        const serviceCode = document.getElementById('changerDirectionServiceCode').value;

        if (!selectDirection || !selectDirection.value) {
            this.showFieldError('nouvelleDirection', 'Veuillez sélectionner une direction active');
            return;
        }

        const nouvelleDirectionCode = selectDirection.value;

        try {
            // Afficher le loading
            const btnConfirmer = document.getElementById('btnConfirmerChangementDirection');
            const originalText = btnConfirmer.innerHTML;
            btnConfirmer.innerHTML = '<div class="loading-spinner me-2"></div> Changement...';
            btnConfirmer.disabled = true;

            // RÉCUPÉRER LE CHEF DE SERVICE ACTUEL POUR LE CONSERVER
            const serviceActuel = this.allServices.find(s => s.CodeService === serviceCode);
            const chefServiceActuel = serviceActuel && serviceActuel.chefService ? serviceActuel.chefService.ImPer : null;

            // Préparer les données pour la modification - CONSERVER LE CHEF DE SERVICE
            const data = {
                nomService: service.nomService,
                direction: nouvelleDirectionCode,
                chefService: chefServiceActuel // CONSERVER le chef de service actuel
            };

            const response = await fetch(`/admin/services/api/${serviceCode}/modifier`, {
                method: 'PUT',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify(data)
            });

            const result = await response.json();

            if (result.success) {
                this.showSuccess('Direction changée avec succès - Le chef de service a été conservé');
                
                // Fermer le modal
                const modalElement = document.getElementById('directionInactiveModal');
                if (modalElement) {
                    bootstrap.Modal.getInstance(modalElement).hide();
                }
                
                // Recharger les services
                this.loadServices();
                
            } else {
                if (result.errors) {
                    this.showMultipleErrors(result.errors);
                } else {
                    this.showError(result.message || 'Erreur lors du changement de direction');
                }
                
                // Réactiver le bouton
                btnConfirmer.innerHTML = originalText;
                btnConfirmer.disabled = false;
            }
        } catch (error) {
            console.error('Erreur changement direction:', error);
            this.showError('Erreur lors du changement de direction');
            
            const btnConfirmer = document.getElementById('btnConfirmerChangementDirection');
            if (btnConfirmer) {
                btnConfirmer.innerHTML = '<i class="bi bi-check-circle me-2"></i> Changer la direction';
                btnConfirmer.disabled = false;
            }
        }
    }

    toggleNouveauChefGroup(option) {
        const nouveauChefGroup = document.getElementById('nouveauChefGroup');
        if (option === 'choisir') {
            nouveauChefGroup.style.display = 'block';
        } else {
            nouveauChefGroup.style.display = 'none';
        }
    }

    async activerService() {
    const form = document.getElementById('activationServiceForm');
    const submitBtn = document.getElementById('submitActivationService');
    const originalText = submitBtn.innerHTML;

    try {
        submitBtn.innerHTML = '<div class="loading-spinner me-2"></div> Activation...';
        submitBtn.disabled = true;

        const activationOption = document.querySelector('input[name="activationOption"]:checked').value;
        const nouveauChefSelect = document.getElementById('activationNouveauChef');
        
        let data = {
            garderChef: activationOption === 'garder',
            nouveauChef: null
        };

        // Seulement récupérer la valeur si l'option "choisir" est sélectionnée ET un chef est choisi
        if (activationOption === 'choisir' && nouveauChefSelect.value && nouveauChefSelect.value !== "") {
            data.nouveauChef = nouveauChefSelect.value;
        }

        const serviceCode = document.getElementById('activationServiceCode').value;
        const response = await fetch(`/admin/services/api/${serviceCode}/activer`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify(data)
        });

        const result = await response.json();

        if (result.success) {
            this.showSuccess(result.message);
            bootstrap.Modal.getInstance(document.getElementById('activationServiceModal')).hide();
            this.loadServices();
        } else {
            // GESTION DE LA DIRECTION INACTIVE (double vérification côté serveur)
            if (result.message === 'direction_inactive') {
                this.showDirectionInactiveModal(result.service);
            } else {
                this.showError(result.message);
            }
        }
    } catch (error) {
        console.error('Erreur activation:', error);
        this.showError('Erreur lors de l\'activation du service');
    } finally {
        submitBtn.innerHTML = originalText;
        submitBtn.disabled = false;
    }
}

    

    showSuccess(message) {
    const alertContainer = document.getElementById('fixedAlertContainer');
    const alert = document.createElement('div');
    alert.className = 'alert-success-fixed mb-3';
    alert.innerHTML = `
        <i class="bi bi-check-circle-fill"></i>
        <span>${message}</span>
        <button type="button" class="alert-close-btn" onclick="this.parentElement.remove()">
            <i class="bi bi-x"></i>
        </button>
    `;
    
    // Supprimer les anciennes alertes
    while (alertContainer.firstChild) {
        alertContainer.removeChild(alertContainer.firstChild);
    }
    
    // Ajouter la nouvelle alerte
    alertContainer.appendChild(alert);
    
    // Auto-suppression après 5 secondes
    setTimeout(() => {
        if (alert.parentElement) {
            alert.style.animation = 'fadeOut 0.3s ease-out';
            setTimeout(() => {
                if (alert.parentElement) {
                    alert.remove();
                }
            }, 300);
        }
    }, 5000);
}

showError(message) {
    const alertContainer = document.getElementById('fixedAlertContainer');
    const alert = document.createElement('div');
    alert.className = 'alert-danger-fixed mb-3';
    alert.innerHTML = `
        <i class="bi bi-exclamation-triangle-fill"></i>
        <span>${message}</span>
        <button type="button" class="alert-close-btn" onclick="this.parentElement.remove()">
            <i class="bi bi-x"></i>
        </button>
    `;
    
    // Supprimer les anciennes alertes
    while (alertContainer.firstChild) {
        alertContainer.removeChild(alertContainer.firstChild);
    }
    
    // Ajouter la nouvelle alerte
    alertContainer.appendChild(alert);
    
    // Auto-suppression après 5 secondes
    setTimeout(() => {
        if (alert.parentElement) {
            alert.style.animation = 'fadeOut 0.3s ease-out';
            setTimeout(() => {
                if (alert.parentElement) {
                    alert.remove();
                }
            }, 300);
        }
    }, 5000);
}
}

// Initialisation
document.addEventListener('DOMContentLoaded', function() {
    window.serviceManager = new ServiceManager();
});
</script>
{% endblock %}