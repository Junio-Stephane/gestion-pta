async loadModificationData() {
    return new Promise(async (resolve, reject) => {
        try {
            // Charger les directions d'abord
            await this.loadDirectionsActivesPourModification();
            
            // Charger les personnels ensuite
            await this.loadPersonnelsPourChefService();
            
            resolve();
        } catch (error) {
            reject(error);
        }
    });
}

