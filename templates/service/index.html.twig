    async verifierEtatDirectionAvantActivation(codeService, nomService, ancienChefNom, ancienChefIm) {
        try {
            // Récupérer les données du service pour vérifier la direction
            const service = this.allServices.find(s => s.CodeService === codeService);
            
            if (!service) {
                this.showError('Service non trouvé');
                return;
            }

            const direction = service.direction;
            
            // Vérifier si la direction existe et est active
            if (!direction || direction.statutDirection !== 'ACTIVE') {
                // Afficher le modal de direction inactive
                this.showDirectionInactiveModal({
                    codeService: codeService,
                    nomService: nomService,
                    direction: direction ? {
                        codeDirection: direction.CodeDirection,
                        nomDirection: direction.nomDirection,
                        statutDirection: direction.statutDirection
                    } : null
                });
            } else {
                // La direction est active, afficher le modal d'activation normal
                this.afficherModalActivationNormal(codeService, nomService, ancienChefNom, ancienChefIm);
            }
        } catch (error) {
            console.error('Erreur vérification direction:', error);
            this.showError('Erreur lors de la vérification de la direction');
        }
    }

    afficherModalActivationNormal(codeService, nomService, ancienChefNom, ancienChefIm) {
    // Remplir les champs du modal d'activation normal
    document.getElementById('activationServiceCode').value = codeService;
    document.getElementById('activationServiceNom').value = nomService;
    document.getElementById('activationAncienChef').value = ancienChefNom;
    
    const chefInfo = document.getElementById('activationChefInfo');
    const garderChefRadio = document.getElementById('garderChef');
    const garderChefLabel = document.querySelector('label[for="garderChef"]');
    const choisirChefRadio = document.getElementById('choisirChef');

    if (ancienChefIm && ancienChefIm !== '') {
        chefInfo.textContent = 'Cet ancien chef de service sera réactivé si vous choisissez de le garder.';
        chefInfo.className = 'form-text text-primary';
        garderChefRadio.disabled = false;
        garderChefLabel.innerHTML = 'Garder l\'ancien chef de service';
        garderChefRadio.checked = true; // Option par défaut quand disponible
    } else {
        chefInfo.textContent = 'Aucun ancien chef de service trouvé pour ce service.';
        chefInfo.className = 'form-text text-primary';
        garderChefLabel.innerHTML = 'Garder l\'ancien chef de service <span class="text-muted">(non disponible)</span>';
        garderChefRadio.disabled = true;
        garderChefRadio.checked = false;
        
        // Passer à l'option suivante disponible
        if (!choisirChefRadio.disabled) {
            choisirChefRadio.checked = true;
        } else {
