openModifierServiceModal(codeService, nomService, directionCode, directionNom, chefIm, chefNom) {
    console.log('Données reçues pour modification:', { 
        codeService, 
        nomService, 
        directionCode, 
        directionNom, 
        chefIm, 
        chefNom 
    });
    
    // Stocker les informations
    this.currentModificationData = {
        codeService,
        nomService,
        directionCode,
        directionNom,
        chefIm,
        chefNom
    };
    
    // Remplir les champs simples immédiatement
    document.getElementById('modifierServiceCode').value = codeService;
    document.getElementById('modifierCodeService').value = codeService;
    document.getElementById('modifierNomService').value = nomService;
    
    const modalElement = document.getElementById('modifierServiceModal');
    
    // Vider les selects avant de recharger
    const directionSelect = this.selects.modifierDirection;
    const chefSelect = this.selects.modifierChefService;
    
    if (directionSelect) {
        directionSelect.empty();
        directionSelect.append('<option value="">Sélectionnez une direction</option>');
        directionSelect.val('').trigger('change.select2');
    }
    
    if (chefSelect) {
        chefSelect.empty();
        chefSelect.append('<option value="">Aucun chef de service</option>');
        chefSelect.val('').trigger('change.select2');
    }
    
    // Créer le modal mais NE PAS l'afficher tout de suite
    const modal = new bootstrap.Modal(modalElement);
    
    // Charger les données AVANT d'afficher le modal
    this.loadModificationData().then(() => {
        // Appliquer les sélections après le chargement
        this.applyModificationSelections();
        
        // Maintenant afficher le modal
        modal.show();
    }).catch(error => {
        console.error('Erreur lors du chargement des données:', error);
        this.showError('Erreur lors du chargement des données');
        
        // Afficher quand même le modal même en cas d'erreur
        modal.show();
    });
