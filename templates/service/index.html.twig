{% extends 'base.html.twig' %}

{% block title %}Gestion des Services{% endblock %}

{% block stylesheets %}
<style>
/* Styles pour Select2 - Version harmonisée */
/* Styles Select2 pour les filtres (version compacte) */
.filters-container .select2-container--bootstrap-5 .select2-selection {
    min-height: 36px !important;
    height: 36px !important;
    padding: 0.375rem !important;
    font-size: 0.85rem !important;
}

.filters-container .select2-container--bootstrap-5 .select2-selection--single {
    height: 36px !important;
}

.filters-container .select2-container--bootstrap-5 .select2-selection--single .select2-selection__rendered {
    line-height: 20px !important;
    padding-left: 0.5rem !important;
    font-size: 0.85rem !important;
}

.filters-container .select2-container--bootstrap-5 .select2-selection--single .select2-selection__arrow {
    height: 34px !important;
    right: 0.5rem !important;
}

.filters-container .select2-container--bootstrap-5 .select2-dropdown {
    font-size: 0.85rem !important;
}

.filters-container .select2-container--bootstrap-5 .select2-results__option {
    padding: 0.4rem 0.6rem !important;
    font-size: 0.85rem !important;
    min-height: 34px !important;
}

/* Style spécifique pour le filtre de direction */
#directionFilter + .select2 .select2-selection {
    min-height: 36px !important;
    height: 36px !important;
}

/* Style pour les selects dans les modaux (garder la taille normale) */
.modal .select2-container--bootstrap-5 .select2-selection {
    min-height: 45px !important;
    height: 45px !important;
}

.select2-container--bootstrap-5 .select2-selection {
    min-height: 45px !important;
    height: 45px !important;
    padding: 0.575rem !important;
    border: 1px solid #d1d5db !important;
    border-radius: 6px !important;
    font-size: 0.9rem !important;
    line-height: 1.5 !important;
    background-color: white !important;
    transition: all 0.3s ease !important;
}

.select2-container--bootstrap-5 .select2-selection--single {
    height: 38px !important;
}

.select2-container--bootstrap-5 .select2-selection--single .select2-selection__rendered {
    line-height: 24px !important;
    padding-left: 0.75rem !important;
    padding-right: 2.5rem !important;
    color: #374151 !important;
}

.select2-container--bootstrap-5 .select2-selection--single .select2-selection__arrow {
    height: 36px !important;
    right: 0.5rem !important;
}

/* Style au survol (hover) */
.select2-container--bootstrap-5 .select2-selection:hover {
    border-color: #964ee3 !important;
    box-shadow: 0 0 0 3px rgba(150, 78, 227, 0.1) !important;
}

/* Style au focus */
.select2-container--bootstrap-5.select2-container--focus .select2-selection,
.select2-container--bootstrap-5.select2-container--open .select2-selection {
    border-color: #964ee3 !important;
    box-shadow: 0 0 0 3px rgba(150, 78, 227, 0.1) !important;
    outline: none !important;
}

/* Style pour le dropdown */
.select2-container--bootstrap-5 .select2-dropdown {
    border: 1px solid #d1d5db !important;
    border-radius: 6px !important;
    box-shadow: 0 4px 6px rgba(0,0,0,0.1) !important;
    background-color: white !important;
}

/* Champ de recherche dans le dropdown */
.select2-container--bootstrap-5 .select2-search--dropdown .select2-search__field {
    border: 1px solid #d1d5db !important;
    border-radius: 4px !important;
    padding: 0.375rem 0.75rem !important;
    font-size: 0.9rem !important;
    height: 38px !important;
}

.select2-container--bootstrap-5 .select2-search--dropdown .select2-search__field:focus {
    border-color: #964ee3 !important;
    box-shadow: 0 0 0 3px rgba(150, 78, 227, 0.1) !important;
    outline: none !important;
}

/* Options dans le dropdown */
.select2-container--bootstrap-5 .select2-results__option {
    padding: 0.5rem 0.75rem !important;
    font-size: 0.9rem !important;
    min-height: 38px !important;
    display: flex !important;
    align-items: center !important;
}

/* Option sélectionnée */
.select2-container--bootstrap-5 .select2-results__option--selected {
    background-color: #f3f4f6 !important;
    color: #374151 !important;
}

/* Option au survol/surbrillance */
.select2-container--bootstrap-5 .select2-results__option--highlighted.select2-results__option--selectable {
    background-color: #3f7ee3 !important;
    color: white !important;
}

/* Options désactivées */
.select2-container--bootstrap-5 .select2-results__option.option-desactive {
    color: #6b7280 !important;
    font-style: italic !important;
    background-color: #f9fafb !important;
}

.select2-container--bootstrap-5 .select2-results__option.option-desactive.select2-results__option--highlighted {
    background-color: #f3f4f6 !important;
    color: #6b7280 !important;
}

/* Style pour les sélects dans les modaux (z-index corrigé) */
.modal .select2-container {
    z-index: 1060 !important;
}

.modal .select2-dropdown {
    z-index: 1061 !important;
}

/* Style pour le placeholder */
.select2-container--bootstrap-5 .select2-selection--single .select2-selection__placeholder {
    color: #6b7280 !important;
    font-size: 0.9rem !important;
}

/* Style pour les sélects désactivés */
.select2-container--bootstrap-5 .select2-selection--single[aria-disabled="true"] {
    background-color: #f1f3f6 !important;
    border-color: #ced1d6 !important;
    color: #626771 !important;
    cursor: default !important;
}

/* Style pour le clear button */
.select2-container--bootstrap-5 .select2-selection--single .select2-selection__clear {
    height: 36px !important;
    padding: 0 0.5rem !important;
    color: #6b7280 !important;
    font-size: 1.2rem !important;
}

.select2-container--bootstrap-5 .select2-selection--single .select2-selection__clear:hover {
    color: #ef4444 !important;
}

/* Responsive adjustments */
@media (max-width: 768px) {
    .select2-container--bootstrap-5 .select2-selection {
        min-height: 36px !important;
        height: 36px !important;
        font-size: 0.85rem !important;
    }
    
    .select2-container--bootstrap-5 .select2-selection--single {
        height: 36px !important;
    }
    
    .select2-container--bootstrap-5 .select2-selection--single .select2-selection__rendered {
        padding-left: 0.5rem !important;
        font-size: 0.85rem !important;
    }
    
    .select2-container--bootstrap-5 .select2-results__option {
        font-size: 0.85rem !important;
        min-height: 36px !important;
    }
}

.services-container {
    background: #fdfdffff;
    border-radius: 12px;
    padding: 2rem;
    box-shadow: rgba(0, 0, 0, 0.13) 0px 3px 8px;
    margin-bottom: 2rem;
}

.table-services {
    width: 100%;
    border-collapse: collapse;
    margin-top: 1rem;
}

.table-services th,
.table-services td {
    padding: 1rem;
    text-align: left;
    border-bottom: 1px solid #e5e7eb;
}

.table-services th {
    background: #eaeafaff;
    font-weight: 600;
    color: #1f2937;
    font-size: 0.8rem;
    text-transform: uppercase;
}

.table-services td {
    font-size: 14px;
}

.table-services tr:hover {
    background: #f8fafc;
}

/* Ligne désactivée */
.table-services tr.service-desactive {
    background-color: #f9fafb;
    color: #6b7280;
}

.table-services tr.service-desactive:hover {
    background-color: #f3f4f6;
}

.table-services tr.service-desactive td {
    opacity: 0.7;
}

.status-badge {
    padding: 0.4rem 0.8rem;
    border-radius: 20px;
    font-size: 0.65rem;
    font-weight: 600;
}

.status-active {
    background: #d1fae5;
    color: #065f46;
}

.status-waiting {
    background: #fef3c7;
    color: #d97706;
}

.status-desactive {
    background: #e5e7eb;
    color: #374151;
}

.role-badge {
    background: #dbeafe;
    color: #1e40af;
}

.role-badge-desactive {
    background: #e5e7eb;
    color: #6b7280;
}

.actions-container {
    display: flex;
    gap: 0.2rem;
    flex-wrap: nowrap;
    align-items: center;
    justify-content: center;
    min-height: 38px;
    width: 100%;
    box-sizing: border-box;
}

/* Style pour le dropdown des services */
.dropdown .btn {
    min-width: 80px;
    max-width: 80px;
    padding: 0.1rem 0.3rem;
}

.dropdown-menu {
    min-width: 180px;
    border-radius: 6px;
    padding: 0.3rem;
}

.dropdown-item {
    padding: 0.4rem 0.6rem;
    font-size: 0.7rem;
    gap: 0.3rem;
}

.dropdown {
    display: inline-flex;
    color: #ffff;
}



/* Dropdown responsive */
.dropdown {
    display: inline-flex;
    position: relative;
}

.dropdown-menu {
    min-width: 200px;
    border-radius: 8px;
    border: 1px solid #e5e7eb;
    box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    background: #fffdf5ff;
    position: absolute;
    z-index: 1000;
}

.dropdown-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 0.8rem;
    font-size: 0.75rem;
    color: #374151;
    text-decoration: none;
    white-space: nowrap;
}

.dropdown-item:hover {
    background: #f5ebc0ff;
    color: #374151;
}

/* Responsive pour mobile - Priorité au dropdown */
@media (max-width: 768px) {
    .actions-container {
        flex-direction: row;
        gap: 0.3rem;
        min-height: auto;
        width: 100%;
        justify-content: center;
        flex-wrap: wrap;
    }
    
    .btn {
        min-width: 70px;
        padding: 0.2rem 0.4rem;
        font-size: 0.65rem;
    }
    
    /* Dropdown spécifique pour mobile */
    .dropdown {
        position: static; /* Important pour le responsive */
    }
    
    .dropdown .btn {
        min-width: 70px;
        font-size: 0.65rem;
        padding: 0.2rem 0.4rem;
    }
    
    .dropdown-menu {
        position: absolute;
        left: 50% !important;
        transform: translateX(-50%) !important;
        min-width: 180px;
        z-index: 1050;
    }
    
    /* Ajustement spécifique pour la colonne Actions */
    .table-services th:nth-child(9),
    .table-services td:nth-child(9) {
        width: 200px;
        min-width: 200px;
        max-width: 200px;
    }
    
    /* Pour les très petits écrans */
    @media (max-width: 576px) {
        .actions-container {
            flex-direction: column;
            gap: 0.2rem;
        }
        
        .dropdown-menu {
            position: fixed;
            top: 50% !important;
            left: 50% !important;
            transform: translate(-50%, -50%) !important;
            width: 90%;
            max-width: 250px;
        }
        
        .table-services th:nth-child(9),
        .table-services td:nth-child(9) {
            width: 180px;
            min-width: 180px;
            max-width: 180px;
        }
    }
}

/* Pour les tableaux - Assurer la visibilité du dropdown */
.table-responsive {
    position: relative;
    overflow-x: auto;
}

/* Empêcher le overflow-x de cacher le dropdown */
.table-services {
    position: relative;
}

/* Z-index pour s'assurer que le dropdown soit au-dessus */
.dropdown-menu {
    z-index: 1060;
}

.dropdown-item:hover {
    background: #f5ebc0ff;
}

.btnG {
    padding: 0.5rem 1rem;
    border: none;
    border-radius: 16px;
    font-size: 0.8rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.3s ease;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    min-height: 38px;
    line-height: 1;
    white-space: nowrap;
    box-shadow: rgba(60, 64, 67, 0.3) 0px 1px 2px 0px, rgba(60, 64, 67, 0.12) 0px 1px 3px 1px;
}

.btnG:hover {
    transform: translateY(-1px);
    opacity: 0.9;
}

/* Styles des boutons - Version compacte */
.btn {
    padding: 0.1rem 0.3rem;
    border: none;
    border-radius: 10px;
    font-size: 0.7rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.3s ease;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.2rem;
    white-space: nowrap;
    min-height: 28px;
    line-height: 1;
    box-shadow: rgba(60, 64, 67, 0.2) 0px 1px 2px 0px;
    flex-shrink: 0;
}

/* Styles des boutons */
.btn-warning {
    background: linear-gradient(135deg, #f5bf62ff 0%, #df9618ff 100%);
    color: #ffff;
    border: 1px solid #df9618ff;
    min-width: 80px; /* Réduit de 120px à 80px */
    max-width: 80px;
}

.btn-success {
    background: linear-gradient(135deg, #1fbe89ff 0%, #04704cff 100%);
    color: #ffff;
    border: 1px solid #087d56ff;
    min-width: 80px; /* Réduit de 120px à 80px */
    max-width: 80px;
}

.btn-danger {
    background: linear-gradient(135deg, #fa6565ff 0%, #e13636ff 100%);
    color: #ffff;
    border: 1px solid #e13636ff;
    min-width: 80px; /* Réduit de 120px à 80px */
    max-width: 80px;
}

.btn-dangerG {
    background: linear-gradient(135deg, #fa6565ff 0%, #e13636ff 100%);
    color: #ffff;
    border: 1px solid #e13636ff;
    min-width: 200px; /* Réduit de 120px à 80px */
    max-width: 200px;
}

.btn-warningG {
    background: linear-gradient(135deg, #f5bf62ff 0%, #df9618ff 100%);
    color: #ffff;
    border: 1px solid #df9618ff;
    min-width: 120px; /* Réduit de 120px à 80px */
    max-width: 120px;
}

.btn-successG {
    background: linear-gradient(135deg, #1fbe89ff 0%, #04704cff 100%);
    color: #ffff;
    border: 1px solid #087d56ff;
    min-width: 190px; /* Réduit de 120px à 80px */
    max-width: 190px;
}

.btn-primary {
    background: linear-gradient(135deg, #3f7ee3ff 0%, #2b6ed8ff 100%);
    color: white;
    border: 1px solid #3f7ee3ff;
}

.btn-secondary {
    background: #6b7280;
    color: white;
    border: 1px solid #6b7280;
}


/* Hover states */
.btn:hover:not(:disabled) {
    transform: translateY(-1px);
    color: #ffff;
}

.btn-warning:hover:not(:disabled) {
    background: #f59e0b linear-gradient(135deg, #d68d0eff 0%, #895b09ff 100%);
    border-color: #d68d0eff;
}

.btn-success:hover:not(:disabled) {
    background: linear-gradient(135deg, #0f9d6eff 0%, #036343ff 100%);
}

.btn-danger:hover:not(:disabled) {
    background: linear-gradient(135deg, #e14242ff 0%, #b01818ff 100%);
}

.btn-primary:hover:not(:disabled) {
    background: linear-gradient(135deg, #4a6897ff 0%, #1c488fff 100%);
    border-color: #1c488fff;
}

.btn-secondary:hover:not(:disabled) {
    background: #4b5563;
    border-color: #4b5563;
}

.btn-warning:hover,
.btn-warningG:hover {
    background: #f59e0b linear-gradient(135deg, #d68d0eff 0%, #895b09ff 100%);
    border-color: #d68d0eff;
}

.btn-success:hover,
.btn-successG:hover {
    background: linear-gradient(135deg, #0f9d6eff 0%, #036343ff 100%);

}

.btn-danger:hover,
.btn-dangerG:hover {
    background: linear-gradient(135deg, #e14242ff 0%, #b01818ff 100%);
}

/* Boutons désactivés */
.btn:disabled {
    opacity: 0.7;
    cursor: not-allowed;
    transform: none !important;
}

.btn-desactive {
    background: #9ca3af;
    color: white;
    border: 1px solid #9ca3af;
}

/* Modal styles */
.modal-content {
    border-radius: 12px;
    border: none;
    box-shadow: 0 20px 60px rgba(0,0,0,0.3);
}

.modal-header {
    background: linear-gradient(135deg, #964ee3 0%, #75165f 100%);
    color: white;
    border-radius: 12px 12px 0 0;
    border: none;
    padding: 1.5rem;
}

.btn-close-custom {
    background: none;
    border: none;
    font-size: 2rem;
    color: white;
    opacity: 0.8;
    transition: all 0.3s ease;
    padding: 0.5rem;
    line-height: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    margin: -0.5rem -0.5rem -0.5rem auto;
}

.btn-close-custom:hover {
    opacity: 1;
    background: rgba(255, 255, 255, 0.2);
}


.modal-title {
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0;
}

.modal-body {
    padding: 1.5rem;
}

.modal-footer {
    border-top: 1px solid #e5e7eb;
    padding: 1rem 1.5rem;
}

.changerDirectionForm {
    margin: 8px 0;
    padding: 12px;
    background: #f6effeff;
    border-radius: 8px;
    border: 1px solid #cb9dfdff;
}

.btn-close-white {
    filter: invert(1);
}

.form-group {
    margin-bottom: 1.25rem;
}

.form-label {
    font-weight: 500;
    color: #374151;
    margin-bottom: 0.5rem;
    display: block;
}

.form-control, .form-select {
    width: 100%;
    padding: 0.75rem;
    border: 1px solid #d1d5db;
    border-radius: 6px;
    background: white;
    font-size: 0.9rem;
    transition: all 0.3s ease;
}

.form-control[readonly]{
    background-color: #f1f3f6ff;
    border-color: #ced1d6ff;
    color: #626771ff;
    cursor: default;
}

.form-control:focus, .form-select:focus {
    outline: none;
    border-color: #964ee3;
    box-shadow: 0 0 0 3px rgba(150, 78, 227, 0.1);
}

.form-text {
    font-size: 0.8rem;
    color: #6b7280;
    margin-top: 0.29rem;
}

.is-invalid {
    border-color: #dc3545 !important;
    box-shadow: 0 0 0 0.2rem rgba(220, 53, 69, 0.25) !important;
}

.invalid-feedback {
    display: block;
    width: 100%;
    margin-top: 0.25rem;
    font-size: 0.875em;
    color: #dc3545;
}

