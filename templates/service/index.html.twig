/* Style spécifique pour les badges */
.attribution-badge {
    display: inline-block;
    text-align: center;
    padding: 0.4rem 0.6rem;
    border-radius: 20px;
    font-size: 0.7rem;
    font-weight: 600;
    line-height: 1.2;
    white-space: normal;
    word-break: break-word;
    max-width: 100%;
}

/* Styles pour les filtres et la recherche */
.filters-container {
    background: #f3f3fbff;
    border-radius: 8px;
    padding: 1.5rem;
    margin-bottom: 1rem;
    border: 1px solid #e5e7eb;
    box-shadow: rgba(0, 0, 0, 0.12) 0px 1px 3px, rgba(0, 0, 0, 0.13) 0px 1px 2px;
}

.filter-row {
    display: flex;
    gap: 1rem;
    align-items: end;
    flex-wrap: wrap;
}

.filter-group {
    flex: 1;
    min-width: 200px;
}

.search-group {
    flex: 2;
    min-width: 300px;
}

.filter-group label,
.search-group label {
    font-weight: 500;
    color: #374151;
    margin-bottom: 0.5rem;
    display: block;
    font-size: 0.875rem;
}

.filter-group .form-control,
.filter-group .form-select,
.search-group .form-control {
    padding: 0.4rem 0.75rem;
    height: 38px;
    font-size: 0.85rem;
    line-height: 1.3;
}

.filter-actions {
    display: flex;
    gap: 0.5rem;
}

/* Pagination compacte */
.pagination-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 1rem;
    padding: 0.75rem 0;
    border-top: 1px solid #e5e7eb;
}

.pagination-info {
    color: #6b7280;
    font-size: 0.8rem;
}

.pagination {
    margin: 0;
    gap: 0.25rem;
}

.page-item .page-link {
    padding: 0.3rem 0.5rem;
    border: 1px solid #d1d5db;
    color: #374151;
    background: white;
    font-size: 0.8rem;
    min-width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    border-radius: 6px;
}

/* Réduire encore plus pour les boutons précédent/suivant */
.page-item .page-link i {
    font-size: 0.7rem;
}

/* États */
.page-item.active .page-link {
    background: linear-gradient(135deg, #964ee3 0%, #8b1970ff 100%);    border-color: #964ee3;
    color: white;
}

.page-item.disabled .page-link {
    color: #9ca3af;
    background: #f9fafb;
    cursor: not-allowed;
}

.page-link:hover:not(.disabled) {
    background: #f3f4f6;
    color: #1f2937;
}

/* Badge spécifique pour "Non défini" */
.attribution-badge-non-defini {
    background: #6b7280 !important;
    color: white !important;
}

/* Ajoutez ceci dans votre section CSS */
#nouveauServiceMutation:disabled {
    background-color: #f8f9fa;
    color: #6c757d;
    cursor: default;
}

#nouveauServiceMutation option:disabled {
    color: #6c757d;
    font-style: italic;
}

/* Style pour le bouton désactivé */
#submitMutationChef:disabled {
    background: linear-gradient(135deg, #6b7280 0%, #4b5563 100%);
    color: #d1d5db;
    border-color: #6b7280;
    cursor: default;
}

/* Style pour l'option "Aucun service disponible" */
#nouveauServiceMutation option[value=""] {
    font-style: italic;
    color: #6c757d;
}

/* Style de la consigne quand pas de service disponible */
.no-services-message {
    background: #f8f9fa;
    border-left: 4px solid #6c757d;
    padding: 0.75rem;
    margin: 0.5rem 0;
    border-radius: 6px;
    font-size: 0.85rem;
    color: #6c757d;
}

.no-services-message i {
    margin-right: 0.5rem;
}

/* Position fixe pour les alertes - AJOUTEZ CETTE SECTION DANS VOTRE STYLESHEETS */
.fixed-alert-container {
    position: fixed;
    top: 100px;
    right: 20px;
    z-index: 9999;
    max-width: 400px;
    animation: slideInRight 0.3s ease-out;
}

@keyframes slideInRight {
    from {
        transform: translateX(100%);
        opacity: 0;
    }
    to {
        transform: translateX(0);
        opacity: 1;
    }
}

.alert-success-fixed {
    background: linear-gradient(135deg, #10b981 0%, #059669 100%);
    color: white;
    border: none;
    border-radius: 10px;
    padding: 1rem 1.25rem;
    box-shadow: 0 8px 25px rgba(16, 185, 129, 0.3);
    border-left: 4px solid #047857;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    animation: fadeIn 0.3s ease-out;
}

.alert-danger-fixed {
    background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
    color: white;
    border: none;
    border-radius: 10px;
    padding: 1rem 1.25rem;
    box-shadow: 0 8px 25px rgba(239, 68, 68, 0.3);
    border-left: 4px solid #b91c1c;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    animation: fadeIn 0.3s ease-out;
}

.alert-success-fixed i,
.alert-danger-fixed i {
    font-size: 1.2rem;
}

.alert-close-btn {
    background: none;
    border: none;
    color: white;
    opacity: 0.8;
    padding: 0.25rem;
    margin-left: auto;
    cursor: pointer;
    transition: opacity 0.2s ease;
}

.alert-close-btn:hover {
    opacity: 1;
}

@keyframes fadeIn {
    from {
        opacity: 0;
        transform: translateY(-10px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

@keyframes fadeOut {
    from {
        opacity: 1;
        transform: translateX(0);
    }
    to {
        opacity: 0;
        transform: translateX(100%);
    }
}
/* Responsive adjustments pour les alertes */
@media (max-width: 768px) {
    .fixed-alert-container {
        top: 80px;
        right: 10px;
        left: 10px;
        max-width: none;
    }
    
    .alert-success-fixed,
    .alert-danger-fixed {
        padding: 0.75rem 1rem;
        font-size: 0.9rem;
    }
}

@media (max-width: 576px) {
    .fixed-alert-container {
        top: 70px;
    }
    
    .alert-success-fixed,
    .alert-danger-fixed {
        padding: 0.5rem 0.75rem;
    }
    
    .alert-success-fixed i,
    .alert-danger-fixed i {
        font-size: 1rem;
    }
}
</style>
{% endblock %}

