    // Nouvelle méthode pour appliquer toutes les sélections
applyModificationSelections() {
    if (!this.currentModificationData) return;
    
    const { directionCode, chefIm } = this.currentModificationData;
    
    console.log('Application des sélections:', { directionCode, chefIm });
    
    // Utiliser un délai court pour s'assurer que Select2 est prêt
    setTimeout(() => {
        // SÉLECTIONNER LA DIRECTION
        if (directionCode && directionCode !== '') {
            const directionSelect = this.selects.modifierDirection;
            if (directionSelect && directionSelect.find('option[value="' + directionCode + '"]').length) {
                directionSelect.val(directionCode).trigger('change.select2');
                console.log('Direction sélectionnée:', directionCode);
            }
        }
        
        // SÉLECTIONNER LE CHEF DE SERVICE (avec option "AUCUN")
        const chefSelect = this.selects.modifierChefService;
        if (chefSelect) {
            setTimeout(() => {
                if (chefIm && chefIm !== '' && chefIm !== 'null') {
                    if (chefSelect.find('option[value="' + chefIm + '"]').length) {
                        chefSelect.val(chefIm).trigger('change.select2');
                        console.log('Chef sélectionné:', chefIm);
                    } else {
                        console.warn('Chef non trouvé dans la liste:', chefIm);
                    }
                } else {
                    // Aucun chef - sélectionner l'option "AUCUN"
                    chefSelect.val('AUCUN').trigger('change.select2');
                    console.log('Aucun chef - option AUCUN sélectionnée');
                }
            }, 200);
        }
    }, 100);
}

