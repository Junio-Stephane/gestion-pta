    resetFilters() {
    // Réinitialiser les filtres standards
    document.getElementById('statutFilter').value = '';
    document.getElementById('attributionFilter').value = '';
    document.getElementById('searchInput').value = '';

    // Réinitialiser le Select2 pour la direction
    if (this.selects.directionFilter) {
        this.selects.directionFilter.val('').trigger('change.select2');
    } else {
        // Fallback si Select2 n'est pas initialisé
        document.getElementById('directionFilter').value = '';
    }

    // Réinitialiser les filtres internes
    this.currentFilters = {
        statut: '',
        attribution: '',
        direction: '',
        search: ''
    };
    
    // Appliquer les filtres (tout sera affiché)
    this.applyFilters();
    
    // Animation du bouton
    const resetBtn = document.getElementById('resetFilters');
    const originalText = resetBtn.innerHTML;
    const originalColor = resetBtn.style.background;
    
    resetBtn.innerHTML = '<i class="bi bi-check"></i> Réinitialisé !';
    resetBtn.style.background = '#10b981';
    resetBtn.style.color = 'white';
    
    setTimeout(() => {
        resetBtn.innerHTML = originalText;
        resetBtn.style.background = originalColor;
        resetBtn.style.color = '';
    }, 1500);
}

    async loadDirectionsPourFiltre() {
    try {
        const response = await fetch('/admin/directions/api/list');
        const data = await response.json();
        
        if (data.success) {
            const select = this.selects.directionFilter;
            if (!select) return;
            
            select.empty();
            select.append('<option value=""></option>');
            
            data.directions.forEach(direction => {
                const optionText = `${direction.nomDirection}`;
                const option = new Option(optionText, direction.CodeDirection, false, false);
                select.append(option);
            });
            
            select.trigger('change.select2');
        }
    } catch (error) {
        console.error('Erreur chargement directions pour filtre:', error);
    }
}

    async loadDirectionsActives() {
    try {
        const response = await fetch('/admin/services/api/directions-actives');
        const data = await response.json();
        
        if (data.success) {
            const selectAdd = this.selects.direction;
            const selectModify = this.selects.modifierDirection;
            
            if (!selectAdd || !selectModify) return;
            
            // Vider et réinitialiser
            selectAdd.empty();
            selectAdd.append('<option value=""></option>');
            
            selectModify.empty();
            selectModify.append('<option value=""></option>');
            
            data.directions.forEach(direction => {
                const optionText = `${direction.nomDirection} (${direction.CodeDirection})`;
                const option = new Option(optionText, direction.CodeDirection, false, false);
                selectAdd.append(option);
                selectModify.append(option.cloneNode(true));
            });
            
            // Mettre à jour Select2
            selectAdd.trigger('change.select2');
            selectModify.trigger('change.select2');
        }
    } catch (error) {
        console.error('Erreur chargement directions actives:', error);
    }
}

async loadPersonnelsPourChefService() {
    try {
        const response = await fetch('/admin/services/api/personnels-pour-chef-service');
        const data = await response.json();
        
        if (data.success) {
            const selectAdd = this.selects.chefService;
            const selectModify = this.selects.modifierChefService;
            
            if (!selectAdd || !selectModify) return;
            
            // Modal AJOUT
            selectAdd.empty();
            selectAdd.append('<option value="">Sélectionnez un chef de service</option>');
            selectAdd.append('<option value="AUCUN">Aucun chef de service</option>');
            
            // Modal MODIFICATION
            selectModify.empty();
            selectModify.append('<option value="">Sélectionnez un chef de service</option>');
            selectModify.append('<option value="AUCUN">Aucun chef de service</option>');
            
            data.personnels.forEach(personnel => {
                const desactive = personnel.StatutPer === 'DESACTIVE';
                let suffix = '';
                
                if (desactive) {
                    if (personnel.FonctionPer === 'Directeur') {
                        suffix = ' (Directeur désactivé)';
                    } else if (personnel.FonctionPer === 'Chef_service') {
                        suffix = ' (Chef désactivé)';
                    } else {
                        suffix = ' (Agent désactivé)';
                    }
                }
                
                const optionText = `${personnel.NomPer} ${personnel.PrenomPer} - ${personnel.EmailPer}${suffix}`;
                const option = new Option(optionText, personnel.ImPer, false, false);
                
                if (desactive) {
                    $(option).addClass('option-desactive');
                }
                
                selectAdd.append(option.cloneNode(true));
                selectModify.append(option.cloneNode(true));
            });
            
            selectAdd.trigger('change.select2');
            selectModify.trigger('change.select2');
            
            // Si on a un chef actuel à pré-sélectionner dans le modal de modification
            if (this.currentModificationData && this.currentModificationData.chefIm) {
                const chefIm = this.currentModificationData.chefIm;
                const chefNom = this.currentModificationData.chefNom;
                
                // Si aucun chef, sélectionner "AUCUN"
                if (chefIm === 'null' || !chefIm || chefIm === '') {
                    selectModify.val('AUCUN').trigger('change.select2');
                    console.log('Aucun chef sélectionné - option AUCUN');
                } else {
                    // Vérifier si le chef existe déjà dans la liste
                    const exists = Array.from(selectModify[0].options).some(option => 
                        option.value === chefIm
                    );
                    
                    if (!exists) {
                        const optionText = `${chefNom}`;
                        const option = new Option(optionText, chefIm, false, false);
                        selectModify.append(option);
                    }
                    selectModify.val(chefIm).trigger('change.select2');
                    console.log('Chef sélectionné:', chefIm);
                }
            }
        } else {
            console.error('Erreur API personnels:', data.message);
            throw new Error(data.message);
        }
    } catch (error) {
        console.error('Erreur chargement personnels pour chef service:', error);
        throw error;
    }
}

async loadPersonnelsPourActivationService() {
    try {
        const serviceCode = document.getElementById('activationServiceCode').value;
        const response = await fetch(`/admin/services/api/personnels-pour-activation-service?serviceCode=${serviceCode}`);
        const data = await response.json();
        
        if (data.success) {
            const select = this.selects.activationNouveauChef;
            if (!select) return;
            
            const ancienChefIm = data.ancienChefIm;
            
            select.empty();
            select.append('<option value=""></option>');
            
            if (data.personnels && data.personnels.length > 0) {
                let hasAvailablePersonnels = false;
                
                data.personnels.forEach(personnel => {
                    const desactive = personnel.StatutPer === 'DESACTIVE';
                    let suffix = '';
                    
                    if (desactive) {
                        if (personnel.FonctionPer === 'Directeur') {
                            suffix = ' (Directeur désactivé)';
                        } else if (personnel.FonctionPer === 'Chef_service') {
                            suffix = ' (Chef désactivé)';
                        } else {
                            suffix = ' (Agent désactivé)';
                        }
                    }
                    
                    // Exclure l'ancien chef de la liste des nouveaux chefs
                    if (personnel.ImPer === ancienChefIm) return;
                    
                    const optionText = `${personnel.NomPer} ${personnel.PrenomPer} - ${personnel.EmailPer}${suffix}`;
                    const option = new Option(optionText, personnel.ImPer, false, false);
                    
                    if (desactive) {
                        $(option).addClass('option-desactive');
                    }
                    
                    select.append(option);
                    hasAvailablePersonnels = true;
                });
                
                if (!hasAvailablePersonnels) {
                    select.empty();
                    select.append('<option value="">Aucun chef de service disponible</option>');
                    select.prop('disabled', true);
                    
                    document.getElementById('choisirChef').disabled = true;
                    document.querySelector('label[for="choisirChef"]').innerHTML = 
                        'Choisir un nouveau chef de service <span class="text-muted">(non disponible)</span>';
                    
                    if (document.getElementById('garderChef').disabled) {
                        document.getElementById('aucunChef').checked = true;
                        this.toggleNouveauChefGroup('aucun');
                    }
                } else {
                    select.prop('disabled', false);
                    document.getElementById('choisirChef').disabled = false;
                }
            } else {
                select.empty();
                select.append('<option value="">Aucun chef de service disponible</option>');
                select.prop('disabled', true);
                
                document.getElementById('choisirChef').disabled = true;
                document.querySelector('label[for="choisirChef"]').innerHTML = 
                    'Choisir un nouveau chef de service <span class="text-muted">(non disponible)</span>';
                
                document.getElementById('aucunChef').checked = true;
                this.toggleNouveauChefGroup('aucun');
            }
            
            select.trigger('change.select2');
        }
    } catch (error) {
        console.error('Erreur chargement personnels pour activation:', error);
    }
}

    showMultipleErrors(errors) {
        Object.keys(errors).forEach(fieldKey => {
            const errorMessage = errors[fieldKey];
            
            const fieldMapping = {
                'codeService': 'codeService',
                'nomService': 'nomService',
                'direction': 'direction',
                'chefService': 'chefService'
            };
            
            const modifierFieldMapping = {
                'nomService': 'modifierNomService',
                'direction': 'modifierDirection',
                'chefService': 'modifierChefService'
            };
            
            const addModal = document.getElementById('addServiceModal');
            const modifyModal = document.getElementById('modifierServiceModal');
            
            if (addModal && addModal.classList.contains('show')) {
                if (fieldMapping[fieldKey]) {
                    this.showFieldError(fieldMapping[fieldKey], errorMessage);
                }
            } else if (modifyModal && modifyModal.classList.contains('show')) {
                if (modifierFieldMapping[fieldKey]) {
                    this.showFieldError(modifierFieldMapping[fieldKey], errorMessage);
                }
            }
        });
    }

    showFieldError(fieldId, errorMessage) {
        const field = document.getElementById(fieldId);
        const errorElement = document.getElementById(fieldId + 'Error');
        
        if (field && errorElement) {
            field.classList.add('is-invalid');
            errorElement.textContent = errorMessage;
            errorElement.style.display = 'block';
        }
    }

    clearFieldError(fieldId) {
        const field = document.getElementById(fieldId);
        const errorElement = document.getElementById(fieldId + 'Error');
        
        if (field) {
            field.classList.remove('is-invalid');
        }
        if (errorElement) {
            errorElement.textContent = '';
            errorElement.style.display = 'none';
        }
    }

    clearModalErrors(modalType) {
    if (modalType === 'add') {
        ['codeService', 'nomService', 'direction', 'chefService'].forEach(field => {
            this.clearFieldError(field);
        });
    } else if (modalType === 'modify') {
        ['modifierNomService', 'modifierDirection', 'modifierChefService'].forEach(field => {
            this.clearFieldError(field);
        });
    } else if (modalType === 'directionInactive') {
        this.clearFieldError('nouvelleDirection');
    }
}

    async ajouterService() {
        const form = document.getElementById('addServiceForm');
        const submitBtn = document.getElementById('submitAddService');
        const originalText = submitBtn.innerHTML;

        try {
            this.clearModalErrors('add');
            
            submitBtn.innerHTML = '<div class="loading-spinner me-2"></div> Création...';
            submitBtn.disabled = true;

            const formData = new FormData(form);
            const data = {
                codeService: formData.get('codeService'),
                nomService: formData.get('nomService'),
                direction: formData.get('direction'),
                chefService: formData.get('chefService') || null
            };

            const response = await fetch('/admin/services/api/create', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify(data)
            });

            const result = await response.json();

            if (result.success) {
                this.showSuccess(result.message);
                bootstrap.Modal.getInstance(document.getElementById('addServiceModal')).hide();
                form.reset();
                this.loadServices();
            } else {
                if (result.errors) {
                    this.showMultipleErrors(result.errors);
                } else {
                    this.showError(result.message);
                }
            }
        } catch (error) {
            console.error('Erreur création service:', error);
            this.showError('Erreur lors de la création du service');
        } finally {
            submitBtn.innerHTML = originalText;
            submitBtn.disabled = false;
        }
    }

    async modifierService() {
        const form = document.getElementById('modifierServiceForm');
        const submitBtn = document.getElementById('submitModifierService');
        const originalText = submitBtn.innerHTML;

        try {
            this.clearModalErrors('modify');
            
            submitBtn.innerHTML = '<div class="loading-spinner me-2"></div> Modification...';
