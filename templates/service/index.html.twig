{% block javascripts %}
<script>
class ServiceManager {
    constructor() {
        this.currentPage = 1;
        this.itemsPerPage = 5;
        this.totalItems = 0;
        this.allServices = [];
        this.filteredServices = [];
        this.currentFilters = {
            statut: '',
            attribution: '',
            direction: '',
            search: ''
        };
        this.init();
        this.currentServiceCode = null;
        this.currentModificationData = null;
    }

initSelect2() {
    // Options par défaut pour les modaux (style normal)
    const defaultModalOptions = {
        theme: 'bootstrap-5',
        width: '100%',
        placeholder: 'Rechercher...',
        allowClear: true,
        dropdownParent: null,
        language: {
            noResults: () => "Aucun résultat trouvé",
            searching: () => "Recherche en cours..."
        }
    };

    // Options spécifiques pour les filtres (style compact)
    const filterOptions = {
        ...defaultModalOptions,
        dropdownParent: $(document.body),
        minimumResultsForSearch: 5 // Afficher la recherche seulement si + de 5 résultats
    };

    // Initialiser chaque select avec ses options spécifiques
    this.selects = {
        // MODAUX - Style normal
        direction: this.initSelectWithOptions('#direction', {
            ...defaultModalOptions,
            dropdownParent: $('#addServiceModal')
        }),
        
        chefService: this.initSelectWithOptions('#chefService', {
            ...defaultModalOptions,
            dropdownParent: $('#addServiceModal')
        }),
        
        modifierDirection: this.initSelectWithOptions('#modifierDirection', {
            ...defaultModalOptions,
            dropdownParent: $('#modifierServiceModal')
        }),
        
        modifierChefService: this.initSelectWithOptions('#modifierChefService', {
            ...defaultModalOptions,
            dropdownParent: $('#modifierServiceModal')
        }),
        
        nouveauServiceMutation: this.initSelectWithOptions('#nouveauServiceMutation', {
            ...defaultModalOptions,
            placeholder: 'Rechercher un service...',
            dropdownParent: $('#mutationChefModal')
        }),
        
        activationNouveauChef: this.initSelectWithOptions('#activationNouveauChef', {
            ...defaultModalOptions,
            placeholder: 'Rechercher un chef de service...',
            dropdownParent: $('#activationServiceModal')
        }),
        
        // FILTRES - Style compact
        directionFilter: this.initSelectWithOptions('#directionFilter', {
            ...filterOptions,
            placeholder: 'Toutes les directions',
            minimumResultsForSearch: 5
        }),

        nouvelleDirection: this.initSelectWithOptions('#nouvelleDirection', {
    ...defaultModalOptions,
    placeholder: 'Sélectionnez une direction active',
    dropdownParent: $('#directionInactiveModal')
})
    };

    // Gérer la fermeture des modaux
    $('.modal').on('hidden.bs.modal', () => {
        Object.values(this.selects).forEach(select => {
            if (select && $.fn.select2) {
                select.select2('close');
            }
        });
    });

    console.log('✅ Select2 initialisé avec styles différents pour modaux et filtres');
}

initSelectWithOptions(selector, options) {
    const $select = $(selector);
    if ($select.length) {
        return $select.select2(options);
    }
    return null;
}

// Modifiez la méthode init() pour inclure initSelect2
init() {
    this.loadServices();
    this.setupModalResetListeners();
    this.initSelect2();
    
    // PRÉCHARGER les données pour tous les modaux
    this.preloadModalData();
    
    this.setupEventListeners();
    this.loadDirectionsPourFiltre();
}

async preloadModalData() {
    try {
        // Charger les directions actives pour tous les modaux
        await this.loadDirectionsActives();
        
        // Charger les personnels pour chef de service
        await this.loadPersonnelsPourChefService();
        
        console.log('✅ Données des modaux préchargées');
    } catch (error) {
        console.error('Erreur préchargement données:', error);
    }
}

    async loadServices() {
        try {
            const response = await fetch('/admin/services/api/list');
            const data = await response.json();
            
            if (data.success) {
                this.allServices = data.services;
                this.applyFilters();
            } else {
                this.showError(data.message);
            }
        } catch (error) {
            console.error('Erreur chargement services:', error);
            this.showError('Erreur lors du chargement des services');
        }
    }

    applyFilters() {
        let filtered = [...this.allServices];

        // Filtre par statut
        if (this.currentFilters.statut) {
            filtered = filtered.filter(service => 
                service.statutService === this.currentFilters.statut
            );
        }

        // Filtre par attribution
        if (this.currentFilters.attribution) {
            if (this.currentFilters.attribution === 'AVEC_CHEF') {
                filtered = filtered.filter(service => service.chefService !== null);
            } else if (this.currentFilters.attribution === 'SANS_CHEF') {
                filtered = filtered.filter(service => service.chefService === null);
            }
        }

        // Filtre par direction
        if (this.currentFilters.direction) {
            filtered = filtered.filter(service => 
                service.direction && service.direction.CodeDirection === this.currentFilters.direction
            );
        }

        // Filtre par recherche
        if (this.currentFilters.search) {
            const searchTerm = this.currentFilters.search.toLowerCase();
            filtered = filtered.filter(service => {
                const chefService = service.chefService;
                const direction = service.direction;
                return (
                    service.CodeService.toLowerCase().includes(searchTerm) ||
                    service.nomService.toLowerCase().includes(searchTerm) ||
                    (direction && direction.nomDirection.toLowerCase().includes(searchTerm)) ||
                    (chefService && (
                        chefService.NomPer.toLowerCase().includes(searchTerm) ||
                        chefService.PrenomPer.toLowerCase().includes(searchTerm) ||
                        (chefService.EmailPer && chefService.EmailPer.toLowerCase().includes(searchTerm)) ||
                        (chefService.ImPer && chefService.ImPer.toLowerCase().includes(searchTerm))
                    ))
                );
            });
        }

        this.filteredServices = filtered;
        this.totalItems = filtered.length;
        this.currentPage = 1;
        this.renderServices();
        this.renderPagination();
    }

    getPaginatedServices() {
        const startIndex = (this.currentPage - 1) * this.itemsPerPage;
        const endIndex = startIndex + this.itemsPerPage;
        return this.filteredServices.slice(startIndex, endIndex);
    }

