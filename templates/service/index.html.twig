    // Charger les personnels après avoir configuré les options
    this.loadPersonnelsPourActivationService().then(() => {
        this.toggleNouveauChefGroup(document.querySelector('input[name="activationOption"]:checked').value);
    });
    
    // Afficher le modal d'activation normal (VOTRE MODAL EXISTANT)
    const modal = new bootstrap.Modal(document.getElementById('activationServiceModal'));
    modal.show();
}

