<script>
// SYSTÈME DE DIAGRAMMES CAMEMBERT
// SYSTÈME DE DIAGRAMMES CAMEMBERT
class PieChartSystem {
    constructor() {
        this.init();
    }

    init() {
        console.log('📊 Initialisation système diagrammes camembert');
        this.calculatePercentages();
        this.updateCharts();
        this.setupChartInteractions();
    }

    // 🎯 CALCULER LES POURCENTAGES - VERSION CORRIGÉE
    calculatePercentages() {
        // Directions - utiliser parseInt pour s'assurer d'avoir des nombres
        const directionsTotal = parseInt('{{ total_directions ?? 0 }}') || 0;
        if (directionsTotal > 0) {
            const activeDir = parseInt('{{ active_directions ?? 0 }}') || 0;
            const pendingDir = parseInt('{{ pending_directions ?? 0 }}') || 0;
            const disabledDir = parseInt('{{ disabled_directions ?? 0 }}') || 0;
            
            document.getElementById('directionsActivePercent').textContent = 
                Math.round((activeDir / directionsTotal) * 100) + '%';
            document.getElementById('directionsPendingPercent').textContent = 
                Math.round((pendingDir / directionsTotal) * 100) + '%';
            document.getElementById('directionsDisabledPercent').textContent = 
                Math.round((disabledDir / directionsTotal) * 100) + '%';
        } else {
            document.getElementById('directionsActivePercent').textContent = '0%';
            document.getElementById('directionsPendingPercent').textContent = '0%';
            document.getElementById('directionsDisabledPercent').textContent = '0%';
        }

        // Services
        const servicesTotal = parseInt('{{ total_services ?? 0 }}') || 0;
        if (servicesTotal > 0) {
            const activeServ = parseInt('{{ active_services ?? 0 }}') || 0;
            const pendingServ = parseInt('{{ pending_services ?? 0 }}') || 0;
            const disabledServ = parseInt('{{ disabled_services ?? 0 }}') || 0;
            
            document.getElementById('servicesActivePercent').textContent = 
                Math.round((activeServ / servicesTotal) * 100) + '%';
            document.getElementById('servicesPendingPercent').textContent = 
                Math.round((pendingServ / servicesTotal) * 100) + '%';
            document.getElementById('servicesDisabledPercent').textContent = 
                Math.round((disabledServ / servicesTotal) * 100) + '%';
        } else {
            document.getElementById('servicesActivePercent').textContent = '0%';
            document.getElementById('servicesPendingPercent').textContent = '0%';
            document.getElementById('servicesDisabledPercent').textContent = '0%';
        }

        // Projets
        const projetsTotal = parseInt('{{ total_projets ?? 0 }}') || 0;
        if (projetsTotal > 0) {
            const startedProj = parseInt('{{ started_projets ?? 0 }}') || 0;
            const inProgressProj = parseInt('{{ in_progress_projets ?? 0 }}') || 0;
            const completedProj = parseInt('{{ completed_projets ?? 0 }}') || 0;
            const suspendedProj = parseInt('{{ suspended_projets ?? 0 }}') || 0;
            
            document.getElementById('projetsStartedPercent').textContent = 
                Math.round((startedProj / projetsTotal) * 100) + '%';
            document.getElementById('projetsProgressPercent').textContent = 
                Math.round((inProgressProj / projetsTotal) * 100) + '%';
            document.getElementById('projetsCompletedPercent').textContent = 
                Math.round((completedProj / projetsTotal) * 100) + '%';
            document.getElementById('projetsSuspendedPercent').textContent = 
                Math.round((suspendedProj / projetsTotal) * 100) + '%';
        } else {
            document.getElementById('projetsStartedPercent').textContent = '0%';
            document.getElementById('projetsProgressPercent').textContent = '0%';
            document.getElementById('projetsCompletedPercent').textContent = '0%';
            document.getElementById('projetsSuspendedPercent').textContent = '0%';
        }

        // Tâches
        const tachesTotal = parseInt('{{ total_taches ?? 0 }}') || 0;
        if (tachesTotal > 0) {
            const startedTache = parseInt('{{ started_taches ?? 0 }}') || 0;
            const inProgressTache = parseInt('{{ in_progress_taches ?? 0 }}') || 0;
            const completedTache = parseInt('{{ completed_taches ?? 0 }}') || 0;
            const suspendedTache = parseInt('{{ suspended_taches ?? 0 }}') || 0;
            
            document.getElementById('tachesStartedPercent').textContent = 
                Math.round((startedTache / tachesTotal) * 100) + '%';
            document.getElementById('tachesProgressPercent').textContent = 
                Math.round((inProgressTache / tachesTotal) * 100) + '%';
            document.getElementById('tachesCompletedPercent').textContent = 
                Math.round((completedTache / tachesTotal) * 100) + '%';
            document.getElementById('tachesSuspendedPercent').textContent = 
                Math.round((suspendedTache / tachesTotal) * 100) + '%';
        } else {
            document.getElementById('tachesStartedPercent').textContent = '0%';
            document.getElementById('tachesProgressPercent').textContent = '0%';
            document.getElementById('tachesCompletedPercent').textContent = '0%';
            document.getElementById('tachesSuspendedPercent').textContent = '0%';
        }
    }

    // 🎯 METTRE À JOUR LES DIAGRAMMES
    updateCharts() {
        this.updateChart('directionsChart', [
            { value: parseInt('{{ active_directions ?? 0 }}') || 0, color: 'var(--success-color)' },
            { value: parseInt('{{ pending_directions ?? 0 }}') || 0, color: 'var(--warning-color)' },
            { value: parseInt('{{ disabled_directions ?? 0 }}') || 0, color: 'var(--danger-color)' }
        ]);

        this.updateChart('servicesChart', [
            { value: parseInt('{{ active_services ?? 0 }}') || 0, color: 'var(--success-color)' },
            { value: parseInt('{{ pending_services ?? 0 }}') || 0, color: 'var(--warning-color)' },
            { value: parseInt('{{ disabled_services ?? 0 }}') || 0, color: 'var(--danger-color)' }
        ]);

        this.updateChart('projetsChart', [
            { value: parseInt('{{ started_projets ?? 0 }}') || 0, color: 'var(--info-color)' },
            { value: parseInt('{{ in_progress_projets ?? 0 }}') || 0, color: 'var(--warning-color)' },
            { value: parseInt('{{ completed_projets ?? 0 }}') || 0, color: 'var(--success-color)' },
            { value: parseInt('{{ suspended_projets ?? 0 }}') || 0, color: 'var(--secondary-color)' }
        ]);

        this.updateChart('tachesChart', [
            { value: parseInt('{{ started_taches ?? 0 }}') || 0, color: 'var(--info-color)' },
            { value: parseInt('{{ in_progress_taches ?? 0 }}') || 0, color: 'var(--warning-color)' },
            { value: parseInt('{{ completed_taches ?? 0 }}') || 0, color: 'var(--success-color)' },
            { value: parseInt('{{ suspended_taches ?? 0 }}') || 0, color: 'var(--secondary-color)' }
        ]);
    }

    // 🎯 METTRE À JOUR UN DIAGRAMME SPÉCIFIQUE
    updateChart(chartId, data) {
        const chart = document.getElementById(chartId);
        if (!chart) return;
        
        const total = data.reduce((sum, item) => sum + item.value, 0);
        
        if (total === 0) {
            chart.style.background = 'conic-gradient(#e5e7eb 0% 100%)';
            return;
        }

        let gradientString = '';
        let currentPercent = 0;

        data.forEach((item, index) => {
            const percent = (item.value / total) * 100;
            const startPercent = currentPercent;
            const endPercent = currentPercent + percent;
            
            gradientString += `${item.color} ${startPercent}% ${endPercent}%`;
            if (index < data.length - 1) {
                gradientString += ', ';
            }
            
            currentPercent = endPercent;
        });

        chart.style.background = `conic-gradient(${gradientString})`;
    }

    // 🎯 INTERACTIONS DES DIAGRAMMES
    setupChartInteractions() {
        document.querySelectorAll('.legend-item').forEach(item => {
            item.addEventListener('mouseenter', () => {
                item.style.background = '#f8fafc';
                item.style.transform = 'translateX(5px)';
            });

            item.addEventListener('mouseleave', () => {
                item.style.background = '';
                item.style.transform = '';
            });
        });
    }
}

// SYSTÈME CRITIQUE D'INITIALISATION DES BOUTONS
class ButtonInitializationSystem {
    constructor() {
        this.isInitialized = false;
        this.initializedElements = new Set();
        this.init();
    }

    init() {
        console.log('🎯 Initialisation système boutons (version sans polling)');
        
        // Initialiser immédiatement les éléments existants
        this.initializeExistingElements();
        
        // Observer les changements du DOM pour les nouveaux éléments
        this.setupDOMObserver();
        
        // S'assurer que l'initialisation se fait même après un délai
        this.setupDelayedInitialization();
        
        this.isInitialized = true;
    }

    initializeExistingElements() {
        console.log('🔄 Initialisation des éléments existants...');
        
        // Initialiser tous les selects de rôle
        this.initializeAllRoleSelects();
        
        // Initialiser tous les boutons
        this.initializeAllButtons();
        
        // Vérifier la surbrillance
        this.checkForHighlight();
        
        console.log('✅ Éléments existants initialisés');
    }

    initializeAllRoleSelects() {
        const roleSelects = document.querySelectorAll('.role-select, .role-select-mobile');
        console.log(`🔍 ${roleSelects.length} selects de rôle trouvés`);
        
        roleSelects.forEach(select => {
            this.initializeSingleSelect(select);
        });
    }

    initializeSingleSelect(selectElement) {
        const selectId = selectElement.id;
        
        // Éviter les doubles initialisations
        if (this.initializedElements.has(selectId)) {
            return;
        }

        const version = selectElement.classList.contains('role-select-mobile') ? 'mobile' : 'desktop';
        const userIm = selectId.replace('role-select-', '').replace('role-select-mobile-', '');
        
        // Trouver le bouton correspondant
        const approveBtnId = version === 'mobile' 
            ? `approve-btn-mobile-${userIm}`
            : `approve-btn-${userIm}`;
        
        const approveBtn = document.getElementById(approveBtnId);
        
        if (approveBtn) {
            // État initial basé sur la valeur actuelle
            const hasValue = selectElement.value !== '';
            this.updateSelectAndButton(selectElement, approveBtn, hasValue);
            
            // Événement de changement
            selectElement.addEventListener('change', () => {
                const isValid = selectElement.value !== '';
                this.updateSelectAndButton(selectElement, approveBtn, isValid);
            });
            
            // Marquer comme initialisé
            this.initializedElements.add(selectId);
            selectElement.dataset.initialized = 'true';
            
            console.log(`✅ Select ${selectId} initialisé`);
        }
    }

    initializeAllButtons() {
        // Boutons d'approbation
        const approveBtns = document.querySelectorAll('.approve-btn, .approve-btn-mobile');
        approveBtns.forEach(btn => {
            this.initializeApproveButton(btn);
        });

        // Boutons de rejet
        const rejectBtns = document.querySelectorAll('.reject-btn, .reject-btn-mobile');
        rejectBtns.forEach(btn => {
            this.initializeRejectButton(btn);
        });

        console.log(`✅ ${approveBtns.length} boutons approbation et ${rejectBtns.length} boutons rejet initialisés`);
    }

    initializeApproveButton(button) {
        const buttonId = button.id;
        
        if (this.initializedElements.has(buttonId)) {
            return;
        }

        const version = button.classList.contains('approve-btn-mobile') ? 'mobile' : 'desktop';
        const userIm = button.getAttribute('data-user-im');
        
        // Trouver le select correspondant
        const selectId = `role-select-${version === 'mobile' ? 'mobile-' : ''}${userIm}`;
        const select = document.getElementById(selectId);
        
        // Si le select existe, s'assurer qu'il est initialisé
        if (select && !this.initializedElements.has(selectId)) {
            this.initializeSingleSelect(select);
        }
        
        // Ajouter l'événement de clic
        button.addEventListener('click', (e) => {
            e.preventDefault();
            
            if (button.disabled) {
                this.showRoleRequiredAlert(button, version);
                return;
            }
            
            const userName = button.getAttribute('data-user-name');
            console.log(`📝 Tentative approbation: ${userName} (${userIm})`);
            
            // Utiliser le système modal
            if (window.pendingListModalSystem) {
                window.pendingListModalSystem.handleApprove(userIm, userName, version);
            }
        });

        this.initializedElements.add(buttonId);
        button.dataset.initialized = 'true';
    }

    initializeRejectButton(button) {
        const buttonId = button.id;
        
        if (this.initializedElements.has(buttonId)) {
            return;
        }

        const version = button.classList.contains('reject-btn-mobile') ? 'mobile' : 'desktop';
        const userIm = button.getAttribute('data-user-im');
        const userName = button.getAttribute('data-user-name');
        
        // Ajouter l'événement de clic
        button.addEventListener('click', (e) => {
            e.preventDefault();
            console.log(`📝 Tentative rejet: ${userName} (${userIm})`);
            
            // Utiliser le système modal
            if (window.pendingListModalSystem) {
                window.pendingListModalSystem.handleReject(userIm, userName, version);
            }
        });

        this.initializedElements.add(buttonId);
        button.dataset.initialized = 'true';
    }

    updateSelectAndButton(selectElement, button, isValid) {
        // Mettre à jour l'apparence du select
        selectElement.classList.remove('is-invalid', 'is-valid');
        if (isValid) {
            selectElement.classList.add('is-valid');
        } else {
            selectElement.classList.add('is-invalid');
        }
        
        // Mettre à jour l'état du bouton
        if (button) {
            button.disabled = !isValid;
        }
    }

    showRoleRequiredAlert(button, version) {
        const userIm = button.getAttribute('data-user-im');
        const select = document.getElementById(`role-select-${version === 'mobile' ? 'mobile-' : ''}${userIm}`);
        
        if (!select) return;
        
        // Animation de shake
        select.classList.add('shake-animation');
        select.focus();
        
        setTimeout(() => {
            select.classList.remove('shake-animation');
        }, 500);
        
        console.log('⚠️ Rôle requis pour valider');
    }

    setupDOMObserver() {
        const observer = new MutationObserver((mutations) => {
            let shouldInitialize = false;
            
            mutations.forEach((mutation) => {
                if (mutation.type === 'childList' && mutation.addedNodes.length > 0) {
                    mutation.addedNodes.forEach((node) => {
                        if (node.nodeType === 1) {
                            // Vérifier si le nœud contient des éléments à initialiser
                            if (node.matches('.role-select, .role-select-mobile, .approve-btn, .approve-btn-mobile, .reject-btn, .reject-btn-mobile') ||
                                node.querySelector('.role-select, .role-select-mobile, .approve-btn, .approve-btn-mobile, .reject-btn, .reject-btn-mobile')) {
                                shouldInitialize = true;
                            }
                        }
                    });
                }
            });
            
            if (shouldInitialize) {
                console.log('🆕 Nouveaux éléments détectés dans le DOM');
                setTimeout(() => {
                    this.initializeExistingElements();
                }, 100);
            }
        });
        
        // Observer le conteneur principal et le document entier
        const container = document.getElementById('pendingListContainer');
        if (container) {
            observer.observe(container, {
                childList: true,
                subtree: true
            });
        }
        
        // Observer aussi le body pour les cas extrêmes
        observer.observe(document.body, {
            childList: true,
            subtree: false
        });
        
        this.observer = observer;
    }

    setupDelayedInitialization() {
        // Réessayer l'initialisation après 1 seconde (pour les chargements lents)
        setTimeout(() => {
            const uninitializedSelects = document.querySelectorAll('.role-select:not([data-initialized]), .role-select-mobile:not([data-initialized])');
            const uninitializedButtons = document.querySelectorAll('.approve-btn:not([data-initialized]), .approve-btn-mobile:not([data-initialized]), .reject-btn:not([data-initialized]), .reject-btn-mobile:not([data-initialized])');
            
            if (uninitializedSelects.length > 0 || uninitializedButtons.length > 0) {
                console.log('⏱️ Réinitialisation différée pour éléments non initialisés');
                this.initializeExistingElements();
            }
        }, 1000);
    }

    checkForHighlight() {
        const highlightedRow = document.querySelector('.highlighted-user');
        const highlightedCard = document.querySelector('.user-card.highlighted-user');
        
        if (highlightedRow) {
            setTimeout(() => {
                highlightedRow.scrollIntoView({ 
                    behavior: 'smooth', 
                    block: 'center',
                    inline: 'nearest'
                });
            }, 500);
        }
        
        if (highlightedCard) {
            setTimeout(() => {
                highlightedCard.scrollIntoView({ 
                    behavior: 'smooth', 
                    block: 'center',
                    inline: 'nearest'
                });
            }, 500);
        }
    }

    // Méthode pour forcer la réinitialisation (utile après rafraîchissement AJAX manuel)
    reinitialize() {
        console.log('🔄 Réinitialisation forcée du système de boutons');
        this.initializedElements.clear();
        this.initializeExistingElements();
    }
}

// SYSTÈME DE RAFRAÎCHISSEMENT MANUEL
class ManualRefreshSystem {
    constructor() {
        this.init();
    }

    init() {
        console.log('🔄 Initialisation système rafraîchissement manuel');
        this.addRefreshButton();
    }

    async refreshPendingList() {
        try {
            console.log('🔄 Rafraîchissement manuel de la liste...');
            
            const response = await fetch('{{ path('app_dashboard_admin') }}?partial=pending_list&_=' + Date.now(), {
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                }
            });
            
            if (!response.ok) throw new Error('Erreur lors du chargement');
            
            const html = await response.text();
            
            const container = document.getElementById('pendingListContainer');
            if (container) {
                // Animation de transition
                container.style.opacity = '0.7';
                container.style.transition = 'opacity 0.3s ease';
                
                setTimeout(() => {
                    container.innerHTML = html;
                    container.style.opacity = '1';
                    
                    // Réinitialiser les systèmes après le rafraîchissement
                    this.reinitializeSystems();
                    
                    console.log('✅ Liste rafraîchie avec succès');
                }, 300);
            }
            
        } catch (error) {
            console.error('❌ Erreur rafraîchissement:', error);
            alert('Erreur lors du rafraîchissement de la liste');
        }
    }

    reinitializeSystems() {
        // Réinitialiser le système de boutons
        if (window.buttonInitializationSystem) {
            window.buttonInitializationSystem.reinitialize();
        }
        
        // Réinitialiser le système modal
        if (window.pendingListModalSystem) {
            window.pendingListModalSystem.init();
        }
        
        // Réinitialiser les modals Bootstrap
        reinitializeBootstrapModals();
        
        // Vérifier la surbrillance
        this.checkForHighlight();
        
        // METTRE À JOUR LES STATISTIQUES DES AGENTS
        this.updateAgentStats();
    }

    async updateAgentStats() {
        try {
            // Récupérer les nouvelles statistiques via une requête AJAX
            const response = await fetch('{{ path('app_dashboard_admin_stats') }}?_=' + Date.now());
            if (response.ok) {
                const data = await response.json();
                
                // Mettre à jour les cartes d'aperçu des agents
                document.querySelectorAll('.stat-card-compact h3').forEach(card => {
                    const label = card.nextElementSibling?.textContent?.toLowerCase();
                    if (label) {
                        if (label.includes('utilisateurs totaux')) {
                            card.textContent = data.total_users || 0;
                        } else if (label.includes('comptes actifs')) {
                            card.textContent = data.active_users || 0;
                        } else if (label.includes('en attente')) {
                            card.textContent = data.pending_users || 0;
                        } else if (label.includes('désactivés')) {
                            card.textContent = data.disabled_users || 0;
                        }
                    }
                });
                
                // Mettre à jour le badge de demande
                const pendingCountBadge = document.getElementById('pendingCountBadge');
                if (pendingCountBadge) {
                    pendingCountBadge.textContent = data.pending_users + ' demandes';
                }
                
                console.log('📊 Statistiques agents mises à jour');
            }
        } catch (error) {
            console.error('❌ Erreur mise à jour stats agents:', error);
        }
    }

    checkForHighlight() {
        const highlightedRow = document.querySelector('.highlighted-user');
        const highlightedCard = document.querySelector('.user-card.highlighted-user');
        
        if (highlightedRow || highlightedCard) {
            console.log('🎯 Utilisateur mis en évidence détecté');
        }
    }

    addRefreshButton() {
        const sectionHeader = document.querySelector('.section-header-inscription');
        if (sectionHeader && !sectionHeader.querySelector('.manual-refresh-btn')) {
            const refreshBtn = document.createElement('button');
            refreshBtn.className = 'btn btn-sm btn-outline-primary ms-2 manual-refresh-btn';
            refreshBtn.innerHTML = '<i class="bi bi-arrow-clockwise"></i>';
            refreshBtn.title = 'Actualiser la liste manuellement';
            refreshBtn.onclick = (e) => {
                e.preventDefault();
                this.refreshPendingList();
            };
            sectionHeader.appendChild(refreshBtn);
        }
    }
}

// SYSTÈME DE FILTRES POUR LES STATISTIQUES - VERSION CORRIGÉE
class StatutFilterSystem {
    constructor() {
        this.currentDirectionServiceFilter = 'all';
        this.currentProjetTacheFilter = 'all';
        this.init();
    }

    init() {
        console.log('🎛️ Initialisation système filtres statuts');
        this.setupFilterEvents();
        this.updateCharts();
    }

    // 🎛️ CONFIGURATION DES ÉVÉNEMENTS DES FILTRES
    setupFilterEvents() {
        // Filtres pour Directions & Services
        document.querySelectorAll('#directionServiceFilters .filter-btn').forEach(btn => {
            btn.addEventListener('click', (e) => {
                e.preventDefault();
                this.setActiveFilter('directionService', btn.dataset.statut);
            });
        });

        // Filtres pour Projets & Tâches
        document.querySelectorAll('#projetTacheFilters .filter-btn').forEach(btn => {
            btn.addEventListener('click', (e) => {
                e.preventDefault();
                this.setActiveFilter('projetTache', btn.dataset.statut);
            });
        });
    }

    // 🎯 DÉFINIR LE FILTRE ACTIF
    setActiveFilter(filterGroup, statut) {
        if (filterGroup === 'directionService') {
            this.currentDirectionServiceFilter = statut;
            this.updateFilterButtons('directionServiceFilters', statut);
        } else {
            this.currentProjetTacheFilter = statut;
            this.updateFilterButtons('projetTacheFilters', statut);
        }
        
        this.updateCharts();
    }

    // 🎯 METTRE À JOUR L'ÉTAT DES BOUTONS DE FILTRE
    updateFilterButtons(containerId, activeStatut) {
        document.querySelectorAll(`#${containerId} .filter-btn`).forEach(btn => {
            btn.classList.toggle('active', btn.dataset.statut === activeStatut);
        });
    }

    // 📊 METTRE À JOUR LES DIAGRAMMES EN FONCTION DES FILTRES
    updateCharts() {
        this.updateDirectionServiceCharts();
        this.updateProjetTacheCharts();
    }

    // 📊 METTRE À JOUR LES DIAGRAMMES DIRECTIONS & SERVICES
    updateDirectionServiceCharts() {
        const filter = this.currentDirectionServiceFilter;
        
        // Directions
        this.updateSingleChart('direction', filter, {
            active: parseInt('{{ active_directions ?? 0 }}') || 0,
            pending: parseInt('{{ pending_directions ?? 0 }}') || 0,
            disabled: parseInt('{{ disabled_directions ?? 0 }}') || 0,
            total: parseInt('{{ total_directions ?? 0 }}') || 0
        });

        // Services
        this.updateSingleChart('service', filter, {
            active: parseInt('{{ active_services ?? 0 }}') || 0,
            pending: parseInt('{{ pending_services ?? 0 }}') || 0,
            disabled: parseInt('{{ disabled_services ?? 0 }}') || 0,
            total: parseInt('{{ total_services ?? 0 }}') || 0
        });
    }

    // 📊 METTRE À JOUR LES DIAGRAMMES PROJETS & TÂCHES
    updateProjetTacheCharts() {
        const filter = this.currentProjetTacheFilter;
        
        // Projets
        this.updateSingleChart('projet', filter, {
            started: parseInt('{{ started_projets ?? 0 }}') || 0,
            in_progress: parseInt('{{ in_progress_projets ?? 0 }}') || 0,
            completed: parseInt('{{ completed_projets ?? 0 }}') || 0,
            suspended: parseInt('{{ suspended_projets ?? 0 }}') || 0,
            total: parseInt('{{ total_projets ?? 0 }}') || 0
        });

        // Tâches
        this.updateSingleChart('tache', filter, {
            started: parseInt('{{ started_taches ?? 0 }}') || 0,
            in_progress: parseInt('{{ in_progress_taches ?? 0 }}') || 0,
            completed: parseInt('{{ completed_taches ?? 0 }}') || 0,
            suspended: parseInt('{{ suspended_taches ?? 0 }}') || 0,
            total: parseInt('{{ total_taches ?? 0 }}') || 0
        });
    }

    // 📊 METTRE À JOUR UN DIAGRAMME INDIVIDUEL
    updateSingleChart(type, filter, data) {
        const chartElement = document.querySelector(`.pie-chart-container[data-type="${type}"]`);
        if (!chartElement) return;
        
        const totalElement = chartElement.querySelector('.total-count');
        const chartId = `${type}sChart`;
        
        let filteredData = [];
        let filteredTotal = 0;

        if (type === 'direction' || type === 'service') {
            // Filtrage pour Directions & Services
            switch (filter) {
                case 'active':
                    filteredData = [{ value: data.active, color: 'var(--success-color)' }];
                    filteredTotal = data.active;
                    break;
                case 'pending':
                    filteredData = [{ value: data.pending, color: 'var(--warning-color)' }];
                    filteredTotal = data.pending;
                    break;
                case 'disabled':
                    filteredData = [{ value: data.disabled, color: 'var(--danger-color)' }];
                    filteredTotal = data.disabled;
                    break;
                default: // 'all'
                    filteredData = [
                        { value: data.active, color: 'var(--success-color)' },
                        { value: data.pending, color: 'var(--warning-color)' },
                        { value: data.disabled, color: 'var(--danger-color)' }
                    ];
                    filteredTotal = data.total;
            }
        } else {
            // Filtrage pour Projets & Tâches
            switch (filter) {
                case 'started':
                    filteredData = [{ value: data.started, color: 'var(--info-color)' }];
                    filteredTotal = data.started;
                    break;
                case 'in_progress':
                    filteredData = [{ value: data.in_progress, color: 'var(--warning-color)' }];
                    filteredTotal = data.in_progress;
                    break;
                case 'completed':
                    filteredData = [{ value: data.completed, color: 'var(--success-color)' }];
                    filteredTotal = data.completed;
                    break;
                case 'suspended':
                    filteredData = [{ value: data.suspended, color: 'var(--secondary-color)' }];
                    filteredTotal = data.suspended;
                    break;
                default: // 'all'
                    filteredData = [
                        { value: data.started, color: 'var(--info-color)' },
                        { value: data.in_progress, color: 'var(--warning-color)' },
                        { value: data.completed, color: 'var(--success-color)' },
                        { value: data.suspended, color: 'var(--secondary-color)' }
                    ];
                    filteredTotal = data.total;
            }
        }

        // Mettre à jour le total affiché
        if (totalElement) {
            totalElement.textContent = filteredTotal;
        }

        // Mettre à jour le diagramme
        this.updateChartVisual(chartId, filteredData);

        // Mettre à jour les pourcentages dans la légende
        this.updateLegendPercentages(chartElement, filteredData, filteredTotal);
    }

    // 🎨 METTRE À JOUR L'APPEARANCE VISUELLE DU DIAGRAMME
    updateChartVisual(chartId, data) {
        const chart = document.getElementById(chartId);
        if (!chart) return;
        
        const total = data.reduce((sum, item) => sum + item.value, 0);
        
        if (total === 0) {
            chart.style.background = 'conic-gradient(#e5e7eb 0% 100%)';
            return;
        }

        let gradientString = '';
        let currentPercent = 0;

        data.forEach((item, index) => {
            if (item.value > 0) {
                const percent = (item.value / total) * 100;
                const startPercent = currentPercent;
                const endPercent = currentPercent + percent;
                
                if (gradientString) gradientString += ', ';
                gradientString += `${item.color} ${startPercent}% ${endPercent}%`;
                
                currentPercent = endPercent;
            }
        });

        // Si un seul statut est sélectionné, créer un diagramme complet avec cette couleur
        if (data.length === 1 && data[0].value > 0) {
            gradientString = `${data[0].color} 0% 100%`;
        }

        chart.style.background = `conic-gradient(${gradientString})`;
    }

    // 📈 METTRE À JOUR LES POURCENTAGES DANS LA LÉGENDE
    updateLegendPercentages(chartElement, data, total) {
        const legendItems = chartElement.querySelectorAll('.legend-item');
        
        legendItems.forEach(item => {
            const valueElement = item.querySelector('.legend-value');
            const percentElement = item.querySelector('.legend-percentage');
            const statut = this.getStatutFromLegend(item.querySelector('.legend-label').textContent);
            
            let value = 0;
            
            // Trouver la valeur correspondante dans les données
            data.forEach(dataItem => {
                if (this.getColorForStatut(statut) === dataItem.color) {
                    value = dataItem.value;
                }
            });
            
            if (valueElement) {
                valueElement.textContent = value;
            }
            
            // Calculer le pourcentage
            const percentage = total > 0 ? Math.round((value / total) * 100) : 0;
            if (percentElement) {
                percentElement.textContent = `${percentage}%`;
            }
        });
    }

    // 🎯 OBTENIR LE STATUT À PARTIR DU LABEL
    getStatutFromLegend(label) {
        const mappings = {
            'Actives': 'active',
            'Actifs': 'active',
            'En attente': 'pending',
            'Débutés': 'started',
            'Débutées': 'started',
            'En cours': 'in_progress',
            'Terminés': 'completed',
            'Terminées': 'completed',
            'Désactivées': 'disabled',
            'Désactivés': 'disabled',
            'Suspendus': 'suspended',
            'Suspendues': 'suspended'
        };
        
        return mappings[label] || label.toLowerCase();
    }

    // 🎨 OBTENIR LA COULEUR POUR UN STATUT
    getColorForStatut(statut) {
        const colors = {
            'active': 'var(--success-color)',
            'pending': 'var(--warning-color)',
            'disabled': 'var(--danger-color)',
            'started': 'var(--info-color)',
            'in_progress': 'var(--warning-color)',
            'completed': 'var(--success-color)',
            'suspended': 'var(--secondary-color)'
        };
        
        return colors[statut] || 'var(--primary-color)';
    }
}

// SYSTÈME DE GESTION DES MODALS - VÉRIFICATION POUR ÉVITER LA DOUBLE DÉCLARATION
if (typeof window.PendingListModalSystem === 'undefined') {
    window.PendingListModalSystem = class PendingListModalSystem {
        constructor() {
            this.currentApproveForm = null;
            this.currentRejectForm = null;
            this.isMobile = window.innerWidth <= 768;
            this.init();
            this.setupResponsive();
        }

        setupResponsive() {
            window.addEventListener('resize', () => {
                this.isMobile = window.innerWidth <= 768;
            });
        }

        init() {
            console.log('🎯 Initialisation système modals pending list');
            this.setupModalDelegation();
            this.setupFormDelegation();
            this.checkForHighlight();
        }
        
        setupModalDelegation() {
            document.addEventListener('click', (e) => {
                if (e.target.matches('#confirmApprove, #confirmApprove *')) {
                    e.preventDefault();
                    this.handleConfirmApprove();
                    return;
                }
                
                if (e.target.matches('#confirmReject, #confirmReject *')) {
                    e.preventDefault();
                    this.handleConfirmReject();
                    return;
                }
                
                if (e.target.matches('#cancelApproveBtn, #cancelApproveBtn *')) {
                    e.preventDefault();
                    this.handleCancelModal('approveModal');
                    return;
                }
                
                if (e.target.matches('#cancelRejectBtn, #cancelRejectBtn *')) {
                    e.preventDefault();
                    this.handleCancelModal('rejectModal');
                    return;
                }
                
                if (e.target.matches('.btn-close-custom, .btn-close-custom *')) {
                    e.preventDefault();
                    const modal = e.target.closest('.modal');
                    if (modal) {
                        this.handleCancelModal(modal.id);
                    }
                    return;
                }
            });
            
            document.addEventListener('hidden.bs.modal', (e) => {
                const modal = e.target;
                this.handleModalHidden(modal);
            });
        }
        
        setupFormDelegation() {
            // La délégation est maintenant gérée par ButtonInitializationSystem
            // Cette méthode est conservée pour compatibilité
        }
        
        handleConfirmApprove() {
            const btn = document.getElementById('confirmApprove');
            if (!btn) {
                console.error('❌ Bouton confirmApprove non trouvé');
                return;
            }
            
            this.showLoading(btn);
            this.disableCancelButtons(true);
            
            setTimeout(() => {
                if (this.currentApproveForm) {
                    console.log('✅ Confirmation approbation soumise');
                    this.currentApproveForm.submit();
                } else {
                    console.error('❌ Formulaire d\'approbation non trouvé');
                    this.hideLoading(btn);
                    this.disableCancelButtons(false);
                }
            }, 500);
        }
        
        handleConfirmReject() {
            const btn = document.getElementById('confirmReject');
            if (!btn) {
                console.error('❌ Bouton confirmReject non trouvé');
                return;
            }
            
            this.showLoading(btn);
            this.disableCancelButtons(true);
            
            setTimeout(() => {
                if (this.currentRejectForm) {
                    console.log('❌ Confirmation rejet soumise');
                    this.currentRejectForm.submit();
                } else {
                    console.error('❌ Formulaire de rejet non trouvé');
                    this.hideLoading(btn);
                    this.disableCancelButtons(false);
                }
            }, 500);
        }
        
        handleCancelModal(modalId) {
            const modal = document.getElementById(modalId);
            if (!modal) {
                console.error(`❌ Modal ${modalId} non trouvé`);
                return;
            }
            
            const bsModal = bootstrap.Modal.getInstance(modal);
            if (bsModal) {
                bsModal.hide();
            }
        }
        
        handleModalHidden(modal) {
            const modalId = modal.id;
            
            if (modalId === 'approveModal') {
                const approveBtn = document.getElementById('confirmApprove');
                if (approveBtn) {
                    this.hideLoading(approveBtn);
                    this.disableCancelButtons(false);
                }
                this.currentApproveForm = null;
            } else if (modalId === 'rejectModal') {
                const rejectBtn = document.getElementById('confirmReject');
                if (rejectBtn) {
                    this.hideLoading(rejectBtn);
                    this.disableCancelButtons(false);
                }
                this.currentRejectForm = null;
            }
        }

        showLoading(button) {
            if (button) {
                button.classList.add('loading');
                button.disabled = true;
            }
        }

        hideLoading(button) {
            if (button) {
                button.classList.remove('loading');
                button.disabled = false;
            }
        }

        disableCancelButtons(disabled) {
            const cancelApproveBtn = document.getElementById('cancelApproveBtn');
            const cancelRejectBtn = document.getElementById('cancelRejectBtn');
            
            if (cancelApproveBtn) cancelApproveBtn.disabled = disabled;
            if (cancelRejectBtn) cancelRejectBtn.disabled = disabled;
        }

        handleApprove(userIm, userName, version) {
            const formId = version === 'mobile' ? `approve-form-mobile-${userIm}` : `approve-form-${userIm}`;
            const form = document.getElementById(formId);
            
            if (!form) {
                console.error(`❌ Formulaire non trouvé: ${formId}`);
                return;
            }
            
            const roleSelect = form.querySelector(version === 'mobile' ? '.role-select-mobile' : '.role-select');
            
            if (!roleSelect) {
                console.error(`❌ Sélecteur de rôle non trouvé pour: ${userIm}`);
                return;
            }

            if (!roleSelect.value) {
                const btnId = version === 'mobile' ? `approve-btn-mobile-${userIm}` : `approve-btn-${userIm}`;
                const button = document.getElementById(btnId);
                if (button) {
                    this.showRoleRequiredAlert(button, version);
                }
                return;
            }

            this.currentApproveForm = form;
            
            const approveBtn = document.getElementById('confirmApprove');
            if (approveBtn) {
                this.hideLoading(approveBtn);
                this.disableCancelButtons(false);
            }
            
            const approveUserName = document.getElementById('approveUserName');
            const selectedRoleText = document.getElementById('selectedRoleText');
            
            if (approveUserName) approveUserName.textContent = userName;
            
            const selectedOption = roleSelect.options[roleSelect.selectedIndex];
            if (selectedRoleText) selectedRoleText.textContent = selectedOption.text;
            
            const modalElement = document.getElementById('approveModal');
            if (modalElement) {
                const modal = new bootstrap.Modal(modalElement);
                modal.show();
                
                console.log(`✅ Modal approbation ouvert pour: ${userName}`);
            } else {
                console.error('❌ Modal approbation non trouvé');
            }
        }

        handleReject(userIm, userName, version) {
            const formId = version === 'mobile' ? `reject-form-mobile-${userIm}` : `reject-form-${userIm}`;
            const form = document.getElementById(formId);
            
            if (!form) {
                console.error(`❌ Formulaire de rejet non trouvé: ${formId}`);
                return;
            }
            
            this.currentRejectForm = form;
            
            const rejectBtn = document.getElementById('confirmReject');
            if (rejectBtn) {
                this.hideLoading(rejectBtn);
                this.disableCancelButtons(false);
            }
            
            const rejectUserName = document.getElementById('rejectUserName');
            if (rejectUserName) rejectUserName.textContent = userName;
            
            const modalElement = document.getElementById('rejectModal');
            if (modalElement) {
                const modal = new bootstrap.Modal(modalElement);
                modal.show();
                
                console.log(`❌ Modal rejet ouvert pour: ${userName}`);
            } else {
                console.error('❌ Modal rejet non trouvé');
            }
        }

        checkForHighlight() {
            const highlightedRow = document.querySelector('.highlighted-user');
            const highlightedCard = document.querySelector('.user-card.highlighted-user');
            
            if (highlightedRow) {
                highlightedRow.scrollIntoView({ behavior: 'smooth', block: 'center' });
            }
            
            if (highlightedCard) {
                highlightedCard.scrollIntoView({ behavior: 'smooth', block: 'center' });
            }
            
            if (highlightedRow || highlightedCard) {
                console.log('🎯 Utilisateur mis en évidence détecté');
            }
        }
    };
}

// FONCTION POUR RÉINITIALISER LES MODALS BOOTSTRAP
function reinitializeBootstrapModals() {
    const modalIds = ['approveModal', 'rejectModal'];
    
    modalIds.forEach(modalId => {
        const modalElement = document.getElementById(modalId);
        if (modalElement) {
            const oldInstance = bootstrap.Modal.getInstance(modalElement);
            if (oldInstance) {
                oldInstance.dispose();
            }
            
            new bootstrap.Modal(modalElement, {
                backdrop: 'static',
                keyboard: false
            });
            
            console.log(`✅ Modal ${modalId} réinitialisé`);
        }
    });
}

// FONCTION DE DÉPANNAGE
window.forceButtonInit = function() {
    console.log('🛠️ Forçage manuel de l\'initialisation des boutons');
    
    if (window.buttonInitializationSystem) {
        window.buttonInitializationSystem.reinitialize();
    }
    
    if (window.pendingListModalSystem) {
        window.pendingListModalSystem.init();
    }
    
    reinitializeBootstrapModals();
    
    console.log('✅ Initialisation forcée terminée');
};

// 🚀 DÉMARRAGE DES SYSTÈMES - COMBINAISON
document.addEventListener('DOMContentLoaded', () => {
    console.log('🚀 Démarrage des systèmes combinés');
    
    // 1. Système de diagrammes
    window.pieChartSystem = new PieChartSystem();
    
    // 2. Système CRITIQUE d'initialisation des boutons
    window.buttonInitializationSystem = new ButtonInitializationSystem();
    
    // 3. Système de rafraîchissement manuel
    window.dashboardRefreshSystem = new ManualRefreshSystem();
    
    // 4. Système de filtres
    window.statutFilterSystem = new StatutFilterSystem();
    
    // 5. Système modal (avec vérification pour éviter double déclaration)
    window.pendingListModalSystem = new window.PendingListModalSystem();
    
    console.log('✅ Tous les systèmes initialisés');
    
    // Vérification finale
    setTimeout(() => {
        const totalUsers = parseInt('{{ pending_users|default(0) }}') || 0;
        const totalButtons = document.querySelectorAll('.approve-btn, .reject-btn').length;
        
        console.log(`📊 Vérification: ${totalUsers} utilisateurs en attente, ${totalButtons} boutons trouvés`);
        
        if (totalUsers > 0 && totalButtons === 0) {
            console.warn('⚠️ Problème détecté: utilisateurs mais pas de boutons');
            window.forceButtonInit();
        }
    }, 1500);
});

// GESTION DES CHANGEMENTS DE RÔLE POUR LE SYSTÈME DE BOUTONS
document.addEventListener('change', (e) => {
    if (e.target.matches('.role-select, .role-select-mobile')) {
        // Cette logique est maintenant gérée par ButtonInitializationSystem
        // Laisser le gestionnaire pour compatibilité
        const version = e.target.matches('.role-select-mobile') ? 'mobile' : 'desktop';
        const userIm = e.target.id.replace('role-select-', '').replace('role-select-mobile-', '');
        
        const approveBtnId = version === 'mobile' 
            ? `approve-btn-mobile-${userIm}`
            : `approve-btn-${userIm}`;
        
        const approveBtn = document.getElementById(approveBtnId);
        if (approveBtn) {
            const hasValue = e.target.value !== '';
            
            // Mettre à jour l'apparence
            e.target.classList.remove('is-invalid', 'is-valid');
            if (hasValue) {
                e.target.classList.add('is-valid');
            } else {
                e.target.classList.add('is-invalid');
            }
            
            // Mettre à jour le bouton
            approveBtn.disabled = !hasValue;
        }
    }
});
</script>
