{% extends 'base.html.twig' %}

{% block title %}Tableau de Bord Admin{% endblock %}

{% block stylesheets %}
<style>
:root {
    --primary-color: #964ee3;
    --secondary-color: #75165f;
    --success-color: #10b981;
    --warning-color: #f59e0b;
    --danger-color: #ef4444;
    --info-color: #3b82f6;
    --dark-color: #1f2937;
    --light-color: #f8fafc;
}

/* Dashboard Layout */
.dashboard-container {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
}

/* Message de bienvenue amélioré */
.welcome-container {
    background: linear-gradient(135deg, #964ee3 0%, #75165f 100%);
    color: white;
    padding: 2rem;
    border-radius: 16px;
    margin-bottom: 1.5rem;
    box-shadow: 0 8px 32px rgba(150, 78, 227, 0.3);
    position: relative;
    overflow: hidden;
}

.welcome-container::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -50%;
    width: 100%;
    height: 100%;
    background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, rgba(255,255,255,0) 70%);
    transform: rotate(30deg);
}

.welcome-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    position: relative;
    z-index: 2;
}

.welcome-text {
    flex: 1;
}

.welcome-text h1 {
    margin: 0 0 0.75rem 0;
    font-size: 2rem;
    font-weight: 700;
    color: white;
    line-height: 1.2;
}

.welcome-text p {
    margin: 0 0 1.5rem 0;
    opacity: 0.95;
    font-size: 1.1rem;
    line-height: 1.6;
    max-width: 700px;
    font-weight: 400;
}

.welcome-icon {
    font-size: 4rem;
    opacity: 0.9;
    flex-shrink: 0;
    animation: float 3s ease-in-out infinite;
}

.welcome-badge {
    background: rgba(255, 255, 255, 0.2);
    color: white;
    padding: 0.5rem 1rem;
    border-radius: 20px;
    font-size: 0.85rem;
    font-weight: 600;
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.3);
    margin-top: 1rem;
    display: inline-block;
}

@keyframes float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-10px); }
}

/* Responsive pour le message de bienvenue */
@media (max-width: 768px) {
    .welcome-container {
        padding: 1.5rem;
    }
    
    .welcome-content {
        flex-direction: column;
        text-align: center;
        gap: 1.5rem;
    }
    
    .welcome-text h1 {
        font-size: 1.5rem;
    }
    
    .welcome-text p {
        font-size: 1rem;
    }
    
    .welcome-icon {
        font-size: 2.5rem;
        order: -1;
    }
}

@media (max-width: 480px) {
    .welcome-container {
        padding: 1.25rem;
    }
    
    .welcome-text h1 {
        font-size: 1.3rem;
    }
    
    .welcome-text p {
        font-size: 0.95rem;
    }
}

/* Reste du CSS existant... */
.inscriptions-table th:nth-child(1) { width: 120px; }
.inscriptions-table th:nth-child(2) { width: 140px; }
.inscriptions-table th:nth-child(3) { width: 140px; }
.inscriptions-table th:nth-child(4) { width: 140px; }
.inscriptions-table th:nth-child(5) { width: 140px; }
.inscriptions-table th:nth-child(6) { width: 110px; }
.inscriptions-table th:nth-child(7) { width: 190px; text-align: center;}

/* Section Grid Compact pour Personnel */
.section-grid-compact {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
    margin-bottom: 0;
}

/* Stat Cards Compact */
.stat-card-compact {
    background: #d28eef58;
    padding: 1.25rem;
    border-radius: 12px;
    box-shadow: 0 4px 6px rgba(0,0,0,0.05);
    border-left: 4px solid var(--primary-color);
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
}

.stat-card-compact:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 20px rgba(0,0,0,0.1);
}

.stat-card-compact.success { border-left-color: var(--success-color); }
.stat-card-compact.warning { border-left-color: var(--warning-color); }
.stat-card-compact.danger { border-left-color: var(--danger-color); }
.stat-card-compact.info { border-left-color: var(--info-color); }
.stat-card-compact.secondary { border-left-color: var(--secondary-color); }

.stat-header-compact {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.75rem;
}

.stat-icon-compact {
    width: 45px;
    height: 45px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.3rem;
    color: white;
    flex-shrink: 0;
}

.stat-card-compact .stat-icon-compact { background: var(--primary-color); }
.stat-card-compact.success .stat-icon-compact { background: var(--success-color); }
.stat-card-compact.warning .stat-icon-compact { background: var(--warning-color); }
.stat-card-compact.danger .stat-icon-compact { background: var(--danger-color); }
.stat-card-compact.info .stat-icon-compact { background: var(--info-color); }
.stat-card-compact.secondary .stat-icon-compact { background: var(--secondary-color); }

.stat-content-compact h3 {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--dark-color);
    margin: 0;
    line-height: 1;
}

.stat-label-compact {
    color: #6b7280;
    font-size: 0.8rem;
    margin: 0.25rem 0 0 0;
    font-weight: 500;
}

/* Sections principales */
.dashboard-section {
    background: white;
    border-radius: 16px;
    padding: 1.5rem;
    box-shadow: rgba(0, 0, 0, 0.1) 0px 4px 12px;
    margin-bottom: 1.5rem;
}

.section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 2px solid #f1f5f9;
}

.section-header-inscription {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 2px solid #f1f5f9;
}

.section-title {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--dark-color);
    margin: 0;
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.section-title i {
    color: var(--primary-color);
}

