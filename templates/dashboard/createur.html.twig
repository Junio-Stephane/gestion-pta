    color: var(--dark-color);
    background: #f1f5f9;
    padding: 0.2rem 0.5rem;
    border-radius: 12px;
}

/* Filtres */
.filters {
    display: flex;
    gap: 1rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
    align-items: end;
}

.filter-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    min-width: 150px;
}

.filter-label {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--dark-color);
}

.filter-select {
    padding: 0.5rem;
    border: 1px solid #d1d5db;
    border-radius: 6px;
    background: white;
    font-size: 0.8rem;
    min-width: 100%;
    cursor: pointer;
}

.filter-select:focus {
    outline: none;
    border-color: var(--primary-color);
    box-shadow: 0 0 0 3px rgba(150, 78, 227, 0.1);
}

/* Style pour le bouton Réinitialiser */
.btn-reset-filters {
