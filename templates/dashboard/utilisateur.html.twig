{% block javascripts %}
<script>
class UtilisateurDashboardCharts {
    constructor() {
        this.projetsData = {{ donnees_projets_utilisateur|json_encode|raw }};
        this.tachesData = {{ donnees_taches_utilisateur|json_encode|raw }};
        this.init();
    }

    init() {
        console.log('📊 Initialisation dashboard utilisateur');
        console.log('📁 Données projets:', this.projetsData);
        console.log('📋 Données tâches:', this.tachesData);
        
        this.updateOverviewCharts();
        this.updateDetailCharts();
        this.updateTachesPieChart(); // Chargement immédiat
        this.setupFilters();
    }

    // 🎯 FILTRER LES PROJETS POUR LA VUE D'ENSEMBLE
    getFilteredOverviewProjets() {
        const statutFilter = document.getElementById('statutFilter').value;
        const avancementFilter = document.getElementById('avancementFilter').value;
        
        let filteredProjets = this.projetsData;

        // Filtre par statut
        if (statutFilter !== 'all') {
            filteredProjets = filteredProjets.filter(p => p.statut === statutFilter);
        }

        // Filtre par avancement
        if (avancementFilter !== 'all') {
            filteredProjets = filteredProjets.filter(projet => {
                const avancement = projet.avancement;
                
                switch (avancementFilter) {
                    case '0':
                        return avancement === 0;
                    case '1-25':
                        return avancement >= 1 && avancement <= 25;
                    case '26-50':
                        return avancement >= 26 && avancement <= 50;
                    case '51-75':
                        return avancement >= 51 && avancement <= 75;
                    case '76-99':
                        return avancement >= 76 && avancement <= 99;
                    case '100':
                        return avancement === 100;
                    default:
                        return true;
                }
            });
        }

        console.log('Projets vue d\'ensemble filtrés:', filteredProjets.length);
        return filteredProjets;
    }

    // 🎯 FILTRER LES PROJETS POUR LA VUE DÉTAILLÉE
    getFilteredDetailProjets() {
        const statutFilter = document.getElementById('detailStatutFilter').value;
        const avancementFilter = document.getElementById('detailAvancementFilter').value;
        
        let filteredProjets = this.projetsData;

        // Filtre par statut
        if (statutFilter !== 'all') {
            filteredProjets = filteredProjets.filter(p => p.statut === statutFilter);
        }

        // Filtre par avancement
        if (avancementFilter !== 'all') {
            filteredProjets = filteredProjets.filter(projet => {
                const avancement = projet.avancement;
                
                switch (avancementFilter) {
                    case '0':
                        return avancement === 0;
                    case '1-25':
                        return avancement >= 1 && avancement <= 25;
                    case '26-50':
                        return avancement >= 26 && avancement <= 50;
                    case '51-75':
                        return avancement >= 51 && avancement <= 75;
                    case '76-99':
                        return avancement >= 76 && avancement <= 99;
                    case '100':
                        return avancement === 100;
                    default:
                        return true;
                }
            });
        }

        console.log('Projets vue détaillée filtrés:', filteredProjets.length);
        return filteredProjets;
    }

    // 🎯 FILTRER LES TÂCHES PAR PROJET - CORRIGÉ
    getFilteredTaches() {
        const projetFilter = document.getElementById('projetFilter').value;
        
        console.log('🔍 Filtre projet sélectionné:', projetFilter);
        console.log('📋 Toutes les tâches disponibles:', this.tachesData);

        let filteredTaches = this.tachesData;

        // Filtre par projet
        if (projetFilter !== 'all') {
            filteredTaches = filteredTaches.filter(t => {
                const match = t.projetId == projetFilter;
                console.log(`🔍 Tâche "${t.titre}" - projetId: ${t.projetId}, filtre: ${projetFilter}, match: ${match}`);
                return match;
            });
        }

        console.log('✅ Tâches filtrées:', filteredTaches.length, filteredTaches);
        return filteredTaches;
    }

    // 🔄 RÉINITIALISER LES FILTRES VUE D'ENSEMBLE
    resetOverviewFilters() {
        document.getElementById('statutFilter').value = 'all';
        document.getElementById('avancementFilter').value = 'all';
        
        this.updateOverviewCharts();
        
        const resetBtn = document.getElementById('resetOverviewFilters');
        const originalText = resetBtn.innerHTML;
        resetBtn.innerHTML = '<i class="bi bi-check"></i> Réinitialisé !';
        resetBtn.style.background = 'var(--success-color)';
        
        setTimeout(() => {
            resetBtn.innerHTML = originalText;
            resetBtn.style.background = '';
        }, 1500);
    }

    // 🔄 RÉINITIALISER LES FILTRES VUE DÉTAILLÉE
    resetDetailFilters() {
        document.getElementById('detailStatutFilter').value = 'all';
        document.getElementById('detailAvancementFilter').value = 'all';
        
        this.updateDetailCharts();
        
        const resetBtn = document.getElementById('resetDetailFilters');
        const originalText = resetBtn.innerHTML;
        resetBtn.innerHTML = '<i class="bi bi-check"></i> Réinitialisé !';
        resetBtn.style.background = 'var(--success-color)';
        
        setTimeout(() => {
            resetBtn.innerHTML = originalText;
            resetBtn.style.background = '';
        }, 1500);
    }

    // 📊 DIAGRAMME EN BÂTONS VERTICAL CLASSIQUE (VUE D'ENSEMBLE)
    updateVerticalBarChart() {
        const filteredProjets = this.getFilteredOverviewProjets();
        const chartArea = document.getElementById('verticalBarChart');
        
        chartArea.innerHTML = '';

        if (filteredProjets.length === 0) {
            const emptyMessage = document.createElement('div');
            emptyMessage.className = 'empty-chart-message';
            emptyMessage.textContent = 'Aucun projet correspondant aux filtres';
            chartArea.appendChild(emptyMessage);
            return;
        }

        filteredProjets.forEach(projet => {
            const barColumn = document.createElement('div');
            barColumn.className = 'bar-column';
            
            const barWrapper = document.createElement('div');
            barWrapper.className = 'bar-wrapper';
            
            const barValue = document.createElement('div');
            barValue.className = 'bar-value';
            barValue.textContent = `${projet.avancement}%`;
            
            const bar = document.createElement('div');
            bar.className = 'bar';
            
            const barHeight = Math.max(projet.avancement, 3);
            bar.style.height = `${barHeight}%`;
            
            if (projet.avancement === 0) {
                bar.classList.add('zero-progress');
            } else {
                const color = this.getColorForStatus(projet.statut);
                bar.style.background = color;
            }
            
            bar.appendChild(barValue);
            barWrapper.appendChild(bar);
            
            const barLabel = document.createElement('div');
            barLabel.className = 'bar-label';
            barLabel.textContent = this.truncateText(projet.titre, 15);
            barLabel.title = `${projet.titre} (${projet.avancement}%) - ${projet.statut}`;
            
            barColumn.appendChild(barWrapper);
            barColumn.appendChild(barLabel);
            chartArea.appendChild(barColumn);
        });
    }

    // 📊 DIAGRAMME HORIZONTAL AMÉLIORÉ (VUE DÉTAILLÉE)
    updateHorizontalGanttChart() {
        const filteredProjets = this.getFilteredDetailProjets();
        const container = document.getElementById('horizontalGanttChart');
        
        container.innerHTML = '';

        if (filteredProjets.length === 0) {
            const emptyMessage = document.createElement('div');
            emptyMessage.className = 'empty-chart-message';
            emptyMessage.textContent = 'Aucun projet correspondant aux filtres';
            container.appendChild(emptyMessage);
            return;
        }

        // Trier les projets par date de début
        const projetsTries = [...filteredProjets].sort((a, b) => {
            const dateA = this.parseDate(a.dateDebut);
            const dateB = this.parseDate(b.dateDebut);
            return dateA - dateB;
        });

        projetsTries.forEach(projet => {
            const ganttRow = document.createElement('div');
            ganttRow.className = 'gantt-row';
            
            // Informations du projet
            const projectInfo = document.createElement('div');
            projectInfo.className = 'gantt-project-info';
            
            const projectName = document.createElement('div');
            projectName.className = 'gantt-project-name';
            projectName.textContent = this.truncateText(projet.titre, 30);
            projectName.title = projet.titre;
            
            const projectDates = document.createElement('div');
            projectDates.className = 'gantt-project-dates';
            projectDates.innerHTML = `
                <span><i class="bi bi-play-fill"></i> ${this.formatDate(projet.dateDebut)}</span>
                <span><i class="bi bi-flag-fill"></i> ${projet.dateFin ? this.formatDate(projet.dateFin) : '?'}</span>
            `;
            
            projectInfo.appendChild(projectName);
            projectInfo.appendChild(projectDates);
            ganttRow.appendChild(projectInfo);

            // Timeline et barre de progression
            const timelineContainer = document.createElement('div');
            timelineContainer.className = 'gantt-timeline-container';
            
            const barContainer = document.createElement('div');
            barContainer.className = 'gantt-bar-container';
            
            const bar = document.createElement('div');
            bar.className = 'gantt-bar';
            
            // Déterminer la classe de couleur en fonction du statut et des dates
            const today = new Date();
            const endDate = projet.dateFin ? this.parseDate(projet.dateFin) : null;
            let barClass = 'in-progress';
            let statusIndicator = null;
            let daysText = '';

            if (projet.statut === 'Terminé') {
                barClass = 'completed';
                statusIndicator = { type: 'success', icon: 'bi-check-circle', text: 'Terminé' };
                daysText = 'Terminé';
            } else if (projet.statut === 'Suspendu') {
                barClass = 'suspended';
                statusIndicator = { type: 'secondary', icon: 'bi-pause-circle', text: 'Suspendu' };
                daysText = 'Suspendu';
            } else if (endDate) {
                const daysUntilDeadline = Math.ceil((endDate - today) / (1000 * 60 * 60 * 24));
                
                if (daysUntilDeadline < 0) {
                    barClass = 'danger';
                    const daysLate = Math.abs(daysUntilDeadline);
                    daysText = `${daysLate} jour${daysLate > 1 ? 's' : ''} de retard`;
                    statusIndicator = { 
                        type: 'danger', 
                        icon: 'bi-clock', 
                        text: daysText, 
                        blink: true 
                    };
                } else if (daysUntilDeadline <= 5) {
                    barClass = 'warning';
                    daysText = `${daysUntilDeadline} jour${daysUntilDeadline > 1 ? 's' : ''} restant${daysUntilDeadline > 1 ? 's' : ''}`;
                    statusIndicator = { 
                        type: 'warning', 
                        icon: 'bi-exclamation-triangle', 
                        text: daysText 
                    };
                } else {
                    barClass = 'in-progress';
                    daysText = `${daysUntilDeadline} jour${daysUntilDeadline > 1 ? 's' : ''} restant${daysUntilDeadline > 1 ? 's' : ''}`;
                    statusIndicator = { 
                        type: 'info', 
                        icon: 'bi-play-circle', 
                        text: daysText 
                    };
                }
            } else {
                barClass = 'in-progress';
                daysText = 'Pas de date fin';
                statusIndicator = { 
                    type: 'info', 
                    icon: 'bi-play-circle', 
                    text: daysText 
                };
            }
            
            bar.classList.add(barClass);
            bar.style.width = `${Math.max(projet.avancement, 5)}%`;
            
            const barValue = document.createElement('div');
            barValue.className = 'gantt-bar-value';
            barValue.textContent = `${projet.avancement}%`;
            bar.appendChild(barValue);
            
            barContainer.appendChild(bar);
            timelineContainer.appendChild(barContainer);
            
            // Pourcentage
            const percentage = document.createElement('div');
            percentage.className = 'gantt-percentage';
            percentage.textContent = `${projet.avancement}%`;
            timelineContainer.appendChild(percentage);
            
            // Indicateurs de statut avec nombre de jours
            if (statusIndicator) {
                const statusContainer = document.createElement('div');
                statusContainer.className = 'gantt-status-indicators';
                
                const indicator = document.createElement('div');
                indicator.className = `status-indicator ${statusIndicator.type}`;
                if (statusIndicator.blink) {
                    indicator.classList.add('danger');
                }
                
                indicator.innerHTML = `
                    <i class="bi ${statusIndicator.icon}"></i>
                    <span>${statusIndicator.text}</span>
                `;
                
                statusContainer.appendChild(indicator);
                timelineContainer.appendChild(statusContainer);
            }
            
            ganttRow.appendChild(timelineContainer);
            container.appendChild(ganttRow);
        });

        // Afficher le nombre de projets affichés
        if (filteredProjets.length > 10) {
            const countInfo = document.createElement('div');
            countInfo.className = 'text-center text-muted small mt-2';
            countInfo.textContent = `${filteredProjets.length} projets affichés - Faites défiler pour voir tous les projets`;
            container.appendChild(countInfo);
        }
    }

    // 🥧 DIAGRAMME CAMEMBERT DES TÂCHES - CORRIGÉ
    updateTachesPieChart() {
        console.log('🔄 Mise à jour du camembert des tâches');
        
        const filteredTaches = this.getFilteredTaches();
        const pieChart = document.getElementById('tachesPieChart');
        const totalCount = document.getElementById('totalTachesCount');
        const legend = document.getElementById('tachesLegend');
        
        // Mettre à jour le total
        totalCount.textContent = filteredTaches.length;
        console.log(`📊 Total tâches: ${filteredTaches.length}`);

        if (filteredTaches.length === 0) {
            console.log('❌ Aucune tâche à afficher');
            pieChart.style.background = 'conic-gradient(#e5e7eb 0% 100%)';
            legend.innerHTML = '<div class="empty-chart-message">Aucune tâche correspondant au filtre</div>';
            return;
        }

        // Compter les tâches par statut
        const statuts = {
            'Débuté': 0,
            'En cours': 0,
            'Terminé': 0,
            'Suspendu': 0
        };

        filteredTaches.forEach(tache => {
            if (statuts.hasOwnProperty(tache.statut)) {
                statuts[tache.statut]++;
            } else {
                console.warn(`⚠️ Statut inconnu: ${tache.statut} pour la tâche: ${tache.titre}`);
            }
        });

        const total = filteredTaches.length;
        console.log('📈 Répartition des statuts:', statuts);
        
        // Générer le gradient pour le camembert
        let currentPercent = 0;
        let gradientString = '';
        const colors = {
            'Débuté': 'var(--info-color)',
            'En cours': 'var(--warning-color)',
            'Terminé': 'var(--success-color)',
            'Suspendu': 'var(--danger-color)'
        };

        // Créer un tableau ordonné pour un affichage cohérent
        const statutsOrder = ['Débuté', 'En cours', 'Terminé', 'Suspendu'];
        
        statutsOrder.forEach(statut => {
            const count = statuts[statut];
            if (count > 0) {
                const percent = (count / total) * 100;
                if (gradientString) gradientString += ', ';
                gradientString += `${colors[statut]} ${currentPercent}% ${currentPercent + percent}%`;
                currentPercent += percent;
                console.log(`🎨 Ajout segment: ${statut} - ${percent}% (${count} tâches)`);
            }
        });

        // Appliquer le dégradé
        if (gradientString) {
            pieChart.style.background = `conic-gradient(${gradientString})`;
            console.log('✅ Dégradé appliqué:', gradientString);
        } else {
            pieChart.style.background = 'conic-gradient(#e5e7eb 0% 100%)';
            console.log('⚠️ Dégradé par défaut appliqué');
        }

        // Mettre à jour la légende
        legend.innerHTML = '';
        let hasData = false;
        
        statutsOrder.forEach(statut => {
            const count = statuts[statut];
            if (count > 0) {
                hasData = true;
                const percent = total > 0 ? Math.round((count / total) * 100) : 0;
                
                const legendItem = document.createElement('div');
                legendItem.className = 'legend-item';
                
                legendItem.innerHTML = `
                    <div class="legend-color" style="background-color: ${colors[statut]};"></div>
                    <div class="legend-info">
                        <span class="legend-label">${statut}</span>
                        <span class="legend-value">${count}</span>
                    </div>
                    <span class="legend-percentage">${percent}%</span>
                `;
                
                legend.appendChild(legendItem);
                console.log(`📝 Légende ajoutée: ${statut} - ${count} tâches (${percent}%)`);
            }
        });

        // Si aucun statut n'est trouvé mais qu'il y a des tâches
        if (!hasData && filteredTaches.length > 0) {
            const legendItem = document.createElement('div');
            legendItem.className = 'legend-item';
            legendItem.innerHTML = `
                <div class="legend-color" style="background-color: #6b7280;"></div>
                <div class="legend-info">
                    <span class="legend-label">Statut inconnu</span>
                    <span class="legend-value">${filteredTaches.length}</span>
                </div>
                <span class="legend-percentage">100%</span>
            `;
            legend.appendChild(legendItem);
            console.log('📝 Légende par défaut ajoutée');
        }

        console.log('✅ Camembert des tâches mis à jour avec succès');
    }

    // 🎛️ CONFIGURATION DES FILTRES SÉPARÉS - CORRIGÉ
    setupFilters() {
        console.log('⚙️ Configuration des filtres');
        
        // Boutons de réinitialisation
        document.getElementById('resetOverviewFilters').addEventListener('click', () => {
            this.resetOverviewFilters();
        });

        document.getElementById('resetDetailFilters').addEventListener('click', () => {
            this.resetDetailFilters();
        });

        // Filtres pour la vue d'ensemble
        ['statutFilter', 'avancementFilter'].forEach(filterId => {
            document.getElementById(filterId).addEventListener('change', () => {
                console.log(`🔄 Filtre ${filterId} changé - mise à jour vue d'ensemble`);
                this.updateOverviewCharts();
            });
        });

        // Filtres pour la vue détaillée
        ['detailStatutFilter', 'detailAvancementFilter'].forEach(filterId => {
            document.getElementById(filterId).addEventListener('change', () => {
                console.log(`🔄 Filtre ${filterId} changé - mise à jour vue détaillée`);
                this.updateDetailCharts();
            });
        });

        // Filtre pour les tâches - CORRECTION AVEC DÉBOGAGE
        const projetFilter = document.getElementById('projetFilter');
        if (projetFilter) {
            projetFilter.addEventListener('change', (e) => {
                console.log('🔄 Filtre projet changé:', e.target.value);
                console.log('📋 Options disponibles:', Array.from(projetFilter.options).map(opt => ({ value: opt.value, text: opt.text })));
                this.updateTachesPieChart();
            });
            
            // Forcer le rafraîchissement initial
            setTimeout(() => {
                console.log('🔄 Chargement initial du camembert des tâches');
                this.updateTachesPieChart();
            }, 500);
        } else {
            console.error('❌ Élément projetFilter non trouvé');
        }

        console.log('✅ Tous les filtres configurés');
    }

    // 🎨 COULEURS PAR STATUT
    getColorForStatus(statut) {
        const colors = {
            'Débuté': '#964ee3',
            'En cours': '#f59e0b',
            'Terminé': '#10b981',
            'Suspendu': '#ef4444'
        };
        return colors[statut] || '#964ee3';
    }

    // 📅 CORRECTION DU PARSING DES DATES
    parseDate(dateString) {
        if (!dateString) return new Date();
        
        // Si c'est déjà un objet Date
        if (dateString instanceof Date) {
            return dateString;
        }
        
        // Si c'est une chaîne au format YYYY-MM-DD
        if (typeof dateString === 'string') {
            // Essayer différents formats de date
            const date = new Date(dateString);
            if (!isNaN(date.getTime())) {
                return date;
            }
            
            // Essayer avec le format français
            const parts = dateString.split('/');
            if (parts.length === 3) {
                return new Date(parts[2], parts[1] - 1, parts[0]);
            }
            
            // Essayer avec le format timestamp
            const timestamp = Date.parse(dateString);
            if (!isNaN(timestamp)) {
                return new Date(timestamp);
            }
        }
        
        console.warn('Date invalide:', dateString);
        return new Date();
    }

    // 📅 FORMATER LES DATES - CORRIGÉ
    formatDate(dateString) {
        try {
            const date = this.parseDate(dateString);
            return date.toLocaleDateString('fr-FR', {
                day: '2-digit',
                month: '2-digit',
                year: 'numeric'
            });
        } catch (error) {
            console.error('Erreur format date:', error, dateString);
            return 'N/A';
        }
    }

    // 🔄 METTRE À JOUR LES GRAPHIQUES DE LA VUE D'ENSEMBLE
    updateOverviewCharts() {
        console.log('🔄 Mise à jour des graphiques vue d\'ensemble');
        this.updateVerticalBarChart();
    }

    // 🔄 METTRE À JOUR LES GRAPHIQUES DE LA VUE DÉTAILLÉE
    updateDetailCharts() {
        console.log('🔄 Mise à jour des graphiques vue détaillée');
        this.updateHorizontalGanttChart();
    }

    // ✂️ TRONQUER LE TEXTE POUR LES LABELS
    truncateText(text, maxLength) {
        if (!text) return '';
        if (text.length <= maxLength) return text;
        return text.substring(0, maxLength - 3) + '...';
    }
}

