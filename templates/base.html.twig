            // Synchronisation entre les systèmes
            function synchronizeNotificationSystems() {
                if (window.globalNotificationSystem && window.dashboardRefreshSystem) {
                    console.log('🔗 Synchronisation des systèmes de notification et dashboard');
                    
                    // Créer un canal de communication entre les systèmes
                    window.globalNotificationSystem.refreshDashboard = function() {
                        if (window.dashboardRefreshSystem) {
                            window.dashboardRefreshSystem.refreshPendingList();
                        }
                    };
                    
                    window.dashboardRefreshSystem.notifyNewRegistration = function() {
                        if (window.globalNotificationSystem) {
