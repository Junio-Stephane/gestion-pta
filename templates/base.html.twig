        <script>
            // SYSTÈME DE NOTIFICATIONS GLOBALES - ADMIN SEULEMENT
            class GlobalNotificationSystem {
                constructor() {
                    this.currentNotificationCount = 0;
                    this.isChecking = false;
                    this.displayedNotificationIds = new Set();
                    this.isAdmin = false;
                    
                    this.init();
                }

                init() {
                    console.log('🌍 Initialisation système notifications globales');
                    
                    this.checkUserRole();
                    
                    if (this.isAdmin) {
                        this.loadInitialCount();
                        this.startGlobalPolling();
                        console.log('✅ Système notifications activé pour ADMIN');
                    } else {
                        console.log('🔕 Notifications désactivées - Rôle non admin');
                        this.hideNotificationElements();
                    }
                    
                    window.globalNotificationSystem = this;
                }

                checkUserRole() {
                    // Méthode 1: Vérifier via le texte du rôle
                    const userRoleElement = document.querySelector('.user-role');
                    if (userRoleElement) {
                        const roleText = userRoleElement.textContent.toLowerCase();
                        this.isAdmin = roleText.includes('administrateur') || roleText.includes('admin');
                    }
                    
                    // Méthode 2: Vérifier via les classes du body
                    const body = document.body;
                    this.isAdmin = body.classList.contains('role-admin') || this.isAdmin;
                    
                    console.log('👤 Rôle utilisateur détecté:', this.isAdmin ? 'ADMIN' : 'NON-ADMIN');
                }

                hideNotificationElements() {
                    const notificationContainer = document.querySelector('.notification-container');
                    if (notificationContainer) {
                        notificationContainer.style.display = 'none';
                    }
                    
                    const globalNotifications = document.getElementById('globalNotifications');
                    if (globalNotifications) {
                        globalNotifications.style.display = 'none';
                    }
                }

                startGlobalPolling() {
                    if (!this.isAdmin) {
                        console.log('🔕 Polling désactivé - Rôle non admin');
                        return;
                    }

                    const checkNotifications = async () => {
                        if (this.isChecking || !this.isAdmin) return;
                        
                        this.isChecking = true;
                        try {
                            const response = await fetch(`/api/notifications/count?_=${Date.now()}`);
                            
                            if (!response.ok) throw new Error('Erreur de chargement');
                            
                            const data = await response.json();
                            const newCount = data.count;
                            
                            if (newCount > this.currentNotificationCount) {
                                const newNotificationsCount = newCount - this.currentNotificationCount;
                                console.log('🆕 Nouvelles notifications détectées:', newNotificationsCount);
                                
                                const latestNotifications = await this.getLatestNotifications();
                                
                                const newNotifications = latestNotifications.filter(notification => 
                                    !this.displayedNotificationIds.has(notification.id)
                                );
                                
                                newNotifications.forEach(notification => {
                                    this.showGlobalNotification(notification);
                                    this.displayedNotificationIds.add(notification.id);
                                });
                            }
                            
                            this.updateGlobalBadge(newCount);
                            this.currentNotificationCount = newCount;
                            
                        } catch (error) {
                            console.error('❌ Erreur polling global:', error);
                        } finally {
                            this.isChecking = false;
                        }
                    };
                    
                    setTimeout(() => {
                        if (this.isAdmin) {
                            checkNotifications();
                            setInterval(checkNotifications, 8000);
                        }
                    }, 2000);
                }

                async loadInitialCount() {
                    if (!this.isAdmin) return;
                    
                    try {
                        const response = await fetch(`/api/notifications/count?_=${Date.now()}`);
                        if (response.ok) {
                            const data = await response.json();
                            this.currentNotificationCount = data.count;
                            this.updateGlobalBadge(data.count);
                            
                            const existingNotifications = await this.getLatestNotifications();
                            existingNotifications.forEach(notif => {
                                this.displayedNotificationIds.add(notif.id);
                            });
                        }
                    } catch (error) {
                        console.error('❌ Erreur chargement compteur initial:', error);
                    }
                }

                async getLatestNotifications() {
                    if (!this.isAdmin) return [];
                    
                    try {
                        const response = await fetch('/api/notifications/latest?_=' + Date.now());
                        if (response.ok) {
                            return await response.json();
                        }
                    } catch (error) {
                        console.error('Erreur récupération dernières notifications:', error);
                    }
                    return [];
                }

                showGlobalNotification(notification) {
                    if (!this.isAdmin) return;

                    const notificationContainer = document.getElementById('globalNotifications');
                    if (!notificationContainer) return;

                    if (this.isNotificationDisplayed(notification.id)) {
                        console.log('📌 Notification déjà affichée:', notification.id);
                        return;
                    }

                    // 🆕 RAFRAÎCHIR LA LISTE AVANT D'AFFICHER LA NOTIFICATION
                    this.handleNewNotification(notification);

                    const toast = document.createElement('div');
                    toast.className = `messenger-notification ${notification.type || 'warning'}`;
                    toast.id = `notification-${notification.id}`;
                    
                    toast.innerHTML = `
                        <div class="messenger-notification-header">
                            <div class="messenger-notification-icon">
                                <i class="bi bi-${this.getNotificationIcon(notification.type)}"></i>
                            </div>
                            <h3 class="messenger-notification-title">${notification.title || 'Nouvelle demande d\'inscription'}</h3>
                            <button class="messenger-close" onclick="window.globalNotificationSystem.removeNotification('${notification.id}')">×</button>
                        </div>
                        <div class="messenger-notification-body">
                            <p class="messenger-notification-message">
                                ${notification.message}
                            </p>
                            <div class="messenger-notification-time">
                                <i class="bi bi-clock"></i>
                                ${notification.timeAgo || 'À l\'instant'}
                            </div>
                        </div>
                        <div class="messenger-notification-actions">
                            <button class="messenger-btn messenger-btn-secondary" onclick="window.globalNotificationSystem.removeNotification('${notification.id}')">
                                <i class="bi bi-eye"></i> Ignorer
                            </button>
                            <button class="messenger-btn messenger-btn-primary" onclick="window.globalNotificationSystem.handleNotificationAction('${notification.id}', '${notification.relatedUserId}')">
                                <i class="bi bi-arrow-right"></i> Voir
                            </button>
                        </div>
                    `;

                    notificationContainer.appendChild(toast);

                    this.playNotificationSound();

                    setTimeout(() => {
                        this.removeNotification(notification.id);
                    }, 8000);
                }

                isNotificationDisplayed(notificationId) {
                    return document.getElementById(`notification-${notificationId}`) !== null || 
                           this.displayedNotificationIds.has(notificationId);
                }

                removeNotification(notificationId) {
                    const toast = document.getElementById(`notification-${notificationId}`);
                    if (toast && toast.parentNode) {
                        toast.style.animation = 'messengerSlideOut 0.3s ease';
                        setTimeout(() => {
                            if (toast.parentNode) {
                                toast.parentNode.removeChild(toast);
                            }
                        }, 300);
                    }
                }

                getNotificationIcon(type) {
                    const icons = {
                        'info': 'info-circle',
                        'warning': 'person-plus-fill',
                        'success': 'check-circle',
                        'danger': 'x-circle'
                    };
                    return icons[type] || 'bell';
                }

                updateGlobalBadge(count) {
                    if (!this.isAdmin) return;
                    
                    const badge = document.getElementById('notificationBadge');
                    if (badge) {
                        badge.textContent = count;
                        if (count > 0) {
                            badge.style.display = 'flex';
                            if (count > this.currentNotificationCount) {
                                badge.style.animation = 'pulse 1s ease-in-out';
                                setTimeout(() => {
                                    badge.style.animation = '';
                                }, 1000);
                            }
                        } else {
                            badge.style.display = 'none';
                        }
                    }
                }

                handleNotificationAction(notificationId, userIm) {
                    if (!this.isAdmin) return;
                    
                    console.log('🔔 Action sur notification:', notificationId, userIm);
                    
                    this.markAsRead(notificationId);
                    
                    const currentPath = window.location.pathname;
                    if (!currentPath.includes('/dashboard')) {
                        if (userIm) {
                            sessionStorage.setItem('highlightUserIm', userIm);
                            sessionStorage.setItem('highlightTimestamp', Date.now().toString());
                            window.location.href = '/dashboard';
                        } else {
                            window.location.href = '/dashboard';
                        }
                    } else {
                        if (userIm) {
                            this.highlightUserRow(userIm);
                        }
                    }
                    
                    this.removeNotification(notificationId);
                }

                highlightUserRow(userIm) {
                    if (!this.isAdmin) return;
                    
                    const row = document.getElementById(`user-row-${userIm}`);
                    if (row) {
                        row.classList.remove('highlighted-user', 'new-request');
                        void row.offsetWidth;
                        row.classList.add('highlighted-user');
                        
                        console.log('🎯 Mise en surbrillance de l\'utilisateur:', userIm);
                        
                        setTimeout(() => {
                            row.scrollIntoView({ 
                                behavior: 'smooth', 
                                block: 'center',
                                inline: 'nearest'
                            });
                        }, 300);
                        
                        setTimeout(() => {
                            if (row.classList.contains('highlighted-user')) {
                                row.classList.remove('highlighted-user');
                            }
                        }, 15000);
                    }
                }

                async markAsRead(notificationId) {
                    if (!this.isAdmin) return;
                    
                    try {
                        await fetch(`/api/notifications/${notificationId}/read`, {
                            method: 'POST',
                            headers: { 
                                'Content-Type': 'application/json',
                                'X-Requested-With': 'XMLHttpRequest'
                            }
                        });
                    } catch (error) {
                        console.error('Erreur marquage comme lu:', error);
                    }
                }

                playNotificationSound() {
                    if (!this.isAdmin) return;
                    
                    try {
                        const audioContext = new (window.AudioContext || window.webkitAudioContext)();
                        const oscillator = audioContext.createOscillator();
                        const gainNode = audioContext.createGain();
                        
                        oscillator.connect(gainNode);
                        gainNode.connect(audioContext.destination);
                        
                        oscillator.frequency.value = 800;
                        oscillator.type = 'sine';
                        
                        gainNode.gain.setValueAtTime(0.3, audioContext.currentTime);
                        gainNode.gain.exponentialRampToValueAtTime(0.01, audioContext.currentTime + 0.5);
                        
                        oscillator.start(audioContext.currentTime);
                        oscillator.stop(audioContext.currentTime + 0.5);
                    } catch (error) {
                        console.log('Audio non supporté');
                    }
                }

                testNewNotification() {
                    if (!this.isAdmin) {
                        console.log('🔕 Test notification désactivé - Rôle non admin');
                        return;
                    }
                    
                    const testNotification = {
                        id: 'test-' + Date.now(),
                        title: 'Test Notification',
                        message: 'Ceci est une notification de test pour une NOUVELLE demande',
                        type: 'warning',
                        timeAgo: 'À l\'instant',
                        relatedUserId: 'TEST123'
                    };
                    this.showGlobalNotification(testNotification);
                }

                // Dans base.html.twig - Ajoutez à la classe GlobalNotificationSystem
                async handleNewNotification(notification) {
                    if (!this.isAdmin) return;

                    console.log('🔄 Nouvelle notification reçue, rafraîchissement de la liste...');
                    
                    // Rafraîchir la liste des inscriptions en attente
                    if (window.dashboardRefreshSystem) {
                        await window.dashboardRefreshSystem.refreshPendingList();
                    } else {
                        // Fallback: rafraîchir manuellement si le système n'est pas disponible
                        await this.refreshPendingListFallback();
                    }
                    
                    // Mettre à jour le badge du compteur
                    this.updatePendingCountBadge();
                }

                // Méthode de fallback pour rafraîchir la liste
                async refreshPendingListFallback() {
                    try {
                        const response = await fetch('{{ path('app_dashboard_admin') }}?partial=pending_list', {
                            headers: {
                                'X-Requested-With': 'XMLHttpRequest'
                            }
                        });
                        
                        if (!response.ok) throw new Error('Erreur rafraîchissement');
                        
                        const html = await response.text();
                        const container = document.getElementById('pendingListContainer');
                        if (container) {
                            container.style.opacity = '0.7';
                            setTimeout(() => {
                                container.innerHTML = html;
                                container.style.opacity = '1';
                                
                                // Réinitialiser les événements après le rafraîchissement
                                if (window.pendingListModalSystem) {
                                    window.pendingListModalSystem.init();
                                }
                            }, 300);
                        }
                    } catch (error) {
                        console.error('❌ Erreur rafraîchissement fallback:', error);
                    }
                }

                // Mettre à jour le badge du compteur
                updatePendingCountBadge() {
                    const badge = document.getElementById('pendingCountBadge');
                    if (badge) {
                        // Incrémenter le compteur visuellement
                        const currentCount = parseInt(badge.textContent) || 0;
                        badge.textContent = (currentCount + 1) + ' demandes';
                        
                        // Animation visuelle
                        badge.style.animation = 'pulse 0.5s ease-in-out';
                        setTimeout(() => {
                            badge.style.animation = '';
                        }, 500);
                    }
                }
            }

            // SYSTÈME DE NOTIFICATIONS DE LA CLOCHE - ADMIN SEULEMENT
            class NotificationManager {
                constructor() {
                    this.bell = document.getElementById('notificationBell');
                    this.panel = document.getElementById('notificationPanel');
                    this.badge = document.getElementById('notificationBadge');
                    this.list = document.getElementById('notificationList');
                    this.markAllBtn = document.getElementById('markAllRead');
                    this.isAdmin = false;
                    
                    this.init();
                }

                init() {
                    this.checkUserRole();
                    
                    if (!this.isAdmin) {
                        console.log('🔕 NotificationManager désactivé - Rôle non admin');
                        this.hideNotificationElements();
                        return;
                    }

                    if (this.bell) {
                        this.bell.addEventListener('click', (e) => {
                            e.stopPropagation();
                            this.togglePanel();
                        });
                    }
                    
                    if (this.markAllBtn) {
                        this.markAllBtn.addEventListener('click', () => this.markAllAsRead());
                    }
                    
                    this.syncWithGlobalSystem();
                    
                    document.addEventListener('click', (e) => {
                        if (this.panel && !this.panel.contains(e.target) && this.bell && !this.bell.contains(e.target)) {
                            this.panel.classList.remove('active');
                        }
                    });

                    document.addEventListener('keydown', (e) => {
                        if (e.key === 'Escape' && this.panel) {
                            this.panel.classList.remove('active');
                        }
                    });
                }

                checkUserRole() {
                    const userRoleElement = document.querySelector('.user-role');
                    if (userRoleElement) {
                        const roleText = userRoleElement.textContent.toLowerCase();
                        this.isAdmin = roleText.includes('administrateur') || roleText.includes('admin');
                    }
                    
                    const body = document.body;
                    this.isAdmin = body.classList.contains('role-admin') || this.isAdmin;
                    
                    console.log('👤 NotificationManager - Rôle:', this.isAdmin ? 'ADMIN' : 'NON-ADMIN');
                }

                hideNotificationElements() {
                    const notificationContainer = document.querySelector('.notification-container');
                    if (notificationContainer) {
                        notificationContainer.style.display = 'none';
                    }
                }

                syncWithGlobalSystem() {
                    if (window.globalNotificationSystem && this.isAdmin) {
                        console.log('✅ NotificationManager synchronisé avec GlobalNotificationSystem');
                    } else if (!this.isAdmin) {
                        this.loadNotificationCount();
                    }
                }

                togglePanel() {
                    if (!this.isAdmin) return;
                    
                    if (this.panel) {
                        this.panel.classList.toggle('active');
                        if (this.panel.classList.contains('active')) {
                            this.loadNotifications();
                        }
                    }
                }

                async loadNotificationCount() {
                    if (!this.isAdmin) return;
                    
                    try {
                        const response = await fetch('/api/notifications/count?_=' + Date.now());
                        if (!response.ok) throw new Error('Erreur de chargement du compteur');
                        
                        const data = await response.json();
                        this.updateBadge(data.count);
                    } catch (error) {
                        console.error('Erreur chargement compteur notifications:', error);
                    }
                }

                async loadNotifications() {
                    if (!this.isAdmin) return;
                    
                    try {
                        const response = await fetch('/api/notifications?_=' + Date.now());
                        if (!response.ok) throw new Error('Erreur de chargement');
                        
                        const notifications = await response.json();
                        this.renderNotifications(notifications);
                        
                    } catch (error) {
                        console.error('Erreur chargement notifications:', error);
                        if (this.list) {
                            this.list.innerHTML = `
                                <div class="empty-notifications">
                                    <i class="bi bi-exclamation-triangle"></i>
                                    <p>Erreur de chargement</p>
                                </div>
                            `;
                        }
                    }
                }

                updateBadge(count) {
                    if (!this.isAdmin) return;
                    
                    if (this.badge) {
                        this.badge.textContent = count;
                        if (count > 0) {
                            this.badge.style.display = 'flex';
                            this.badge.style.animation = 'pulse 1s infinite';
                            setTimeout(() => {
                                this.badge.style.animation = '';
                            }, 1000);
                        } else {
                            this.badge.style.display = 'none';
                        }
                    }
                }

                renderNotifications(notifications) {
                    if (!this.list || !this.isAdmin) return;

                    if (notifications.length === 0) {
                        this.list.innerHTML = `
                            <div class="empty-notifications">
                                <i class="bi bi-check-circle"></i>
                                <p>Aucune notification</p>
                                <small>Toutes les demandes ont été traitées</small>
                            </div>
                        `;
                        return;
                    }

                    this.list.innerHTML = notifications.map(notif => `
                        <div class="notification-item unread" data-id="${notif.id}" data-user-im="${notif.relatedUserId}">
                            <div class="notification-icon ${notif.type}">
                                <i class="bi bi-${this.getIcon(notif.type)}"></i>
                            </div>
                            <div class="notification-content">
                                <p class="notification-message">${this.escapeHtml(notif.message)}</p>
                                <div class="notification-meta">
                                    <span class="notification-time">${this.formatDateTime(notif.createdAt)}</span>
                                    ${notif.relatedUserName ? `<span class="notification-user">• ${this.escapeHtml(notif.relatedUserName)}</span>` : ''}
                                </div>
                            </div>
                        </div>
                    `).join('');

                    this.list.querySelectorAll('.notification-item').forEach(item => {
                        item.addEventListener('click', (e) => {
                            e.preventDefault();
                            this.handleNotificationClick(item.dataset.id, item.dataset.userIm);
                        });
                    });
                }

                formatDateTime(isoString) {
                    if (!isoString) return 'Date inconnue';
                    
                    try {
                        const date = new Date(isoString);
                        
                        if (isNaN(date.getTime())) {
                            return 'Date invalide';
                        }
                        
                        const day = date.getDate().toString().padStart(2, '0');
                        const month = (date.getMonth() + 1).toString().padStart(2, '0');
                        const year = date.getFullYear();
                        const hours = date.getHours().toString().padStart(2, '0');
                        const minutes = date.getMinutes().toString().padStart(2, '0');
                        
                        return `${day}/${month}/${year} à ${hours}:${minutes}`;
                        
                    } catch (error) {
                        console.error('Erreur de formatage de date:', error);
                        return 'Date invalide';
                    }
                }

                async handleNotificationClick(notificationId, userIm) {
                    if (!this.isAdmin) return;
                    
                    try {
                        await this.markAsRead(notificationId);
                        
                        if (this.panel) {
                            this.panel.classList.remove('active');
                        }
                        
                        if (userIm) {
                            console.log('🔔 Clic notification - Surbrillance:', userIm);
                            
                            const currentPath = window.location.pathname;
                            if (!currentPath.includes('/dashboard')) {
                                sessionStorage.setItem('highlightUserIm', userIm);
                                sessionStorage.setItem('highlightTimestamp', Date.now().toString());
                                window.location.href = '/dashboard';
                            } else {
                                if (window.globalNotificationSystem) {
                                    window.globalNotificationSystem.highlightUserRow(userIm);
                                }
                            }
                        }
                        
                    } catch (error) {
                        console.error('Erreur gestion clic notification:', error);
                        window.location.href = '/dashboard';
                    }
                }

                getIcon(type) {
                    const icons = {
                        'info': 'info-circle',
                        'warning': 'person-plus-fill',
                        'success': 'check-circle',
                        'danger': 'x-circle'
                    };
                    return icons[type] || 'bell';
                }

                escapeHtml(unsafe) {
                    return unsafe
                        .replace(/&/g, "&amp;")
                        .replace(/</g, "&lt;")
                        .replace(/>/g, "&gt;")
                        .replace(/"/g, "&quot;")
                        .replace(/'/g, "&#039;");
                }

                async markAsRead(notificationId) {
                    if (!this.isAdmin) return;
                    
                    try {
                        const response = await fetch(`/api/notifications/${notificationId}/read`, {
                            method: 'POST',
                            headers: { 
                                'Content-Type': 'application/json',
                                'X-Requested-With': 'XMLHttpRequest'
                            }
                        });
                        
                        if (!response.ok) throw new Error('Erreur lors du marquage');
                        
                        this.loadNotifications();
                        this.loadNotificationCount();
                        
                    } catch (error) {
                        console.error('Erreur marquage comme lu:', error);
                    }
                }

                async markAllAsRead() {
                    if (!this.isAdmin) return;
                    
                    try {
                        const response = await fetch('/api/notifications/read-all', {
                            method: 'POST',
                            headers: { 
                                'Content-Type': 'application/json',
                                'X-Requested-With': 'XMLHttpRequest'
                            }
                        });
                        
                        if (!response.ok) throw new Error('Erreur lors du marquage global');
                        
                        this.loadNotifications();
                        this.loadNotificationCount();
                        
                        this.showToast('Toutes les notifications ont été marquées comme lues', 'success');
                    } catch (error) {
                        console.error('Erreur marquage tout comme lu:', error);
                        this.showToast('Erreur lors du marquage global', 'error');
                    }
                }

                showToast(message, type = 'info') {
                    if (!this.isAdmin) return;
                    
                    const toast = document.createElement('div');
                    toast.className = `notification-toast notification-toast-${type}`;
                    toast.innerHTML = `
                        <div class="toast-content">
                            <i class="bi bi-${this.getToastIcon(type)}"></i>
                            <span>${message}</span>
                        </div>
                    `;
                    
                    document.body.appendChild(toast);
                    
                    setTimeout(() => {
                        toast.style.animation = 'slideOutRight 0.3s ease';
                        setTimeout(() => {
                            if (toast.parentNode) {
                                toast.parentNode.removeChild(toast);
                            }
                        }, 300);
                    }, 3000);
                }

                getToastIcon(type) {
                    const icons = {
                        'success': 'check-circle',
                        'error': 'x-circle',
                        'info': 'info-circle',
                        'warning': 'exclamation-triangle'
                    };
                    return icons[type] || 'info-circle';
                }
            }

            // GESTION DU MENU MOBILE
            document.addEventListener('DOMContentLoaded', function() {
                const menuToggle = document.getElementById('menuToggle');
                const navMenu = document.getElementById('navMenu');
                const menuIcon = document.getElementById('menuIcon');
                const userDropdownToggle = document.getElementById('userDropdownToggle');
                const userCompactToggle = document.getElementById('userCompactToggle');
                const userDropdownMenu = document.getElementById('userDropdownMenu');

                // Menu principal mobile
                if (menuToggle && navMenu) {
                    menuToggle.addEventListener('click', function() {
                        navMenu.classList.toggle('active');
                        
                        if (navMenu.classList.contains('active')) {
                            menuIcon.classList.remove('bi-list');
                            menuIcon.classList.add('bi-x');
                        } else {
                            menuIcon.classList.remove('bi-x');
                            menuIcon.classList.add('bi-list');
                        }
                    });

                    // Fermer le menu en cliquant sur un lien
                    const navLinks = document.querySelectorAll('.nav-link');
                    navLinks.forEach(link => {
                        link.addEventListener('click', function() {
                            navMenu.classList.remove('active');
                            menuIcon.classList.remove('bi-x');
                            menuIcon.classList.add('bi-list');
                        });
                    });
                }

                // Menu déroulant utilisateur - Desktop
                if (userDropdownToggle && userDropdownMenu) {
                    userDropdownToggle.addEventListener('click', function(e) {
                        e.stopPropagation();
                        userDropdownMenu.classList.toggle('active');
                    });
                }

                // Menu déroulant utilisateur - Mobile
                if (userCompactToggle && userDropdownMenu) {
                    userCompactToggle.addEventListener('click', function(e) {
                        e.stopPropagation();
                        userDropdownMenu.classList.toggle('active');
                    });
                }

                // Fermer le menu déroulant en cliquant à l'extérieur
                document.addEventListener('click', function() {
                    if (userDropdownMenu) {
                        userDropdownMenu.classList.remove('active');
                    }
                });

                // Empêcher la fermeture quand on clique dans le menu
                if (userDropdownMenu) {
                    userDropdownMenu.addEventListener('click', function(e) {
                        e.stopPropagation();
                    });
                }

                // Fermer les menus avec la touche Échap
                document.addEventListener('keydown', function(event) {
                    if (event.key === 'Escape') {
                        if (navMenu) navMenu.classList.remove('active');
                        if (userDropdownMenu) userDropdownMenu.classList.remove('active');
                        if (menuIcon) {
                            menuIcon.classList.remove('bi-x');
                            menuIcon.classList.add('bi-list');
                        }
                    }
                });

                // Fermer automatiquement les messages flash après 5 secondes
                setTimeout(() => {
                    const alerts = document.querySelectorAll('.alert');
                    alerts.forEach(alert => {
                        alert.style.animation = 'slideInDown 0.3s ease reverse';
                        setTimeout(() => {
                            if (alert.parentNode) {
                                alert.parentNode.removeChild(alert);
                            }
                        }, 300);
                    });
                }, 5000);

                // GESTION DE LA SURBRILLANCE AU CHARGEMENT DE LA PAGE
                const urlParams = new URLSearchParams(window.location.search);
                const highlightUserIm = urlParams.get('highlight');
                
                if (highlightUserIm) {
                    setTimeout(() => {
                        highlightUserRow(highlightUserIm);
                        
                        setTimeout(() => {
                            scrollToUser(highlightUserIm);
                        }, 800);
                        
                        cleanUrlHighlight();
                    }, 1000);
                }
                
                // Vérifier aussi la session storage
                const sessionHighlight = sessionStorage.getItem('highlightUserIm');
                const sessionTimestamp = sessionStorage.getItem('highlightTimestamp');
                
                if (sessionHighlight && sessionTimestamp) {
                    const now = Date.now();
                    const timestamp = parseInt(sessionTimestamp);
                    
                    if (now - timestamp < 20000) {
                        setTimeout(() => {
                            highlightUserRow(sessionHighlight);
                            setTimeout(() => {
                                scrollToUser(sessionHighlight);
                            }, 800);
                        }, 1000);
                    }
                    
                    sessionStorage.removeItem('highlightUserIm');
                    sessionStorage.removeItem('highlightTimestamp');
                }
            });

            // FONCTIONS GLOBALES POUR LA SURBRILLANCE
            function highlightUserRow(userIm) {
                const row = document.getElementById(`user-row-${userIm}`);
                if (row) {
                    row.classList.remove('highlighted-user', 'new-request');
                    
                    void row.offsetWidth;
                    
                    row.classList.add('highlighted-user');
                    
                    console.log('🎯 Mise en surbrillance de l\'utilisateur:', userIm);
                    
                    setTimeout(() => {
                        if (row.classList.contains('highlighted-user')) {
                            row.classList.remove('highlighted-user');
                            console.log('✅ Fin de la surbrillance pour:', userIm);
                        }
                    }, 15000);
                }
            }

            function scrollToUser(userIm) {
                const row = document.getElementById(`user-row-${userIm}`);
                if (row) {
                    setTimeout(() => {
                        row.scrollIntoView({ 
                            behavior: 'smooth', 
                            block: 'center',
                            inline: 'nearest'
                        });
                    }, 100);
                }
            }

            function cleanUrlHighlight() {
                const url = new URL(window.location);
                url.searchParams.delete('highlight');
                window.history.replaceState({}, document.title, url.toString());
            }

            // 🚀 DÉMARRAGE DES SYSTÈMES - AVEC VÉRIFICATION DU RÔLE
            document.addEventListener('DOMContentLoaded', () => {
                // Déterminer le rôle de l'utilisateur
                const userRoleElement = document.querySelector('.user-role');
                let isAdmin = false;
                
                if (userRoleElement) {
                    const roleText = userRoleElement.textContent.toLowerCase();
                    isAdmin = roleText.includes('administrateur') || roleText.includes('admin');
