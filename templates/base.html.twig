            });

            // Gestion du modal de chargement pour la déconnexion
    document.addEventListener('DOMContentLoaded', function() {
        const logoutLinks = document.querySelectorAll('a[href*="logout"], a.dropdown-item[href*="logout"]');
        const modal = document.getElementById('logoutLoadingModal');
        
        if (!modal) return;
        
        logoutLinks.forEach(link => {
            link.addEventListener('click', function(e) {
                // Empêcher le comportement par défaut
                e.preventDefault();
                
                // Afficher le modal de chargement
                modal.style.display = 'flex';
                
                // Forcer le reflow pour déclencher l'animation
                void modal.offsetWidth;
                
                // Désactiver tous les liens pendant la déconnexion
                const allLinks = document.querySelectorAll('a');
                allLinks.forEach(l => {
                    l.style.pointerEvents = 'none';
                });
                
                // Désactiver les boutons
                const allButtons = document.querySelectorAll('button');
                allButtons.forEach(btn => {
                    btn.disabled = true;
                });
                
                // Désactiver les formulaires
                const allForms = document.querySelectorAll('form');
                allForms.forEach(form => {
                    form.style.pointerEvents = 'none';
                    form.style.opacity = '0.5';
                });
                
                console.log('🔒 Déconnexion en cours...');
                
                // Récupérer l'URL de déconnexion
                const logoutUrl = this.getAttribute('href');
                
                // Attendre un peu pour que l'animation du modal soit visible
                setTimeout(() => {
                    // Rediriger vers l'URL de déconnexion
                    window.location.href = logoutUrl;
                }, 500);
            });
        });
        
        // Animation de sortie si l'utilisateur annule (avec la touche Échap)
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape' && modal.style.display === 'flex') {
                hideLogoutModal();
            }
        });
        
        // Fonction pour cacher le modal
        function hideLogoutModal() {
            modal.style.animation = 'fadeOut 0.3s ease forwards';
            
            setTimeout(() => {
                modal.style.display = 'none';
                modal.style.animation = '';
                
                // Réactiver tous les liens
                const allLinks = document.querySelectorAll('a');
                allLinks.forEach(l => {
                    l.style.pointerEvents = '';
                });
                
                // Réactiver les boutons
                const allButtons = document.querySelectorAll('button');
                allButtons.forEach(btn => {
                    btn.disabled = false;
                });
                
                // Réactiver les formulaires
                const allForms = document.querySelectorAll('form');
                allForms.forEach(form => {
                    form.style.pointerEvents = '';
                    form.style.opacity = '';
                });
            }, 300);
        }
        
        // Gestion de la navigation avant déchargement
        window.addEventListener('beforeunload', function(e) {
            // Ne montrer le modal que si c'est pour la déconnexion
            if (document.visibilityState === 'hidden') {
                modal.style.display = 'flex';
            }
        });
        
        // Gestion des cas où la déconnexion pourrait échouer
        window.addEventListener('pageshow', function(event) {
            // Si la page est chargée depuis le cache, cacher le modal
            if (event.persisted) {
                modal.style.display = 'none';
                
                // Réactiver tous les éléments
                const allLinks = document.querySelectorAll('a');
                allLinks.forEach(l => {
                    l.style.pointerEvents = '';
                });
                
                const allButtons = document.querySelectorAll('button');
                allButtons.forEach(btn => {
                    btn.disabled = false;
                });
                
                const allForms = document.querySelectorAll('form');
                allForms.forEach(form => {
                    form.style.pointerEvents = '';
                    form.style.opacity = '';
                });
            }
        });
    });
    
    // Fonction globale pour afficher manuellement le modal
    window.showLogoutLoader = function() {
        const modal = document.getElementById('logoutLoadingModal');
        if (modal) {
            modal.style.display = 'flex';
            
            // Désactiver tous les liens et boutons
            const allInteractiveElements = document.querySelectorAll('a, button, input, select, textarea');
            allInteractiveElements.forEach(el => {
                el.style.pointerEvents = 'none';
                if (el.tagName === 'BUTTON' || el.tagName === 'INPUT') {
                    el.disabled = true;
                }
            });
        }
    };
    
    // Fonction globale pour cacher le modal
    window.hideLogoutLoader = function() {
        const modal = document.getElementById('logoutLoadingModal');
        if (modal) {
            modal.style.animation = 'fadeOut 0.3s ease forwards';
            
            setTimeout(() => {
                modal.style.display = 'none';
                modal.style.animation = '';
                
                // Réactiver tous les éléments
                const allInteractiveElements = document.querySelectorAll('a, button, input, select, textarea');
                allInteractiveElements.forEach(el => {
                    el.style.pointerEvents = '';
                    if (el.tagName === 'BUTTON' || el.tagName === 'INPUT') {
                        el.disabled = false;
                    }
                });
            }, 300);
        }
    };
        </script>
        {% endif %}

        <!-- Bootstrap JS -->
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

<!-- JavaScript pour Select2 -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

        {% block javascripts %}{% endblock %}
    </body>

</html>