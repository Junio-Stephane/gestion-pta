        }

        .alert-content {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-size: 0.75rem;
            font-weight: 500;
        }

        .alert-dot {
            width: 12px;
            height: 12px;
            border-radius: 50%;
            flex-shrink: 0;
            animation: pulse 2s infinite;
        }

        .alert-red-dot {
            background-color: #ef4444;
        }

        .alert-orange-dot {
            background-color: #f97316;
        }

        .alert-yellow-dot {
            background-color: #f2ad35ff;
        }

        .alert-text {
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .no-alert {
            color: #9ca3af;
            font-style: italic;
        }

        /* Position fixe pour les alertes - AJOUTEZ CETTE SECTION DANS VOTRE STYLESHEETS */
.fixed-alert-container {
    position: fixed;
    top: 100px;
    right: 20px;
    z-index: 9999;
    max-width: 400px;
    animation: slideInRight 0.3s ease-out;
}

@keyframes slideInRight {
    from {
        transform: translateX(100%);
        opacity: 0;
    }
    to {
        transform: translateX(0);
        opacity: 1;
    }
}

.alert-success-fixed {
    background: linear-gradient(135deg, #10b981 0%, #059669 100%);
    color: white;
    border: none;
    border-radius: 10px;
    padding: 1rem 1.25rem;
    box-shadow: 0 8px 25px rgba(16, 185, 129, 0.3);
    border-left: 4px solid #047857;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    animation: fadeIn 0.3s ease-out;
}

.alert-danger-fixed {
    background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
    color: white;
    border: none;
    border-radius: 10px;
    padding: 1rem 1.25rem;
    box-shadow: 0 8px 25px rgba(239, 68, 68, 0.3);
    border-left: 4px solid #b91c1c;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    animation: fadeIn 0.3s ease-out;
}

.alert-success-fixed i,
.alert-danger-fixed i {
    font-size: 1.2rem;
}

.alert-close-btn {
    background: none;
    border: none;
    color: white;
    opacity: 0.8;
    padding: 0.25rem;
    margin-left: auto;
    cursor: pointer;
    transition: opacity 0.2s ease;
}

.alert-close-btn:hover {
    opacity: 1;
}

@keyframes fadeIn {
    from {
        opacity: 0;
        transform: translateY(-10px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

@keyframes fadeOut {
    from {
        opacity: 1;
        transform: translateX(0);
    }
    to {
        opacity: 0;
        transform: translateX(100%);
    }
}

/* Responsive adjustments pour les alertes */
@media (max-width: 768px) {
    .fixed-alert-container {
        top: 80px;
        right: 10px;
        left: 10px;
        max-width: none;
    }
    
    .alert-success-fixed,
    .alert-danger-fixed {
        padding: 0.75rem 1rem;
        font-size: 0.9rem;
    }
}

@media (max-width: 576px) {
    .fixed-alert-container {
        top: 70px;
    }
    
    .alert-success-fixed,
    .alert-danger-fixed {
        padding: 0.5rem 0.75rem;
    }
    
    .alert-success-fixed i,
    .alert-danger-fixed i {
        font-size: 1rem;
    }
}

/* Ajoutez ceci dans votre section CSS */
.popover-alert-content {
    max-width: 300px;
}

.popover-alert-content ul {
    margin-bottom: 0.5rem;
}

.popover-alert-content li {
    margin-bottom: 0.25rem;
}

.popover-alert-content hr {
    margin: 0.5rem 0;
}

/* Style spécifique pour le popup d'alerte */
.popover {
    max-width: 350px !important;
}

.popover-header {
    background-color: #dc3545;
    color: white;
    border-bottom: 1px solid rgba(255,255,255,0.2);
}

.popover-body {
    padding: 1rem;
}
    </style>
