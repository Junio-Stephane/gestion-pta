showServiceInactiveModalProjet(projet) {
    const modalHtml = `
        <div class="modal fade" id="serviceInactiveModalProjet" tabindex="-1" aria-labelledby="serviceInactiveModalProjetLabel" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">
                            <i class="bi bi-exclamation-triangle me-2"></i>
                            Service Inactif
                        </h5>
                        <button type="button" class="btn-close-custom" data-bs-dismiss="modal" aria-label="Close">
                            <i class="bi bi-x"></i>
                        </button>
                    </div>
                    <div class="modal-body">
                        <div class="consigne-warning">
                            <h6 class="alert-heading">
                                <i class="bi bi-exclamation-triangle me-2 text-warning"></i>
                                <span class="text-muted">Impossible de reprendre le projet :</span> <span id="serviceInactiveProjetNom" class="fw-bold">${this.escapeHtml(projet.titrePro)}</span>
                            </h6>
                            <p class="mb-0">Le service associé à ce projet n'est pas actif.</p>
                        </div>
                        
                        <form id="changerServiceFormProjet" class="changerDirectionForm">
                            <input type="hidden" id="changerServiceProjetNum" value="${projet.numProjet}">
                            
                            <div class="form-group">
                                <label for="nouveauServiceProjet" class="form-label">
                                    <i class="bi bi-building-gear me-1"></i>
                                    Choisir un nouveau service actif
                                </label>
                                <select class="form-select search-select" id="nouveauServiceProjet" name="nouveauService" required>
                                    <option value="">Sélectionnez un service actif</option>
                                </select>
                                <div class="form-text">
                                    <i class="bi bi-info-circle me-1 text-primary"></i>
                                    Sélectionnez un service actif pour pouvoir reprendre ce projet
                                </div>
                                <div class="invalid-feedback" id="nouveauServiceProjetError"></div>
                            </div>
                        </form>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btnG btn-secondary" data-bs-dismiss="modal">
                            Annuler
                        </button>
                        <button type="button" class="btnG btn-primary" id="btnConfirmerChangementServiceProjet">
                            <i class="bi bi-check-circle me-2"></i>
                            Changer le service
                        </button>
                    </div>
                </div>
            </div>
        </div>
    `;

    document.body.insertAdjacentHTML('beforeend', modalHtml);

    const modalElement = document.getElementById('serviceInactiveModalProjet');
    
    // Initialiser Select2 pour ce modal
    this.select2Instances.nouveauServiceProjet = $('#nouveauServiceProjet').select2({
        theme: 'bootstrap-5',
        width: '100%',
        placeholder: 'Rechercher un service actif...',
        allowClear: true,
        dropdownParent: $('#serviceInactiveModalProjet')
    });
    
    this.chargerServicesActifsPourSelectProjet().then(() => {
        this.configurerEvenementsModalServiceProjet(modalElement, projet);
    });

    const modal = new bootstrap.Modal(modalElement);
    modal.show();

    modalElement.addEventListener('hidden.bs.modal', function() {
        // Détruire Select2 avant de supprimer l'élément
        const select2Instance = $('#nouveauServiceProjet').data('select2');
        if (select2Instance) {
            select2Instance.destroy();
        }
        this.remove();
    });
}

            async chargerServicesActifsPourSelectProjet() {
    try {
        const response = await fetch('/admin/projets/api/services-actifs');
        const data = await response.json();
        
        if (data.success) {
            const select = this.select2Instances.nouveauServiceProjet;
            if (select) {
                select.empty();
                select.append('<option value=""></option>');
                
                data.services.forEach(service => {
                    const option = new Option(
                        `${service.CodeService} - ${service.nomService}`,
                        service.CodeService,
                        false,
                        false
                    );
                    select.append(option);
                });
                
                select.trigger('change.select2');
            }
        }
    } catch (error) {
        console.error('Erreur chargement services actifs:', error);
    }
}

            configurerEvenementsModalServiceProjet(modalElement, projet) {
                const btnConfirmer = document.getElementById('btnConfirmerChangementServiceProjet');
                const form = document.getElementById('changerServiceFormProjet');
                const selectService = document.getElementById('nouveauServiceProjet');

                if (btnConfirmer) {
                    btnConfirmer.onclick = () => {
                        this.confirmerChangementServiceProjet(projet);
                    };
                }

                if (selectService) {
                    selectService.addEventListener('change', () => {
                        this.clearFieldError('nouveauServiceProjet');
                    });
                }

                if (form) {
                    form.addEventListener('submit', (e) => {
                        e.preventDefault();
                        this.confirmerChangementServiceProjet(projet);
                    });
                }
            }

            async confirmerChangementServiceProjet(projet) {
    const selectService = document.getElementById('nouveauServiceProjet');
    const projetNum = document.getElementById('changerServiceProjetNum').value;

    if (!selectService || !selectService.value) {
        this.showFieldError('nouveauServiceProjet', 'Veuillez sélectionner un service actif');
        return;
    }

    const nouveauServiceCode = selectService.value;

    try {
        const btnConfirmer = document.getElementById('btnConfirmerChangementServiceProjet');
        const originalText = btnConfirmer.innerHTML;
        
        // AJOUT DU SPINNER
        btnConfirmer.innerHTML = '<div class="loading-spinner me-2"></div> Reprise...';
        btnConfirmer.disabled = true;

        const data = {
            nouveauService: nouveauServiceCode
        };

        const response = await fetch(`/admin/projets/api/${projetNum}/reprendre`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify(data)
        });

        const result = await response.json();

        if (result.success) {
            this.showSuccess('Projet repris avec succès avec nouveau service');
            
            const modalElement = document.getElementById('serviceInactiveModalProjet');
            if (modalElement) {
                bootstrap.Modal.getInstance(modalElement).hide();
            }
            
            this.loadProjets();
            
        } else {
            this.showError(result.message || 'Erreur lors de la reprise du projet');
            
            // RESTAURATION DU BOUTON EN CAS D'ERREUR
            btnConfirmer.innerHTML = originalText;
            btnConfirmer.disabled = false;
        }
    } catch (error) {
        console.error('Erreur reprise projet:', error);
        this.showError('Erreur lors de la reprise du projet');
        
        const btnConfirmer = document.getElementById('btnConfirmerChangementServiceProjet');
        if (btnConfirmer) {
            // RESTAURATION DU BOUTON EN CAS D'ERREUR
            btnConfirmer.innerHTML = '<i class="bi bi-check-circle me-2"></i> Reprendre le projet';
            btnConfirmer.disabled = false;
        }
    }
}


            async confirmReprendreProjet(numProjet) {
    try {
        const modalElement = document.getElementById('confirmationRepriseProjetModal');
        const confirmBtn = document.getElementById('confirmReprendreProjet');
        const originalBtnText = confirmBtn.innerHTML;
        
        // AJOUT DU SPINNER
        confirmBtn.innerHTML = '<div class="loading-spinner me-2"></div> Reprise...';
        confirmBtn.disabled = true;

        if (modalElement) {
            bootstrap.Modal.getInstance(modalElement).hide();
        }

        const response = await fetch(`/admin/projets/api/${numProjet}/reprendre`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify({})
        });

        const result = await response.json();

        if (result.success) {
            this.showSuccess(result.message);
            this.loadProjets();
        } else {
            if (result.message === 'service_inactive') {
                const projet = this.allProjets.find(p => p.numProjet === numProjet);
                if (projet) {
                    this.showServiceInactiveModalProjet({
                        ...projet,
                        ...result.projet
                    });
                }
            } else {
                this.showError(result.message);
            }
            // RESTAURATION DU BOUTON EN CAS D'ERREUR
            confirmBtn.innerHTML = originalBtnText;
            confirmBtn.disabled = false;
        }
    } catch (error) {
        console.error('Erreur reprise:', error);
        this.showError('Erreur lors de la reprise');
        // RESTAURATION DU BOUTON EN CAS D'ERREUR
        const confirmBtn = document.getElementById('confirmReprendreProjet');
        if (confirmBtn) {
            confirmBtn.innerHTML = '<i class="bi bi-play-circle me-2"></i> Confirmer la reprise';
            confirmBtn.disabled = false;
        }
    }
}

            renderPagination() {
                const totalPages = Math.ceil(this.totalItems / this.itemsPerPage);
                const paginationElement = document.getElementById('pagination');
                const paginationInfoElement = document.getElementById('paginationInfo');

                if (!paginationElement || !paginationInfoElement) return;

                const startItem = (this.currentPage - 1) * this.itemsPerPage + 1;
                const endItem = Math.min(this.currentPage * this.itemsPerPage, this.totalItems);
                
                paginationInfoElement.textContent = 
                    `Affichage de ${startItem} à ${endItem} sur ${this.totalItems} projet${this.totalItems !== 1 ? 's' : ''}`;

                let paginationHTML = '';

                paginationHTML += `
                    <li class="page-item ${this.currentPage === 1 ? 'disabled' : ''}">
                        <a class="page-link" href="#" onclick="projetManager.changePage(${this.currentPage - 1})">
                            <i class="bi bi-chevron-left"></i>
                        </a>
                    </li>
                `;

                for (let i = 1; i <= totalPages; i++) {
                    if (i === 1 || i === totalPages || (i >= this.currentPage - 1 && i <= this.currentPage + 1)) {
                        paginationHTML += `
                            <li class="page-item ${i === this.currentPage ? 'active' : ''}">
                                <a class="page-link" href="#" onclick="projetManager.changePage(${i})">${i}</a>
                            </li>
                        `;
                    } else if (i === this.currentPage - 2 || i === this.currentPage + 2) {
                        paginationHTML += `<li class="page-item disabled"><span class="page-link">...</span></li>`;
                    }
                }

                paginationHTML += `
                    <li class="page-item ${this.currentPage === totalPages ? 'disabled' : ''}">
                        <a class="page-link" href="#" onclick="projetManager.changePage(${this.currentPage + 1})">
                            <i class="bi bi-chevron-right"></i>
                        </a>
                    </li>
                `;

                paginationElement.innerHTML = paginationHTML;
            }

            changePage(page) {
                if (page < 1 || page > Math.ceil(this.totalItems / this.itemsPerPage)) {
                    return;
                }
                this.currentPage = page;
                this.renderProjets();
                this.renderPagination();
            }

            showMultipleErrors(errors) {
                Object.keys(errors).forEach(fieldKey => {
                    const errorMessage = errors[fieldKey];
                    this.showFieldError(fieldKey, errorMessage);
                });
            }

            showMultipleEditErrors(errors) {
                Object.keys(errors).forEach(fieldKey => {
                    const errorMessage = errors[fieldKey];
                    this.showEditFieldError(fieldKey, errorMessage);
                });
            }

            showFieldError(fieldId, errorMessage) {
                const field = document.getElementById(fieldId);
                const errorElement = document.getElementById(fieldId + 'Error');
                
                if (field && errorElement) {
                    field.classList.add('is-invalid');
                    errorElement.textContent = errorMessage;
                }
            }

            showEditFieldError(fieldId, errorMessage) {
                const field = document.getElementById('edit_' + fieldId);
                const errorElement = document.getElementById('edit_' + fieldId + 'Error');
                
                if (field && errorElement) {
                    field.classList.add('is-invalid');
                    errorElement.textContent = errorMessage;
                }
            }

            clearFieldError(fieldId) {
                const field = document.getElementById(fieldId);
                const errorElement = document.getElementById(fieldId + 'Error');
                
                if (field) {
                    field.classList.remove('is-invalid');
                }
                if (errorElement) {
                    errorElement.textContent = '';
                }
            }

            clearEditFieldError(fieldId) {
                const field = document.getElementById('edit_' + fieldId);
                const errorElement = document.getElementById('edit_' + fieldId + 'Error');
                
                if (field) {
                    field.classList.remove('is-invalid');
                }
                if (errorElement) {
                    errorElement.textContent = '';
                }
            }

            clearModalErrors() {
                const fields = ['numProjet', 'titrePro', 'budgetPro', 'dateDebutPro', 'dateFinPro', 'service', 'dateDebutDuration', 'dureeEstimee'];
                fields.forEach(field => this.clearFieldError(field));
            }

            clearEditModalErrors() {
                const fields = ['titrePro', 'budgetPro', 'dateDebutPro', 'dateFinPro', 'service', 'dateDebutDuration', 'dureeEstimee'];
                fields.forEach(field => this.clearEditFieldError(field));
            }

    showSuccess(message) {
    const alertContainer = document.getElementById('fixedAlertContainer');
    const alert = document.createElement('div');
    alert.className = 'alert-success-fixed mb-3';
    alert.innerHTML = `
        <i class="bi bi-check-circle-fill"></i>
        <span>${message}</span>
        <button type="button" class="alert-close-btn" onclick="this.parentElement.remove()">
            <i class="bi bi-x"></i>
        </button>
    `;
    
    // Supprimer les anciennes alertes
    while (alertContainer.firstChild) {
        alertContainer.removeChild(alertContainer.firstChild);
    }
    
    // Ajouter la nouvelle alerte
    alertContainer.appendChild(alert);
    
    // Auto-suppression après 5 secondes
    setTimeout(() => {
        if (alert.parentElement) {
            alert.style.animation = 'fadeOut 0.3s ease-out';
            setTimeout(() => {
                if (alert.parentElement) {
                    alert.remove();
                }
            }, 300);
        }
    }, 5000);
}

showError(message) {
    const alertContainer = document.getElementById('fixedAlertContainer');
    const alert = document.createElement('div');
    alert.className = 'alert-danger-fixed mb-3';
    alert.innerHTML = `
        <i class="bi bi-exclamation-triangle-fill"></i>
        <span>${message}</span>
        <button type="button" class="alert-close-btn" onclick="this.parentElement.remove()">
            <i class="bi bi-x"></i>
        </button>
    `;
    
    // Supprimer les anciennes alertes
    while (alertContainer.firstChild) {
        alertContainer.removeChild(alertContainer.firstChild);
    }
    
    // Ajouter la nouvelle alerte
    alertContainer.appendChild(alert);
    
    // Auto-suppression après 5 secondes
    setTimeout(() => {
        if (alert.parentElement) {
            alert.style.animation = 'fadeOut 0.3s ease-out';
            setTimeout(() => {
                if (alert.parentElement) {
                    alert.remove();
                }
            }, 300);
        }
    }, 5000);
}
