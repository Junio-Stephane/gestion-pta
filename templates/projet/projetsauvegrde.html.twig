            getInitials(nom, prenom) {
                const firstInitial = prenom ? prenom.charAt(0).toUpperCase() : '';
                const lastInitial = nom ? nom.charAt(0).toUpperCase() : '';
                return firstInitial + lastInitial;
            }

            createCircularProgress(avancement) {
                let progressClass = 'low';
                if (avancement >= 70) {
                    progressClass = 'high';
                } else if (avancement >= 30) {
                    progressClass = 'medium';
                }
                if (avancement === 100) {
                    progressClass = 'complete';
                }

                return `
                    <div class="progress-circular ${progressClass}" 
                         style="--progress-value: ${avancement}" 
                         data-progress="${avancement}">
                    </div>
                `;
            }

            getStatutClass(statut) {
                const classes = {
                    'Débuté': 'status-debute',
                    'En cours': 'status-encours',
                    'Terminé': 'status-termine',
                    'Suspendu': 'status-suspendu'
                };
                return classes[statut] || 'status-debute';
            }

            formatDate(dateString) {
                if (!dateString) return 'N/A';
                const date = new Date(dateString);
                return date.toLocaleDateString('fr-FR');
            }

            formatBudget(budget) {
                return parseFloat(budget).toLocaleString('fr-FR');
            }

            escapeHtml(unsafe) {
                if (!unsafe) return '';
                return unsafe
                    .replace(/&/g, "&amp;")
                    .replace(/</g, "&lt;")
                    .replace(/>/g, "&gt;")
                    .replace(/"/g, "&quot;")
                    .replace(/'/g, "&#039;");
            }

            calculerDureePourAffichage(dateDebut, dateFin) {
                if (!dateDebut || !dateFin) return '';
                
                const debut = new Date(dateDebut);
                const fin = new Date(dateFin);
                
                // Calculer la durée en jours ouvrables (sans week-ends et jours fériés)
                const joursOuvrables = this.holidaysManager.getBusinessDaysCount(debut, fin);
                
                return this.formatDuree(joursOuvrables);
            }

