            // Dans la classe ProjetManager, remplacez complètement la méthode calculerAlerteProjet :

calculerAlerteProjet(projet) {
    // Pas d'alerte pour les projets terminés ou suspendus
    if (projet.StatutPro === 'Terminé' || projet.StatutPro === 'Suspendu') {
        return null;
    }

    // Pas d'alerte si pas de date de fin
    if (!projet.dateFinPro) {
        return null;
    }

    const aujourdhui = new Date();
    aujourdhui.setHours(0, 0, 0, 0);
    
    const dateFin = new Date(projet.dateFinPro);
    dateFin.setHours(0, 0, 0, 0);

    // Calculer la différence en jours calendaires
    const diffTime = dateFin - aujourdhui;
    const joursCalendaires = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
    
    // Si la date est dépassée
    if (joursCalendaires < 0) {
        // Calculer les jours ouvrables de retard (depuis le lendemain de la date de fin jusqu'à aujourd'hui)
        const dateFinPlusUn = new Date(dateFin);
        dateFinPlusUn.setDate(dateFinPlusUn.getDate() + 1);
        
        // Calculer les jours ouvrables écoulés depuis la date de fin
        const joursOuvrablesEcoules = this.holidaysManager.getBusinessDaysCount(dateFinPlusUn, aujourdhui);
        
        console.log(`Projet ${projet.numProjet}: 
            Retard de ${Math.abs(joursCalendaires)} jours calendaires, 
            ${joursOuvrablesEcoules} jours ouvrables écoulés`);
        
        // Détecter si c'est le cas "0 jours ouvrables"
        const estZeroJoursOuvrables = joursOuvrablesEcoules === 0;
        
        // TOUJOURS afficher "0 jours ouvrables" dans ce cas
        const message = estZeroJoursOuvrables ? 
            'En retard de 0 jour ouvrable' : 
            `En retard de ${joursOuvrablesEcoules} jour${joursOuvrablesEcoules > 1 ? 's' : ''} ouvrable${joursOuvrablesEcoules > 1 ? 's' : ''}`;
        
        return {
            niveau: 'red',
            message: message, // Toujours afficher le nombre de jours
            joursRestants: -joursOuvrablesEcoules,
            estDepasse: true,
            zeroJoursOuvrables: estZeroJoursOuvrables  // Indicateur pour le popup
        };
    } 
    // Si échéance aujourd'hui
    else if (joursCalendaires === 0) {
        return {
            niveau: 'red',
            message: 'Échéance aujourd\'hui',
            joursRestants: 0,
            estDepasse: false,
            zeroJoursOuvrables: false
        };
    }
    // Si date future - calculer jours ouvrables restants
    else {
        // Calculer les jours ouvrables restants (depuis demain jusqu'à la date de fin)
        const demain = new Date(aujourdhui);
        demain.setDate(demain.getDate() + 1);
        
        const joursOuvrablesRestants = this.holidaysManager.getBusinessDaysCount(demain, dateFin);
        
        // Formater le message selon la durée
        let messageFormate = '';
        
        if (joursOuvrablesRestants >= 22) {
            const mois = Math.floor(joursOuvrablesRestants / 22);
            const resteJours = joursOuvrablesRestants % 22;
            
            if (resteJours === 0) {
                messageFormate = `Fin dans ${mois} mois ouvrable${mois > 1 ? 's' : ''}`;
            } else if (resteJours >= 14) {
                const semaines = Math.floor(resteJours / 5);
                messageFormate = `Fin dans ${mois} mois et ${semaines} semaine${semaines > 1 ? 's' : ''} ouvrables`;
            } else {
                messageFormate = `Fin dans ${mois} mois et ${resteJours} jour${resteJours > 1 ? 's' : ''} ouvrable${resteJours > 1 ? 's' : ''}`;
            }
        } 
        else if (joursOuvrablesRestants >= 5) {
            const semaines = Math.floor(joursOuvrablesRestants / 5);
            const resteJours = joursOuvrablesRestants % 5;
            
            if (resteJours === 0) {
                messageFormate = `Fin dans ${semaines} semaine${semaines > 1 ? 's' : ''} ouvrable${semaines > 1 ? 's' : ''}`;
            } else {
                messageFormate = `Fin dans ${semaines} semaine${semaines > 1 ? 's' : ''} et ${resteJours} jour${resteJours > 1 ? 's' : ''} ouvrable${resteJours > 1 ? 's' : ''}`;
            }
        }
        else {
            messageFormate = `Fin dans ${joursOuvrablesRestants} jour${joursOuvrablesRestants > 1 ? 's' : ''} ouvrable${joursOuvrablesRestants > 1 ? 's' : ''}`;
        }
        
        let niveau = '';
        if (joursOuvrablesRestants <= 3) {
            niveau = 'orange';
        } else if (joursOuvrablesRestants <= 5) {
            niveau = 'yellow';
        } else {
            // Pas d'alerte pour plus de 5 jours ouvrables
            return null;
        }
        
        return {
            niveau: niveau,
            message: messageFormate,
            joursRestants: joursOuvrablesRestants,
            estDepasse: false,
            zeroJoursOuvrables: false
        };
    }
}


getAlerteHTML(alerte) {
    if (!alerte) {
        return '<div class="no-alert">—</div>';
    }

    const dotClass = {
        'yellow': 'alert-yellow-dot',
        'orange': 'alert-orange-dot',
        'red': 'alert-red-dot'
    }[alerte.niveau] || '';

    const messageClass = {
        'yellow': 'alert-attention',
        'orange': 'alert-urgence',
        'red': 'alert-retard'
    }[alerte.niveau] || '';

    // ICI: Logique CORRECTE pour le popup "0 jours ouvrables"
    let popoverAttributes = '';
    
    // Condition spécifique pour le popup "0 jours ouvrables"
    if (alerte.zeroJoursOuvrables) {
        const popoverContent = `
            <div class="popover-alert-content">
                <p><i class="bi bi-info-circle text-primary me-1"></i> 
                L'échéance est dépassée mais il n'y a pas encore eu de jour ouvrable depuis la date de fin.</p>
                
            </div>
        `;
        
        popoverAttributes = `
            data-bs-toggle="popover"
            data-bs-trigger="hover focus"
            data-bs-placement="top"
            data-bs-html="true"
            data-bs-title="Échéance dépassée - 0 jour ouvrable"
            data-bs-content='${popoverContent.replace(/'/g, "&apos;")}'
        `;
    }

    return `
        <div class="alert-content" ${popoverAttributes} title="${alerte.message}">
            <div class="alert-dot ${dotClass}"></div>
            <div class="alert-message ${messageClass}">
                <span class="alert-text">${alerte.message}</span>
            </div>
        </div>
    `;
}

initPopovers() {
    // Initialiser les popovers Bootstrap
    const popoverTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="popover"]'));
    popoverTriggerList.map(function (popoverTriggerEl) {
        return new bootstrap.Popover(popoverTriggerEl);
    });
}

