        .projet-suspendu td:not(:last-child) {
            opacity: 0.6;
            color: #6b7280 !important;
        }

        /* La cellule des actions reste normale */
        .projet-suspendu td:last-child {
            opacity: 1 !important;
            background-color: transparent !important;
        }

