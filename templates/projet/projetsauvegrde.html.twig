            async modifierProjet() {
    const form = document.getElementById('editProjetForm');
    const submitBtn = document.getElementById('submitEditProjet');
    
    if (!form || !submitBtn || !this.currentEditingProjet) {
        this.showError('Données de modification manquantes');
        return;
    }

    const originalText = submitBtn.innerHTML;

    try {
        this.clearEditModalErrors();
        
        // AJOUT DU SPINNER
        submitBtn.innerHTML = '<div class="loading-spinner me-2"></div> Modification...';
        submitBtn.disabled = true;

        const formData = new FormData(form);
        const periodType = document.querySelector('#editProjetForm input[name="periodType"]:checked').value;
        
        const personnelsSelectionnes = this.editSelect ? this.editSelect.getSelectedValues() : [];

        let dateDebutPro, dateFinPro;

        if (periodType === 'dates') {
            dateDebutPro = this.convertDateToISO(formData.get('dateDebutPro'));
            dateFinPro = formData.get('dateFinPro') ? this.convertDateToISO(formData.get('dateFinPro')) : null;
        } else {
            dateDebutPro = this.convertDateToISO(formData.get('dateDebutDuration'));
            const dureeValue = formData.get('dureeEstimee');
            const dureeUnite = formData.get('dureeUnite');
            
            if (dateDebutPro && dureeValue) {
                dateFinPro = this.calculerDateFin(dateDebutPro, dureeValue, dureeUnite);
            } else {
                dateFinPro = null;
            }
        }

        // Préparer les données selon le mode d'avancement
        const data = {
            numProjet: this.currentEditingProjet.numProjet,
            titrePro: formData.get('titrePro'),
            descriptionPro: formData.get('descriptionPro'),
            commentairePro: formData.get('commentairePro'),
            budgetPro: formData.get('budgetPro'),
            dateDebutPro: dateDebutPro,
            dateFinPro: dateFinPro,
            service: formData.get('service'),
            personnels: personnelsSelectionnes,
        };

        console.log('Données de modification:', data);

        const response = await fetch(`/admin/projets/api/${this.currentEditingProjet.numProjet}/modifier`, {
            method: 'PUT',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify(data)
        });

        const result = await response.json();

        if (result.success) {
            this.showSuccess(result.message);
            bootstrap.Modal.getInstance(document.getElementById('editProjetModal')).hide();
            this.loadProjets();
        } else {
            if (result.errors) {
                this.showMultipleEditErrors(result.errors);
            } else {
                this.showError(result.message);
            }
        }
    } catch (error) {
        console.error('Erreur modification projet:', error);
        this.showError('Erreur lors de la modification du projet');
    } finally {
        // RESTAURATION DU BOUTON
        submitBtn.innerHTML = originalText;
        submitBtn.disabled = false;
    }
}

