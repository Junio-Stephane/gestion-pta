            async ouvrirModification(numProjet) {
    try {
        console.log('Ouverture modification projet:', numProjet);
        
        const response = await fetch(`/admin/projets/api/${numProjet}`);
        const data = await response.json();
        
        if (data.success) {
            this.currentEditingProjet = data.projet;
            this.remplirFormulaireModification(data.projet);
            
            const modal = new bootstrap.Modal(document.getElementById('editProjetModal'));
            modal.show();
            
            // Écouter l'ouverture du modal pour forcer une mise à jour
            const modalElement = document.getElementById('editProjetModal');
            modalElement.addEventListener('shown.bs.modal', () => {
                // Vérifier et mettre à jour les responsables après l'ouverture du modal
                if (this.editSelect && data.projet.personnels) {
                    setTimeout(() => {
                        const responsablesIds = data.projet.personnels.map(p => p.ImPer);
                        this.editSelect.setSelectedValues(responsablesIds);
                    }, 300);
                }
            });
        } else {
            this.showError(data.message);
        }
    } catch (error) {
        console.error('Erreur chargement projet:', error);
        this.showError('Erreur lors du chargement du projet');
    }
}

            remplirFormulaireModification(projet) {
    console.log('Remplissage formulaire modification pour:', projet.numProjet);
    
    // Numéro de projet (lecture seule)
    document.getElementById('edit_numProjet').value = projet.numProjet;
    document.getElementById('edit_numProjet_display').value = projet.numProjet;

    // Informations de base
    document.getElementById('edit_titrePro').value = projet.titrePro || '';
    document.getElementById('edit_budgetPro').value = projet.budgetPro || '';
    document.getElementById('edit_descriptionPro').value = projet.descriptionPro || '';
    document.getElementById('edit_commentairePro').value = projet.commentairePro || '';

    // Service
    if (projet.service && projet.service.CodeService) {
        const serviceSelect = this.select2Instances.edit_service;
        if (serviceSelect) {
            serviceSelect.val(projet.service.CodeService).trigger('change.select2');
        } else {
            document.getElementById('edit_service').value = projet.service.CodeService;
        }
    }

    // Période
    if (projet.dateDebutPro) {
        const dateDebut = this.formatDateForInput(projet.dateDebutPro);
        document.getElementById('edit_dateDebutPro').value = dateDebut;
        if (this.editDatePickers.edit_dateDebutPro) {
            this.editDatePickers.edit_dateDebutPro.setDate(dateDebut);
        }
    }

    if (projet.dateFinPro) {
        const dateFin = this.formatDateForInput(projet.dateFinPro);
        document.getElementById('edit_dateFinPro').value = dateFin;
        if (this.editDatePickers.edit_dateFinPro) {
            this.editDatePickers.edit_dateFinPro.setDate(dateFin);
        }
    }

    // Responsables - CORRECTION ICI
    // Attendre que les personnels soient chargés avant de sélectionner
    if (projet.personnels && this.editSelect) {
        const responsablesIds = projet.personnels.map(p => p.ImPer);
        
        // Vérifier si les personnels sont déjà chargés
        if (this.editSelect.allPersonnels && this.editSelect.allPersonnels.length > 0) {
            // Personnels déjà chargés, sélectionner immédiatement
            this.editSelect.setSelectedValues(responsablesIds);
        } else {
            // Attendre le chargement des personnels
            console.log('En attente du chargement des personnels...');
            
            // Créer un observer pour attendre que les personnels soient chargés
            const checkPersonnelsLoaded = setInterval(() => {
                if (this.editSelect.allPersonnels && this.editSelect.allPersonnels.length > 0) {
                    clearInterval(checkPersonnelsLoaded);
                    console.log('Personnels chargés, sélection maintenant');
                    this.editSelect.setSelectedValues(responsablesIds);
                }
            }, 100);
            
            // Timeout de sécurité
            setTimeout(() => {
                clearInterval(checkPersonnelsLoaded);
                if (this.editSelect.allPersonnels && this.editSelect.allPersonnels.length > 0) {
                    this.editSelect.setSelectedValues(responsablesIds);
                } else {
                    console.warn('Timeout - personnels non chargés');
                }
            }, 2000);
        }
    }

    // Calculer la période
    this.calculerEditDureeEstimee();
}

            formatDateForInput(dateString) {
                if (!dateString) return '';
                const date = new Date(dateString);
