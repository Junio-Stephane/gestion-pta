            100% { transform: rotate(360deg); }
        }

        .date-range-separator {
            display: flex;
            align-items: center;
            padding-bottom: 0.5rem;
            color: #6b7280;
            font-weight: 500;
        }

        /* Styles pour la gestion de l'avancement */
        .avancement-management {
            background: #f8fafc;
            border: 1px solid #e5e7eb;
            border-radius: 8px;
            padding: 1rem;
            margin-bottom: 1rem;
        }

        .avancement-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1rem;
        }

        .avancement-title {
            font-weight: 600;
            color: #374151;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .avancement-mode-badge {
            padding: 0.3rem 0.6rem;
            border-radius: 12px;
            font-size: 0.7rem;
            font-weight: 600;
        }

        .mode-auto {
            background: #d1fae5;
            color: #065f46;
        }

        .mode-manuel {
