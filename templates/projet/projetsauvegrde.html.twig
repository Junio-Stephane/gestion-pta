{% block javascripts %}
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/fr.js"></script>

    <script>
        // Classe pour gérer les jours fériés à Madagascar
        class MadagascarHolidays {
            constructor() {
                this.holidays = [];
            }

            // Récupérer les jours fériés pour une année donnée
            getHolidays(year) {
                const holidays = [];
                
                // Jours fériés fixes
                holidays.push(`${year}-01-01`); // Nouvel An
                holidays.push(`${year}-03-08`);
                holidays.push(`${year}-03-29`); // Commémoration du 29 mars 1947
                holidays.push(`${year}-05-01`); // Fête du Travail
                holidays.push(`${year}-06-26`); // Fête Nationale
                holidays.push(`${year}-08-15`); // Assomption
                holidays.push(`${year}-11-01`); // Toussaint
                holidays.push(`${year}-12-25`); // Noël
                
                // Lundi de Pâques (variable - 1er dimanche après pleine lune de printemps)
                const easterMonday = this.calculateEasterMonday(year);
                holidays.push(easterMonday);
                
                // Lundi de Pentecôte (variable - 50 jours après Pâques)
                const pentecostMonday = this.calculatePentecostMonday(year);
                holidays.push(pentecostMonday);
                
                // Fête de l'Indépendance (26 juin)
                // Si le 26 juin est un samedi ou dimanche, le lendemain est férié
                const independenceDay = new Date(year, 5, 26); // 26 juin
                if (independenceDay.getDay() === 0) { // Dimanche
                    holidays.push(`${year}-06-27`);
                } else if (independenceDay.getDay() === 6) { // Samedi
                    holidays.push(`${year}-06-28`);
                }
                
                return holidays;
            }

            // Calculer le lundi de Pâques
            calculateEasterMonday(year) {
                // Algorithme de calcul de Pâques
                const a = year % 19;
                const b = Math.floor(year / 100);
                const c = year % 100;
                const d = Math.floor(b / 4);
                const e = b % 4;
                const f = Math.floor((b + 8) / 25);
                const g = Math.floor((b - f + 1) / 3);
                const h = (19 * a + b - d - g + 15) % 30;
                const i = Math.floor(c / 4);
                const k = c % 4;
                const l = (32 + 2 * e + 2 * i - h - k) % 7;
                const m = Math.floor((a + 11 * h + 22 * l) / 451);
                const month = Math.floor((h + l - 7 * m + 114) / 31);
                const day = ((h + l - 7 * m + 114) % 31) + 1;
                
                const easter = new Date(year, month - 1, day);
                const easterMonday = new Date(easter);
                easterMonday.setDate(easterMonday.getDate() + 1);
                
                return easterMonday.toISOString().split('T')[0];
            }

            // Calculer le lundi de Pentecôte
            calculatePentecostMonday(year) {
                const easterMonday = this.calculateEasterMonday(year);
                const easterDate = new Date(easterMonday);
                const pentecostMonday = new Date(easterDate);
                pentecostMonday.setDate(pentecostMonday.getDate() + 49); // 50 jours après Pâques (lundi de Pentecôte)
                
                return pentecostMonday.toISOString().split('T')[0];
            }

            // Vérifier si une date est un jour férié
            isHoliday(date) {
                const dateStr = date.toISOString().split('T')[0];
                const year = date.getFullYear();
                
                // Charger les jours fériés pour l'année si pas encore fait
                if (this.holidays.length === 0 || !this.holidays.some(h => h.startsWith(year))) {
                    this.holidays = this.getHolidays(year);
                }
                
                return this.holidays.includes(dateStr);
            }

            // Vérifier si une date est un week-end
            isWeekend(date) {
                const day = date.getDay();
                return day === 0 || day === 6; // 0 = dimanche, 6 = samedi
            }

            // Vérifier si une date est un jour ouvrable (ni week-end, ni férié)
            isBusinessDay(date) {
                return !this.isWeekend(date) && !this.isHoliday(date);
            }


getBusinessDaysCount(startDate, endDate) {
    let count = 0;
    const current = new Date(startDate);
    const end = new Date(endDate);
    
    // Si la date de début est après la date de fin, on inverse le calcul
    if (current > end) {
        // Pour les retards, on compte depuis la date de fin jusqu'à aujourd'hui
        const temp = current;
        current = new Date(endDate);
        end = temp;
        
        // On compte les jours ouvrables de la date de fin à aujourd'hui
        while (current <= end) {
            if (this.isBusinessDay(current)) {
                count++;
            }
            current.setDate(current.getDate() + 1);
        }
        
        // Pour les retards, on retourne un nombre négatif
        return -count;
    }
    
    // Cas normal (date de début avant date de fin)
    while (current <= end) {
        if (this.isBusinessDay(current)) {
            count++;
        }
        current.setDate(current.getDate() + 1);
    }
    
    return count;
}

            // Ajouter des jours ouvrables à une date
            addBusinessDays(startDate, businessDays) {
                let count = 0;
                const current = new Date(startDate);
                
                while (count < businessDays) {
                    current.setDate(current.getDate() + 1);
                    if (this.isBusinessDay(current)) {
                        count++;
                    }
                }
                
                return new Date(current);
            }

            // Calculer la date de fin en fonction de la durée estimée (en jours ouvrables)
            calculateEndDate(startDate, durationDays, unit = 'jours') {
                let businessDaysToAdd = durationDays;
                
                // Convertir en jours ouvrables si l'unité n'est pas "jours"
                if (unit === 'semaines') {
                    businessDaysToAdd = durationDays * 5; // 5 jours ouvrables par semaine
                } else if (unit === 'mois') {
                    businessDaysToAdd = durationDays * 22; // Environ 22 jours ouvrables par mois
                }
                
                return this.addBusinessDays(startDate, businessDaysToAdd);
            }
        }

        class BootstrapMultipleSelect {
            constructor(prefix = '') {
                this.prefix = prefix;
                this.selectToggle = document.getElementById(this.prefix + 'selectToggle');
                this.selectDropdown = document.getElementById(this.prefix + 'selectDropdown');
                this.selectOptionsContainer = document.getElementById(this.prefix + 'selectOptionsContainer');
                this.selectedContainer = document.getElementById(this.prefix + 'selectedItemsContainer');
                this.selectionCount = document.getElementById(this.prefix + 'selectionCount');
                this.toggleText = document.getElementById(this.prefix + 'toggleText');
                this.hiddenSelect = document.getElementById(this.prefix + 'personnels');
                this.selectedValues = new Set();
                this.searchInput = null;
                this.allPersonnels = [];
                this.filteredPersonnels = [];
                this.init();
            }

            init() {
                this.loadPersonnels();
                this.setupEventListeners();
            }

            setupEventListeners() {
                this.selectToggle.addEventListener('click', (e) => {
                    e.stopPropagation();
                    this.toggleDropdown();
                });

                document.addEventListener('click', (e) => {
                    if (!this.selectToggle.contains(e.target) && !this.selectDropdown.contains(e.target)) {
                        this.closeDropdown();
                    }
                });

                document.addEventListener('keydown', (e) => {
                    if (e.key === 'Escape' && this.selectDropdown.classList.contains('show')) {
                        this.closeDropdown();
                    }
                });

                document.getElementById(this.prefix + 'closeDropdownBtn')?.addEventListener('click', () => {
                    this.closeDropdown();
                });

                document.getElementById(this.prefix + 'selectAllBtn')?.addEventListener('click', () => {
                    this.selectAll();
                });

                document.getElementById(this.prefix + 'clearSelectionBtn')?.addEventListener('click', () => {
                    this.clearSelection();
                });

                this.selectDropdown.addEventListener('click', (e) => {
                    e.stopPropagation();
                });
            }

            toggleDropdown() {
                if (this.selectDropdown.classList.contains('show')) {
                    this.closeDropdown();
                } else {
                    this.openDropdown();
                }
            }

            openDropdown() {
                this.selectDropdown.classList.add('show');
                this.selectToggle.classList.add('expanded');
                this.selectToggle.classList.add('active');
                
                // Focus sur le champ de recherche quand le dropdown s'ouvre
                setTimeout(() => {
                    if (this.searchInput) {
                        this.searchInput.focus();
                    }
                }, 100);
            }

            closeDropdown() {
                this.selectDropdown.classList.remove('show');
                this.selectToggle.classList.remove('expanded');
                this.selectToggle.classList.remove('active');
                
                // Réinitialiser la recherche
                if (this.searchInput) {
                    this.searchInput.value = '';
                    this.filterOptions('');
                }
            }

            async loadPersonnels() {
                try {
                    const response = await fetch('/admin/projets/api/personnels-actifs');
                    const data = await response.json();
                    
                    if (data.success && data.personnels) {
                        this.allPersonnels = data.personnels;
                        this.filteredPersonnels = [...data.personnels];
                        this.createSearchInput();
                        this.populateOptions();
                    }
                } catch (error) {
                    console.error('Erreur chargement personnels:', error);
                    this.selectOptionsContainer.innerHTML = `
                        <div class="no-results">
                            <i class="bi bi-exclamation-circle"></i>
                            Erreur de chargement
                        </div>
                    `;
                }
            }

            createSearchInput() {
                // Créer le champ de recherche si il n'existe pas
                if (!this.searchInput) {
                    const searchContainer = document.createElement('div');
                    searchContainer.className = 'select-search-container';
                    
                    this.searchInput = document.createElement('input');
                    this.searchInput.type = 'text';
                    this.searchInput.className = 'select-search-input';
                    this.searchInput.placeholder = 'Rechercher un responsable...';
                    
                    searchContainer.appendChild(this.searchInput);
                    
                    // Insérer après le header mais avant les options
                    const dropdownHeader = this.selectDropdown.querySelector('.dropdown-header');
                    if (dropdownHeader) {
                        dropdownHeader.after(searchContainer);
                    } else {
                        this.selectDropdown.insertBefore(searchContainer, this.selectOptionsContainer);
                    }
                    
                    // Ajouter l'écouteur d'événement
                    this.searchInput.addEventListener('input', (e) => {
                        this.filterOptions(e.target.value);
                    });
                    
                    // Empêcher la propagation du clic
                    this.searchInput.addEventListener('click', (e) => {
                        e.stopPropagation();
                    });
                }
            }

            filterOptions(searchTerm) {
                const term = searchTerm.toLowerCase().trim();
                
                if (term === '') {
                    this.filteredPersonnels = [...this.allPersonnels];
                } else {
                    this.filteredPersonnels = this.allPersonnels.filter(personnel => {
                        const fullName = `${personnel.NomPer} ${personnel.PrenomPer || ''}`.toLowerCase();
                        const email = personnel.EmailPer.toLowerCase();
                        const matricule = personnel.ImPer.toLowerCase();
                        
                        return fullName.includes(term) || 
                               email.includes(term) || 
                               matricule.includes(term);
                    });
                }
                
                this.populateOptions();
            }

            populateOptions() {
                this.selectOptionsContainer.innerHTML = '';
                
                if (this.filteredPersonnels.length === 0) {
                    this.selectOptionsContainer.innerHTML = `
                        <div class="no-results">
                            <i class="bi bi-search"></i>
                            Aucun résultat trouvé
                        </div>
                    `;
                    return;
                }
                
                this.filteredPersonnels.forEach(personnel => {
                    const optionId = this.prefix + 'personnel_' + personnel.ImPer;
                    const fullName = `${personnel.NomPer} ${personnel.PrenomPer || ''}`.trim();
                    const isSelected = this.selectedValues.has(personnel.ImPer);
                    
                    const optionDiv = document.createElement('div');
                    optionDiv.className = 'select-option';
                    optionDiv.innerHTML = `
                        <input type="checkbox" id="${optionId}" value="${personnel.ImPer}" 
                               ${isSelected ? 'checked' : ''}
                               data-text="${fullName}">
                        <label for="${optionId}" class="option-text">
                            <span>${fullName}</span>
                            <span class="option-details">${personnel.EmailPer}</span>
                        </label>
                    `;
                    
                    const checkbox = optionDiv.querySelector('input[type="checkbox"]');
                    checkbox.addEventListener('change', (e) => {
                        this.handleCheckboxChange(e.target);
                    });
                    
                    this.selectOptionsContainer.appendChild(optionDiv);
                });

                console.log(`✅ ${this.filteredPersonnels.length} personnels affichés pour ${this.prefix}`);
            }

            handleCheckboxChange(checkbox) {
                const value = checkbox.value;
                const text = checkbox.getAttribute('data-text');
                
                if (checkbox.checked) {
                    this.selectedValues.add(value);
                    this.addToHiddenSelect(value, text);
                } else {
                    this.selectedValues.delete(value);
                    this.removeFromHiddenSelect(value);
                }
                
                this.updateSelectedItemsDisplay();
            }

            addToHiddenSelect(value, text) {
                const option = document.createElement('option');
                option.value = value;
                option.textContent = text;
                option.selected = true;
                this.hiddenSelect.appendChild(option);
            }

            removeFromHiddenSelect(value) {
                const option = this.hiddenSelect.querySelector(`option[value="${value}"]`);
                if (option) {
                    option.remove();
                }
            }

            updateSelectedItemsDisplay() {
                const selectedOptions = Array.from(this.hiddenSelect.selectedOptions);
                
                this.selectionCount.textContent = selectedOptions.length;
                
                if (selectedOptions.length === 0) {
                    this.toggleText.textContent = 'Cliquez pour sélectionner les responsables';
                } else {
                    this.toggleText.textContent = `${selectedOptions.length} responsable(s) sélectionné(s)`;
                }
                
                if (selectedOptions.length === 0) {
                    this.selectedContainer.innerHTML = '<div class="empty-selection">Aucun responsable sélectionné</div>';
                    return;
                }

                const badgesHTML = selectedOptions.map(option => {
                    const text = option.textContent;
                    return `
                        <div class="selected-item-badge" data-value="${option.value}">
                            <div class="badge-content">
                                <span class="person-name">${text}</span>
                                <button type="button" class="remove-btn" onclick="projetManager.${this.prefix === 'edit_' ? 'editSelect' : 'bootstrapSelect'}.removeItem('${option.value}')">
                                    ×
                                </button>
                            </div>
                        </div>
                    `;
                }).join('');

                this.selectedContainer.innerHTML = badgesHTML;
            }

            removeItem(value) {
                const checkbox = this.selectOptionsContainer.querySelector(`input[value="${value}"]`);
                if (checkbox) {
                    checkbox.checked = false;
                    this.handleCheckboxChange(checkbox);
                }
            }

            selectAll() {
                const checkboxes = this.selectOptionsContainer.querySelectorAll('input[type="checkbox"]');
                checkboxes.forEach(checkbox => {
                    if (!checkbox.checked) {
                        checkbox.checked = true;
                        this.handleCheckboxChange(checkbox);
                    }
                });
            }

            clearSelection() {
                const checkboxes = this.selectOptionsContainer.querySelectorAll('input[type="checkbox"]');
                checkboxes.forEach(checkbox => {
                    if (checkbox.checked) {
                        checkbox.checked = false;
                        this.handleCheckboxChange(checkbox);
                    }
                });
            }

            getSelectedValues() {
                return Array.from(this.selectedValues);
            }

            setSelectedValues(values) {
                this.clearSelection();
                
                // S'assurer que les personnels sont chargés avant de définir les valeurs
                if (this.allPersonnels.length === 0) {
                    console.warn('Personnels pas encore chargés');
                    return;
                }
                
                values.forEach(value => {
                    const checkbox = this.selectOptionsContainer.querySelector(`input[value="${value}"]`);
                    if (checkbox) {
                        checkbox.checked = true;
                        this.handleCheckboxChange(checkbox);
                    } else {
                        // Si la checkbox n'est pas trouvée (personnel filtré), on l'ajoute quand même
                        const personnel = this.allPersonnels.find(p => p.ImPer === value);
                        if (personnel) {
                            this.selectedValues.add(value);
                            this.addToHiddenSelect(value, `${personnel.NomPer} ${personnel.PrenomPer || ''}`.trim());
                        }
                    }
                });
                
                this.updateSelectedItemsDisplay();
            }
        }

