        /* Styles pour les alertes de date */
.alert-indicator {
    position: relative;
}

.alert-badge {
    position: absolute;
    top: -8px;
    right: -8px;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    border: 2px solid white;
    animation: pulse 2s infinite;
}

.alert-content {
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.alert-message {
    font-size: 0.8rem;
    font-weight: 500;
    padding: 0.4rem 0.6rem;
    border-radius: 6px;
    display: inline-block;
    flex: 1;
    white-space: normal;
    word-wrap: break-word;
    min-height: 32px;
    display: flex;
    align-items: center;
    animation: pulse-container 2s infinite;
}

/* Animation pour le container entier */
@keyframes pulse-container {
    0% {
        opacity: 1;
        box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.7);
    }
    50% {
        opacity: 0.8;
        box-shadow: 0 0 0 8px rgba(239, 68, 68, 0);
    }
    100% {
        opacity: 1;
        box-shadow: 0 0 0 0 rgba(239, 68, 68, 0);
    }
}

/* Animation spécifique pour chaque niveau d'alerte */
.alert-retard {
    background: #fef2f2;
    color: #dc2626;
    border: 1px solid #fecaca;
    animation: pulse-retard 2s infinite;
}

.alert-urgence {
    background: #feece1ff;
    color: #ea580c;
    border: 1px solid #d38254ff;
    animation: pulse-urgence 2s infinite;
}

.alert-attention {
    background: #fef5e5d6;
    color: #faba4cff;
    border: 1px solid #f0cc8aff;
    animation: pulse-attention 2s infinite;
}

.alert-projet-termine {
    background: linear-gradient(135deg, #d4edda 0%, #c3e6cb 100%);
    border-left: 4px solid #28a745;
    color: #155724;
}

.alert-projet-termine .alert-icon {
    color: #28a745;
} 

/* Animations spécifiques par couleur */
@keyframes pulse-retard {
    0% {
        opacity: 1;
        box-shadow: 0 0 0 0 rgba(220, 38, 38, 0.7);
    }
    50% {
        opacity: 0.8;
        box-shadow: 0 0 0 8px rgba(220, 38, 38, 0);
    }
    100% {
        opacity: 1;
        box-shadow: 0 0 0 0 rgba(220, 38, 38, 0);
    }
}

@keyframes pulse-urgence {
    0% {
        opacity: 1;
        box-shadow: 0 0 0 0 rgba(217, 119, 6, 0.7);
    }
    50% {
        opacity: 0.8;
        box-shadow: 0 0 0 8px rgba(217, 119, 6, 0);
    }
    100% {
        opacity: 1;
        box-shadow: 0 0 0 0 rgba(217, 119, 6, 0);
    }
}

@keyframes pulse-attention {
    0% {
        opacity: 1;
        box-shadow: 0 0 0 0 rgba(204, 164, 5, 0.7);
    }
    50% {
        opacity: 0.8;
        box-shadow: 0 0 0 8px rgba(3, 105, 161, 0);
    }
    100% {
        opacity: 1;
        box-shadow: 0 0 0 0 rgba(3, 105, 161, 0);
    }
}

/* Optionnel : Animation plus subtile avec juste l'opacité */
.alert-message.alternative-animation {
    animation: subtle-pulse 2s infinite;
}

@keyframes subtle-pulse {
    0% {
        opacity: 1;
        transform: scale(1);
    }
    50% {
        opacity: 0.7;
        transform: scale(1.02);
    }
    100% {
        opacity: 1;
        transform: scale(1);
    }
}

@keyframes pulse {
    0% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(245, 158, 11, 0.7); }
    70% { transform: scale(1); box-shadow: 0 0 0 6px rgba(245, 158, 11, 0); }
    100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(245, 158, 11, 0); }
}

.alert-row {
    position: relative;
}

.alert-row::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 4px;
}

.alert-row-yellow::before {
    background-color: #f59e0b;
}

.alert-row-orange::before {
    background-color: #f97316;
}

.alert-row-red::before {
    background-color: #ef4444;
}

.alert-tooltip {
