                const avancementNum = parseInt(avancement);
                let statut = 'Débuté';
                
                if (avancementNum === 0) {
                    statut = 'Débuté';
                } else if (avancementNum > 0 && avancementNum < 100) {
                    statut = 'En cours';
                } else if (avancementNum === 100) {
                    statut = 'Terminé';
                }
                
                // Mettre à jour le statut dans le projet en cours d'édition
                if (this.currentEditingProjet) {
                    this.currentEditingProjet.StatutPro = statut;
                }
            }

            calculerAvancementAuto(projet) {
                if (!projet || !projet.taches || projet.taches.length === 0) {
                    return 0;
                }

                const totalAvancement = projet.taches.reduce((sum, tache) => {
                    return sum + (tache.avancementTache || 0);
                }, 0);

                return Math.round(totalAvancement / projet.taches.length);
            }

