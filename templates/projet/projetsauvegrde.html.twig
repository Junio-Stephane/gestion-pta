// Nouvelle méthode pour charger les instances
loadSelectInstances(personnels) {
    // Créer l'instance pour l'ajout
    this.bootstrapSelect = new BootstrapMultipleSelect('');
    // Injecter les données directement
    this.bootstrapSelect.allPersonnels = personnels;
    this.bootstrapSelect.filteredPersonnels = [...personnels];
    this.bootstrapSelect.populateOptions();
    
    // Créer l'instance pour l'édition
    this.editSelect = new BootstrapMultipleSelect('edit_');
    this.editSelect.allPersonnels = personnels;
    this.editSelect.filteredPersonnels = [...personnels];
    this.editSelect.populateOptions();
    
    // Si un projet est en cours d'édition, sélectionner ses responsables
    if (this.currentEditingProjet && this.currentEditingProjet.personnels) {
        const responsablesIds = this.currentEditingProjet.personnels.map(p => p.ImPer);
        this.editSelect.setSelectedValues(responsablesIds);
    }
    
    window.bootstrapSelect = this.bootstrapSelect;
}

            

