// Modifiez la méthode calculerDureeEstimee() pour utiliser la vérification

calculerDureeEstimee() {
    const periodeInfo = document.getElementById('periodeInfo');
    const displayDateDebut = document.getElementById('displayDateDebut');
    const displayDateFin = document.getElementById('displayDateFin');
    const displayDureeEstimee = document.getElementById('displayDureeEstimee');

    const periodType = document.querySelector('input[name="periodType"]:checked').value;
    
    let dateDebut, dateFin, dureeText;

    if (periodType === 'dates') {
        const dateDebutPro = document.getElementById('dateDebutPro').value;
        const dateFinPro = document.getElementById('dateFinPro').value;

        if (dateDebutPro && dateFinPro) {
            try {
                const dateDebutObj = flatpickr.parseDate(dateDebutPro, 'd/m/Y');
                const dateFinObj = flatpickr.parseDate(dateFinPro, 'd/m/Y');

                if (dateFinObj > dateDebutObj) {
                    // Calculer la durée en jours ouvrables
                    const joursOuvrables = this.holidaysManager.getBusinessDaysCount(dateDebutObj, dateFinObj);
                    
                    dureeText = this.formatDuree(joursOuvrables);

                    displayDateDebut.textContent = dateDebutPro;
                    displayDateFin.textContent = dateFinPro;
                    displayDureeEstimee.textContent = dureeText;
                    periodeInfo.style.display = 'block';
                    
                    // Effacer l'erreur si elle existe
                    this.clearFieldError('dateFinPro');
                } else {
                    periodeInfo.style.display = 'none';
                    // L'erreur est déjà affichée par verifierDateFinEnTempsReel()
                }
            } catch (error) {
                console.error('Erreur parsing date:', error);
                periodeInfo.style.display = 'none';
            }
        } else {
            periodeInfo.style.display = 'none';
        }
    } else {
        const dateDebutDuration = document.getElementById('dateDebutDuration').value;
        const dureeValue = document.getElementById('dureeEstimee').value;
        const dureeUnite = document.getElementById('dureeUnite').value;

        if (dateDebutDuration && dureeValue) {
            try {
                const dateDebutObj = flatpickr.parseDate(dateDebutDuration, 'd/m/Y');
                
                // Calculer la date de fin en prenant en compte les jours fériés et week-ends
                const dateFinObj = this.holidaysManager.calculateEndDate(dateDebutObj, parseInt(dureeValue), dureeUnite);

                const formattedDateFin = dateFinObj.toLocaleDateString('fr-FR', {
                    day: '2-digit',
                    month: '2-digit',
                    year: 'numeric'
                });

                dureeText = `${dureeValue} ${dureeUnite} ouvrables`;

                displayDateDebut.textContent = dateDebutDuration;
                displayDateFin.textContent = formattedDateFin;
                displayDureeEstimee.textContent = dureeText;
                periodeInfo.style.display = 'block';
            } catch (error) {
                console.error('Erreur calcul durée:', error);
                periodeInfo.style.display = 'none';
            }
        } else {
            periodeInfo.style.display = 'none';
        }
    }
}

