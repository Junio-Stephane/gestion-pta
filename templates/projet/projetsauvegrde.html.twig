            gererTaches(numProjet, estSuspendu = false, estTermine = false) {
    const projet = this.allProjets.find(p => p.numProjet === numProjet);
    
    if (!projet) {
        this.showError('Projet non trouvé');
        return;
    }

    if (estTermine) {
        // Pour un projet terminé, afficher le modal spécifique
        this.showProjetTermineModal(numProjet);
    } else if (estSuspendu) {
        // Pour un projet suspendu, afficher le modal d'avertissement
        this.showTachesWarningModal(numProjet);
    } else {
        // Pour un projet actif, rediriger normalement
        window.location.href = `/admin/taches/projet/${numProjet}`;
    }
}

