            formatDuree(diffDays) {
                if (diffDays >= 14) {
                    const weeks = Math.ceil(diffDays / 7);
                    return `${weeks} semaine${weeks > 1 ? 's' : ''} ouvrables`;
                } else {
                    return `${diffDays} jour${diffDays > 1 ? 's' : ''} ouvrables`;
                }
            }

            calculerDateFin(dateDebutISO, dureeValue, dureeUnite) {
                const dateDebut = new Date(dateDebutISO);
                
                // Utiliser le gestionnaire de jours fériés pour calculer la date de fin
                return this.holidaysManager.calculateEndDate(dateDebut, parseInt(dureeValue), dureeUnite)
                    .toISOString().split('T')[0];
            }

