            renderResponsablesSummary(personnels, projetNum, estSuspendu = false) {
                if (!personnels || personnels.length === 0) {
                    return `
                        <div class="responsables-summary ${estSuspendu ? 'responsables-suspendu' : ''}" 
                             onclick="projetManager.showResponsablesModal([], '${projetNum}')">
                            <span class="responsables-count ${estSuspendu ? 'bg-secondary' : ''}">0</span>
                            <span class="responsables-text">Aucun responsable</span>
                            <i class="bi bi-chevron-right responsables-icon"></i>
                        </div>
                    `;
                }

                const firstTwo = personnels.slice(0, 2);
                const remainingCount = personnels.length - 2;
                
                const displayText = firstTwo.map(p => {
                    const fullName = `${p.NomPer} ${p.PrenomPer || ''}`.trim();
                    return this.truncateText(fullName, 20);
                }).join(', ');
                
                const truncatedDisplayText = this.truncateText(displayText, 40);

                return `
                    <div class="responsables-summary ${estSuspendu ? 'responsables-suspendu' : ''}" 
                         onclick="projetManager.showResponsablesModal(${JSON.stringify(personnels).replace(/"/g, '&quot;')}, '${projetNum}')">
                        <span class="responsables-count ${estSuspendu ? 'bg-secondary' : ''}">${personnels.length}</span>
                        <span class="responsables-text" title="${firstTwo.map(p => `${p.NomPer} ${p.PrenomPer || ''}`.trim()).join(', ')}${remainingCount > 0 ? `, +${remainingCount} autres` : ''}">
                            ${truncatedDisplayText}${remainingCount > 0 ? ` +${remainingCount}` : ''}
                        </span>
                        <i class="bi bi-chevron-right responsables-icon"></i>
                    </div>
                    ${personnels.length > 0 ? `
                        <div class="responsables-badges">
                            ${firstTwo.map(p => {
                                const fullName = `${p.NomPer} ${p.PrenomPer || ''}`.trim();
                                const truncatedName = this.truncateText(fullName, 15);
                                return `
                                    <div class="responsable-badge ${estSuspendu ? 'bg-secondary' : ''}" title="${fullName} - ${p.EmailPer || ''}">
                                        ${truncatedName}
                                    </div>
                                `;
                            }).join('')}
                        </div>
                    ` : ''}
                `;
            }

            truncateText(text, maxLength) {
                if (!text) return '';
                if (text.length <= maxLength) return text;
                return text.substring(0, maxLength - 3) + '...';
            }

            showResponsablesModal(personnels, projetNum) {
                const modalElement = document.getElementById('responsablesModal');
                const listContainer = document.getElementById('responsablesListModal');
                
                if (!personnels || personnels.length === 0) {
