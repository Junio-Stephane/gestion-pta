                                            <strong><i class="bi bi-exclamation-triangle text-warning"></i> Ce projet est suspendu.</strong> Toutes ses tâches sont également suspendues.
                                        </p>
                                    </div>
                                    <p class="mb-3">Souhaitez-vous tout de même consulter les tâches en mode lecture seule ?</p>
                                    <div class="consigne">
                                        <small>
                                            <i class="bi bi-info-circle text-primary"></i>
                                            En mode lecture seule, vous pourrez visualiser les tâches mais aucune modification ne sera possible.
                                        </small>
                                    </div>
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btnG btn-secondary" data-bs-dismiss="modal">
                                        Annuler
                                    </button>
                                    <button type="button" class="btnG btn-info" id="confirmVoirTaches">
                                        <i class="bi bi-eye me-2"></i>
                                        Voir les tâches
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                `;

                // Ajouter le modal au DOM s'il n'existe pas déjà
                if (!document.getElementById('tachesWarningModal')) {
                    document.body.insertAdjacentHTML('beforeend', modalHTML);
                }

                const modalElement = document.getElementById('tachesWarningModal');
                const modal = new bootstrap.Modal(modalElement);
                
                // Gérer la confirmation
                const confirmBtn = document.getElementById('confirmVoirTaches');
                const confirmHandler = () => {
                    window.location.href = `/admin/taches/projet/${numProjet}?readonly=true`;
                    modal.hide();
                };
                
                confirmBtn.onclick = confirmHandler;
                
                modal.show();
                
                // Nettoyer l'écouteur d'événement quand le modal est fermé
                modalElement.addEventListener('hidden.bs.modal', () => {
                    confirmBtn.onclick = null;
                });
            }

            // Mettre à jour la méthode createCircularProgress pour les projets suspendus
            createCircularProgress(avancement, estSuspendu = false) {
                let progressClass = 'low';
                if (avancement >= 70) {
                    progressClass = 'high';
                } else if (avancement >= 30) {
                    progressClass = 'medium';
                }
                if (avancement === 100) {
                    progressClass = 'complete';
                }

                if (estSuspendu) {
                    progressClass = 'suspendu';
                }

                return `
                    <div class="progress-circular ${progressClass}" 
                         style="--progress-value: ${avancement}" 
                         data-progress="${avancement}">
                    </div>
                `;
            }

            async reprendreProjet(numProjet) {
                try {
                    const projet = this.allProjets.find(p => p.numProjet === numProjet);
                    
                    if (!projet) {
                        this.showError('Projet non trouvé');
                        return;
                    }

                    const hasService = projet.service && projet.service.CodeService;
                    const serviceInactif = hasService && projet.service.statutService !== 'ACTIF';

                    if (hasService && serviceInactif) {
                        this.showServiceInactiveModalProjet(projet);
                    } else {
                        this.afficherModalRepriseNormal(projet);
                    }
                } catch (error) {
                    console.error('Erreur vérification service:', error);
                    this.showError('Erreur lors de la vérification du service');
                }
            }

            afficherModalRepriseNormal(projet) {
                const modalHtml = `
                    <div class="modal fade" id="confirmationRepriseProjetModal" tabindex="-1" aria-labelledby="confirmationRepriseProjetModalLabel" aria-hidden="true">
                        <div class="modal-dialog">
                            <div class="modal-content">
                                <div class="modal-header">
                                    <h5 class="modal-title">
                                        <i class="bi bi-play-circle"></i>
                                        Confirmation de reprise
                                    </h5>
                                    <button type="button" class="btn-close-custom" data-bs-dismiss="modal" aria-label="Close">
                                        <i class="bi bi-x"></i>
                                    </button>
                                </div>
                                <div class="modal-body">
                                    <div class="consigneD consigne-success">
                                        <h5><i class="bi bi-play-circle"></i> Reprise du projet</h5>
                                        <p>Êtes-vous sûr de vouloir reprendre ce projet ?</p>
                                    </div>
                                    <div class="mt-3">
                                        <small class="text-muted">Projet concerné :</small>
                                        <span id="projetNomReprise" class="fw-bold mb-1">${this.escapeHtml(projet.titrePro)}</span>
                                    </div>
                                    <div>
                                        <small class="text-muted">Numéro :</small>
                                        <span id="projetNumReprise" class="fw-bold mb-1">${projet.numProjet}</span>
                                    </div>
                                    ${projet.service ? `
                                        <div class="mt-2 p-2 bg-light rounded">
                                            <small>Service : <strong>${projet.service.nomService} (${projet.service.CodeService})</strong></small>
                                        </div>
                                    ` : ''}
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btnG btn-secondary" data-bs-dismiss="modal">
                                        Annuler
                                    </button>
                                    <button type="button" class="btnG btn-success" id="confirmReprendreProjet">
                                        <i class="bi bi-play-circle me-2"></i>
                                        Confirmer la reprise
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                `;

                document.body.insertAdjacentHTML('beforeend', modalHtml);

                const modalElement = document.getElementById('confirmationRepriseProjetModal');
                
                document.getElementById('confirmReprendreProjet').addEventListener('click', () => {
                    this.confirmReprendreProjet(projet.numProjet);
                });

                const modal = new bootstrap.Modal(modalElement);
                modal.show();

                modalElement.addEventListener('hidden.bs.modal', function() {
                    this.remove();
                });
