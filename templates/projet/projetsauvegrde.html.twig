           applyFilters() {
    let filtered = [...this.allProjets];

    // Filtre par statut
    if (this.currentFilters.statut) {
        filtered = filtered.filter(projet => 
            projet.StatutPro === this.currentFilters.statut
        );
    }

    // Filtre par direction
    if (this.currentFilters.direction) {
        filtered = filtered.filter(projet => 
            projet.service && 
            projet.service.direction && 
            projet.service.direction.CodeDirection === this.currentFilters.direction
        );
    }

    // Filtre par service
    if (this.currentFilters.service) {
        filtered = filtered.filter(projet => 
            projet.service && 
            projet.service.CodeService === this.currentFilters.service
        );
    }

    // Filtre par agent
    if (this.currentFilters.agent) {
        filtered = filtered.filter(projet => {
            if (!projet.personnels || projet.personnels.length === 0) return false;
            
            return projet.personnels.some(personnel => 
                personnel.ImPer === this.currentFilters.agent
            );
        });
    }

    // Filtre par période
    if (this.currentFilters.dateDebut || this.currentFilters.dateFin) {
        filtered = filtered.filter(projet => {
            const projetDateDebut = projet.dateDebutPro ? new Date(projet.dateDebutPro) : null;
            
            let match = true;

            // Filtre date de début
            if (this.currentFilters.dateDebut) {
                const filterDateDebut = this.parseFilterDate(this.currentFilters.dateDebut);
                if (projetDateDebut && projetDateDebut < filterDateDebut) {
                    match = false;
                }
            }

            // Filtre date de fin
            if (this.currentFilters.dateFin) {
                const filterDateFin = this.parseFilterDate(this.currentFilters.dateFin);
                if (projetDateDebut && projetDateDebut > filterDateFin) {
                    match = false;
                }
            }

            return match;
        });
    }

    // Filtre "Mes projets" (projets créés par l'utilisateur connecté)
    if (this.currentFilters.mesProjets) {
        const currentUserId = this.getCurrentUserId();
        filtered = filtered.filter(projet => 
            projet.createur && projet.createur.ImPer === currentUserId
        );
    }

    // Filtre par recherche
    if (this.currentFilters.search) {
        const searchTerm = this.currentFilters.search.toLowerCase();
        filtered = filtered.filter(projet => {
            return (
                projet.numProjet.toLowerCase().includes(searchTerm) ||
                projet.titrePro.toLowerCase().includes(searchTerm) ||
                (projet.service && projet.service.nomService.toLowerCase().includes(searchTerm)) ||
                (projet.service && projet.service.direction && 
                 projet.service.direction.nomDirection.toLowerCase().includes(searchTerm)) ||
                (projet.personnels && projet.personnels.some(p => 
                    `${p.NomPer} ${p.PrenomPer || ''}`.toLowerCase().includes(searchTerm)
                ))
            );
        });
    }

    // Application du tri
    if (this.currentFilters.tri) {
        filtered = this.trierProjets(filtered, this.currentFilters.tri);
    }

    this.filteredProjets = filtered;
    this.totalItems = filtered.length;
    this.currentPage = 1;
    this.renderProjets();
    this.renderPagination();
}

trierProjets(projets, triType) {
    const projetsTries = [...projets];
    
    switch(triType) {
        case 'echeance':
            // Trier par échéance la plus proche (dateFinPro)
            // Les projets sans date de fin en dernier
            projetsTries.sort((a, b) => {
                if (!a.dateFinPro && !b.dateFinPro) return 0;
                if (!a.dateFinPro) return 1; // a en dernier
                if (!b.dateFinPro) return -1; // b en dernier
                
                const dateA = new Date(a.dateFinPro);
                const dateB = new Date(b.dateFinPro);
                return dateA - dateB; // Dates les plus proches en premier
            });
            break;
            
        case 'recent':
            // Trier du plus récent au plus ancien (par dateDebutPro)
            projetsTries.sort((a, b) => {
                if (!a.dateDebutPro && !b.dateDebutPro) return 0;
                if (!a.dateDebutPro) return 1;
                if (!b.dateDebutPro) return -1;
                
                const dateA = new Date(a.dateDebutPro);
                const dateB = new Date(b.dateDebutPro);
                return dateB - dateA; // Plus récent en premier
            });
            break;
            
        case 'ancien':
            // Trier du plus ancien au plus récent (par dateDebutPro)
            projetsTries.sort((a, b) => {
                if (!a.dateDebutPro && !b.dateDebutPro) return 0;
                if (!a.dateDebutPro) return 1;
                if (!b.dateDebutPro) return -1;
                
                const dateA = new Date(a.dateDebutPro);
                const dateB = new Date(b.dateDebutPro);
                return dateA - dateB; // Plus ancien en premier
            });
            break;
    }
    
    return projetsTries;
}

            parseFilterDate(dateString) {
                if (!dateString) return null;
                
                // Format "dd/mm/yyyy"
                const [day, month, year] = dateString.split('/');
                return new Date(`${year}-${month}-${day}`);
            }

            getPaginatedProjets() {
                const startIndex = (this.currentPage - 1) * this.itemsPerPage;
                const endIndex = startIndex + this.itemsPerPage;
                return this.filteredProjets.slice(startIndex, endIndex);
            }

