async activerPersonnel(imPer) {
    try {
        const personnel = this.allPersonnels.find(p => p.ImPer === imPer);
        
        if (!personnel) {
            this.showError('Personnel non trouvé');
            return;
        }

        console.log('=== DEBUG: Données du personnel ===');
        console.log('Personnel:', personnel);
        console.log('Service complet:', JSON.stringify(personnel.service, null, 2));
        console.log('Direction directe:', personnel.direction);

        const isDirecteur = personnel.FonctionPer === 'Directeur';
        const isChefService = personnel.FonctionPer === 'Chef_service';
        const hasService = personnel.service && personnel.service.codeService;
        
        // Pour les chefs de service uniquement, on vérifie la direction
        if (isChefService && hasService) {
            // Étape 1: Vérifier la direction
            let directionCode = null;
            
            // Récupérer le code direction depuis personnel.direction
            if (personnel.direction && personnel.direction.codeDirection) {
                directionCode = personnel.direction.codeDirection;
                console.log('Code direction trouvé:', directionCode);
            }
            
            if (directionCode) {
                console.log('Vérification statut direction...');
                console.log('URL:', `/admin/personnels/api/directions/${directionCode}/details`);
                
                const directionResponse = await fetch(`/admin/personnels/api/directions/${directionCode}/details`);
                
                if (directionResponse.ok) {
                    const directionData = await directionResponse.json();
                    console.log('Réponse API direction:', directionData);
                    
                    if (directionData.success && directionData.direction) {
                        const statutDirection = directionData.direction.statutDirection;
                        console.log('Statut direction:', statutDirection);
                        
                        // CAS 1: Direction inactive - afficher modal changement de direction
                        if (statutDirection !== 'ACTIVE') {
                            console.log('Direction INACTIVE - afficher modal direction inactive pour chef');
                            this.showDirectionInactiveModalChefService(personnel);
                            return;
                        }
                        // CAS 2: Direction active - afficher modal classique d'activation (PAS de modal service inactif)
                        else {
                            console.log('Direction ACTIVE - modal classique pour chef de service');
                            this.afficherModalActivationDirecteurChef(personnel);
                            return;
                        }
                    }
                } else {
                    console.warn('Erreur API direction:', await directionResponse.text());
                }
            } else {
                console.warn('Aucun code direction trouvé');
            }
            
            // Si aucune vérification de direction n'a abouti, afficher modal classique
            console.log('Aucune vérification direction - modal classique');
            this.afficherModalActivationDirecteurChef(personnel);
            return;
        }

        // Logique pour les directeurs
        if (isDirecteur) {
            this.afficherModalActivationDirecteurChef(personnel);
        } 
        // Logique pour les autres personnels (agents) - PAS les chefs de service
        else {
            const serviceInactif = hasService && personnel.service.statutService !== 'ACTIF';
            
            if (hasService && serviceInactif) {
                this.showServiceInactiveModal({
                    ImPer: personnel.ImPer,
                    NomPer: personnel.NomPer,
                    PrenomPer: personnel.PrenomPer,
                    service: personnel.service ? {
                        codeService: personnel.service.codeService,
                        nomService: personnel.service.nomService,
                        statutService: personnel.service.statutService
                    } : null
                });
            } else {
                this.afficherModalActivationNormal(personnel);
            }
        }
    } catch (error) {
        console.error('Erreur vérification direction/service:', error);
        this.showError('Erreur lors de la vérification des données');
    }
}

