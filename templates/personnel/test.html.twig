                        <button type="button" class="btn btn-warning" ${estDesactive ? 'disabled' : ''}
                            onclick="${estDesactive ? '' : `personnelManager.openModifierPersonnelModal(
                                '${personnel.ImPer}',
                                '${this.escapeHtml(personnel.NomPer)}',
                                '${this.escapeHtml(personnel.PrenomPer || '')}',
                                '${this.escapeHtml(personnel.EmailPer)}',
                                '${this.escapeHtml(personnel.TelPer || '')}',
                                '${personnel.FonctionPer}',
                                '${personnel.service ? personnel.service.codeService : ''}',
