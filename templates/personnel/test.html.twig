            this.clearFieldError('nouvelleDirectionChef');
        });
    }

    if (form) {
        form.addEventListener('submit', (e) => {
            e.preventDefault();
            this.confirmerChangementDirectionChef(personnel);
        });
    }
}

async confirmerChangementDirectionChef(personnel) {
    const selectDirection = $('#nouvelleDirectionChef');
    const chefIm = document.getElementById('changerDirectionChefIm').value;

    if (!selectDirection.length || !selectDirection.val()) {
        this.showFieldError('nouvelleDirectionChef', 'Veuillez sélectionner une direction active');
        return;
    }

    const nouvelleDirectionCode = selectDirection.val();

    try {
        // AJOUT DU SPINNER
        const btnConfirmer = document.getElementById('btnConfirmerChangementDirectionChef');
        const originalText = btnConfirmer.innerHTML;
        btnConfirmer.innerHTML = '<div class="loading-spinner me-2"></div> Activation...';
        btnConfirmer.disabled = true;

        const data = {
            nouvelleDirection: nouvelleDirectionCode
        };

        const response = await fetch(`/admin/personnels/api/${chefIm}/activer`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify(data)
        });

        const result = await response.json();

        if (result.success) {
            this.showSuccess('Chef de service activé avec succès');
            
            const modalElement = document.getElementById('directionInactiveChefServiceModal');
            if (modalElement) {
                bootstrap.Modal.getInstance(modalElement).hide();
            }
            
            this.loadPersonnels();
            
        } else {
            this.showError(result.message || 'Erreur lors de l\'activation');
            
            // RESTAURATION DU BOUTON EN CAS D'ERREUR
            btnConfirmer.innerHTML = originalText;
            btnConfirmer.disabled = false;
        }
    } catch (error) {
        console.error('Erreur activation chef de service:', error);
        this.showError('Erreur lors de l\'activation');
        
        const btnConfirmer = document.getElementById('btnConfirmerChangementDirectionChef');
        if (btnConfirmer) {
            // RESTAURATION DU BOUTON EN CAS D'ERREUR
            btnConfirmer.innerHTML = '<i class="bi bi-check-circle me-2"></i> Changer la direction';
            btnConfirmer.disabled = false;
        }
    }
}

    async chargerServicesActifsPourSelect() {
        try {
            const response = await fetch('/admin/personnels/api/services-actifs');
            const data = await response.json();
            
            if (data.success) {
                const select = $('#nouveauService');
                if (select.length) {
                    select.empty();
                    select.append('<option value=""></option>');
                    
                    data.services.forEach(service => {
                        const option = new Option(`${service.codeService} - ${service.nomService}`, service.codeService, false, false);
                        select.append(option);
                    });
                    
                    select.trigger('change.select2');
                }
            }
        } catch (error) {
            console.error('Erreur chargement services actifs:', error);
        }
    }

