{% block javascripts %}
<script>
class PersonnelManager {
    constructor() {
        this.currentPersonnelIm = null;
        this.allPersonnels = [];
        this.filteredPersonnels = [];
        this.currentPage = 1;
        this.itemsPerPage = 7;
        this.totalItems = 0;
        this.currentFilters = {
            statut: '',
            fonction: '',
            role: '',
            direction: '',
            service: '',
            search: ''
        };
        this.directions = [];
        this.services = [];
        this.allServices = [];
        this.selects = {}; // Pour stocker les instances Select2
        this.init();
    }

    init() {
        this.initSelect2();
        this.loadPersonnels();
        this.loadServices();
        this.setupEventListeners();
        this.loadAllServices();
        this.loadDirectionsActifs();
    }

    initSelect2() {
        // Options pour les filtres (style compact)
        const filterOptions = {
            theme: 'bootstrap-5',
            width: '100%',
            placeholder: 'Rechercher...',
            allowClear: true,
            dropdownParent: $(document.body),
            language: {
                noResults: () => "Aucun résultat trouvé",
                searching: () => "Recherche en cours..."
            }
        };

        // Options pour les modaux (style normal)
        const modalOptions = {
            theme: 'bootstrap-5',
            width: '100%',
            placeholder: 'Rechercher...',
            allowClear: true,
            language: {
                noResults: () => "Aucun résultat trouvé",
                searching: () => "Recherche en cours..."
            }
        };

        // Initialiser seulement les selects qui ont beaucoup d'options
        this.selects.directionFilter = $('#directionFilter').select2(filterOptions);
        this.selects.serviceFilter = $('#serviceFilter').select2(filterOptions);

        // Initialiser le select du modal de modification
        this.selects.modifierService = $('#modifierService').select2({
            ...modalOptions,
            dropdownParent: $('#modifierPersonnelModal')
        });

        // Gérer la fermeture des modaux
        $('.modal').on('hidden.bs.modal', () => {
            Object.values(this.selects).forEach(select => {
                if (select && $.fn.select2) {
                    select.select2('close');
                }
            });
        });

        console.log('✅ Select2 initialisé pour direction, service et modal seulement');
    }

    hasActiveFilters() {
        return this.currentFilters.statut || this.currentFilters.fonction || 
               this.currentFilters.role || this.currentFilters.direction || 
               this.currentFilters.service || this.currentFilters.search;
    }

    async loadPersonnels() {
        try {
            const response = await fetch('/admin/personnels/api/list');
            const data = await response.json();
            
            if (data.success) {
                this.allPersonnels = data.personnels;
                this.applyFilters();
            } else {
                this.showError(data.message);
            }
        } catch (error) {
            console.error('Erreur chargement personnels:', error);
            this.showError('Erreur lors du chargement des personnels');
        }
    }

    async loadAllServices() {
        try {
            const response = await fetch('/admin/services/api/list');
            const data = await response.json();
            
            if (data.success) {
                this.allServices = data.services;
                this.populateServiceFilter();
            }
        } catch (error) {
            console.error('Erreur chargement tous les services:', error);
        }
    }

    async loadServicesActifs() {
        try {
            const response = await fetch('/admin/personnels/api/services-actifs');
            const data = await response.json();
            
            if (data.success) {
                this.services = data.services;
            }
        } catch (error) {
            console.error('Erreur chargement services actifs:', error);
        }
    }

    async loadServices() {
        try {
            const response = await fetch('/admin/services/api/list');
            const data = await response.json();
            
            if (data.success) {
                this.allServices = data.services;
                this.applyFilters();
            } else {
                this.showError(data.message);
            }
        } catch (error) {
            console.error('Erreur chargement services:', error);
            this.showError('Erreur lors du chargement des services');
        }
    }

    async loadDirectionsActifs() {
        try {
            const response = await fetch('/admin/directions/api/list');
            const data = await response.json();
            
            if (data.success) {
                this.directions = data.directions;
                this.populateDirectionFilter();
            }
        } catch (error) {
            console.error('Erreur chargement directions:', error);
        }
    }

populateServiceFilter() {
    const serviceFilter = this.selects.serviceFilter;
    serviceFilter.empty();
    
    // Option vide par défaut (tous les services)
    serviceFilter.append('<option value=""></option>');
    
    // Ajouter l'option "Aucun" en deuxième position
    serviceFilter.append('<option value="aucun">Aucun service</option>');
    
    if (this.allServices) {
        this.allServices.forEach(service => {
            const displayText = `${service.CodeService} - ${service.nomService}`;
            const option = new Option(displayText, service.CodeService, false, false);
            serviceFilter.append(option);
        });
    }
    serviceFilter.val('').trigger('change.select2'); // S'assurer que rien n'est sélectionné par défaut
}

    populateDirectionFilter() {
        const directionFilter = this.selects.directionFilter;
        directionFilter.empty();
        directionFilter.append('<option value=""></option>');
        
        if (this.directions) {
            this.directions.forEach(direction => {
                const displayText = `${direction.CodeDirection} - ${direction.nomDirection}`;
                const option = new Option(displayText, direction.CodeDirection, false, false);
                directionFilter.append(option);
            });
        }
        directionFilter.trigger('change.select2');
    }

    applyFilters() {
        let filtered = [...this.allPersonnels];

        // Filtre par statut
        if (this.currentFilters.statut) {
            filtered = filtered.filter(personnel => 
                personnel.StatutPer === this.currentFilters.statut
            );
        }

        // Filtre par fonction
        if (this.currentFilters.fonction) {
            filtered = filtered.filter(personnel => 
                personnel.FonctionPer === this.currentFilters.fonction
            );
        }

        // Filtre par rôle
        if (this.currentFilters.role) {
            filtered = filtered.filter(personnel => 
                personnel.RolePer === this.currentFilters.role
            );
        }

        // Filtre par direction
        if (this.currentFilters.direction) {
            filtered = filtered.filter(personnel => 
                personnel.direction && personnel.direction.codeDirection === this.currentFilters.direction
            );
        }

        // Filtre par service
        if (this.currentFilters.service) {
        if (this.currentFilters.service === 'aucun') {
            // Filtrer les personnels sans service
            filtered = filtered.filter(personnel => 
                !personnel.service || !personnel.service.codeService
            );
        } else {
            // Filtrer par service spécifique
            filtered = filtered.filter(personnel => 
                personnel.service && personnel.service.codeService === this.currentFilters.service
            );
        }
    }

        // Filtre par recherche
        if (this.currentFilters.search) {
            const searchTerm = this.currentFilters.search.toLowerCase();
            filtered = filtered.filter(personnel => {
                return (
                    personnel.ImPer.toLowerCase().includes(searchTerm) ||
                    personnel.NomPer.toLowerCase().includes(searchTerm) ||
                    (personnel.PrenomPer && personnel.PrenomPer.toLowerCase().includes(searchTerm)) ||
                    personnel.EmailPer.toLowerCase().includes(searchTerm) ||
                    (personnel.TelPer && personnel.TelPer.toLowerCase().includes(searchTerm))
                );
            });
        }

        this.filteredPersonnels = filtered;
        this.totalItems = filtered.length;
        this.currentPage = 1;
        this.renderPersonnels();
        this.renderPagination();
    }

    getPaginatedPersonnels() {
        const startIndex = (this.currentPage - 1) * this.itemsPerPage;
        const endIndex = startIndex + this.itemsPerPage;
        return this.filteredPersonnels.slice(startIndex, endIndex);
    }

    renderPersonnels() {
    const personnels = this.getPaginatedPersonnels();
    const tbody = document.getElementById('personnelsTableBody');
    
    if (!personnels || personnels.length === 0) {
        tbody.innerHTML = `
            <tr>
                <td colspan="10" class="text-center py-4 text-muted">
                    <i class="bi bi-people" style="font-size: 2rem;"></i>
                    <p class="mt-2">Aucun personnel trouvé</p>
                    ${this.hasActiveFilters() ? 
                        '<p class="text-sm">Essayez de modifier vos critères de recherche</p>' : 
                        ''
                    }
                </td>
            </tr>
        `;
        return;
    }

    tbody.innerHTML = personnels.map(personnel => {
        const estDesactive = personnel.StatutPer === 'DESACTIVE';
        const rowClass = estDesactive ? 'personnel-desactive' : '';
        
        const statutBadge = estDesactive ? 
            '<span class="status-badge status-desactive">Désactivé</span>' :
            (personnel.StatutPer === 'ACTIF' ? 
                '<span class="status-badge status-active">Actif</span>' : 
                '<span class="status-badge status-waiting">En attente</span>'
            );
        
        let fonctionBadgeClass = 'fonction-agent';
        let fonctionText = 'Agent';
        
        if (personnel.FonctionPer === 'Directeur') {
            fonctionBadgeClass = 'fonction-directeur';
            fonctionText = 'Directeur';
        } else if (personnel.FonctionPer === 'Chef_service') {
            fonctionBadgeClass = 'fonction-chef';
            fonctionText = 'Chef de service';
        }
        
        const fonctionBadge = `<span class="fonction-badge ${fonctionBadgeClass}">${fonctionText}</span>`;

        // Affichage simple du rôle sans badge coloré
        let roleText = 'Utilisateur';
        
        if (personnel.RolePer === 'ROLE_ADMIN') {
            roleText = 'Administrateur';
        } else if (personnel.RolePer === 'ROLE_CREATEUR_DE_PROJET') {
            roleText = 'Créateur de projet';
        }
        
        const roleDisplay = `<span>${roleText}</span>`;

        const directionDisplay = personnel.direction ? 
            `${personnel.direction.codeDirection} - ${personnel.direction.nomDirection}` : 'Aucune';
        
        const serviceDisplay = personnel.service ? 
            `${personnel.service.codeService} - ${personnel.service.nomService}` : 'Aucun';

        return `
            <tr class="personnel-item ${rowClass}" id="personnel-${personnel.ImPer}">
                <td><strong>${personnel.ImPer}</strong></td>
                <td>${personnel.NomPer} ${personnel.PrenomPer || ''}</td>
                <td>${personnel.EmailPer}</td>
                <td>${personnel.TelPer || 'Non defini'}</td>
                <td>${directionDisplay}</td>
