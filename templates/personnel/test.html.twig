    resetFilters() {
    // Réinitialiser les selects classiques
    document.getElementById('statutFilter').value = '';
    document.getElementById('fonctionFilter').value = '';
    document.getElementById('roleFilter').value = '';
    
    // Réinitialiser les selects Select2
    this.selects.directionFilter.val('').trigger('change.select2');
    this.selects.serviceFilter.val('').trigger('change.select2'); // Vide par défaut
    
    document.getElementById('searchInput').value = '';

    const resetBtn = document.getElementById('resetFilters');
    const originalText = resetBtn.innerHTML;
    resetBtn.innerHTML = '<i class="bi bi-check"></i> Réinitialisé !';
    resetBtn.style.background = '#10b981';
    
    setTimeout(() => {
        resetBtn.innerHTML = originalText;
        resetBtn.style.background = '';
    }, 1500);
    
    this.currentFilters = {
        statut: '',
        fonction: '',
        role: '',
        direction: '',
        service: '',
        search: ''
    };
    
    this.applyFilters();
}

    updateDirectionFromService(serviceCode) {
        const directionField = document.getElementById('modifierDirection');
        
        if (serviceCode && this.allServices) {
            const selectedService = this.allServices.find(service => service.CodeService === serviceCode);
            if (selectedService && selectedService.direction) {
                const displayText = `${selectedService.direction.CodeDirection} - ${selectedService.direction.nomDirection}`;
                directionField.value = displayText;
            } else {
                directionField.value = '';
            }
        } else {
            directionField.value = '';
        }
    }

    async modifierPersonnel() {
    const form = document.getElementById('modifierPersonnelForm');
    const submitBtn = document.getElementById('submitModifierPersonnel');
    const originalText = submitBtn.innerHTML;

    try {
        this.clearModalErrors();
        
        // AJOUT DU SPINNER
        submitBtn.innerHTML = '<div class="loading-spinner me-2"></div> Modification...';
        submitBtn.disabled = true;

        const formData = new FormData(form);
        const personnelData = {
            NomPer: formData.get('NomPer'),
            PrenomPer: formData.get('PrenomPer'),
            EmailPer: formData.get('EmailPer'),
            TelPer: formData.get('TelPer'),
            RolePer: formData.get('RolePer')
        };

        const fonctionPer = document.getElementById('modifierFonctionPer').value;
        if (fonctionPer !== 'Chef de service') {
            personnelData.service = formData.get('service') || null;
        }

        const response = await fetch(`/admin/personnels/api/${this.currentPersonnelIm}/modifier`, {
            method: 'PUT',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify(personnelData)
        });

        const result = await response.json();

        if (result.success) {
            this.showSuccess(result.message);
            bootstrap.Modal.getInstance(document.getElementById('modifierPersonnelModal')).hide();
            this.loadPersonnels();
        } else {
            if (result.errors) {
                this.showMultipleErrors(result.errors);
            } else {
                this.showError(result.message);
            }
        }
    } catch (error) {
        console.error('Erreur modification personnel:', error);
        this.showError('Erreur lors de la modification du personnel');
    } finally {
        // RESTAURATION DU BOUTON
        submitBtn.innerHTML = originalText;
        submitBtn.disabled = false;
    }
}

openConfirmationDesactivationModal(imPer, nomComplet) {
    this.currentPersonnelIm = imPer;
    
    document.getElementById('personnelNomDesactivation').textContent = nomComplet;
    document.getElementById('personnelImDesactivation').textContent = imPer;
    
    // ATTACHER L'ÉVÉNEMENT AU MOMENT DE L'OUVERTURE DU MODAL
    const confirmBtn = document.getElementById('confirmDesactiverPersonnel');
    
    // Supprimer tout événement existant
    const newConfirmBtn = confirmBtn.cloneNode(true);
    confirmBtn.parentNode.replaceChild(newConfirmBtn, confirmBtn);
    
    // Attacher le nouvel événement
    newConfirmBtn.addEventListener('click', () => {
        this.confirmDesactiverPersonnel();
    });
    
    // Réinitialiser le bouton (retirer spinner si présent)
    newConfirmBtn.innerHTML = '<i class="bi bi-x-circle me-2"></i> Confirmer la désactivation';
    newConfirmBtn.disabled = false;
    
    const modal = new bootstrap.Modal(document.getElementById('confirmationDesactivationModal'));
    modal.show();
}

async confirmDesactiverPersonnel() {
    if (!this.currentPersonnelIm) return;

    const modal = bootstrap.Modal.getInstance(document.getElementById('confirmationDesactivationModal'));
    const confirmBtn = document.getElementById('confirmDesactiverPersonnel');
    const originalBtnText = confirmBtn.innerHTML;
    
    try {
        // AJOUT DU SPINNER
        confirmBtn.innerHTML = '<div class="loading-spinner me-2"></div> Désactivation...';
        confirmBtn.disabled = true;

        const response = await fetch(`/admin/personnels/api/${this.currentPersonnelIm}/desactiver`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            }
        });

        const result = await response.json();

        if (result.success) {
            modal.hide();
            this.showSuccess(result.message);
            this.loadPersonnels();
        } else {
            this.showError(result.message);
            // RESTAURATION DU BOUTON EN CAS D'ERREUR
            confirmBtn.innerHTML = originalBtnText;
            confirmBtn.disabled = false;
        }
    } catch (error) {
        console.error('Erreur désactivation:', error);
        this.showError('Erreur lors de la désactivation');
        // RESTAURATION DU BOUTON EN CAS D'ERREUR
        confirmBtn.innerHTML = originalBtnText;
        confirmBtn.disabled = false;
    } finally {
        this.currentPersonnelIm = null;
    }
}

