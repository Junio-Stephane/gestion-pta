        // AJOUT DU SPINNER
        confirmBtn.innerHTML = '<div class="loading-spinner me-2"></div> Activation...';
        confirmBtn.disabled = true;

        const response = await fetch(`/admin/personnels/api/${this.currentPersonnelIm}/activer`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
