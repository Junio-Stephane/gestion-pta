async chargerDirectionsActivesPourSelectChef() {
    try {
        const response = await fetch('/admin/personnels/api/directions-actives');
        const data = await response.json();
        
        if (data.success) {
            const select = $('#nouvelleDirectionChef');
            if (select.length) {
                select.empty();
                select.append('<option value=""></option>');
                
                data.directions.forEach(direction => {
                    const option = new Option(direction.nomDirection, direction.CodeDirection, false, false);
                    select.append(option);
                });
                
                select.trigger('change.select2');
            }
        }
    } catch (error) {
        console.error('Erreur chargement directions actives:', error);
    }
}

configurerEvenementsModalDirectionChef(modalElement, personnel) {
    const btnConfirmer = document.getElementById('btnConfirmerChangementDirectionChef');
    const form = document.getElementById('changerDirectionChefForm');
    const selectDirection = $('#nouvelleDirectionChef');

    if (btnConfirmer) {
        btnConfirmer.onclick = () => {
            this.confirmerChangementDirectionChef(personnel);
