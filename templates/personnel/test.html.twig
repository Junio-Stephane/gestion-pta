                                '${personnel.RolePer}'
                            )`}">
                            <i class="bi bi-pencil"></i>
                            Modifier
                        </button>
                        
                        ${!estDesactive ? 
                            `<button type="button" class="btn btn-danger" 
                                onclick="personnelManager.openConfirmationDesactivationModal(
                                    '${personnel.ImPer}', 
                                    '${this.escapeHtml(personnel.NomPer)} ${this.escapeHtml(personnel.PrenomPer || '')}'
                                )">
                                <i class="bi bi-x-circle"></i>
                                Désactiver
                            </button>` :
                            `<button type="button" class="btn btn-success"
                                onclick="personnelManager.activerPersonnel('${personnel.ImPer}')">
                                <i class="bi bi-check-circle"></i>
                                Activer
                            </button>`
                        }
                    </div>
                </td>
            </tr>
        `;
    }).join('');
}

    renderPagination() {
        const totalPages = Math.ceil(this.totalItems / this.itemsPerPage);
        const paginationElement = document.getElementById('pagination');
        const paginationInfoElement = document.getElementById('paginationInfo');

        const startItem = (this.currentPage - 1) * this.itemsPerPage + 1;
        const endItem = Math.min(this.currentPage * this.itemsPerPage, this.totalItems);
        
        paginationInfoElement.textContent = 
            `Affichage de ${startItem} à ${endItem} sur ${this.totalItems} personnel${this.totalItems !== 1 ? 's' : ''}`;

        let paginationHTML = '';

        paginationHTML += `
            <li class="page-item ${this.currentPage === 1 ? 'disabled' : ''}">
                <a class="page-link" href="#" onclick="personnelManager.changePage(${this.currentPage - 1}); return false;">
                    <i class="bi bi-chevron-left"></i>
                </a>
            </li>
        `;

        const maxVisiblePages = 5;
        let startPage = Math.max(1, this.currentPage - Math.floor(maxVisiblePages / 2));
        let endPage = Math.min(totalPages, startPage + maxVisiblePages - 1);

        if (endPage - startPage + 1 < maxVisiblePages) {
            startPage = Math.max(1, endPage - maxVisiblePages + 1);
        }

        if (startPage > 1) {
            paginationHTML += `
                <li class="page-item">
                    <a class="page-link" href="#" onclick="personnelManager.changePage(1); return false;">1</a>
                </li>
            `;
            if (startPage > 2) {
                paginationHTML += `<li class="page-item disabled"><span class="page-link">...</span></li>`;
            }
        }

        for (let i = startPage; i <= endPage; i++) {
            paginationHTML += `
                <li class="page-item ${i === this.currentPage ? 'active' : ''}">
                    <a class="page-link" href="#" onclick="personnelManager.changePage(${i}); return false;">${i}</a>
                </li>
            `;
        }

        if (endPage < totalPages) {
            if (endPage < totalPages - 1) {
                paginationHTML += `<li class="page-item disabled"><span class="page-link">...</span></li>`;
            }
            paginationHTML += `
                <li class="page-item">
                    <a class="page-link" href="#" onclick="personnelManager.changePage(${totalPages}); return false;">${totalPages}</a>
                </li>
            `;
        }

        paginationHTML += `
            <li class="page-item ${this.currentPage === totalPages ? 'disabled' : ''}">
                <a class="page-link" href="#" onclick="personnelManager.changePage(${this.currentPage + 1}); return false;">
                    <i class="bi bi-chevron-right"></i>
                </a>
            </li>
        `;

        paginationElement.innerHTML = paginationHTML;
    }

    changePage(page) {
        if (page < 1 || page > Math.ceil(this.totalItems / this.itemsPerPage)) {
            return;
        }
        this.currentPage = page;
        this.renderPersonnels();
        this.renderPagination();
        
        document.querySelector('.table-responsive').scrollIntoView({ 
            behavior: 'smooth', 
            block: 'start' 
        });
    }

    openModifierPersonnelModal(imPer, nomPer, prenomPer, emailPer, telPer, fonctionPer, serviceCode, directionNom, rolePer) {
        this.currentPersonnelIm = imPer;
        
        document.getElementById('modifierPersonnelIm').value = imPer;
        document.getElementById('modifierImPer').value = imPer;
        document.getElementById('modifierNomPer').value = nomPer;
        document.getElementById('modifierPrenomPer').value = prenomPer;
        document.getElementById('modifierEmailPer').value = emailPer;
        document.getElementById('modifierTelPer').value = telPer || '';
        document.getElementById('modifierFonctionPer').value = this.formatFonction(fonctionPer);
        document.getElementById('modifierDirection').value = directionNom || '';
        document.getElementById('modifierRolePer').value = rolePer;

        // Vider et recharger le select2 du service
        const serviceSelect = this.selects.modifierService;
        serviceSelect.empty();
        serviceSelect.append('<option value="">Aucun service</option>');
        
        this.chargerServicesActifsPourModal().then(() => {
            if (serviceCode) {
                const service = this.allServices.find(s => s.CodeService === serviceCode);
                if (service) {
                    serviceSelect.val(serviceCode).trigger('change.select2');
                    this.updateDirectionFromService(serviceCode);
                }
            }
        });

        this.adjustInterfaceForFonction(fonctionPer, serviceCode);
        this.adjustInfoForFonction(fonctionPer, serviceCode);

        const modal = new bootstrap.Modal(document.getElementById('modifierPersonnelModal'));
        modal.show();
    }

    async chargerServicesActifsPourModal() {
        try {
            const response = await fetch('/admin/personnels/api/services-actifs');
            const data = await response.json();
            
            const serviceSelect = this.selects.modifierService;
            
            if (data.success && serviceSelect) {
                serviceSelect.empty();
                serviceSelect.append('<option value="">Aucun service</option>');
                
                data.services.forEach(service => {
                    const code = service.CodeService || service.codeService;
                    const nom = service.nomService;
                    const displayText = `${code} - ${nom}`;
                    const option = new Option(displayText, code, false, false);
                    serviceSelect.append(option);
                });
                
                serviceSelect.trigger('change.select2');
            }
        } catch (error) {
            console.error('Erreur chargement services actifs pour modal:', error);
        }
    }

    adjustInterfaceForFonction(fonctionPer, serviceCode) {
        const serviceSelect = this.selects.modifierService;
        const serviceHelpText = document.getElementById('serviceHelpText');
        
        if (fonctionPer === 'Directeur') {
            serviceSelect.prop('disabled', true);
            serviceHelpText.innerHTML = '<i class="bi bi-info-circle text-warning"></i> Les directeurs n\'ont pas de service fixe';
        } else if (fonctionPer === 'Chef_service') {
            serviceSelect.prop('disabled', true);
            serviceHelpText.innerHTML = '<i class="bi bi-info-circle text-warning"></i> Le service d\'un chef de service se modifie dans la gestion des services';
        } else {
            serviceSelect.prop('disabled', false);
            serviceHelpText.innerHTML = 'La direction sera automatiquement déterminée depuis le service';
        }
        
        serviceSelect.trigger('change.select2');
    }

    adjustInfoForFonction(fonctionPer, serviceCode) {
        const serviceInfoText = document.getElementById('serviceInfoText');
        
        if (fonctionPer === 'Chef_service') {
            serviceInfoText.innerHTML = '<li><strong>Service pour chef de service :</strong> Non modifiable ici (géré dans la gestion des services)</li>';
        } else if (fonctionPer === 'Directeur') {
            serviceInfoText.innerHTML = '<li><strong>Direction pour directeur :</strong> Non modifiable ici (géré dans la gestion des directions)</li>';
        } else {
            serviceInfoText.innerHTML = '<li><strong>Service pour agent :</strong> modifiable ici (vous pouvez sélectionner le service de l\'agent)</li>';
        }
    }

    setupEventListeners() {
        document.getElementById('modifierPersonnelForm').addEventListener('submit', (e) => {
            e.preventDefault();
            this.modifierPersonnel();
        });

        // Écouteurs pour les filtres classiques
        document.getElementById('statutFilter').addEventListener('change', (e) => {
            this.currentFilters.statut = e.target.value;
            this.applyFilters();
        });

        document.getElementById('fonctionFilter').addEventListener('change', (e) => {
            this.currentFilters.fonction = e.target.value;
            this.applyFilters();
        });

        document.getElementById('roleFilter').addEventListener('change', (e) => {
            this.currentFilters.role = e.target.value;
            this.applyFilters();
        });

        // Écouteurs pour les filtres Select2
        this.selects.directionFilter.on('change', (e) => {
            this.currentFilters.direction = e.target.value;
            this.applyFilters();
        });

        this.selects.serviceFilter.on('change', (e) => {
            this.currentFilters.service = e.target.value;
            this.applyFilters();
        });

        // Écouteur pour le service dans le modal
        this.selects.modifierService.on('change', (e) => {
            this.updateDirectionFromService(e.target.value);
        });

        document.getElementById('searchInput').addEventListener('input', (e) => {
            this.currentFilters.search = e.target.value;
            clearTimeout(this.searchTimeout);
            this.searchTimeout = setTimeout(() => {
                this.applyFilters();
            }, 300);
        });

        document.getElementById('resetFilters').addEventListener('click', () => {
            this.resetFilters();
        });

        document.getElementById('confirmDesactiverPersonnel').addEventListener('click', () => {
            this.confirmDesactiverPersonnel();
        });

        document.getElementById('confirmActiverPersonnel').addEventListener('click', () => {
            this.confirmActiverPersonnel();
        });

        document.getElementById('confirmActiverDirecteurChef').addEventListener('click', () => {
            this.confirmActiverDirecteurChef();
        });

        document.getElementById('modifierNomPer')?.addEventListener('input', () => {
            this.clearFieldError('modifierNomPer');
        });
        
        document.getElementById('modifierEmailPer')?.addEventListener('input', () => {
            this.clearFieldError('modifierEmailPer');
        });

        document.getElementById('modifierRolePer')?.addEventListener('change', () => {
            this.clearFieldError('modifierRolePer');
        });

        // Reset des modaux
        $('#modifierPersonnelModal').on('hidden.bs.modal', () => {
            document.getElementById('modifierPersonnelForm').reset();
            this.clearModalErrors();
            this.selects.modifierService.val('').trigger('change.select2');
            this.selects.modifierService.prop('disabled', false);
        });
