        const response = await fetch(`/admin/personnels/api/${personnelIm}/activer`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify(data)
        });

        const result = await response.json();

        if (result.success) {
            this.showSuccess('Personnel activé avec succès avec nouveau service');
            
            const modalElement = document.getElementById('serviceInactiveModal');
            if (modalElement) {
                bootstrap.Modal.getInstance(modalElement).hide();
            }
            
            this.loadPersonnels();
            
        } else {
            this.showError(result.message || 'Erreur lors de l\'activation du personnel');
            
            // RESTAURATION DU BOUTON EN CAS D'ERREUR
            btnConfirmer.innerHTML = originalText;
            btnConfirmer.disabled = false;
        }
    } catch (error) {
        console.error('Erreur activation personnel:', error);
        this.showError('Erreur lors de l\'activation du personnel');
        
        const btnConfirmer = document.getElementById('btnConfirmerChangementService');
        if (btnConfirmer) {
            // RESTAURATION DU BOUTON EN CAS D'ERREUR
            btnConfirmer.innerHTML = '<i class="bi bi-check-circle me-2"></i> Activer le personnel';
            btnConfirmer.disabled = false;
        }
    }
}

    // MÉTHODES UTILITAIRES
    showMultipleErrors(errors) {
        Object.keys(errors).forEach(fieldKey => {
            const errorMessage = errors[fieldKey];
            const fieldMapping = {
                'NomPer': 'modifierNomPer',
                'EmailPer': 'modifierEmailPer',
                'service': 'modifierService',
                'RolePer': 'modifierRolePer'
            };
            
            if (fieldMapping[fieldKey]) {
                this.showFieldError(fieldMapping[fieldKey], errorMessage);
            }
        });
    }

    showFieldError(fieldId, errorMessage) {
        const field = document.getElementById(fieldId);
        const errorElement = document.getElementById(fieldId + 'Error');
        
        if (field && errorElement) {
            field.classList.add('is-invalid');
            errorElement.textContent = errorMessage;
        }
    }

    clearFieldError(fieldId) {
        const field = document.getElementById(fieldId);
        const errorElement = document.getElementById(fieldId + 'Error');
        
        if (field) {
            field.classList.remove('is-invalid');
        }
        if (errorElement) {
            errorElement.textContent = '';
        }
    }

    clearModalErrors() {
        this.clearFieldError('modifierNomPer');
        this.clearFieldError('modifierEmailPer');
        this.clearFieldError('modifierService');
        this.clearFieldError('modifierRolePer');
    }

    formatRole(role) {
        const roles = {
            'ROLE_ADMIN': 'Administrateur',
            'ROLE_UTILISATEUR': 'Utilisateur',
            'ROLE_CREATEUR_DE_PROJET': 'Créateur de projet'
        };
        return roles[role] || role;
    }

    formatFonction(fonction) {
        const fonctions = {
            'Directeur': 'Directeur',
            'Chef_service': 'Chef de service',
            'Agent': 'Agent'
        };
        return fonctions[fonction] || fonction;
    }

    escapeHtml(unsafe) {
        if (!unsafe) return '';
        return unsafe
            .replace(/&/g, "&amp;")
            .replace(/</g, "&lt;")
            .replace(/>/g, "&gt;")
            .replace(/"/g, "&quot;")
            .replace(/'/g, "&#039;");
    }

    showSuccess(message) {
    const alertContainer = document.getElementById('fixedAlertContainer');
    const alert = document.createElement('div');
    alert.className = 'alert-success-fixed mb-3';
    alert.innerHTML = `
        <i class="bi bi-check-circle-fill"></i>
        <span>${message}</span>
        <button type="button" class="alert-close-btn" onclick="this.parentElement.remove()">
            <i class="bi bi-x"></i>
        </button>
    `;
    
    // Supprimer les anciennes alertes
    while (alertContainer.firstChild) {
        alertContainer.removeChild(alertContainer.firstChild);
    }
    
    // Ajouter la nouvelle alerte
    alertContainer.appendChild(alert);
    
    // Auto-suppression après 5 secondes
    setTimeout(() => {
        if (alert.parentElement) {
            alert.style.animation = 'fadeOut 0.3s ease-out';
            setTimeout(() => {
                if (alert.parentElement) {
                    alert.remove();
                }
            }, 300);
        }
    }, 5000);
}

showError(message) {
    const alertContainer = document.getElementById('fixedAlertContainer');
    const alert = document.createElement('div');
    alert.className = 'alert-danger-fixed mb-3';
    alert.innerHTML = `
        <i class="bi bi-exclamation-triangle-fill"></i>
        <span>${message}</span>
        <button type="button" class="alert-close-btn" onclick="this.parentElement.remove()">
            <i class="bi bi-x"></i>
        </button>
    `;
    
    // Supprimer les anciennes alertes
    while (alertContainer.firstChild) {
        alertContainer.removeChild(alertContainer.firstChild);
    }
    
    // Ajouter la nouvelle alerte
    alertContainer.appendChild(alert);
    
    // Auto-suppression après 5 secondes
    setTimeout(() => {
        if (alert.parentElement) {
            alert.style.animation = 'fadeOut 0.3s ease-out';
            setTimeout(() => {
                if (alert.parentElement) {
                    alert.remove();
                }
            }, 300);
        }
    }, 5000);
}
}

