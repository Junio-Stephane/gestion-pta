                <button type="button" class="btnG btn-danger" id="confirmDeleteBtn">
                    <i class="bi bi-trash"></i>
                    Supprimer définitivement
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Modal de Confirmation pour Terminer une Tâche -->
<div class="modal fade" id="terminerTacheModal" tabindex="-1" aria-labelledby="terminerTacheModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-check-circle me-2"></i>
                    Terminer la Tâche
                </h5>
                <button type="button" class="btn-close-custom" data-bs-dismiss="modal" aria-label="Close">
                    <i class="bi bi-x"></i>
                </button>
            </div>
            <div class="modal-body">
                <div class="consigneD consigne-success">
                    <div class="d-flex">
                        <div class="flex-grow-1 ms-3">
                            <h5><i class="bi bi-check-circle"></i> Finalisation de la tâche</h5>
                            <p class="mb-0">Cette action marquera la tâche comme terminée à 100%. Voulez-vous continuer ?</p>
