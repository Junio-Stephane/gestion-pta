        .projet-details-row {
            grid-template-columns: 1fr; /* 1 colonne sur mobiles */
        }
        
        .detail-card {
            min-height: auto; /* Supprime la hauteur fixe sur mobile */
        }

        .projet-summary-grid {
            grid-template-columns: 1fr;
        }
        
        .summary-card {
            padding: 0.75rem;
        }
        
        .projet-header-container {
            flex-direction: column;
            align-items: flex-start;
            gap: 1rem;
        }
        
        .projet-header-statut {
            align-self: flex-end;
        }
        
        .projet-title-line,
        .projet-service-line {
            flex-direction: column;
            align-items: flex-start;
            gap: 0.25rem;
        }
        
        .projet-main-title {
            font-size: 1.5rem;
        }
        
        .projet-service-info {
            font-size: 1rem;
        }

        .filters-container {
            padding: 1rem;
        }
        
        .filters-row {
            gap: 0.75rem;
        }
        
        .filter-group-compact,
        .filter-group-dates,
