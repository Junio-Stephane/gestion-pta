        `;
    }).join('');

    const tooltipTriggerList = [].slice.call(tbody.querySelectorAll('[data-bs-toggle="tooltip"]'));
    tooltipTriggerList.map(function (tooltipTriggerEl) {
        return new bootstrap.Tooltip(tooltipTriggerEl);
    });
}

getCurrentUserRole() {
    const userRoleElement = document.querySelector('.user-role');
    
    if (userRoleElement) {
        const roleText = userRoleElement.textContent.toLowerCase().trim();
        
        if (roleText.includes('administrateur') || roleText.includes('admin')) {
            return 'ROLE_ADMIN';
        } else if (roleText.includes('createur') || roleText.includes('créateur')) {
            return 'ROLE_CREATEUR_DE_PROJET';
        } else if (roleText.includes('utilisateur')) {
            return 'ROLE_UTILISATEUR';
        }
    }
    return 'ROLE_UTILISATEUR'; // Par défaut
}

getCurrentUserId() {
    const userAvatar = document.querySelector('.user-avatar');
    if (userAvatar) {
        return userAvatar.getAttribute('data-user-id') || 
               userAvatar.getAttribute('data-user-im') || 
               userAvatar.getAttribute('data-im-per');
    }
    return null;
}

getNoPermissionText() {
    const role = this.currentUserRole;
    
    if (role === 'ROLE_CREATEUR_DE_PROJET') {
        return 'Nouvelle tache';
    } else if (role === 'ROLE_UTILISATEUR') {
        return 'Nouvelle tache';
    } else {
        return 'Accès non autorisé';
    }
}

getTooltipText(estProjetTermine, estSuspendu, noPermissionText) {
    if (estProjetTermine) {
        return 'Projet terminé à 100%';
    } else if (estSuspendu) {
        return 'Tâche suspendue';
    } else {
        return noPermissionText;
    }
}

async showTerminerConfirmation(numTache) {
    try {
        console.log('Début showTerminerConfirmation pour tâche:', numTache);
        
        const response = await fetch(`/admin/taches/api/${numTache}`);
        const data = await response.json();
        
        console.log('Données tâche chargées:', data);
        
        if (data.success) {
            this.currentActionTache = data.tache;
            
            // IMPORTANT: Vérifier si c'est la dernière tâche AVANT d'afficher le modal
            console.log('Vérification clôture pour tâche:', numTache);
            const vaCloturerProjet = await this.verifierClotureProjet(numTache);
            console.log('Résultat vérification clôture:', vaCloturerProjet);
            
            // Stocker le résultat dans l'objet tâche
            data.tache.vaCloturerProjet = vaCloturerProjet;
            
            if (vaCloturerProjet) {
                // CAS 2 : Terminer LA DERNIÈRE tâche
                console.log('Afficher modal clôture (dernière tâche)');
                this.prepareClotureModal(data.tache, 'terminer');
            } else {
                // CAS 1 : Terminer UNE tâche normale
                console.log('Afficher modal terminaison normal');
                this.prepareTerminerModal(data.tache);
                const modal = new bootstrap.Modal(document.getElementById('terminerTacheModal'));
                modal.show();
            }
        } else {
            this.showError('Impossible de charger les informations de la tâche');
        }
    } catch (error) {
        console.error('Erreur chargement tâche:', error);
        this.showError('Erreur lors du chargement de la tâche');
    }
}

// Nouvelle méthode pour vérifier si l'action va clôturer le projet
async verifierClotureProjet(numTache) {
    try {
        const response = await fetch(`/admin/taches/api/${numTache}/verifier-cloture`);
        const data = await response.json();
        
        console.log('Vérification clôture:', data);
        
        if (data.success) {
            return data.vaCloturer;
        }
        return false;
    } catch (error) {
        console.error('Erreur vérification clôture:', error);
        return false;
    }
}

// Nouvelle méthode pour préparer le modal de clôture
// NOUVELLE MÉTHODE POUR PRÉPARER LE MODAL DE CLÔTURE (VERSION SIMPLIFIÉE)
prepareClotureModal(tache, actionType) {
    // Remplir les informations
    document.getElementById('clotureTacheNumero').textContent = tache.numTache;
    document.getElementById('clotureTacheTitre').textContent = tache.titreTache;
    
    // Définir le message et l'action en fonction du type
    if (actionType === 'terminer') {
        document.getElementById('clotureMessage').textContent = 
            'En terminant cette dernière tâche, le projet sera automatiquement clôturé à 100%.';
        document.getElementById('clotureAction').textContent = 'Terminer et clôturer le projet';
        document.getElementById('confirmClotureBtn').innerHTML = 
            '<i class="bi bi-check-circle me-2"></i> Terminer et clôturer le projet';
        
        // Stocker l'action type dans le bouton
        document.getElementById('confirmClotureBtn').dataset.actionType = 'terminer';
    } else {
        document.getElementById('clotureMessage').textContent = 
            'En mettant cette dernière tâche à 100%, le projet sera automatiquement clôturé à 100%.';
        document.getElementById('clotureAction').textContent = 'Mettre à 100% et clôturer';
        document.getElementById('confirmClotureBtn').innerHTML = 
            '<i class="bi bi-check-circle me-2"></i> Mettre à 100% et clôturer';
        
        // Stocker l'action type dans le bouton
        document.getElementById('confirmClotureBtn').dataset.actionType = 'modifier';
    }
    
    // Afficher le modal
    const modal = new bootstrap.Modal(document.getElementById('clotureProjetModal'));
    modal.show();
}



