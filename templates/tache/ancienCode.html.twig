    /* Position fixe pour les alertes - AJOUTEZ CETTE SECTION DANS VOTRE STYLESHEETS */
.fixed-alert-container {
    position: fixed;
    top: 100px;
    right: 20px;
    z-index: 9999;
    max-width: 400px;
    animation: slideInRight 0.3s ease-out;
}

@keyframes slideInRight {
    from {
        transform: translateX(100%);
        opacity: 0;
    }
    to {
        transform: translateX(0);
        opacity: 1;
    }
}

.alert-success-fixed {
    background: linear-gradient(135deg, #10b981 0%, #059669 100%);
    color: white;
    border: none;
    border-radius: 10px;
    padding: 1rem 1.25rem;
    box-shadow: 0 8px 25px rgba(16, 185, 129, 0.3);
    border-left: 4px solid #047857;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    animation: fadeIn 0.3s ease-out;
}

.alert-danger-fixed {
    background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
    color: white;
    border: none;
    border-radius: 10px;
    padding: 1rem 1.25rem;
    box-shadow: 0 8px 25px rgba(239, 68, 68, 0.3);
    border-left: 4px solid #b91c1c;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    animation: fadeIn 0.3s ease-out;
}

.alert-success-fixed i,
.alert-danger-fixed i {
    font-size: 1.2rem;
}

.alert-close-btn {
    background: none;
    border: none;
    color: white;
    opacity: 0.8;
    padding: 0.25rem;
    margin-left: auto;
    cursor: pointer;
    transition: opacity 0.2s ease;
}

.alert-close-btn:hover {
    opacity: 1;
}

@keyframes fadeIn {
    from {
        opacity: 0;
        transform: translateY(-10px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

@keyframes fadeOut {
    from {
        opacity: 1;
        transform: translateX(0);
    }
    to {
        opacity: 0;
        transform: translateX(100%);
    }
}

/* Responsive adjustments pour les alertes */
@media (max-width: 768px) {
    .fixed-alert-container {
        top: 80px;
        right: 10px;
        left: 10px;
        max-width: none;
    }
    
    .alert-success-fixed,
    .alert-danger-fixed {
        padding: 0.75rem 1rem;
        font-size: 0.9rem;
    }
}

@media (max-width: 576px) {
    .fixed-alert-container {
        top: 70px;
    }
    
    .alert-success-fixed,
    .alert-danger-fixed {
        padding: 0.5rem 0.75rem;
    }
    
    .alert-success-fixed i,
    .alert-danger-fixed i {
        font-size: 1rem;
    }
}
</style>
{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    
    <div id="fixedAlertContainer" class="fixed-alert-container"></div>
    <div class="breadcrumb-container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item">
                    <a href="{{ path('app_dashboard_par_role') }}">
                        <i class="bi bi-speedometer2"></i>
                        Tableau de bord
                    </a>
                    <span class="breadcrumb-separator"></span>
                </li>
                <li class="breadcrumb-item">
                    <a href="{{ path('app_projet_index') }}" id="projetBreadcrumbLink">
                        <i class="bi bi-folder"></i>
                        Projets
                    </a>
                    <span class="breadcrumb-separator"></span>
                </li>
                <li class="breadcrumb-item active">
                    <i class="bi bi-list-task"></i>
                    Tâches du projet {{ numProjet }}
                </li>
            </ol>
        </nav>
    </div>

    <div class="taches-container">
        <!-- Bouton retour -->
        <div style="display: flex; gap: 1rem; align-items: center; margin-bottom: 1.5rem;">
            <button class="back-button" onclick="window.history.back()">
                <i class="bi bi-arrow-left me-2"></i>
                Retour aux projets
            </button>
        </div>

        <!-- En-tête -->
        <div class="section-header">
            <div>
                <h1 class="section-title">
                    <i class="bi bi-list-task"></i>
                    Gestion des Tâches
                </h1>
                <p class="text-muted mb-0">Gérez les tâches du projet</p>
            </div>
            
            <button class="btnG btn-primary btn-lg" data-bs-toggle="modal" data-bs-target="#addTacheModal">
                <i class="bi bi-plus-circle me-2"></i>
                Ajouter une tâche
            </button>
        </div>

        <!-- Résumé du projet -->
        <div class="projet-summary" id="projetSummary">
            <div class="loading-spinner"></div> Chargement du projet...
        </div>

        <!-- FILTRES POUR LES TÂCHES -->
        <div class="filters-container">
            <div class="filter-section-title">
                <i class="bi bi-funnel"></i>
                Filtres de recherche
            </div>
            
            <div class="filters-grid">
                <!-- Première ligne : Filtres principaux -->
                <div class="filters-row filters-row-top">
                    <!-- Filtre par statut -->
                    <div class="filter-group filter-group-compact">
                        <label for="statutFilter">Statut</label>
                        <select class="form-select" id="statutFilter">
                            <option value="">Tous les statuts</option>
                            <option value="Débuté">Débuté</option>
                            <option value="En cours">En cours</option>
                            <option value="Terminé">Terminé</option>
                            <option value="Suspendu">Suspendu</option>
                        </select>
                    </div>
                    
                    <!-- Filtre par avancement -->
                    <div class="filter-group filter-group-compact">
                        <label for="avancementFilter">Avancement</label>
                        <select class="form-select" id="avancementFilter">
                            <option value="">Tous les avancements</option>
                            <option value="0-25">0-25%</option>
                            <option value="25-50">25-50%</option>
                            <option value="50-75">50-75%</option>
                            <option value="75-100">75-100%</option>
                            <option value="100">100% (Terminé)</option>
                        </select>
                    </div>
                </div>

                <!-- Deuxième ligne : Filtres de date et recherche -->
                <div class="filters-row filters-row-bottom">
                    <!-- Filtres par période -->
                    <div class="filter-date-range">
                        <div class="filter-group filter-group-dates">
                            <label for="dateDebutFilter">Date début</label>
                            <input type="text" class="form-control flatpickr filter-date" id="dateDebutFilter" 
                                   placeholder="jj/mm/aaaa">
                        </div>
                        
                        <div class="date-range-separator">
                            <i class="bi bi-arrow-right"></i>
                        </div>
                        
                        <div class="filter-group filter-group-dates">
                            <label for="dateFinFilter">Date fin</label>
                            <input type="text" class="form-control flatpickr filter-date" id="dateFinFilter" 
                                   placeholder="jj/mm/aaaa">
                        </div>
                    </div>
                    
                    <!-- Recherche -->
                    <div class="search-group">
                        <label for="searchInput">Recherche</label>
                        <input type="text" class="form-control" id="searchInput" 
                               placeholder="Rechercher par titre, numéro, description...">
                    </div>
                    
                    <!-- Actions des filtres -->
                    <div class="filter-actions">
                        <button type="button" class="btnG btn-secondary" id="resetFilters">
                            <i class="bi bi-arrow-clockwise me-2"></i>
                            Réinitialiser
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Liste des tâches -->
        <div class="table-responsive">
            <table class="table-taches">
                <thead>
                    <tr>
                        <th>NUMÉRO</th>
                        <th>TITRE</th>
                        <th>DESCRIPTION</th>
                        <th>COMMENTAIRE</th>
                        <th>PÉRIODE</th>
                        <th>AVANCEMENT</th>
                        <th>STATUT</th>
                        <th>ACTIONS</th>
                    </tr>
                </thead>
                <tbody id="tachesTableBody">
                    <tr>
                        <td colspan="8" class="text-center py-4">
                            <div class="loading-spinner me-2"></div>
                            Chargement des tâches...
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>

        <!-- PAGINATION -->
        <div class="pagination-container">
            <div class="pagination-info" id="paginationInfo">
                Affichage de 0 à 0 sur 0 tâches
            </div>
            <nav>
                <ul class="pagination" id="pagination">
                    <!-- La pagination sera générée via JavaScript -->
                </ul>
            </nav>
        </div>
    </div>
</div>

<!-- Modal Ajouter Tâche -->
<div class="modal fade" id="addTacheModal" tabindex="-1" aria-labelledby="addTacheModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-plus-circle"></i>
                    Nouvelle Tâche
                </h5>
                <button type="button" class="btn-close-custom" data-bs-dismiss="modal" aria-label="Close">
                    <i class="bi bi-x"></i>
                </button>
            </div>
            <div class="modal-body">
                <form id="addTacheForm">
                    <input type="hidden" id="numProjet" name="numProjet" value="{{ numProjet }}">
                    
                    <div class="row">
                        <div class="col-md-12">
                            <div class="form-group">
                                <label for="titreTache" class="form-label">Titre de la tâche *</label>
                                <input type="text" class="form-control" id="titreTache" name="titreTache" required>
                                <div class="invalid-feedback" id="titreTacheError"></div>
                            </div>
                        </div>
                    </div>

                    <div class="date-range-consigne">
                        <div class="consigne-content" id="addDateConsigne">
                            Veuillez sélectionner les dates entre <span id="projetDateDebut">...</span> et <span id="projetDateFin">...</span>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="dateDebutTache" class="form-label">Date de début *</label>
                                    <input type="text" class="form-control flatpickr" id="dateDebutTache" name="dateDebutTache" placeholder="jj/mm/aaaa" required>
                                    <div class="invalid-feedback" id="dateDebutTacheError"></div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="dateFinTache" class="form-label">Date de fin</label>
                                    <input type="text" class="form-control flatpickr" id="dateFinTache" name="dateFinTache" placeholder="jj/mm/aaaa">
                                    <div class="invalid-feedback" id="dateFinTacheError"></div>
                                </div>
                            </div>
                        </div>
                    </div>

                    
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="descriptionTache" class="form-label">Description</label>
                                <textarea class="form-control" id="descriptionTache" name="descriptionTache" rows="3" placeholder="Description détaillée de la tâche..."></textarea>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="commentaireTache" class="form-label">Commentaire</label>
                                <textarea class="form-control" id="commentaireTache" name="commentaireTache" rows="3" placeholder="Commentaires additionnels..."></textarea>
                            </div>
                        </div>
                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btnG btn-secondary" data-bs-dismiss="modal">Annuler</button>
                        <button type="submit" class="btnG btn-primary" id="submitAddTache">
                            <i class="bi bi-check-circle me-2"></i>
                            Créer la tâche
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Modal Modifier Tâche -->
<div class="modal fade" id="editTacheModal" tabindex="-1" aria-labelledby="editTacheModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-pencil-square"></i>
                    Modifier la Tâche
                </h5>
                <button type="button" class="btn-close-custom" data-bs-dismiss="modal" aria-label="Close">
                    <i class="bi bi-x"></i>
                </button>
            </div>
            <div class="modal-body">
                <form id="editTacheForm">
                    <input type="hidden" id="edit_numTache" name="numTache">
                    
                    <div class="row">
                        <div class="col-md-6">
