<script>
class MadagascarHolidays {
    constructor() {
        this.holidays = [];
    }

    // Récupérer les jours fériés pour une année donnée
    getHolidays(year) {
        const holidays = [];
        
        // Jours fériés fixes
        holidays.push(`${year}-01-01`); // Nouvel An
        holidays.push(`${year}-03-08`);
        holidays.push(`${year}-03-29`); // Commémoration du 29 mars 1947
        holidays.push(`${year}-05-01`); // Fête du Travail
        holidays.push(`${year}-06-26`); // Fête Nationale
        holidays.push(`${year}-08-15`); // Assomption
        holidays.push(`${year}-11-01`); // Toussaint
        holidays.push(`${year}-12-25`); // Noël
        
        // Lundi de Pâques (variable - 1er dimanche après pleine lune de printemps)
        const easterMonday = this.calculateEasterMonday(year);
        holidays.push(easterMonday);
        
        // Lundi de Pentecôte (variable - 50 jours après Pâques)
        const pentecostMonday = this.calculatePentecostMonday(year);
        holidays.push(pentecostMonday);
        
        // Fête de l'Indépendance (26 juin)
        // Si le 26 juin est un samedi ou dimanche, le lendemain est férié
        const independenceDay = new Date(year, 5, 26); // 26 juin
        if (independenceDay.getDay() === 0) { // Dimanche
            holidays.push(`${year}-06-27`);
        } else if (independenceDay.getDay() === 6) { // Samedi
            holidays.push(`${year}-06-28`);
        }
        
        return holidays;
    }

    // Calculer le lundi de Pâques
    calculateEasterMonday(year) {
        // Algorithme de calcul de Pâques
        const a = year % 19;
        const b = Math.floor(year / 100);
        const c = year % 100;
        const d = Math.floor(b / 4);
        const e = b % 4;
        const f = Math.floor((b + 8) / 25);
        const g = Math.floor((b - f + 1) / 3);
        const h = (19 * a + b - d - g + 15) % 30;
        const i = Math.floor(c / 4);
        const k = c % 4;
        const l = (32 + 2 * e + 2 * i - h - k) % 7;
        const m = Math.floor((a + 11 * h + 22 * l) / 451);
        const month = Math.floor((h + l - 7 * m + 114) / 31);
        const day = ((h + l - 7 * m + 114) % 31) + 1;
        
        const easter = new Date(year, month - 1, day);
        const easterMonday = new Date(easter);
        easterMonday.setDate(easterMonday.getDate() + 1);
        
        return easterMonday.toISOString().split('T')[0];
    }

    // Calculer le lundi de Pentecôte
    calculatePentecostMonday(year) {
        const easterMonday = this.calculateEasterMonday(year);
        const easterDate = new Date(easterMonday);
        const pentecostMonday = new Date(easterDate);
        pentecostMonday.setDate(pentecostMonday.getDate() + 49); // 50 jours après Pâques (lundi de Pentecôte)
        
        return pentecostMonday.toISOString().split('T')[0];
    }

    // Vérifier si une date est un jour férié
    isHoliday(date) {
        const dateStr = date.toISOString().split('T')[0];
        const year = date.getFullYear();
        
        // Charger les jours fériés pour l'année si pas encore fait
        if (this.holidays.length === 0 || !this.holidays.some(h => h.startsWith(year))) {
            this.holidays = this.getHolidays(year);
        }
        
        return this.holidays.includes(dateStr);
    }

    // Vérifier si une date est un week-end
    isWeekend(date) {
        const day = date.getDay();
        return day === 0 || day === 6; // 0 = dimanche, 6 = samedi
    }

    // Vérifier si une date est un jour ouvrable (ni week-end, ni férié)
    isBusinessDay(date) {
        return !this.isWeekend(date) && !this.isHoliday(date);
    }

    getBusinessDaysCount(startDate, endDate) {
        let count = 0;
        let current = new Date(startDate);
        const end = new Date(endDate);
        
        // Si la date de début est après la date de fin, on inverse le calcul
        if (current > end) {
            // Pour les retards, on compte depuis la date de fin jusqu'à aujourd'hui
            const temp = current;
            current = new Date(endDate);
            current.setDate(current.getDate() + 1); // Commencer le lendemain de la date de fin
            end = temp;
            
            // On compte les jours ouvrables de la date de fin à aujourd'hui
            while (current <= end) {
                if (this.isBusinessDay(current)) {
                    count++;
                }
                current.setDate(current.getDate() + 1);
            }
            
            // Pour les retards, on retourne un nombre négatif
            return -count;
        }
        
        // Cas normal (date de début avant date de fin)
        // Commencer le lendemain pour le calcul des jours restants
        current.setDate(current.getDate() + 1);
        while (current <= end) {
            if (this.isBusinessDay(current)) {
                count++;
            }
            current.setDate(current.getDate() + 1);
        }
        
        return count;
    }

    // Ajouter des jours ouvrables à une date
    addBusinessDays(startDate, businessDays) {
        let count = 0;
        const current = new Date(startDate);
        
        while (count < businessDays) {
            current.setDate(current.getDate() + 1);
            if (this.isBusinessDay(current)) {
                count++;
            }
        }
        
        return new Date(current);
    }

    // Calculer la date de fin en fonction de la durée estimée (en jours ouvrables)
    calculateEndDate(startDate, durationDays, unit = 'jours') {
        let businessDaysToAdd = durationDays;
        
        // Convertir en jours ouvrables si l'unité n'est pas "jours"
        if (unit === 'semaines') {
            businessDaysToAdd = durationDays * 5; // 5 jours ouvrables par semaine
        } else if (unit === 'mois') {
            businessDaysToAdd = durationDays * 22; // Environ 22 jours ouvrables par mois
        }
        
        return this.addBusinessDays(startDate, businessDaysToAdd);
    }
}

class TacheManager {
    constructor(numProjet) {
        this.numProjet = numProjet;
        this.currentEditingTache = null;
        this.currentActionTache = null; // Pour stocker la tâche en cours d'action
        this.datePickers = {};
        this.editDatePickers = {};
        this.projetSuspendu = false;
        this.projetTermine = false;
        this.currentUserRole = this.getCurrentUserRole();
        this.currentUserId = this.getCurrentUserId();
        this.currentProjet = null;
        
        this.holidaysManager = new MadagascarHolidays();
        
        this.currentFilters = {
            statut: '',
            avancement: '',
            search: '',
            dateDebut: '',
            dateFin: ''
        };
        this.allTaches = [];
        this.filteredTaches = [];
        
        this.currentPage = 1;
        this.itemsPerPage = 10;
        this.totalItems = 0;
        
