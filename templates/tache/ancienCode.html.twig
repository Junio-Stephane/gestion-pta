/* STYLES POUR LES PROJETS TERMINÉS */
.projet-termine {
    background-color: #f8f9fa !important;
    opacity: 0.85;
    position: relative;
}

.projet-termine:hover {
    background-color: #e9ecef !important;
}

.projet-termine::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(45deg, transparent 95%, #28a745 5%);
    pointer-events: none;
}

/* Griser toutes les cellules SAUF la cellule des actions */
.projet-termine td:not(:last-child) {
    opacity: 0.6;
    color: #6b7280 !important;
}

/* La cellule des actions reste normale mais avec boutons désactivés */
.projet-termine td:last-child {
    opacity: 1 !important;
    background-color: transparent !important;
}

/* Styles spécifiques pour le contenu grisé */
.projet-termine .text-preview {
    background: #f3f4f6 !important;
    color: #6b7280 !important;
}

.progress-circular.termine {
    --progress-color: #28a745;
    --progress-text-color: #28a745;
    opacity: 0.8;
}

/* Tous les boutons désactivés dans un projet terminé */
.projet-termine .actions-container .btn {
    opacity: 0.5 !important;
    cursor: not-allowed;
    pointer-events: none;
}



/* STYLES POUR LES TÂCHES DANS UN PROJET TERMINÉ */
.tache-termine td:not(:last-child) {
    opacity: 0.6;
    color: #6b7280 !important;
}

.tache-termine .text-preview {
    background: #f3f4f6 !important;
    color: #6b7280 !important;
}

/* Boutons désactivés pour les tâches dans un projet terminé */
.tache-termine .btn {
    opacity: 0.5 !important;
    cursor: not-allowed !important;
    pointer-events: none !important;
}

/* STYLES POUR LE BOUTON D'AJOUT DE TÂCHE DÉSACTIVÉ */
.btn-primary:disabled.projet-termine-btn,
.btn-primary.btn-disabled.projet-termine-btn {
    background: linear-gradient(135deg, #82a7e5ff 0%, #6793e9ff 100%) !important;
        color: #e8ebeeff !important;
        border-color: #6793e9ff !important;
        cursor: default !important;
        transform: none !important;
        opacity: 0.9 !important;
        box-shadow: none !important;
}

/* STYLES POUR LES MODALS DE CLÔTURE */
.modal-header.bg-warning {
    background: linear-gradient(135deg, #ffc107 0%, #e0a800 100%) !important;
}

/* Animation pour les projets terminés */
@keyframes fadeInTerminated {
    from { opacity: 0.5; }
    to { opacity: 0.85; }
}

.projet-termine {
    animation: fadeInTerminated 0.5s ease-out;
}

/* Bandeau d'information pour les projets terminés */
.alert-projet-termine {
    background: linear-gradient(135deg, #d4edda 0%, #c3e6cb 100%);
    border-left: 4px solid #28a745;
    color: #155724;
}

.alert-projet-termine .alert-icon {
    color: #28a745;
} 

.alert-projet-suspendu {
    background: linear-gradient(135deg, #f8e9d6ff 0%, #fdf4e7ff 100%);
    border-left: 4px solid #f59e0b;
    color: #a86c03ff;
}

