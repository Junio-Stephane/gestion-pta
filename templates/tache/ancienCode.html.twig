        addForm.addEventListener('submit', (e) => {
            e.preventDefault();
            if (!this.projetSuspendu) {
                this.ajouterTache();
            }
        });
    }

    const editForm = document.getElementById('editTacheForm');
    if (editForm) {
        editForm.addEventListener('submit', (e) => {
            e.preventDefault();
            if (!this.projetSuspendu) {
                this.modifierTache();
            }
        });
    }

    const avancementSlider = document.getElementById('edit_avancementTache');
    const avancementValue = document.getElementById('edit_avancementValue');

    if (avancementSlider) {
        avancementSlider.addEventListener('input', (e) => {
            if (!this.projetSuspendu) {
                avancementValue.textContent = e.target.value + '%';
            }
        });
    }

    // Écouteur pour le bouton "Annuler" du modal d'ajout
    const cancelButton = document.querySelector('#addTacheModal .btn-secondary[data-bs-dismiss="modal"]');
    if (cancelButton) {
        cancelButton.addEventListener('click', () => {
            this.resetAddTacheModal();
        });
    }

