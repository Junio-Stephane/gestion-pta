    formatDate(dateString) {
        if (!dateString) return 'N/A';
        try {
            const date = new Date(dateString);
            if (isNaN(date.getTime())) return 'N/A';
            return date.toLocaleDateString('fr-FR');
        } catch (error) {
            return 'N/A';
        }
    }

    formatBudget(budget) {
        if (!budget) return '0 Ar';
        
        const amount = parseFloat(budget);
        if (isNaN(amount)) return '0 Ar';
        
        return amount.toLocaleString('fr-FR', {
            minimumFractionDigits: 0,
            maximumFractionDigits: 0
        }) + ' Ar';
    }

    getStatutClass(statut) {
        const classes = {
            'Débuté': 'status-debute',
            'En cours': 'status-encours',
            'Terminé': 'status-termine',
            'Suspendu': 'status-suspendu'
        };
        return classes[statut] || 'status-debute';
    }

    createCircularProgress(avancement, estSuspendu = false) {
        let progressClass = 'low';
        if (avancement >= 70) {
            progressClass = 'high';
        } else if (avancement >= 30) {
            progressClass = 'medium';
        }
        if (avancement === 100) {
            progressClass = 'complete';
        }

        if (estSuspendu) {
            progressClass = 'suspendu';
        }

        return `
            <div class="progress-circular ${progressClass}" 
                 style="--progress-value: ${avancement}" 
                 data-progress="${avancement}">
            </div>
        `;
    }

    escapeHtml(unsafe) {
        if (!unsafe) return '';
        return unsafe
            .replace(/&/g, "&amp;")
            .replace(/</g, "&lt;")
            .replace(/>/g, "&gt;")
            .replace(/"/g, "&quot;")
            .replace(/'/g, "&#039;");
    }

    truncateText(text, maxLength) {
        if (!text) return '';
        if (text.length <= maxLength) return text;
        return text.substring(0, maxLength - 3) + '...';
    }

    getInitials(nom, prenom) {
        const firstInitial = prenom ? prenom.charAt(0).toUpperCase() : '';
        const lastInitial = nom ? nom.charAt(0).toUpperCase() : '';
        return firstInitial + lastInitial;
    }

    parseFilterDate(dateString) {
        if (!dateString) return null;
        const [day, month, year] = dateString.split('/');
        return new Date(`${year}-${month}-${day}`);
    }

    hasActiveFilters() {
        return this.currentFilters.statut || this.currentFilters.avancement || 
               this.currentFilters.dateDebut || this.currentFilters.dateFin || 
               this.currentFilters.search;
    }

    // GESTION DES ERREURS
    showMultipleErrors(errors) {
        Object.keys(errors).forEach(fieldKey => {
            const errorMessage = errors[fieldKey];
            this.showFieldError(fieldKey, errorMessage);
        });
    }

    showMultipleEditErrors(errors) {
        Object.keys(errors).forEach(fieldKey => {
            const errorMessage = errors[fieldKey];
            this.showEditFieldError(fieldKey, errorMessage);
        });
    }

    showFieldError(fieldId, errorMessage) {
        const field = document.getElementById(fieldId);
        const errorElement = document.getElementById(fieldId + 'Error');
        
        if (field && errorElement) {
            field.classList.add('is-invalid');
            errorElement.textContent = errorMessage;
        }
    }

    showEditFieldError(fieldId, errorMessage) {
        const field = document.getElementById('edit_' + fieldId);
        const errorElement = document.getElementById('edit_' + fieldId + 'Error');
        
        if (field && errorElement) {
            field.classList.add('is-invalid');
            errorElement.textContent = errorMessage;
        }
    }

    clearModalErrors() {
        const fields = ['titreTache', 'dateDebutTache', 'dateFinTache'];
        fields.forEach(field => this.clearFieldError(field));
    }

    clearEditModalErrors() {
        const fields = ['titreTache', 'dateDebutTache', 'dateFinTache'];
        fields.forEach(field => this.clearEditFieldError(field));
    }

    clearFieldError(fieldId) {
        const field = document.getElementById(fieldId);
        const errorElement = document.getElementById(fieldId + 'Error');
        
        if (field) {
            field.classList.remove('is-invalid');
        }
        if (errorElement) {
            errorElement.textContent = '';
        }
    }

    clearEditFieldError(fieldId) {
        const field = document.getElementById('edit_' + fieldId);
        const errorElement = document.getElementById('edit_' + fieldId + 'Error');
        
        if (field) {
            field.classList.remove('is-invalid');
        }
        if (errorElement) {
            errorElement.textContent = '';
        }
    }

    showSuccess(message) {
    const alertContainer = document.getElementById('fixedAlertContainer');
    const alert = document.createElement('div');
    alert.className = 'alert-success-fixed mb-3';
    alert.innerHTML = `
        <i class="bi bi-check-circle-fill"></i>
        <span>${message}</span>
        <button type="button" class="alert-close-btn" onclick="this.parentElement.remove()">
            <i class="bi bi-x"></i>
        </button>
    `;
    
    // Supprimer les anciennes alertes
    while (alertContainer.firstChild) {
        alertContainer.removeChild(alertContainer.firstChild);
    }
    
    // Ajouter la nouvelle alerte
    alertContainer.appendChild(alert);
    
    // Auto-suppression après 5 secondes
    setTimeout(() => {
        if (alert.parentElement) {
            alert.style.animation = 'fadeOut 0.3s ease-out';
            setTimeout(() => {
                if (alert.parentElement) {
                    alert.remove();
                }
            }, 300);
        }
    }, 5000);
}

showError(message) {
    const alertContainer = document.getElementById('fixedAlertContainer');
    const alert = document.createElement('div');
    alert.className = 'alert-danger-fixed mb-3';
    alert.innerHTML = `
        <i class="bi bi-exclamation-triangle-fill"></i>
        <span>${message}</span>
        <button type="button" class="alert-close-btn" onclick="this.parentElement.remove()">
            <i class="bi bi-x"></i>
        </button>
    `;
    
    // Supprimer les anciennes alertes
    while (alertContainer.firstChild) {
        alertContainer.removeChild(alertContainer.firstChild);
    }
    
    // Ajouter la nouvelle alerte
    alertContainer.appendChild(alert);
    
    // Auto-suppression après 5 secondes
    setTimeout(() => {
        if (alert.parentElement) {
            alert.style.animation = 'fadeOut 0.3s ease-out';
            setTimeout(() => {
                if (alert.parentElement) {
                    alert.remove();
                }
