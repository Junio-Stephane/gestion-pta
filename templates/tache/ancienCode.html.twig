                    <small class="text-muted">Tache concernée :</small>
                    <span id="terminerTacheTitre" class="fw-bold mb-1"></span>
                </div>
                <div>
                    <small class="text-muted">Numéro :</small>
                    <span id="terminerTacheNumero" class="fw-bold mb-1"></span>
                </div>
                
            </div>
            <div class="modal-footer">
                <button type="button" class="btnG btn-secondary" data-bs-dismiss="modal">
                    Annuler
                </button>
                <button type="button" class="btnG btn-success" id="confirmTerminerTacheBtn">
                    <i class="bi bi-check-circle"></i>
                    Terminer la tâche
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Modal de Confirmation pour Réinitialiser une Tâche -->
<div class="modal fade" id="reinitialiserTacheModal" tabindex="-1" aria-labelledby="reinitialiserTacheModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-arrow-repeat me-2"></i>
                    Réinitialiser la Tâche
                </h5>
                <button type="button" class="btn-close-custom" data-bs-dismiss="modal" aria-label="Close">
                    <i class="bi bi-x"></i>
                </button>
            </div>
            <div class="modal-body">
                <div class="consigne-warning">
                    <div class="d-flex">
                        <div class="flex-grow-1 ms-3">
                            <h5><i class="bi bi-arrow-repeat"></i> Réinitialisation de la tâche</h5>
                            <p class="mb-0">Cette action remettra la tâche à l'état "Débuté" avec 0% d'avancement. Voulez-vous continuer ?</p>
                        </div>
                    </div>
                </div>

                <div class="mt-3">
                    <small class="text-muted">Tache concernée :</small>
                    <span id="reinitialiserTacheTitre" class="fw-bold mb-1"></span>
                </div>
                <div>
                    <small class="text-muted">Numéro :</small>
                    <span id="reinitialiserTacheNumero" class="fw-bold mb-1"></span>
                </div>
                
            </div>
            <div class="modal-footer">
                <button type="button" class="btnG btn-secondary" data-bs-dismiss="modal">
                    Annuler
                </button>
                <button type="button" class="btnG btn-warning" id="confirmReinitialiserTacheBtn">
                    <i class="bi bi-arrow-repeat"></i>
                    Réinitialiser la tâche
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Modal de Clôture de Projet (Terminer ou Modifier à 100% la dernière tâche) -->
<div class="modal fade" id="clotureProjetModal" tabindex="-1" aria-labelledby="clotureProjetModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-check-circle me-2"></i> 
                    Clôture du Projet
                </h5>
                <button type="button" class="btn-close-custom" data-bs-dismiss="modal" aria-label="Close">
                    <i class="bi bi-x"></i>
                </button>
            </div>
            <div class="modal-body">
                <div class="consigne-warning">
                    <div class="d-flex">
                        <div class="flex-grow-1 ms-33">
                            <h5><i class="bi bi-exclamation-triangle text-warning"></i>  Clôture du Projet</h5>
                            <p class="mb-0" id="clotureMessage">En terminant cette dernière tâche, le projet sera automatiquement clôturé à 100%.</p>
                        </div>
                    </div>
                </div>

                <div class="mt-3">
                    <small class="text-muted">Tache concernée :</small>
                    <span id="clotureTacheTitre" class="fw-bold mb-1"></span>
                </div>
                <div>
                    <small class="text-muted">Numéro :</small>
                    <span id="clotureTacheNumero" class="fw-bold mb-1"></span>
                </div>
                <div>
                    <small class="text-muted">Action :</small>
                    <span id="clotureAction" class="fw-bold mb-1"></span>
                </div>
                

                <div class="consigne">
                    <small>
                        <i class="bi bi-info-circle text-primary"></i>
                        En projet terminer, vous pourrez visualiser le projet et ses tâches mais aucune modification ne sera possible.
                    </small>
                </div>
                
            </div>
            <div class="modal-footer">
                <button type="button" class="btnG btn-secondary" data-bs-dismiss="modal">
                    Annuler
                </button>
                <button type="button" class="btnG btn-success" id="confirmClotureBtn">
                    <i class="bi bi-check-circle me-2"></i>
                    Confirmer la clôture
                </button>
            </div>
        </div>
    </div>
</div>
