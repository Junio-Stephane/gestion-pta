        const resetFilters = document.getElementById('resetFilters');
        if (resetFilters) {
            resetFilters.addEventListener('click', () => {
                this.resetFilters();
            });
        }

        // ÉVÉNEMENTS POUR LES BOUTONS DE CONFIRMATION DES TÂCHES
        const confirmTerminerTacheBtn = document.getElementById('confirmTerminerTacheBtn');
        if (confirmTerminerTacheBtn) {
            confirmTerminerTacheBtn.addEventListener('click', () => {
                this.executeTerminerTache();
            });
