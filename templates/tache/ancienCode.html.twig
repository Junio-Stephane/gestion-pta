   renderTaches() {
    const tbody = document.getElementById('tachesTableBody');
    const taches = this.getPaginatedTaches();
    
    if (!tbody) return;

    // Vérifier les permissions de l'utilisateur
    const canManageTaches = this.currentProjetPermissions && !this.projetTermine;
    
    // DÉTERMINER SI L'UTILISATEUR EST LE CRÉATEUR OU UN ADMIN
    const isAdmin = this.currentUserRole === 'ROLE_ADMIN';
    const isCreateur = this.currentUserRole === 'ROLE_CREATEUR_DE_PROJET';
    const isUtilisateur = this.currentUserRole === 'ROLE_UTILISATEUR';
    
    // Pour les créateurs : ne peuvent gérer que leurs propres projets
    // Pour les admins : peuvent tout gérer
    // Pour les utilisateurs : ne peuvent gérer que s'ils sont dans personnels
    let userCanManage = false;
    
    if (isAdmin) {
        userCanManage = true;
    } else if (isCreateur) {
        // Vérifier si l'utilisateur actuel est le créateur du projet
        const currentUserId = this.getCurrentUserId();
        const isCurrentUserCreateur = this.currentProjet?.createur?.ImPer === currentUserId;
        userCanManage = isCurrentUserCreateur;
    } else if (isUtilisateur) {
        // Vérifier si l'utilisateur est dans les responsables du projet
        const currentUserId = this.getCurrentUserId();
        const isInPersonnels = this.currentProjet?.personnels?.some(p => p.ImPer === currentUserId) || false;
        userCanManage = isInPersonnels;
    }

    // FINAL PERMISSION : combiner les permissions du projet ET les permissions utilisateur
    const finalCanManage = canManageTaches && userCanManage;

// DÉTERMINER LE TEXTE ET L'ÉTAT DU BOUTON
let buttonText = taches && taches.length === 0 ? 'Créer la première tâche' : 'Nouvelle Tâche';
let buttonDisabled = this.projetSuspendu || this.projetTermine || !finalCanManage;
let buttonStyle = buttonDisabled ? 'style="opacity: 0.6; cursor: not-allowed;"' : '';

if (!taches || taches.length === 0) {
    const hasActiveFilters = this.hasActiveFilters();
    
    tbody.innerHTML = `
        <tr>
            <td colspan="8" class="text-center py-4 text-muted">
                <i class="bi bi-clipboard-x" style="font-size: 2rem;"></i>
                <p class="mt-2">${hasActiveFilters ? 'Aucune tâche ne correspond aux critères' : 'Aucune tâche trouvée'}</p>
                ${hasActiveFilters ? 
                    '<p class="text-sm">Essayez de modifier vos critères de recherche</p>' : 
                    `<button class="btn btn-primary mt-2" 
                            data-bs-toggle="modal" data-bs-target="#addTacheModal"
                            ${buttonDisabled ? 'disabled' : ''}
                            ${buttonStyle}>
                        <i class="bi bi-plus-circle me-2"></i>
                        ${buttonText}
                    </button>`
                }
            </td>
        </tr>
    `;
    return;
}

    tbody.innerHTML = taches.map(tache => {
        const estTacheSuspendue = tache.statutTache === 'Suspendu' || this.projetSuspendu;
        const estProjetTermine = this.projetTermine;
        const statutClass = this.getStatutClass(tache.statutTache);
        const avancement = tache.avancementTache || 0;
        
        // DÉTERMINER CE QUE L'UTILISATEUR PEUT FAIRE
        const tacheCanEdit = !estTacheSuspendue && finalCanManage && !estProjetTermine;
        const tacheCanDelete = !estTacheSuspendue && finalCanManage && !estProjetTermine;
        const tacheCanTerminate = !estTacheSuspendue && finalCanManage && !estProjetTermine && tache.statutTache !== 'Terminé';
        const tacheCanResume = !estTacheSuspendue && finalCanManage && !estProjetTermine && tache.statutTache === 'Terminé';

        // Texte d'info pour les tooltips
        const noPermissionText = this.getNoPermissionText();
        const suspendedText = 'Tâche suspendue';
        const projectTerminatedText = 'Projet terminé à 100%';
        
        return `
            <tr class="tache-item ${estTacheSuspendue ? 'tache-suspendu' : ''}">
                <td><strong>${tache.numTache}</strong></td>
                
                <td>
                    <div class="titre-tache-container">
                        <div class="titre-tache-preview" onclick="this.classList.toggle('expanded')">
                            ${this.escapeHtml(tache.titreTache)}
                        </div>
                    </div>
                </td>
                
                <td>
                    <div class="description-container">
                        <div class="text-preview ${!tache.descriptionTache ? 'empty' : ''}" 
                             onclick="this.classList.toggle('expanded')">
                            ${tache.descriptionTache || 'Aucune description'}
                        </div>
                    </div>
                </td>
                
                <td>
                    <div class="commentaire-container">
                        <div class="text-preview ${!tache.commentaireTache ? 'empty' : ''}" 
                             onclick="this.classList.toggle('expanded')">
                            ${tache.commentaireTache || 'Aucun commentaire'}
                        </div>
                    </div>
                </td>
                
                <td>
                    <div class="period-simple">
                        <div class="period-date-simple">
                            <div class="date-line">
                                <span class="date-label-simple">Début:</span>
                                <span class="date-value-simple">${this.formatDate(tache.dateDebutTache)}</span>
                            </div>
                            <div class="date-line">
                                <span class="date-label-simple">Fin:</span>
                                <span class="date-value-simple">${tache.dateFinTache ? this.formatDate(tache.dateFinTache) : 'Non définie'}</span>
                            </div>
                        </div>
                    </div>
                </td>
                
                <td>
                    <div class="progress-circular-container">
                        ${this.createCircularProgress(avancement, estTacheSuspendue)}
                    </div>
                </td>
                
                <td>
                    <span class="status-badge ${statutClass}">${tache.statutTache}</span>
                </td>
                
                <td>
                    <div class="actions-container">
                        <!-- Bouton Modifier -->
                        <button type="button" class="btn btn-warning btn-sm ${!tacheCanEdit ? 'disabled' : ''}"
                            ${!tacheCanEdit ? 'disabled' : ''}
                            onclick="${tacheCanEdit ? `tacheManager.ouvrirModification('${tache.numTache}')` : ''}"
                            data-bs-toggle="tooltip" data-bs-placement="top" 
                            style="${!tacheCanEdit ? 'opacity: 0.5;' : ''}"
                            title="${!tacheCanEdit ? this.getTooltipText(estProjetTermine, estTacheSuspendue, noPermissionText) : 'Modifier la tâche'}">
                            <i class="bi bi-pencil"></i>
                            Modifier
                        </button>
                        
                        <!-- Bouton Terminer -->
                        ${tacheCanTerminate ? 
                            `<button type="button" class="btn btn-success btn-sm"
                                onclick="tacheManager.showTerminerConfirmation('${tache.numTache}')"
                                data-bs-toggle="tooltip" data-bs-placement="top" 
                                title="Marquer comme terminée">
                                <i class="bi bi-check-circle"></i>
                                Terminer
                            </button>` : 
                            `<button type="button" class="btn btn-success btn-sm disabled" disabled
                                style="opacity: 0.5;"
                                data-bs-toggle="tooltip" data-bs-placement="top" 
                                title="${this.getTooltipText(estProjetTermine, estTacheSuspendue, noPermissionText)}">
                                <i class="bi bi-check-circle"></i>
                                Terminer
                            </button>`
                        }
                        
                        <!-- Bouton Réinitialiser -->
                        ${tacheCanResume ? 
                            `<button type="button" class="btn btn-secondary btn-sm"
                                onclick="tacheManager.showReinitialiserConfirmation('${tache.numTache}')"
                                data-bs-toggle="tooltip" data-bs-placement="top" 
                                title="Réinitialiser la tâche">
                                <i class="bi bi-arrow-repeat"></i>
                                Réinitialiser
                            </button>` : 
                            `<button type="button" class="btn btn-secondary btn-sm disabled" disabled
                                style="opacity: 0.5;"
                                data-bs-toggle="tooltip" data-bs-placement="top" 
                                title="${this.getTooltipText(estProjetTermine, estTacheSuspendue, noPermissionText)}">
                                <i class="bi bi-arrow-repeat"></i>
                                Réinitialiser
                            </button>`
                        }
                        
                        <!-- Bouton Supprimer -->
                        <button type="button" class="btn btn-danger btn-sm ${!tacheCanDelete ? 'disabled' : ''}"
                            ${!tacheCanDelete ? 'disabled' : ''}
                            onclick="${tacheCanDelete ? `tacheManager.supprimerTache('${tache.numTache}')` : ''}"
                            data-bs-toggle="tooltip" data-bs-placement="top" 
                            style="${!tacheCanDelete ? 'opacity: 0.5;' : ''}"
                            title="${!tacheCanDelete ? this.getTooltipText(estProjetTermine, estTacheSuspendue, noPermissionText) : 'Supprimer la tâche'}">
