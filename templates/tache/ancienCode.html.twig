        confirmBtn.innerHTML = '<div class="loading-spinner me-2"></div> Clôture...';
        confirmBtn.disabled = true;

        const form = document.getElementById('editTacheForm');
        const formData = new FormData(form);
        
        const data = {
            titreTache: formData.get('titreTache'),
            descriptionTache: formData.get('descriptionTache'),
            commentaireTache: formData.get('commentaireTache'),
            dateDebutTache: this.convertDateToISO(formData.get('dateDebutTache')),
            dateFinTache: formData.get('dateFinTache') ? 
                this.convertDateToISO(formData.get('dateFinTache')) : null,
            avancementTache: 100 // Forcer à 100% pour la clôture
        };

        const response = await fetch(`/admin/taches/api/${this.currentEditingTache.numTache}/modifier`, {
            method: 'PUT',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify(data)
        });

        const result = await response.json();

        if (result.success) {
            // Fermer tous les modals
            modal?.hide();
            bootstrap.Modal.getInstance(document.getElementById('editTacheModal'))?.hide();
            
            // Afficher le succès
            this.showProjetTermineSuccessModal();
            this.loadProjetAndTaches();
            
            this.currentEditingTache = null;
            this.currentActionTache = null;
        } else {
            this.showError(result.message);
            // RESTAURATION DU BOUTON EN CAS D'ERREUR
            confirmBtn.innerHTML = originalBtnText;
            confirmBtn.disabled = false;
        }
    } catch (error) {
        console.error('Erreur modification avec clôture:', error);
        this.showError('Erreur lors de la modification: ' + error.message);
        // RESTAURATION DU BOUTON EN CAS D'ERREUR
        const confirmBtn = document.getElementById('confirmClotureBtn');
        if (confirmBtn) {
            confirmBtn.innerHTML = '<i class="bi bi-check-circle me-2"></i> Confirmer la clôture';
            confirmBtn.disabled = false;
        }
    }
}





