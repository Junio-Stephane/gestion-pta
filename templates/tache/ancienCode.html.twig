    // Méthode pour calculer l'alerte d'échéance du projet
calculerAlerteProjet(projet) {
    // Pas d'alerte pour les projets terminés ou suspendus
    if (projet.StatutPro === 'Terminé' || projet.StatutPro === 'Suspendu') {
        return null;
    }

    // Pas d'alerte si pas de date de fin
    if (!projet.dateFinPro) {
        return null;
    }

    const aujourdhui = new Date();
    aujourdhui.setHours(0, 0, 0, 0);
    
    const dateFin = new Date(projet.dateFinPro);
    dateFin.setHours(0, 0, 0, 0);

    // Calculer la différence en jours calendaires
    const diffTime = dateFin - aujourdhui;
    const joursCalendaires = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
    
    // Si la date est dépassée
    if (joursCalendaires < 0) {
        // Calculer les jours ouvrables de retard (depuis la date de fin jusqu'à hier)
        const dateFinPlusUn = new Date(dateFin);
        const joursOuvrablesRetard = this.holidaysManager.getBusinessDaysCount(dateFinPlusUn, aujourdhui);
        
        return {
            niveau: 'red',
            message: `En retard de ${joursOuvrablesRetard} jour${joursOuvrablesRetard > 1 ? 's' : ''} ouvrable${joursOuvrablesRetard > 1 ? 's' : ''}`,
            joursRestants: -joursOuvrablesRetard,
            joursCalendaires: joursCalendaires,
            joursOuvrables: -joursOuvrablesRetard,
            dateFin: projet.dateFinPro
        };
    } 
    // Si échéance aujourd'hui
    else if (joursCalendaires === 0) {
        return {
            niveau: 'red',
            message: 'Échéance aujourd\'hui',
            joursRestants: 0,
            joursCalendaires: 0,
            joursOuvrables: 0,
            dateFin: projet.dateFinPro
        };
    }
    // Si date future - calculer jours ouvrables restants
    else {
        // Calculer les jours ouvrables restants (depuis demain jusqu'à la date de fin)
        const demain = new Date(aujourdhui);
        
        const joursOuvrablesRestants = this.holidaysManager.getBusinessDaysCount(demain, dateFin);
        
        // Déterminer le niveau d'alerte basé sur les jours ouvrables
        if (joursOuvrablesRestants <= 3) {
            // Dans 3 jours ouvrables ou moins - Alerte orange
            return {
                niveau: 'orange',
                message: `Fin dans ${joursOuvrablesRestants} jour${joursOuvrablesRestants > 1 ? 's' : ''} ouvrable${joursOuvrablesRestants > 1 ? 's' : ''}`,
                joursRestants: joursOuvrablesRestants,
                joursCalendaires: joursCalendaires,
                joursOuvrables: joursOuvrablesRestants,
                dateFin: projet.dateFinPro
            };
        } else if (joursOuvrablesRestants <= 5) {
            // Dans 5 jours ouvrables ou moins - Alerte jaune
            return {
                niveau: 'yellow',
                message: `Fin dans ${joursOuvrablesRestants} jour${joursOuvrablesRestants > 1 ? 's' : ''} ouvrable${joursOuvrablesRestants > 1 ? 's' : ''}`,
                joursRestants: joursOuvrablesRestants,
                joursCalendaires: joursCalendaires,
                joursOuvrables: joursOuvrablesRestants,
                dateFin: projet.dateFinPro
            };
        }
        // Pas d'alerte si plus de 5 jours ouvrables restants
    }

    return null; // Pas d'alerte si plus de 5 jours ouvrables
}

// Et la méthode renderAlerteProjet() reste la même que dans ma réponse précédente :
renderAlerteProjet(projet) {
    const alerte = this.calculerAlerteProjet(projet);
    
    if (!alerte) {
        return ''; // Pas d'alerte à afficher
    }

    const estProjetSuspendu = projet.StatutPro === 'Suspendu';
    
    // Déterminer l'icône et la couleur en fonction du niveau
    let iconClass = 'bi-info-circle';
    let iconColor = 'linear-gradient(135deg, #10b981 0%, #059669 100%)';
    
    switch(alerte.niveau) {
        case 'red':
            iconClass = 'bi-exclamation-triangle-fill';
            iconColor = 'linear-gradient(135deg, #ef4444 0%, #dc2626 100%)';
            break;
        case 'orange':
            iconClass = 'bi-exclamation-triangle';
            iconColor = 'linear-gradient(135deg, #f97316 0%, #ea580c 100%)';
            break;
        case 'yellow':
            iconClass = 'bi-info-circle';
            iconColor = 'linear-gradient(135deg, #f59e0b 0%, #d97706 100%)';
            break;
    }

    // Déterminer la classe CSS pour les jours
    let joursClass = 'normal';
    if (alerte.niveau === 'red') {
        joursClass = 'retard';
    } else if (alerte.niveau === 'orange') {
        joursClass = 'urgence';
    } else if (alerte.niveau === 'yellow') {
        joursClass = 'attention';
    }

    return `
        <div class="projet-alerte-section">
            <div class="projet-alerte-card ${alerte.niveau} ${estProjetSuspendu ? 'projet-suspendu' : ''}">
                <div class="projet-alerte-header">
                    <div class="projet-alerte-icon" style="background: ${iconColor}; color: white;">
                        <i class="bi ${iconClass}"></i>
                    </div>
                    <h3 class="projet-alerte-title">Échéance du Projet</h3>
                </div>
                <div class="projet-alerte-content">
                    <div class="projet-alerte-indicator ${alerte.niveau}"></div>
                    <div class="projet-alerte-message">${alerte.message}</div>
                    <div class="projet-alerte-details">
                        <i class="bi bi-calendar"></i>
                        Date fin du projet: ${this.formatDate(alerte.dateFin)}
                    </div>
                </div>
            </div>
        </div>
    `;
}

    async loadProjetAndTaches() {
    try {
        const response = await fetch(`/admin/taches/api/projet/${this.numProjet}/list`);
        const data = await response.json();
        
        if (data.success) {
            this.projetSuspendu = data.projet.StatutPro === 'Suspendu';
            this.projetTermine = data.projet.StatutPro === 'Terminé';
            this.allTaches = data.taches || [];
            this.currentProjetPermissions = data.canManage;
            this.currentProjet = data.projet; // STOCKER LE PROJET
            
            this.applyFilters();
            this.renderProjetSummary(data.projet);
            this.updateMainActionButton();
            this.toggleInteractions();
            
            await this.setupDateConstraints();
        } else {
            this.showError(data.message);
        }
    } catch (error) {
        console.error('Erreur chargement tâches:', error);
        this.showError('Erreur lors du chargement des tâches');
    }
}

