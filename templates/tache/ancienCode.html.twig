async modifierTache() {
    if (this.projetSuspendu) {
        this.showError('Impossible de modifier une tâche : le projet est suspendu');
        return;
    }

    this.log('Début modification tâche');

    const form = document.getElementById('editTacheForm');
    const submitBtn = document.getElementById('submitEditTache');
    
    if (!form || !submitBtn || !this.currentEditingTache) {
        this.showError('Données de modification manquantes');
        return;
    }

    const originalText = submitBtn.innerHTML;

    try {
        this.clearEditModalErrors();
        
        // AJOUT DU SPINNER
        submitBtn.innerHTML = '<div class="loading-spinner me-2"></div> Modification...';
        submitBtn.disabled = true;

        const formData = new FormData(form);
        const avancement = parseInt(document.getElementById('edit_avancementTache').value);
        
        // CAS 3 : Vérifier si modification à 100% de la dernière tâche
        if (avancement === 100) {
            const vaCloturerProjet = await this.verifierClotureProjetModification(
                this.currentEditingTache.numTache
            );
            
            if (vaCloturerProjet) {
                // CAS 3 : Modifier à 100% la dernière tâche
                const response = await fetch(`/admin/taches/api/${this.currentEditingTache.numTache}`);
                const data = await response.json();
                
                if (data.success) {
                    this.currentActionTache = data.tache;
                    this.prepareClotureModal(data.tache, 'modifier');
                    return; // Arrêter ici, la suite sera gérée par le modal
                }
            }
        }

        // CAS normal : modification sans clôture
        const dateDebutISO = this.convertDateToISO(formData.get('dateDebutTache'));
        const dateFinISO = formData.get('dateFinTache') ? 
            this.convertDateToISO(formData.get('dateFinTache')) : null;

        if (!dateDebutISO) {
            this.showEditFieldError('dateDebutTache', 'Date de début invalide');
            throw new Error('Date de début invalide');
        }

        const data = {
            titreTache: formData.get('titreTache'),
            descriptionTache: formData.get('descriptionTache'),
            commentaireTache: formData.get('commentaireTache'),
            dateDebutTache: dateDebutISO,
            dateFinTache: dateFinISO,
            avancementTache: avancement
        };

        const response = await fetch(`/admin/taches/api/${this.currentEditingTache.numTache}/modifier`, {
            method: 'PUT',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify(data)
        });

        const result = await response.json();

        if (result.success) {
            this.showSuccess(result.message);
            bootstrap.Modal.getInstance(document.getElementById('editTacheModal')).hide();
            this.loadProjetAndTaches();
        } else {
            if (result.errors) {
                this.showMultipleEditErrors(result.errors);
            } else {
                this.showError(result.message);
            }
        }
    } catch (error) {
        console.error('Erreur modification tâche:', error);
        this.showError('Erreur lors de la modification de la tâche: ' + error.message);
    } finally {
        // RESTAURATION DU BOUTON
        submitBtn.innerHTML = originalText;
        submitBtn.disabled = false;
    }
}



async verifierClotureProjetModification(numTache) {
    try {
        // Vérifier l'avancement actuel de la tâche
        const response = await fetch(`/admin/taches/api/${numTache}`);
        const data = await response.json();
        
        if (data.success) {
            const tache = data.tache;
            const avancementActuel = tache.avancementTache || 0;
            
            // Si la tâche est déjà à 100%, la modifier à 100% ne change rien
            if (avancementActuel === 100) {
                return false;
            }
            
            // Sinon, vérifier si mettre à 100% va clôturer le projet
            const vaCloturer = await this.verifierClotureProjet(numTache);
            return vaCloturer;
        }
        return false;
    } catch (error) {
        console.error('Erreur vérification modification:', error);
        return false;
    }
}

// Nouvelle méthode pour exécuter la modification avec clôture
async handleClotureConfirmation() {
    const actionType = document.getElementById('confirmClotureBtn').dataset.actionType;
    
    console.log('handleClotureConfirmation - actionType:', actionType);
    
    if (actionType === 'terminer') {
        // CAS 2 : Terminer la dernière tâche
        console.log('Exécution terminaison avec clôture');
        await this.executeTerminerTache(true);
    } else if (actionType === 'modifier') {
        // CAS 3 : Modifier à 100% la dernière tâche
        console.log('Exécution modification avec clôture');
        await this.executeModificationAvecCloture();
    }
}

