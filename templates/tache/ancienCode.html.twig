    .progress-circular-container {
        display: flex;
        justify-content: center;
        align-items: center;
        width: 60px;
        height: 60px;
        position: relative;
    }

    .progress-circular {
        width: 50px;
        height: 50px;
        border-radius: 50%;
        background: 
            radial-gradient(closest-side, white 79%, transparent 80% 100%),
            conic-gradient(var(--progress-color) calc(var(--progress-value) * 1%), #e5e7eb 0);
        display: flex;
        justify-content: center;
        align-items: center;
        position: relative;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    }

    .progress-circular::before {
        content: attr(data-progress) '%';
        position: absolute;
        font-size: 0.7rem;
        font-weight: 700;
        color: var(--progress-text-color);
    }

    .progress-circular.low {
        --progress-color: #ef4444;
        --progress-text-color: #ef4444;
    }

    .progress-circular.medium {
        --progress-color: #f59e0b;
        --progress-text-color: #f59e0b;
    }

    .progress-circular.high {
        --progress-color: #10b981;
        --progress-text-color: #10b981;
    }

    .progress-circular.complete {
        --progress-color: #10b981;
        --progress-text-color: #10b981;
    }

