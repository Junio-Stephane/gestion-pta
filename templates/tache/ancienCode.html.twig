                                    <input type="text" class="form-control flatpickr" id="edit_dateFinTache" name="dateFinTache" placeholder="jj/mm/aaaa">
                                    <div class="invalid-feedback" id="edit_dateFinTacheError"></div>
                                </div>
                            </div>
                        </div>
                    </div>

                    

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="edit_descriptionTache" class="form-label">Description</label>
                                <textarea class="form-control" id="edit_descriptionTache" name="descriptionTache" rows="3" placeholder="Description détaillée de la tâche..."></textarea>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="edit_commentaireTache" class="form-label">Commentaire</label>
                                <textarea class="form-control" id="edit_commentaireTache" name="commentaireTache" rows="3" placeholder="Commentaires additionnels..."></textarea>
                            </div>
                        </div>
                    </div>

                    <!-- Gestion de l'avancement -->
                    <div class="avancement-management">
                        <div class="avancement-header">
                            <div class="avancement-title">
                                <i class="bi bi-graph-up"></i>
                                Avancement de la tâche
                            </div>
                        </div>
                        
                        <div class="avancement-controls">
                            <div class="avancement-slider-container">
                                <input type="range" class="avancement-slider" id="edit_avancementTache" 
                                       min="0" max="100" step="1" value="0">
                            </div>
                            <div class="avancement-value">
                                <span id="edit_avancementValue">0%</span>
                            </div>
                        </div>
                        
                        <div class="mt-2">
                            <small class="form-text text-muted">
                                <i class="bi bi-info-circle text-primary"></i>
                                Ajustez manuellement l'avancement de la tâche
                            </small>
                        </div>
                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btnG btn-secondary" data-bs-dismiss="modal">Annuler</button>
                        <button type="submit" class="btnG btn-primary" id="submitEditTache">
                            <i class="bi bi-check-circle me-2"></i>
                            Enregistrer les modifications
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Modal pour afficher tous les responsables et le créateur -->
<div class="modal fade responsables-modal" id="responsablesModal" tabindex="-1" aria-labelledby="responsablesModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-md">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-people-fill me-2"></i>
                    Équipe du projet
                </h5>
                <button type="button" class="btn-close-custom" data-bs-dismiss="modal" aria-label="Close">
                    <i class="bi bi-x"></i>
                </button>
            </div>
            <div class="modal-body">
                <div class="responsables-list-modal" id="responsablesListModal">
