    const addModalElement = document.getElementById('addTacheModal');
    if (addModalElement) {
        addModalElement.addEventListener('hidden.bs.modal', () => {
            this.resetAddTacheModal();
        });
    }

    // Écouteur pour le bouton "Annuler" du modal d'édition
    const editCancelButton = document.querySelector('#editTacheModal .btn-secondary[data-bs-dismiss="modal"]');
    if (editCancelButton) {
        editCancelButton.addEventListener('click', () => {
            this.resetEditTacheModal();
        });
    }

    // Écouteur pour quand le modal d'édition se ferme
    const editModalElement = document.getElementById('editTacheModal');
    if (editModalElement) {
        editModalElement.addEventListener('hidden.bs.modal', () => {
            this.resetEditTacheModal();
        });
    }

        // ÉVÉNEMENTS POUR LES FILTRES
        const statutFilter = document.getElementById('statutFilter');
        if (statutFilter) {
            statutFilter.addEventListener('change', (e) => {
                this.currentFilters.statut = e.target.value;
                this.currentPage = 1;
                this.applyFilters();
            });
        }

        const avancementFilter = document.getElementById('avancementFilter');
        if (avancementFilter) {
            avancementFilter.addEventListener('change', (e) => {
                this.currentFilters.avancement = e.target.value;
                this.currentPage = 1;
                this.applyFilters();
            });
        }

        const searchInput = document.getElementById('searchInput');
