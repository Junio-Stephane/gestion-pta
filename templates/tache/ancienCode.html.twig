                                <div class="form-group">
                                    <label for="edit_dateDebutTache" class="form-label">Date de début *</label>
                                    <input type="text" class="form-control flatpickr" id="edit_dateDebutTache" name="dateDebutTache" placeholder="jj/mm/aaaa" required>
                                    <div class="invalid-feedback" id="edit_dateDebutTacheError"></div>
