async executeTerminerTache(withCloture = false) {
    if (!this.currentActionTache) return;

    try {
        const modal = bootstrap.Modal.getInstance(document.getElementById('terminerTacheModal'));
        const confirmBtn = document.getElementById('confirmTerminerTacheBtn');
        const originalBtnText = confirmBtn.innerHTML;
        
        // AJOUT DU SPINNER
        confirmBtn.innerHTML = '<div class="loading-spinner me-2"></div> Terminaison...';
        confirmBtn.disabled = true;

        const response = await fetch(`/admin/taches/api/${this.currentActionTache.numTache}/terminer`, {
            method: 'POST'
        });

        const result = await response.json();

        if (result.success) {
            // Fermer TOUS les modals existants
            modal?.hide();
            bootstrap.Modal.getInstance(document.getElementById('clotureProjetModal'))?.hide();
            
            if (withCloture || result.projetTermine) {
                // Cas avec clôture - Afficher le modal de succès
                this.showProjetTermineSuccessModal();
            } else {
                // Cas normal - Message standard
                this.showSuccess(result.message);
                this.loadProjetAndTaches();
            }
            
            this.currentActionTache = null;
        } else {
            this.showError(result.message);
            // RESTAURATION DU BOUTON EN CAS D'ERREUR
            confirmBtn.innerHTML = originalBtnText;
            confirmBtn.disabled = false;
        }
    } catch (error) {
        console.error('Erreur terminaison tâche:', error);
        this.showError('Erreur lors de la terminaison de la tâche');
        // RESTAURATION DU BOUTON EN CAS D'ERREUR
        const confirmBtn = document.getElementById('confirmTerminerTacheBtn');
        if (confirmBtn) {
            confirmBtn.innerHTML = '<i class="bi bi-check-circle me-2"></i> Confirmer la terminaison';
            confirmBtn.disabled = false;
        }
    }
}

