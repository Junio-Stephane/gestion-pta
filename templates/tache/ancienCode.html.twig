        this.init();
    }

    log(message, data = null) {
        if (this.debugMode) {
            console.log(`[TacheManager] ${message}`, data || '');
        }
    }

    init() {
        this.setupEventListeners();
        this.setupNavigation();
        this.loadProjetAndTaches();
        this.initDatePickers();
