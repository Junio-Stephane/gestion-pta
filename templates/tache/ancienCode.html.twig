// Ajouter cette méthode pour gérer la modification de l'avancement
async modifierAvancementTache(numTache, avancement) {
    try {
        // Si l'avancement est 100%, vérifier si ça va terminer le projet
        if (avancement === 100) {
            const response = await fetch(`/admin/taches/api/${numTache}`);
            const data = await response.json();
            
            if (data.success) {
                const projet = data.tache.projet;
                const taches = projet.taches || [];
                const totalTaches = taches.length;
                const tachesTerminees = taches.filter(t => t.statutTache === 'Terminé' || t.numTache === numTache).length;
                
                // Si cette tâche va être la dernière terminée
                const vaTerminerProjet = (tachesTerminees === totalTaches);
                
                if (vaTerminerProjet) {
                    // Demander confirmation
                    const confirmTerminer = confirm(
                        `Attention ! En mettant cette tâche à 100%, vous allez clôturer le projet "${projet.titrePro}" à 100%. ` +
                        `Le projet ne pourra plus être modifié. Confirmez-vous cette action ?`
                    );
                    
                    if (!confirmTerminer) {
                        return false;
                    }
                }
            }
        }
        
        // Procéder à la modification normale
        return true;
    } catch (error) {
        console.error('Erreur vérification terminaison:', error);
        return true;
    }
}
