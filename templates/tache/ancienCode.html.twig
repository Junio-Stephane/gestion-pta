checkUserPermissions() {
    if (this.currentUserRole === 'ROLE_ADMIN') {
        return true;
    }
    
    if (!this.currentProjet) {
        return false;
    }
    
    const currentUserId = this.getCurrentUserId();
    
    if (this.currentUserRole === 'ROLE_CREATEUR_DE_PROJET') {
        // Vérifier si l'utilisateur est le créateur du projet
        return this.currentProjet.createur?.ImPer === currentUserId;
    }
    
    if (this.currentUserRole === 'ROLE_UTILISATEUR') {
        // Vérifier si l'utilisateur est dans les responsables du projet
        return this.currentProjet.personnels?.some(p => p.ImPer === currentUserId) || false;
    }
    
    return false;
}

    renderPagination() {
        const totalPages = Math.ceil(this.totalItems / this.itemsPerPage);
        const paginationElement = document.getElementById('pagination');
        const paginationInfoElement = document.getElementById('paginationInfo');

        if (!paginationElement || !paginationInfoElement) return;

        const startItem = (this.currentPage - 1) * this.itemsPerPage + 1;
        const endItem = Math.min(this.currentPage * this.itemsPerPage, this.totalItems);
        
        paginationInfoElement.textContent = 
            `Affichage de ${startItem} à ${endItem} sur ${this.totalItems} tâche${this.totalItems !== 1 ? 's' : ''}`;

        let paginationHTML = '';

        paginationHTML += `
            <li class="page-item ${this.currentPage === 1 ? 'disabled' : ''}">
                <a class="page-link" href="#" onclick="tacheManager.changePage(${this.currentPage - 1})">
                    <i class="bi bi-chevron-left"></i>
                </a>
            </li>
        `;

        for (let i = 1; i <= totalPages; i++) {
            if (i === 1 || i === totalPages || (i >= this.currentPage - 1 && i <= this.currentPage + 1)) {
                paginationHTML += `
                    <li class="page-item ${i === this.currentPage ? 'active' : ''}">
                        <a class="page-link" href="#" onclick="tacheManager.changePage(${i})">${i}</a>
                    </li>
                `;
            } else if (i === this.currentPage - 2 || i === this.currentPage + 2) {
                paginationHTML += `<li class="page-item disabled"><span class="page-link">...</span></li>`;
            }
        }

        paginationHTML += `
            <li class="page-item ${this.currentPage === totalPages ? 'disabled' : ''}">
                <a class="page-link" href="#" onclick="tacheManager.changePage(${this.currentPage + 1})">
                    <i class="bi bi-chevron-right"></i>
                </a>
            </li>
        `;

        paginationElement.innerHTML = paginationHTML;
    }

    changePage(page) {
        if (page < 1 || page > Math.ceil(this.totalItems / this.itemsPerPage)) {
            return;
        }
        this.currentPage = page;
        this.renderTaches();
        this.renderPagination();
        
        const tableElement = document.querySelector('.table-responsive');
        if (tableElement) {
            tableElement.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
    }

    // MÉTHODES SPÉCIFIQUES POUR LES DATES - SOLUTION FORCÉE
    convertDateToISO(dateString) {
        if (!dateString) {
            this.log('convertDateToISO: dateString vide');
            return null;
        }
        
        this.log(`convertDateToISO - Entrée: "${dateString}"`);
        
        try {
            const cleanDate = dateString.trim();
            const dateRegex = /^(\d{1,2})\/(\d{1,2})\/(\d{4})$/;
            const match = cleanDate.match(dateRegex);
            
            if (!match) {
                this.log(`convertDateToISO: Format invalide - "${dateString}"`);
                return null;
            }
            
            const day = match[1].padStart(2, '0');
            const month = match[2].padStart(2, '0');
            const year = match[3];
            
            const isoDate = `${year}-${month}-${day}`;
            
            this.log(`convertDateToISO - Sortie: "${isoDate}"`);
            
            const testDate = new Date(isoDate);
            if (isNaN(testDate.getTime())) {
                this.log(`convertDateToISO: Date invalide après conversion - "${isoDate}"`);
                return null;
            }
            
            return isoDate;
        } catch (error) {
            this.log(`convertDateToISO: Erreur - ${error.message}`);
            return null;
        }
    }

    formatDateForInput(dateString) {
        if (!dateString) {
            this.log('formatDateForInput: dateString vide');
            return '';
        }
        
        this.log(`formatDateForInput - Entrée: "${dateString}"`);
        
        try {
            const date = new Date(dateString);
            if (isNaN(date.getTime())) {
                this.log(`formatDateForInput: Date invalide - "${dateString}"`);
                return '';
            }
            
            const day = date.getDate().toString().padStart(2, '0');
            const month = (date.getMonth() + 1).toString().padStart(2, '0');
            const year = date.getFullYear();
            
            const formatted = `${day}/${month}/${year}`;
            
            this.log(`formatDateForInput - Sortie: "${formatted}"`);
            
            return formatted;
        } catch (error) {
            this.log(`formatDateForInput: Erreur - ${error.message}`);
            return '';
        }
    }

async ajouterTache() {
    if (this.projetSuspendu) {
        this.showError('Impossible d\'ajouter une tâche : le projet est suspendu');
        return;
    }

    const form = document.getElementById('addTacheForm');
    const submitBtn = document.getElementById('submitAddTache');
    
    if (!form || !submitBtn) {
        this.showError('Formulaire non trouvé');
        return;
    }

    const originalText = submitBtn.innerHTML;

    try {
        this.clearModalErrors();
        
        // AJOUT DU SPINNER
        submitBtn.innerHTML = '<div class="loading-spinner me-2"></div> Création...';
        submitBtn.disabled = true;


            const formData = new FormData(form);

            const dateDebutISO = this.convertDateToISO(formData.get('dateDebutTache'));
            const dateFinISO = formData.get('dateFinTache') ? 
                this.convertDateToISO(formData.get('dateFinTache')) : null;

            if (!dateDebutISO) {
                this.showFieldError('dateDebutTache', 'Date de début invalide');
                throw new Error('Date de début invalide');
            }

            const data = {
                titreTache: formData.get('titreTache'),
                descriptionTache: formData.get('descriptionTache'),
                commentaireTache: formData.get('commentaireTache'),
                dateDebutTache: dateDebutISO,
                dateFinTache: dateFinISO,
                numProjet: this.numProjet
            };

        const response = await fetch('/admin/taches/api/create', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify(data)
        });

        const result = await response.json();

        if (result.success) {
            this.showSuccess(result.message);
            bootstrap.Modal.getInstance(document.getElementById('addTacheModal')).hide();
            
            // Réinitialiser le formulaire APRÈS la fermeture du modal
            setTimeout(() => {
                this.resetAddTacheModal();
            }, 300);
            
            this.loadProjetAndTaches();
        } else {
            if (result.errors) {
                this.showMultipleErrors(result.errors);
            } else {
                this.showError(result.message);
            }
        }
    } catch (error) {
        console.error('Erreur création tâche:', error);
        this.showError('Erreur lors de la création de la tâche: ' + error.message);
    } finally {
        // RESTAURATION DU BOUTON
        submitBtn.innerHTML = originalText;
        submitBtn.disabled = false;
    }
}

