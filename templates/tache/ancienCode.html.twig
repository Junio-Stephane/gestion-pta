            confirmReinitialiserTacheBtn.addEventListener('click', () => {
                this.executeReprendreTache();
            });
        }

        const confirmClotureBtn = document.getElementById('confirmClotureBtn');
    if (confirmClotureBtn) {
        confirmClotureBtn.addEventListener('click', () => {
            this.handleClotureConfirmation();
        });
    }

        this.toggleInteractions();
    }

    setupNavigation() {
    // Désactiver TOUS les liens de navigation, y compris le dropdown utilisateur
    const allNavLinks = document.querySelectorAll('a.nav-link, a.dropdown-item');
    allNavLinks.forEach(link => {
        // Garder seulement le lien "Projets" actif
        if (link.getAttribute('href') && link.getAttribute('href').includes('app_projet')) {
            link.classList.add('active');
            link.style.pointerEvents = 'auto';
            link.style.opacity = '1';
        } else if (link.getAttribute('href') && link.getAttribute('href').includes('app_logout')) {
            // Garder le lien de déconnexion actif
            link.style.pointerEvents = 'auto';
            link.style.opacity = '1';
        } else {
            // Désactiver tous les autres liens
            link.style.pointerEvents = 'none';
            link.style.opacity = '0.6';
            link.classList.remove('active');
        }
    });

    // Gérer le clic sur le fil d'ariane "Projets"
    const projetBreadcrumb = document.querySelector('.breadcrumb-item a[href*="app_projet"]');
    if (projetBreadcrumb) {
        projetBreadcrumb.addEventListener('click', (e) => {
            e.preventDefault();
            this.returnToProjects();
        });
    }
}

    returnToProjects() {
        // Sauvegarder l'état actuel si nécessaire
        sessionStorage.setItem('lastProjetPage', this.numProjet);
        
        // Rediriger vers la page des projets
        window.location.href = '/admin/projet';
    }

    initDatePickers() {
        this.log('Initialisation des datepickers');
        
        const datepickerConfig = {
            locale: 'fr',
            dateFormat: 'd/m/Y',
            enableTime: false,
            static: true,
            position: 'auto'
        };

        const dateFields = ['dateDebutTache', 'dateFinTache'];
        
        dateFields.forEach(fieldId => {
            const element = document.getElementById(fieldId);
            if (element) {
                this.datePickers[fieldId] = flatpickr(element, datepickerConfig);
                this.log(`Datepicker créé pour: ${fieldId}`);
            }
        });
        
        this.setupDateConstraints();
    }

    initEditDatePickers() {
        this.log('Initialisation des datepickers d\'édition');
        
        // Configuration de base pour l'édition
        const datepickerConfig = {
            locale: 'fr',
            dateFormat: 'd/m/Y',
            enableTime: false,
            static: true,
            position: 'auto'
        };

        const editDateFields = ['edit_dateDebutTache', 'edit_dateFinTache'];
        
        editDateFields.forEach(fieldId => {
            const element = document.getElementById(fieldId);
            if (element) {
                this.editDatePickers[fieldId] = flatpickr(element, datepickerConfig);
                this.log(`Datepicker édition créé pour: ${fieldId}`);
            }
        });
    }

async setupDateConstraints() {
    try {
        this.log('Chargement des dates du projet...');
        
        const response = await fetch(`/admin/taches/api/projet/${this.numProjet}/dates`);
        const data = await response.json();
        
        this.log('Réponse dates projet:', data);
        
        if (data.success) {
            const projetDebut = data.dateDebut ? new Date(data.dateDebut) : null;
            const projetFin = data.dateFin ? new Date(data.dateFin) : null;
            
            // Mettre à jour les consignes
            this.updateDateConsignes(projetDebut, projetFin);
            
            this.configureDateConstraints(projetDebut, projetFin);
            
            // Ajouter la vérification en temps réel
            this.setupDateValidationListeners(projetDebut, projetFin);
        }
    } catch (error) {
        console.error('Erreur chargement dates projet:', error);
    }
}


setupDateValidationListeners(projetDebut, projetFin) {
    // Validation pour l'ajout
    this.setupDateValidation('dateDebutTache', 'dateFinTache', projetDebut, projetFin);
    
    // Validation pour la modification
    this.setupDateValidation('edit_dateDebutTache', 'edit_dateFinTache', projetDebut, projetFin);
}

setupDateValidation(dateDebutFieldId, dateFinFieldId, projetDebut, projetFin) {
    const dateDebutField = document.getElementById(dateDebutFieldId);
    const dateFinField = document.getElementById(dateFinFieldId);
    
    if (!dateDebutField || !dateFinField) return;
    
    // Fonction de validation
    const validateDates = () => {
        const debutValue = dateDebutField.value;
        const finValue = dateFinField.value;
        
        // Effacer les erreurs précédentes
        this.clearFieldError(dateDebutFieldId.replace('edit_', ''));
        this.clearFieldError(dateFinFieldId.replace('edit_', ''));
        
        if (debutValue && finValue) {
            try {
                const debutDate = this.parseDateFromString(debutValue);
                const finDate = this.parseDateFromString(finValue);
                
                
                if (finDate < debutDate) { 
                    const errorMsg = 'La date de fin doit être postérieure ou égale à la date de début';
                    if (dateDebutFieldId.startsWith('edit_')) {
                        this.showEditFieldError('dateFinTache', errorMsg);
                    } else {
                        this.showFieldError('dateFinTache', errorMsg);
                    }
                }
                
                // Vérifier les contraintes du projet
                if (projetDebut && debutDate < projetDebut) {
                    const errorMsg = `La date doit être après ${projetDebut.toLocaleDateString('fr-FR')}`;
                    if (dateDebutFieldId.startsWith('edit_')) {
                        this.showEditFieldError('dateDebutTache', errorMsg);
                    } else {
                        this.showFieldError('dateDebutTache', errorMsg);
                    }
                }
                
                if (projetFin && finDate > projetFin) {
                    const errorMsg = `La date doit être avant ${projetFin.toLocaleDateString('fr-FR')}`;
                    if (dateFinFieldId.startsWith('edit_')) {
                        this.showEditFieldError('dateFinTache', errorMsg);
                    } else {
                        this.showFieldError('dateFinTache', errorMsg);
                    }
                }
            } catch (error) {
                console.error('Erreur parsing date:', error);
            }
        }
    };
    
    // Ajouter les écouteurs d'événements
    dateDebutField.addEventListener('change', validateDates);
    dateFinField.addEventListener('change', validateDates);
    dateDebutField.addEventListener('input', validateDates);
    dateFinField.addEventListener('input', validateDates);
    
    // Ajouter aussi un écouteur pour flatpickr
    if (dateDebutFieldId.startsWith('edit_')) {
        if (this.editDatePickers[dateDebutFieldId]) {
            this.editDatePickers[dateDebutFieldId].config.onChange.push(validateDates);
        }
        if (this.editDatePickers[dateFinFieldId]) {
            this.editDatePickers[dateFinFieldId].config.onChange.push(validateDates);
        }
    } else {
        if (this.datePickers[dateDebutFieldId]) {
            this.datePickers[dateDebutFieldId].config.onChange.push(validateDates);
        }
        if (this.datePickers[dateFinFieldId]) {
            this.datePickers[dateFinFieldId].config.onChange.push(validateDates);
        }
    }
}

// Méthode utilitaire pour parser une date depuis un string formaté
parseDateFromString(dateString) {
    if (!dateString) return null;
    
    // Format "dd/mm/yyyy"
    const [day, month, year] = dateString.split('/');
    return new Date(`${year}-${month.padStart(2, '0')}-${day.padStart(2, '0')}`);
}

updateDateConsignes(projetDebut, projetFin) {
    // Formater les dates
    const formatDateForDisplay = (date) => {
        if (!date) return 'Non définie';
        return date.toLocaleDateString('fr-FR');
    };

    const debutStr = formatDateForDisplay(projetDebut);
    const finStr = formatDateForDisplay(projetFin);

    // Mettre à jour la consigne d'ajout
    const addConsigne = document.getElementById('addDateConsigne');
    if (addConsigne) {
        addConsigne.innerHTML = `
            Veuillez sélectionner les dates entre <span id="projetDateDebut">${debutStr}</span> 
            et <span id="projetDateFin">${finStr}</span>
        `;
    }

    // Mettre à jour la consigne d'édition
    const editConsigne = document.getElementById('editDateConsigne');
    if (editConsigne) {
        editConsigne.innerHTML = `
            Veuillez sélectionner les dates entre <span id="editProjetDateDebut">${debutStr}</span> 
            et <span id="editProjetDateFin">${finStr}</span>
        `;
    }
}

configureDateConstraints(projetDebut, projetFin) {
    this.log('Configuration des contraintes de dates', { projetDebut, projetFin });

    // Mettre à jour les consignes
    this.updateDateConsignes(projetDebut, projetFin);

    // Configuration pour l'ajout
    ['dateDebutTache', 'dateFinTache'].forEach(fieldId => {
        if (this.datePickers[fieldId]) {
            const config = {
                locale: 'fr',
                dateFormat: 'd/m/Y',
                enableTime: false,
                minDate: projetDebut,
                maxDate: projetFin,
                onChange: (selectedDates, dateStr, instance) => {
                    this.highlightDateConstraint(instance, projetDebut, projetFin);
                    this.validateDateRealTime(fieldId, 'add', projetDebut, projetFin);
                }
            };
            
            this.datePickers[fieldId].destroy();
            this.datePickers[fieldId] = flatpickr(document.getElementById(fieldId), config);
        }
    });

    // Configuration pour l'édition
    ['edit_dateDebutTache', 'edit_dateFinTache'].forEach(fieldId => {
        if (this.editDatePickers[fieldId]) {
            const config = {
                locale: 'fr',
                dateFormat: 'd/m/Y',
                enableTime: false,
                minDate: projetDebut,
                maxDate: projetFin,
                onChange: (selectedDates, dateStr, instance) => {
                    this.highlightDateConstraint(instance, projetDebut, projetFin);
                    this.validateDateRealTime(fieldId, 'edit', projetDebut, projetFin);
                }
            };
            
            this.editDatePickers[fieldId].destroy();
            this.editDatePickers[fieldId] = flatpickr(document.getElementById(fieldId), config);
        }
    });
}

// Nouvelle méthode pour validation en temps réel
validateDateRealTime(fieldId, formType, projetDebut, projetFin) {
    const isEditForm = formType === 'edit';
    const prefix = isEditForm ? 'edit_' : '';
    const baseFieldId = fieldId.replace('edit_', '');
    
    const dateDebutFieldId = isEditForm ? 'edit_dateDebutTache' : 'dateDebutTache';
    const dateFinFieldId = isEditForm ? 'edit_dateFinTache' : 'dateFinTache';
    
    const dateDebutField = document.getElementById(dateDebutFieldId);
    const dateFinField = document.getElementById(dateFinFieldId);
    
    if (!dateDebutField || !dateFinField) return;
    
    const debutValue = dateDebutField.value;
    const finValue = dateFinField.value;
    
    // Effacer les erreurs précédentes
    this.clearFieldError(baseFieldId);
    if (isEditForm) {
        this.clearEditFieldError(baseFieldId);
    }
    
    if (debutValue && finValue) {
        try {
            const debutDate = this.parseDateFromString(debutValue);
            const finDate = this.parseDateFromString(finValue);
            
            // MODIFICATION : permet date fin >= date début
            if (finDate < debutDate) {  // < au lieu de <=
                const errorMsg = 'La date de fin doit être postérieure ou égale à la date de début';
                if (isEditForm) {
                    this.showEditFieldError('dateFinTache', errorMsg);
                } else {
                    this.showFieldError('dateFinTache', errorMsg);
                }
            }
            
            // Vérifier les contraintes du projet
            if (projetDebut && debutDate < projetDebut) {
                const errorMsg = `La date doit être après ${projetDebut.toLocaleDateString('fr-FR')}`;
                if (isEditForm) {
                    this.showEditFieldError('dateDebutTache', errorMsg);
                } else {
                    this.showFieldError('dateDebutTache', errorMsg);
                }
            }
            
            if (projetFin && finDate > projetFin) {
                const errorMsg = `La date doit être avant ${projetFin.toLocaleDateString('fr-FR')}`;
                if (isEditForm) {
                    this.showEditFieldError('dateFinTache', errorMsg);
                } else {
                    this.showFieldError('dateFinTache', errorMsg);
                }
            }
        } catch (error) {
            console.error('Erreur parsing date:', error);
        }
    }
}

highlightDateConstraint(instance, projetDebut, projetFin) {
    const input = instance.input;
    const selectedDate = instance.selectedDates[0];
    
    if (!selectedDate) return;
    
    // Réinitialiser les styles
    input.style.borderColor = '';
    input.style.boxShadow = '';
    
    // Vérifier les contraintes
    if (projetDebut && selectedDate < projetDebut) {
        input.style.borderColor = '#dc2626';
        input.style.boxShadow = '0 0 0 0.2rem rgba(220, 38, 38, 0.25)';
    } else if (projetFin && selectedDate > projetFin) {
        input.style.borderColor = '#dc2626';
        input.style.boxShadow = '0 0 0 0.2rem rgba(220, 38, 38, 0.25)';
    }
}

updateDateConsignes(projetDebut, projetFin) {
    // Formater les dates
    const formatDateForDisplay = (date) => {
        if (!date) return 'Non définie';
        return date.toLocaleDateString('fr-FR');
    };

    const debutStr = formatDateForDisplay(projetDebut);
    const finStr = formatDateForDisplay(projetFin);

    // Message à afficher
    let message = '';
    if (!projetDebut && !projetFin) {
        message = 'Les dates du projet ne sont pas définies. Vous pouvez sélectionner n\'importe quelle date.';
    } else if (!projetDebut) {
        message = `Date de fin du projet : <span>${finStr}</span>. Veuillez sélectionner une date avant cette date.`;
    } else if (!projetFin) {
        message = `Date de début du projet : <span>${debutStr}</span>. Veuillez sélectionner une date après cette date.`;
    } else {
        message = `Veuillez sélectionner les dates entre <span>${debutStr}</span> et <span>${finStr}</span>`;
    }

    // Mettre à jour la consigne d'ajout
    const addConsigne = document.getElementById('addDateConsigne');
    if (addConsigne) {
        addConsigne.innerHTML = `
            ${message}
        `;
    }

    // Mettre à jour la consigne d'édition
    const editConsigne = document.getElementById('editDateConsigne');
    if (editConsigne) {
        editConsigne.innerHTML = `
            ${message}
        `;
    }
}

    initFilterDatePickers() {
        const datepickerConfig = {
            locale: 'fr',
            dateFormat: 'd/m/Y',
            enableTime: false,
            static: true,
            position: 'auto'
        };

        const filterDateFields = ['dateDebutFilter', 'dateFinFilter'];
        
        filterDateFields.forEach(fieldId => {
            const element = document.getElementById(fieldId);
            if (element) {
                this.datePickers[fieldId] = flatpickr(element, datepickerConfig);
            }
        });
    }

toggleInteractions() {
    // Simplement appeler updateMainActionButton() pour garantir la cohérence
    this.updateMainActionButton();
}

    applyFilters() {
        let filtered = [...this.allTaches];

        if (this.currentFilters.statut) {
            filtered = filtered.filter(tache => 
                tache.statutTache === this.currentFilters.statut
            );
        }

        if (this.currentFilters.avancement) {
            filtered = filtered.filter(tache => {
                const avancement = tache.avancementTache || 0;
                
                switch(this.currentFilters.avancement) {
                    case '0-25':
                        return avancement >= 0 && avancement <= 25;
                    case '25-50':
                        return avancement > 25 && avancement <= 50;
                    case '50-75':
                        return avancement > 50 && avancement <= 75;
                    case '75-100':
                        return avancement > 75 && avancement < 100;
                    case '100':
                        return avancement === 100;
                    default:
                        return true;
                }
            });
        }

        if (this.currentFilters.dateDebut || this.currentFilters.dateFin) {
            filtered = filtered.filter(tache => {
                const tacheDateDebut = tache.dateDebutTache ? new Date(tache.dateDebutTache) : null;
                
                let match = true;

                if (this.currentFilters.dateDebut) {
                    const filterDateDebut = this.parseFilterDate(this.currentFilters.dateDebut);
                    if (tacheDateDebut && tacheDateDebut < filterDateDebut) {
                        match = false;
                    }
                }

                if (this.currentFilters.dateFin) {
                    const filterDateFin = this.parseFilterDate(this.currentFilters.dateFin);
                    if (tacheDateDebut && tacheDateDebut > filterDateFin) {
                        match = false;
                    }
                }

                return match;
            });
        }

        if (this.currentFilters.search) {
            const searchTerm = this.currentFilters.search.toLowerCase();
            filtered = filtered.filter(tache => {
                return (
                    tache.numTache.toString().toLowerCase().includes(searchTerm) ||
                    tache.titreTache.toLowerCase().includes(searchTerm) ||
                    (tache.descriptionTache && tache.descriptionTache.toLowerCase().includes(searchTerm)) ||
                    (tache.commentaireTache && tache.commentaireTache.toLowerCase().includes(searchTerm))
                );
            });
        }

        this.filteredTaches = filtered;
        this.totalItems = filtered.length;
        this.renderTaches();
        this.renderPagination();
    }

