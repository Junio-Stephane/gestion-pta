            min-width: 100%;
        }
        
        .filters-row-bottom {
            margin-top: 1rem;
            padding-top: 1rem;
        }
        
        .filter-date-range {
            flex-direction: column;
            gap: 0.5rem;
            min-width: 100%;
        }
        
        .filter-date-range .filter-group {
            min-width: 100%;
        }
        
        .date-range-separator {
            padding: 0;
            justify-content: center;
            transform: rotate(90deg);
            height: 20px;
            margin: 0.25rem 0;
        }
        
        .date-range-separator i {
