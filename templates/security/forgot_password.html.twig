{# templates/security/forgot_password.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Mot de passe oublié - MIC PTA{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
/* Reset et styles de base */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    margin: 0;
    min-height: 100vh;
    background: linear-gradient(135deg, #964ee3 0%, #75165f 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
}

/* Container principal */
.auth-container {
    display: flex;
    width: 90%;
    max-width: 900px;
    min-height: 600px;
    border-radius: 35px;
    overflow: hidden;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.2);
}

/* Partie gauche - Bienvenue */
.auth-pre {
    position: relative;
    background: linear-gradient(135deg, #eada70 0%, #fd8617 100%);
    flex: 1;
    min-width: 300px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 30px;
}

/* Sceau en arrière-plan */
.auth-sceau {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.5;
    z-index: 1;
}

.auth-sceau img {
    width: 80%;
    height: auto;
    object-fit: contain;
}

/* Contenu par-dessus */
.auth-overlay {
    position: relative;
    z-index: 2;
    text-align: center;
    color: #fff;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
}

.auth-welcome .auth-logo {
    margin-bottom: 30px;
}

.auth-logo img {
    width: 100px;
    height: 60px;
    max-width: 100%;
}

.auth-welcome .auth-logo p {
    margin-top: 5px;
    font-size: .65rem;
    line-height: 1.1;
    white-space: nowrap;
    color: white;
    text-align: center;
}

/* Bloc de bienvenue */
.auth-welcome {
    text-align: center;
    color: #fff;
    z-index: 3;
    padding: 20px;
    background: rgba(0, 0, 0, 0.24);
    border-radius: 30px;
    backdrop-filter: blur(5px);
}

.auth-welcome p {
    font-size: 14px;
    margin: 0;
    line-height: 1.6;
    text-align: left;
}

/* Carte de réinitialisation */
.auth-card {
    background: white;
    flex: 1;
    min-width: 300px;
    padding: 40px 30px;
    display: flex;
    align-items: center;
    justify-content: center;
}

.auth-content {
    width: 100%;
    max-width: 320px;
}

.login-icon {
    width: 120px;
    height: 120px;
    background: linear-gradient(135deg, #964ee3 0%, #75165f 100%);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 25px auto;
    box-shadow: 0 8px 20px rgba(128, 102, 234, 0.3);
    border: 4px solid white;
}

.login-icon i {
    font-size: 4.5rem;
    color: white;
}

/* Effet de brillance au survol */
.login-icon:hover i {
    animation: pulse 1s infinite;
}

@keyframes pulse {
    0% { transform: scale(1); }
    50% { transform: scale(1.1); }
    100% { transform: scale(1); }
}

.auth-header {
    text-align: center;
    margin-bottom: 30px;
}

.auth-header h1 {
    color: #1d0933;
    margin-bottom: 10px;
    font-weight: 600;
    font-size: 28px;
}

.auth-header p {
    color: #666;
    font-size: 16px;
}

/* Instructions mot de passe */
.password-instructions {
    background: #f8f9fa;
    border-radius: 8px;
    padding: 15px;
    margin-bottom: 20px;
    border-left: 4px solid #7566ea;
}

.password-instructions p {
    margin: 0;
    color: #495057;
    font-size: 14px;
    line-height: 1.5;
}

/* Formulaire */
.form-group {
    margin-bottom: 20px;
}

.form-group label {
    display: block;
    margin-bottom: 8px;
    color: #333;
    font-weight: 500;
    font-size: 14px;
}

.form-control {
    width: 100%;
    padding: 12px 15px;
    border: 2px solid #e1e5e9;
    border-radius: 8px;
    font-size: 14px;
    transition: all 0.3s ease;
}

.form-control:focus {
    outline: none;
    border-color: #7566ea;
    box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
}

.btn-primary {
    width: 100%;
    padding: 14px;
    background: linear-gradient(135deg, #964ee3 0%, #75165f 100%);
    border: none;
    border-radius: 8px;
    color: white;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    margin-top: 10px;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
}

.btn-primary:hover:not(:disabled) {
    transform: translateY(-2px);
    box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
}

.btn-primary:disabled {
    opacity: 0.7;
    cursor: default;
    transform: none;
}

/* Footer */
.auth-footer {
    text-align: center;
    margin-top: 25px;
    padding-top: 20px;
    border-top: 1px solid #eee;
}

.auth-footer p {
    color: #666;
    font-size: 14px;
    margin-bottom: 10px;
}

.auth-footer a {
    color: #7566ea;
    text-decoration: none;
    font-weight: 500;
    transition: color 0.3s ease;
}

.auth-footer a:hover {
    text-decoration: underline;
    color: #8066ea;
}

/* Alertes */
.alert-error {
    background-color: #fee;
    border: 1px solid #fcc;
    color: #c33;
    padding: 12px;
    border-radius: 8px;
    margin-bottom: 20px;
    font-size: 14px;
    text-align: center;
}

.alert-success {
    background-color: #f0f9f0;
    border: 1px solid #4caf50;
    color: #2e7d32;
    padding: 12px;
    border-radius: 8px;
    margin-bottom: 20px;
    font-size: 14px;
    text-align: center;
}

/* Spinner de chargement */
.loading-spinner {
    display: inline-block;
    width: 1rem;
    height: 1rem;
    border: 2px solid #f3f3f3;
    border-top: 2px solid #964ee3;
    border-radius: 50%;
    animation: spin 1s linear infinite;
}

@keyframes spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
}

/* Responsive Design */
@media (max-width: 768px) {
    .auth-container {
        flex-direction: column;
        width: 95%;
        max-width: 400px;
        min-height: auto;
    }
    
    .auth-pre {
        border-radius: 15px 15px 0 0;
        min-height: 300px;
        padding: 20px;
    }
    
    .auth-card {
        border-radius: 0 0 15px 15px;
        padding: 30px 20px;
    }
    
    .auth-welcome {
        padding: 15px;
    }
    
    .auth-welcome p {
        font-size: 13px;
    }
    
    .auth-header h1 {
        font-size: 24px;
    }
}

@media (max-width: 480px) {
    .auth-container {
        width: 100%;
        border-radius: 0;
        min-height: 100vh;
    }
    
    .auth-pre, .auth-card {
        border-radius: 0;
    }
    
    .auth-pre {
        min-height: 250px;
    }
    
    .auth-content {
        padding: 0 10px;
    }
    
    .auth-logo img {
        width: 100px;
    }
}

/* Animation légère */
.auth-container {
    animation: fadeInUp 0.6s ease-out;
}

@keyframes fadeInUp {
    from {
        opacity: 0;
        transform: translateY(20px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}
</style>
{% endblock %}

{% block body %}
<div class="auth-container">
    <div class="auth-pre">
        <div class="auth-sceau">
            <img src="{{ asset('images/sceau.png') }}" alt="Sceau">
        </div>

        <div class="auth-overlay">      
            <div class="auth-welcome">
                <div class="auth-logo">
                    <img src="{{ asset('images/logo2.png') }}" alt="Logo">
                    <p>Ministère de l'Industrialisation et du Commerce</p>
                </div>
                
                <p>
                    Vous avez oublié votre mot de passe ?<br><br>
                    Pas d'inquiétude, nous allons vous envoyer un lien de réinitialisation 
                    par email. Ce lien sera valable pendant 1 heure.
                </p>
            </div>
        </div>
    </div>
    
    <div class="auth-card">
        <div class="auth-content">
            <div class="login-icon">
                <i class="bi bi-key"></i>
            </div>
            <div class="auth-header">
                <h1>Mot de passe oublié</h1>
                <p>Réinitialisez votre mot de passe</p>
            </div>

            <div class="password-instructions">
                <p><strong>Instructions :</strong> Saisissez votre adresse email. Vous recevrez un lien pour créer un nouveau mot de passe.</p>
            </div>

            {% if error %}
                <div class="alert-error">
                    {{ error }}
                </div>
            {% endif %}

            {% if success %}
                <div class="alert-success">
                    {{ success }}
                </div>
            {% endif %}

            <form method="post" id="forgotPasswordForm">
                <div class="form-group">
                    <label for="email">Email</label>
                    <input 
                        type="email" 
                        name="email" 
                        id="email" 
                        class="form-control" 
                        required 
                        autofocus
                        placeholder="votre@email.com"
                        value="{{ app.request.request.get('email') }}"
                    >
                </div>

                <button type="submit" class="btn-primary" id="submitButton">
                    <span id="buttonText">Envoyer le lien de réinitialisation</span>
                    <div class="loading-spinner" id="submitSpinner" style="display: none;"></div>
                </button>
            </form>

            <div class="auth-footer">
                <p><a href="{{ path('app_login') }}">← Retour à la connexion</a></p>
                <p>Pas encore de compte ? <a href="{{ path('app_register') }}">Créer un compte</a></p>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const forgotPasswordForm = document.getElementById('forgotPasswordForm');
    const submitButton = document.getElementById('submitButton');
    const buttonText = document.getElementById('buttonText');
    const submitSpinner = document.getElementById('submitSpinner');

    forgotPasswordForm.addEventListener('submit', function() {
        // Désactiver le bouton et afficher le spinner
        submitButton.disabled = true;
        buttonText.textContent = 'Envoi en cours...';
        submitSpinner.style.display = 'inline-block';
    });

    // Réactiver le formulaire si la page est rechargée depuis le cache (retour arrière)
    window.addEventListener('pageshow', function(event) {
        if (event.persisted || (window.performance && window.performance.navigation.type === 2)) {
            submitButton.disabled = false;
            buttonText.textContent = 'Envoyer le lien de réinitialisation';
            submitSpinner.style.display = 'none';
            
            const inputs = forgotPasswordForm.querySelectorAll('input');
            inputs.forEach(input => {
                input.disabled = false;
            });
        }
    });
});
</script>
{% endblock %}