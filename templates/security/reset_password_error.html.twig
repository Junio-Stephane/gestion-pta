{% extends 'base.html.twig' %}

{% block title %}Lien non valide - MIC PTA{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
/* Reset et styles de base */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    margin: 0;
    min-height: 100vh;
    background: linear-gradient(135deg, #964ee3 0%, #75165f 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
}

/* Container principal */
.auth-container {
    display: flex;
    width: 95%;
    max-width: 900px;
    min-height: 500px;
    border-radius: 35px;
    overflow: hidden;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.2);
}

/* Carte d'erreur */
.auth-card {
    background: white;
    width: 100%;
    padding: 60px 50px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 35px;
}

.auth-content {
    width: 100%;
    max-width: 600px;
}

/* Container erreur */
.error-container {
    text-align: center;
    width: 100%;
}

/* Icône d'erreur */
.error-icon {
    width: 140px;
    height: 140px;
    background: linear-gradient(135deg, #dc3545 0%, #c82333 100%);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 40px auto;
    box-shadow: 0 12px 30px rgba(220, 53, 69, 0.4);
    border: 8px solid white;
    animation: shake 0.8s ease-in-out;
}

.error-icon i {
    font-size: 4.5rem;
    color: white;
}

.auth-header {
    text-align: center;
    margin-bottom: 40px;
}

.auth-header h1 {
    color: #dc3545;
    margin-bottom: 15px;
    font-weight: 700;
    font-size: 36px;
    letter-spacing: -0.5px;
}

.auth-header p {
    color: #666;
    font-size: 18px;
    line-height: 1.6;
}

/* Message d'erreur */
.error-message {
    background: linear-gradient(135deg, #fdf2f2 0%, #f8d7da 100%);
    border: 3px solid #f5c6cb;
    color: #721c24;
    padding: 35px 30px;
    border-radius: 20px;
    margin: 30px 0;
    box-shadow: 0 6px 20px rgba(220, 53, 69, 0.15);
    transition: all 0.3s ease;
}

.error-message h3 {
    margin-top: 0;
    margin-bottom: 20px;
    color: #721c24;
    font-weight: 700;
    font-size: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
}

.error-details {
    background: rgba(255, 255, 255, 0.8);
    padding: 20px;
    border-radius: 12px;
    margin: 20px 0;
    border-left: 4px solid #dc3545;
    text-align: left;
}

.error-details p {
    margin-bottom: 15px;
    font-size: 16px;
    line-height: 1.6;
    color: #721c24;
}

.validity-info {
    margin-top: 15px;
    padding: 15px;
    background: #f8f9fa;
    border-radius: 8px;
    border: 1px solid #e9ecef;
}

.validity-info small {
    color: #6c757d;
    display: flex;
    flex-direction: column;
    gap: 5px;
}

.validity-info i {
    margin-right: 8px;
    width: 16px;
}

/* Actions */
.error-actions {
    margin-top: 40px;
    display: flex;
    gap: 20px;
    justify-content: center;
    align-items: center;
}

.btn-danger {
    background: linear-gradient(135deg, #dc3545 0%, #c82333 100%);
    border: none;
    border-radius: 12px;
    color: white;
    padding: 18px 35px;
    font-size: 18px;
    font-weight: 600;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    min-width: 220px;
    box-shadow: 0 4px 15px rgba(220, 53, 69, 0.3);
}

.btn-danger:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 25px rgba(220, 53, 69, 0.4);
    color: white;
    text-decoration: none;
}

.btn-secondary {
    background: transparent;
    border: 3px solid #7566ea;
    color: #7566ea;
    padding: 16px 35px;
    border-radius: 12px;
    text-decoration: none;
    font-size: 18px;
    font-weight: 600;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    min-width: 220px;
    box-shadow: 0 4px 15px rgba(117, 102, 234, 0.1);
}

.btn-secondary:hover {
    background: #7566ea;
    color: white;
    text-decoration: none;
    transform: translateY(-3px);
    box-shadow: 0 8px 25px rgba(117, 102, 234, 0.3);
}

/* Informations sécurité */
.security-info {
    margin-top: 35px;
    padding: 20px;
    background: #f8f9fa;
    border-radius: 12px;
    border-left: 6px solid #6c757d;
    border-right: 1px solid #e9ecef;
    border-top: 1px solid #e9ecef;
    border-bottom: 1px solid #e9ecef;
    text-align: left;
}

.security-info small {
    color: #6c757d;
    font-size: 15px;
    line-height: 1.6;
}

.security-info strong {
    color: #495057;
}

.security-info ul {
    margin: 10px 0;
    padding-left: 20px;
}

.security-info li {
    margin-bottom: 5px;
}

/* Solution info */
.solution-info {
    margin-top: 20px;
    padding: 18px;
    background: #e7f3ff;
    border-radius: 10px;
    border-left: 4px solid #0066cc;
}

.solution-info small {
    color: #0066cc;
    font-size: 15px;
    line-height: 1.5;
    display: flex;
    align-items: center;
    gap: 8px;
}

/* Animations */
@keyframes shake {
    0%, 100% { 
        transform: translateX(0) rotate(0); 
    }
    10%, 30%, 50%, 70%, 90% { 
        transform: translateX(-8px) rotate(-5deg); 
    }
    20%, 40%, 60%, 80% { 
        transform: translateX(8px) rotate(5deg); 
    }
}

@keyframes pulse {
    0% { transform: scale(1); }
    50% { transform: scale(1.05); }
    100% { transform: scale(1); }
}

.pulse {
    animation: pulse 2s infinite;
}

/* Animation container principal */
.auth-container {
    animation: fadeInUp 0.6s ease-out;
}

@keyframes fadeInUp {
    from {
        opacity: 0;
        transform: translateY(30px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

/* Responsive Design */
@media (max-width: 768px) {
    .auth-container {
        width: 95%;
        max-width: 500px;
        min-height: auto;
        margin: 20px auto;
    }
    
    .auth-card {
        padding: 40px 30px;
        border-radius: 25px;
    }
    
    .auth-content {
        max-width: 100%;
    }
    
    .auth-header h1 {
        font-size: 28px;
    }
    
    .auth-header p {
        font-size: 16px;
    }
    
    .error-icon {
        width: 120px;
        height: 120px;
    }
    
    .error-icon i {
        font-size: 4rem;
    }
    
    .error-message {
        padding: 25px 20px;
    }
    
    .error-message h3 {
        font-size: 20px;
    }
    
    .error-actions {
        flex-direction: column;
        align-items: center;
        gap: 15px;
    }
    
    .btn-danger,
    .btn-secondary {
        width: 100%;
        max-width: 280px;
        min-width: auto;
        padding: 16px 25px;
        font-size: 16px;
    }
    
    .security-info,
    .solution-info {
        padding: 15px;
    }
    
    .security-info small,
    .solution-info small {
        font-size: 14px;
    }
}

@media (max-width: 480px) {
    .auth-container {
        width: 100%;
        border-radius: 0;
        min-height: 100vh;
        margin: 0;
    }
    
    .auth-card {
        border-radius: 0;
        padding: 30px 20px;
    }
    
    .auth-content {
        padding: 0 5px;
    }
    
    .error-icon {
        width: 100px;
        height: 100px;
    }
    
    .error-icon i {
        font-size: 3.5rem;
    }
    
    .auth-header h1 {
        font-size: 24px;
    }
    
    .error-message {
        padding: 20px 15px;
        margin: 20px 0;
    }
    
    .btn-danger,
    .btn-secondary {
        width: 100%;
        padding: 14px 20px;
    }
}

@media (min-width: 769px) and (max-width: 1024px) {
    .auth-container {
        max-width: 700px;
    }
    
    .auth-content {
        max-width: 500px;
    }
}

/* Effets de hover supplémentaires */
.btn-danger:active,
.btn-secondary:active {
    transform: translateY(-1px);
}

.error-message:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(220, 53, 69, 0.2);
}
</style>
{% endblock %}

{% block body %}
<div class="auth-container">
    <div class="auth-card">
        <div class="auth-content">
            <div class="error-container">
                <!-- Animation d'erreur -->
                <div class="error-icon pulse">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                </div>


                <div class="error-message">
                    <h3>
                        <i class="bi bi-x-circle-fill"></i>
                        Lien de réinitialisation invalide
                    </h3>
                    
                    <div class="error-details">
                        <p>
                            <strong>Raison :</strong><br>
                            {% if app.session.flashbag.peek('error')|first %}
                                {{ app.session.flashbag.get('error')|first }}
                            {% else %}
                                Ce lien de réinitialisation n'est plus valide.
                            {% endif %}
                        </p>
                        
                        <div class="validity-info">
                            <small>
                                <div><i class="bi bi-clock-history"></i><strong>Durée de validité :</strong> 1 heure</div>
                                <div><i class="bi bi-shield-exclamation"></i><strong>Usage :</strong> Unique</div>
                            </small>
                        </div>
                    </div>
                    <div class="solution-info">
                    <small>
                        <i class="bi bi-lightbulb"></i>
                        <strong>Solution :</strong> 
                        Faites une nouvelle demande de réinitialisation et utilisez le nouveau lien rapidement.
                    </small>
                </div>
                </div>

                <div class="error-actions">
                    <a href="{{ path('app_forgot_password') }}" class="btn-danger">
                        <i class="bi bi-arrow-repeat"></i>
                        &nbsp;Nouvelle demande
                    </a>
                    
                    <a href="{{ path('app_login') }}" class="btn-secondary">
                        <i class="bi bi-box-arrow-in-right"></i>
                        &nbsp;Page de connexion
                    </a>
                </div>

                {# <div class="security-info">
                    <small>
                        <i class="bi bi-info-circle"></i>
                        <strong>Pourquoi cette erreur ?</strong>
                        <ul>
                            <li>Le lien a expiré (valable 1 heure seulement)</li>
                            <li>Le lien a déjà été utilisé</li>
                            <li>Le lien est incorrect ou modifié</li>
                            <li>Pour votre sécurité, chaque lien est unique et temporaire</li>
                        </ul>
                    </small>
                </div> #}

                
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // Animation supplémentaire
    const errorIcon = document.querySelector('.error-icon');
    if (errorIcon) {
        setTimeout(() => {
            errorIcon.style.transform = 'rotate(-8deg)';
            setTimeout(() => {
                errorIcon.style.transform = 'rotate(8deg)';
                setTimeout(() => {
                    errorIcon.style.transform = 'rotate(0deg)';
                }, 200);
            }, 200);
        }, 1500);
    }
    
    // Animation du message d'erreur
    const errorMessage = document.querySelector('.error-message');
    if (errorMessage) {
        setTimeout(() => {
            errorMessage.style.transform = 'translateY(-5px) scale(1.02)';
            setTimeout(() => {
                errorMessage.style.transform = 'translateY(0) scale(1)';
            }, 300);
        }, 1000);
    }
});
</script>
{% endblock %}