{# templates/security/reset_password.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Réinitialisation du mot de passe - MIC PTA{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
/* Reset et styles de base */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    margin: 0;
    min-height: 100vh;
    background: linear-gradient(135deg, #964ee3 0%, #75165f 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
}

/* Container principal */
.auth-container {
    display: flex;
    width: 90%;
    max-width: 900px;
    min-height: 600px;
    border-radius: 35px;
    overflow: hidden;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.2);
}

/* Partie gauche - Bienvenue */
.auth-pre {
    position: relative;
    background: linear-gradient(135deg, #eada70 0%, #fd8617 100%);
    flex: 1;
    min-width: 300px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 30px;
}

/* Sceau en arrière-plan */
.auth-sceau {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.5;
    z-index: 1;
}

.auth-sceau img {
    width: 80%;
    height: auto;
    object-fit: contain;
}

/* Contenu par-dessus */
.auth-overlay {
    position: relative;
    z-index: 2;
    text-align: center;
    color: #fff;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
}

.auth-welcome .auth-logo {
    margin-bottom: 30px;
}

.auth-logo img {
    width: 100px;
    height: 60px;
    max-width: 100%;
}

.auth-welcome .auth-logo p {
    margin-top: 5px;
    font-size: .65rem;
    line-height: 1.1;
    white-space: nowrap;
    color: white;
    text-align: center;
}

/* Bloc de bienvenue */
.auth-welcome {
    text-align: center;
    color: #fff;
    z-index: 3;
    padding: 20px;
    background: rgba(0, 0, 0, 0.24);
    border-radius: 30px;
    backdrop-filter: blur(5px);
}

.auth-welcome p {
    font-size: 14px;
    margin: 0;
    line-height: 1.6;
    text-align: left;
}

/* Carte de réinitialisation */
.auth-card {
    background: white;
    flex: 1;
    min-width: 300px;
    padding: 40px 30px;
    display: flex;
    align-items: center;
    justify-content: center;
}

.auth-content {
    width: 100%;
    max-width: 320px;
}

.login-icon {
    width: 120px;
    height: 120px;
    background: linear-gradient(135deg, #964ee3 0%, #75165f 100%);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 25px auto;
    box-shadow: 0 8px 20px rgba(128, 102, 234, 0.3);
    border: 4px solid white;
}

.login-icon i {
    font-size: 4.5rem;
    color: white;
}

/* Effet de brillance au survol */
.login-icon:hover i {
    animation: pulse 1s infinite;
}

@keyframes pulse {
    0% { transform: scale(1); }
    50% { transform: scale(1.1); }
    100% { transform: scale(1); }
}

.auth-header {
    text-align: center;
    margin-bottom: 30px;
}

.auth-header h1 {
    color: #1d0933;
    margin-bottom: 10px;
    font-weight: 600;
    font-size: 28px;
}

.auth-header p {
    color: #666;
    font-size: 16px;
}

/* Exigences mot de passe */
.password-requirements {
    margin: 8px 0;
    padding: 12px;
    background: #f6effeff;
    border-radius: 8px;
    border: 1px solid #cb9dfdff;
}

.requirements-title {
    font-size: 11px;
    font-weight: 600;
    color: #495057;
    margin-bottom: 8px;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.requirements-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 6px;
}

.requirement {
    display: flex;
    align-items: center;
    font-size: 10px;
    padding: 4px 6px;
    border-radius: 4px;
    background: white;
    border: 1px solid #e9ecef;
    transition: all 0.3s ease;
}

.requirement i {
    font-size: 9px;
    margin-right: 4px;
}

.requirement.met {
    color: #198754;
    background: #f8fff9;
    border-color: #d1e7dd;
}

.requirement.unmet {
    color: #6c757d;
    background: #e8dcfaff;
}

.password-strength {
    margin-top: 8px;
    font-size: 12px;
}

.strength-bar {
    height: 4px;
    background-color: #e9ecef;
    border-radius: 2px;
    margin-bottom: 4px;
    overflow: hidden;
}

.strength-fill {
    height: 100%;
    width: 0%;
    transition: all 0.3s ease;
    border-radius: 2px;
}

.strength-weak .strength-fill { background-color: #dc3545; width: 25%; }
.strength-fair .strength-fill { background-color: #fd7e14; width: 50%; }
.strength-good .strength-fill { background-color: #ffc107; width: 75%; }
.strength-strong .strength-fill { background-color: #198754; width: 100%; }

.strength-text {
    font-size: 11px;
    color: #666;
}

/* Formulaire */
.form-group {
    margin-bottom: 20px;
}

.form-group label {
    display: block;
    margin-bottom: 8px;
    color: #333;
    font-weight: 500;
    font-size: 14px;
}

.form-control {
    width: 100%;
    padding: 12px 15px;
    border: 2px solid #e1e5e9;
    border-radius: 8px;
    font-size: 14px;
    transition: all 0.3s ease;
}

.form-control:focus {
    outline: none;
    border-color: #7566ea;
    box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
}

.form-control.is-invalid {
    border-color: #dc3545;
    box-shadow: 0 0 0 3px rgba(220, 53, 69, 0.1);
}

/* Styles pour le groupe mot de passe avec œil */
.password-group {
    position: relative;
}

.password-input-container {
    position: relative;
    display: flex;
    align-items: center;
}

.password-input {
    padding-right: 45px;
    width: 100%;
}

.password-toggle {
    position: absolute;
    right: 12px;
    background: none;
    border: none;
    cursor: pointer;
    color: #666;
    padding: 5px;
    border-radius: 4px;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
}

.password-toggle:hover {
    background-color: #f5f5f5;
    color: #333;
}

.password-toggle i {
    font-size: 1.1rem;
}

.btn-primary {
    width: 100%;
    padding: 14px;
    background: linear-gradient(135deg, #964ee3 0%, #75165f 100%);
    border: none;
    border-radius: 8px;
    color: white;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    margin-top: 10px;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
}

.btn-primary:hover:not(:disabled) {
    transform: translateY(-2px);
    box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
}

.btn-primary:disabled {
    opacity: 0.6;
    cursor: default;
    transform: none;
    box-shadow: none;
}

/* Footer */
.auth-footer {
    text-align: center;
    margin-top: 25px;
    padding-top: 20px;
    border-top: 1px solid #eee;
}

.auth-footer p {
    color: #666;
    font-size: 14px;
    margin-bottom: 10px;
}

.auth-footer a {
    color: #7566ea;
    text-decoration: none;
    font-weight: 500;
    transition: color 0.3s ease;
}

.auth-footer a:hover {
    text-decoration: underline;
    color: #8066ea;
}

/* Alertes */
.alert-error {
    background-color: #fee;
    border: 1px solid #fcc;
    color: #c33;
    padding: 12px;
    border-radius: 8px;
    margin-bottom: 20px;
    font-size: 14px;
    text-align: center;
}

.alert-success {
    background-color: #f0f9f0;
    border: 1px solid #4caf50;
    color: #2e7d32;
    padding: 12px;
    border-radius: 8px;
    margin-bottom: 20px;
    font-size: 14px;
    text-align: center;
}

.invalid-feedback {
    color: #dc3545;
    font-size: 12px;
    margin-top: 5px;
    display: block;
}

/* Spinner de chargement */
.loading-spinner {
    display: inline-block;
    width: 1rem;
    height: 1rem;
    border: 2px solid #f3f3f3;
    border-top: 2px solid #964ee3;
    border-radius: 50%;
    animation: spin 1s linear infinite;
}

@keyframes spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
}

/* Responsive Design */
@media (max-width: 768px) {
    .auth-container {
        flex-direction: column;
        width: 95%;
        max-width: 400px;
        min-height: auto;
    }
    
    .auth-pre {
        border-radius: 15px 15px 0 0;
        min-height: 300px;
        padding: 20px;
    }
    
    .auth-card {
        border-radius: 0 0 15px 15px;
        padding: 30px 20px;
    }
    
    .auth-welcome {
        padding: 15px;
    }
    
    .auth-welcome p {
        font-size: 13px;
    }
    
    .auth-header h1 {
        font-size: 24px;
    }
    
    .requirements-grid {
        grid-template-columns: 1fr;
    }
}

@media (max-width: 480px) {
    .auth-container {
        width: 100%;
        border-radius: 0;
        min-height: 100vh;
    }
    
    .auth-pre, .auth-card {
        border-radius: 0;
    }
    
    .auth-pre {
        min-height: 250px;
    }
    
    .auth-content {
        padding: 0 10px;
    }
    
    .auth-logo img {
        width: 100px;
    }
    
    .password-requirements {
        padding: 10px;
    }
}

/* Animation légère */
.auth-container {
    animation: fadeInUp 0.6s ease-out;
}

@keyframes fadeInUp {
    from {
        opacity: 0;
        transform: translateY(20px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}
</style>
{% endblock %}

{% block body %}
<div class="auth-container">
    <div class="auth-pre">
        <div class="auth-sceau">
            <img src="{{ asset('images/sceau.png') }}" alt="Sceau">
        </div>

        <div class="auth-overlay">      
            <div class="auth-welcome">
                <div class="auth-logo">
                    <img src="{{ asset('images/logo2.png') }}" alt="Logo">
                    <p>Ministère de l'Industrialisation et du Commerce</p>
                </div>
                
                <p>
                    Créez votre nouveau mot de passe.<br><br>
                    Assurez-vous qu'il respecte les exigences de sécurité 
                    pour protéger votre compte.
                </p>
            </div>
        </div>
    </div>
    
    <div class="auth-card">
        <div class="auth-content">
            <div class="login-icon">
                <i class="bi bi-shield-lock"></i>
            </div>
            <div class="auth-header">
                <h1>Nouveau mot de passe</h1>
                <p>Créez un nouveau mot de passe sécurisé</p>
            </div>

            {# {% for message in app.flashes('success') %}
                <div class="alert-success success-animation">
                    <i class="bi bi-check-circle-fill" style="font-size: 1.2em; margin-right: 8px;"></i>
                    {{ message }}
                </div>
            {% endfor %} #}

            {# {% for message in app.flashes('error') %}
                <div class="alert-error">
                    <i class="bi bi-exclamation-circle-fill" style="font-size: 1.2em; margin-right: 8px;"></i>
                    {{ message }}
                </div>
            {% endfor %}

            {% if errors is defined and errors is not empty %}
                <div class="alert-error">
                    <i class="bi bi-exclamation-triangle-fill" style="font-size: 1.2em; margin-right: 8px;"></i>
                    Veuillez corriger les erreurs ci-dessous
                </div>
            {% endif %} #}

            <form method="post" id="resetPasswordForm">
                <div class="form-group password-group">
                    <label for="password">Nouveau mot de passe</label>
                    
                    <div class="password-requirements" id="passwordRequirements">
                        <div class="requirements-title">
                            <span>Exigences de sécurité :</span>
                            <span id="requirementsStatus"></span>
                        </div>
                        <div class="requirements-grid">
                            <div class="requirement unmet" id="reqLength">
                                <i class="bi bi-circle"></i>
                                6+ caractères
                            </div>
                            <div class="requirement unmet" id="reqLowercase">
                                <i class="bi bi-circle"></i>
                                Minuscule
                            </div>
                            <div class="requirement unmet" id="reqUppercase">
                                <i class="bi bi-circle"></i>
                                Majuscule
                            </div>
                            <div class="requirement unmet" id="reqNumber">
                                <i class="bi bi-circle"></i>
                                Chiffre
                            </div>
                            <div class="requirement unmet" id="reqSpecial">
                                <i class="bi bi-circle"></i>
                                Caractères spéciaux (@$!%*?&)
                            </div>
                        </div>
                    </div>
                    
                    <div class="password-input-container">
                        <input 
                            type="password" 
                            name="password" 
                            id="password" 
                            class="form-control password-input {% if errors.password is defined or errors.password_mismatch is defined %}is-invalid{% endif %}" 
                            required
                            minlength="6"
                            placeholder="Votre nouveau mot de passe"
                            value="{{ formData.password ?? '' }}"
                        >
                        <button type="button" class="password-toggle" id="passwordToggle">
                            <i class="bi bi-eye-slash"></i>
                        </button>
                    </div>
                    
                    <div class="password-strength" id="passwordStrength">
                        <div class="strength-bar">
                            <div class="strength-fill"></div>
                        </div>
                        <div class="strength-text" id="strengthText">Saisissez votre mot de passe</div>
                    </div>
                    
                    {% if errors.password is defined %}
                        <div class="invalid-feedback">
                            {{ errors.password }}
                        </div>
                    {% endif %}
                </div>

                <div class="form-group password-group">
                    <label for="confirm_password">Confirmer le mot de passe</label>
                    <div class="password-input-container">
                        <input 
                            type="password" 
                            name="confirm_password" 
                            id="confirm_password" 
                            class="form-control password-input {% if errors.password_mismatch is defined %}is-invalid{% endif %}" 
                            required
                            placeholder="Confirmez votre mot de passe"
                            value="{{ formData.confirm_password ?? '' }}"
                        >
                        <button type="button" class="password-toggle" id="confirmPasswordToggle">
                            <i class="bi bi-eye-slash"></i>
                        </button>
                    </div>
                    
                    {% if errors.password_mismatch is defined %}
                        <div class="invalid-feedback">
                            {{ errors.password_mismatch }}
                        </div>
                    {% endif %}
                    
                    {% if errors.confirm_password is defined %}
                        <div class="invalid-feedback">
                            {{ errors.confirm_password }}
                        </div>
                    {% endif %}
                </div>

                <button type="submit" class="btn-primary" id="submitButton">
                    <span id="buttonText">Réinitialiser le mot de passe</span>
                    <div class="loading-spinner" id="submitSpinner" style="display: none;"></div>
                </button>
            </form>

            <div class="auth-footer">
                <p><a href="{{ path('app_login') }}">← Retour à la connexion</a></p>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const passwordInput = document.getElementById('password');
    const confirmPasswordInput = document.getElementById('confirm_password');
    const submitButton = document.getElementById('submitButton');
    const buttonText = document.getElementById('buttonText');
    const submitSpinner = document.getElementById('submitSpinner');
    const resetPasswordForm = document.getElementById('resetPasswordForm');
    
    // Toggle pour le mot de passe principal
    const passwordToggle = document.getElementById('passwordToggle');
    const eyeIcon = passwordToggle.querySelector('i');
    
    passwordToggle.addEventListener('click', function() {
        const type = passwordInput.getAttribute('type') === 'password' ? 'text' : 'password';
        passwordInput.setAttribute('type', type);
        
        if (type === 'text') {
            eyeIcon.classList.remove('bi-eye-slash');
            eyeIcon.classList.add('bi-eye');
        } else {
            eyeIcon.classList.remove('bi-eye');
            eyeIcon.classList.add('bi-eye-slash');
        }
    });

    // Toggle pour la confirmation du mot de passe
    const confirmPasswordToggle = document.getElementById('confirmPasswordToggle');
    const confirmEyeIcon = confirmPasswordToggle.querySelector('i');
    
    confirmPasswordToggle.addEventListener('click', function() {
        const type = confirmPasswordInput.getAttribute('type') === 'password' ? 'text' : 'password';
        confirmPasswordInput.setAttribute('type', type);
        
        if (type === 'text') {
            confirmEyeIcon.classList.remove('bi-eye-slash');
            confirmEyeIcon.classList.add('bi-eye');
        } else {
            confirmEyeIcon.classList.remove('bi-eye');
            confirmEyeIcon.classList.add('bi-eye-slash');
        }
    });

    // Validation de la force du mot de passe
    function checkPasswordStrength(password) {
        let strength = 0;
        const requirements = {
            length: password.length >= 6,
            lowercase: /[a-z]/.test(password),
            uppercase: /[A-Z]/.test(password),
            number: /[0-9]/.test(password),
            special: /[@$!%*?&]/.test(password)
        };

        const metCount = Object.values(requirements).filter(Boolean).length;
        const totalCount = Object.keys(requirements).length;

        // Mettre à jour les indicateurs visuels
        Object.keys(requirements).forEach(key => {
            const element = document.getElementById(`req${key.charAt(0).toUpperCase() + key.slice(1)}`);
            if (element) {
                if (requirements[key]) {
                    element.classList.remove('unmet');
                    element.classList.add('met');
                    element.innerHTML = '<i class="bi bi-check-circle-fill"></i>' + element.innerHTML.substring(element.innerHTML.indexOf('>') + 1);
                } else {
                    element.classList.remove('met');
                    element.classList.add('unmet');
                    element.innerHTML = '<i class="bi bi-circle"></i>' + element.innerHTML.substring(element.innerHTML.indexOf('>') + 1);
                }
            }
        });

        // Mettre à jour le statut des exigences
        const requirementsStatus = document.getElementById('requirementsStatus');
        if (password.length === 0) {
            requirementsStatus.textContent = '';
            requirementsStatus.style.color = '#6c757d';
        } else if (metCount === totalCount) {
            requirementsStatus.textContent = '✓ Complètes';
            requirementsStatus.style.color = '#198754';
        } else {
            requirementsStatus.textContent = `${metCount}/${totalCount}`;
            requirementsStatus.style.color = '#fd7e14';
        }

        // Mettre à jour la barre de force
        const strengthBar = document.getElementById('passwordStrength');
        const strengthText = document.getElementById('strengthText');
        
        strengthBar.className = 'password-strength';
        
        if (password.length === 0) {
            strengthText.textContent = 'Saisissez votre mot de passe';
        } else if (metCount <= 2) {
            strengthBar.classList.add('strength-weak');
            strengthText.textContent = 'Faible - Améliorez votre mot de passe';
        } else if (metCount <= 3) {
            strengthBar.classList.add('strength-fair');
            strengthText.textContent = 'Moyen - Peut être amélioré';
        } else if (metCount <= 4) {
            strengthBar.classList.add('strength-good');
            strengthText.textContent = 'Bon - Mot de passe sécurisé';
        } else {
            strengthBar.classList.add('strength-strong');
            strengthText.textContent = 'Très fort - Excellent mot de passe';
        }
    }

    // Écouter les changements du mot de passe
    passwordInput.addEventListener('input', function() {
        checkPasswordStrength(this.value);
    });

    // Gestion de la soumission du formulaire
    resetPasswordForm.addEventListener('submit', function() {
        // Désactiver le bouton et afficher le spinner
        submitButton.disabled = true;
        buttonText.textContent = 'Réinitialisation en cours...';
        submitSpinner.style.display = 'inline-block';
    });

    // Réactiver le formulaire si la page est rechargée depuis le cache (retour arrière)
    window.addEventListener('pageshow', function(event) {
        if (event.persisted || (window.performance && window.performance.navigation.type === 2)) {
            submitButton.disabled = false;
            buttonText.textContent = 'Réinitialiser le mot de passe';
            submitSpinner.style.display = 'none';
            
            const inputs = resetPasswordForm.querySelectorAll('input');
            inputs.forEach(input => {
                input.disabled = false;
            });
        }
    });

    // Initialiser la validation
    checkPasswordStrength(passwordInput.value);
});
</script>
{% endblock %}