{# templates/security/reset_password_success.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Mot de passe réinitialisé - MIC PTA{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
/* Reset et styles de base */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    margin: 0;
    min-height: 100vh;
    background: linear-gradient(135deg, #964ee3 0%, #75165f 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
}

/* Container principal */
.auth-container {
    display: flex;
    width: 95%;
    max-width: 900px;
    min-height: 500px;
    border-radius: 35px;
    overflow: hidden;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.2);
}

/* Carte de succès */
.auth-card {
    background: white;
    width: 100%;
    padding: 60px 50px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 35px;
}

.auth-content {
    width: 100%;
    max-width: 600px;
}

/* Container succès */
.success-container {
    text-align: center;
    width: 100%;
}

/* Icône de succès */
.success-icon {
    width: 140px;
    height: 140px;
    background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 40px auto;
    box-shadow: 0 12px 30px rgba(40, 167, 69, 0.4);
    border: 8px solid white;
    animation: bounceIn 1s ease-out;
}

.auth-header {
    text-align: center;
    margin-bottom: 40px;
}

.auth-header h1 {
    color: #1d0933;
    margin-bottom: 15px;
    font-weight: 700;
    font-size: 36px;
    letter-spacing: -0.5px;
}

.auth-header p {
    color: #666;
    font-size: 18px;
    line-height: 1.6;
}

/* Message de succès */
.success-message {
    background: linear-gradient(135deg, #f8fff9 0%, #f0f9f0 100%);
    border: 3px solid #d1e7dd;
    color: #155724;
    padding: 35px 30px;
    border-radius: 20px;
    margin: 30px 0;
    box-shadow: 0 6px 20px rgba(40, 167, 69, 0.15);
    transition: all 0.3s ease;
}

.success-message h3 {
    margin-top: 0;
    margin-bottom: 20px;
    color: #155724;
    font-weight: 700;
    font-size: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
}

.success-message p {
    margin-bottom: 0;
    font-size: 18px;
    line-height: 1.7;
    color: #155724;
    text-align: center;
}

/* Actions */
.success-actions {
    margin-top: 40px;
    display: flex;
    gap: 20px;
    justify-content: center;
    align-items: center;
}

.btn-success {
    background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
    border: none;
    border-radius: 12px;
    color: white;
    padding: 18px 35px;
    font-size: 18px;
    font-weight: 600;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    min-width: 220px;
    box-shadow: 0 4px 15px rgba(40, 167, 69, 0.3);
}

.btn-success:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 25px rgba(40, 167, 69, 0.4);
    color: white;
    text-decoration: none;
}

.btn-secondary {
    background: transparent;
    border: 3px solid #7566ea;
    color: #7566ea;
    padding: 16px 35px;
    border-radius: 12px;
    text-decoration: none;
    font-size: 18px;
    font-weight: 600;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    min-width: 220px;
    box-shadow: 0 4px 15px rgba(117, 102, 234, 0.1);
}

.btn-secondary:hover {
    background: #7566ea;
    color: white;
    text-decoration: none;
    transform: translateY(-3px);
    box-shadow: 0 8px 25px rgba(117, 102, 234, 0.3);
}

/* Conseil sécurité */
.security-tip {
    margin-top: 35px;
    padding: 20px;
    background: #f8f9fa;
    border-radius: 12px;
    border-left: 6px solid #7566ea;
    border-right: 1px solid #e9ecef;
    border-top: 1px solid #e9ecef;
    border-bottom: 1px solid #e9ecef;
}

.security-tip small {
    color: #6c757d;
    font-size: 15px;
    line-height: 1.6;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
}

.security-tip strong {
    color: #495057;
}

/* Animations */
@keyframes bounceIn {
    0% {
        opacity: 0;
        transform: scale(0.3);
    }
    50% {
        opacity: 1;
        transform: scale(1.05);
    }
    70% {
        transform: scale(0.95);
    }
    100% {
        opacity: 1;
        transform: scale(1);
    }
}

/* Animation checkmark SVG */
.checkmark__circle {
    stroke-dasharray: 166;
    stroke-dashoffset: 166;
    stroke-width: 3;
    stroke-miterlimit: 10;
    stroke: #28a745;
    fill: none;
    animation: stroke 0.6s cubic-bezier(0.65, 0, 0.45, 1) forwards;
}

.checkmark {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    display: block;
    stroke-width: 3;
    stroke: #fff;
    stroke-miterlimit: 10;
    margin: 0 auto;
    box-shadow: inset 0px 0px 0px #28a745;
    animation: fill .4s ease-in-out .4s forwards, scale .3s ease-in-out .9s both;
}

.checkmark__check {
    transform-origin: 50% 50%;
    stroke-dasharray: 48;
    stroke-dashoffset: 48;
    animation: stroke 0.3s cubic-bezier(0.65, 0, 0.45, 1) 0.8s forwards;
}

@keyframes stroke {
    100% {
        stroke-dashoffset: 0;
    }
}

@keyframes scale {
    0%, 100% {
        transform: none;
    }
    50% {
        transform: scale3d(1.1, 1.1, 1);
    }
}

@keyframes fill {
    100% {
        box-shadow: inset 0px 0px 0px 50px #28a745;
    }
}

/* Animation container principal */
.auth-container {
    animation: fadeInUp 0.6s ease-out;
}

@keyframes fadeInUp {
    from {
        opacity: 0;
        transform: translateY(30px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

/* Responsive Design */
@media (max-width: 768px) {
    .auth-container {
        width: 95%;
        max-width: 500px;
        min-height: auto;
        margin: 20px auto;
    }
    
    .auth-card {
        padding: 40px 30px;
        border-radius: 25px;
    }
    
    .auth-content {
        max-width: 100%;
    }
    
    .auth-header h1 {
        font-size: 28px;
    }
    
    .auth-header p {
        font-size: 16px;
    }
    
    .success-icon {
        width: 120px;
        height: 120px;
    }
    
    .checkmark {
        width: 80px;
        height: 80px;
    }
    
    .success-message {
        padding: 25px 20px;
    }
    
    .success-message h3 {
        font-size: 20px;
    }
    
    .success-message p {
        font-size: 16px;
    }
    
    .success-actions {
        flex-direction: column;
        align-items: center;
        gap: 15px;
    }
    
    .btn-success,
    .btn-secondary {
        width: 100%;
        max-width: 280px;
        min-width: auto;
        padding: 16px 25px;
        font-size: 16px;
    }
    
    .security-tip {
        padding: 15px;
    }
    
    .security-tip small {
        font-size: 14px;
    }
}

@media (max-width: 480px) {
    .auth-container {
        width: 100%;
        border-radius: 0;
        min-height: 100vh;
        margin: 0;
    }
    
    .auth-card {
        border-radius: 0;
        padding: 30px 20px;
    }
    
    .auth-content {
        padding: 0 5px;
    }
    
    .success-icon {
        width: 100px;
        height: 100px;
    }
    
    .checkmark {
        width: 70px;
        height: 70px;
    }
    
    .auth-header h1 {
        font-size: 24px;
    }
    
    .success-message {
        padding: 20px 15px;
        margin: 20px 0;
    }
    
    .btn-success,
    .btn-secondary {
        width: 100%;
        padding: 14px 20px;
    }
}

@media (min-width: 769px) and (max-width: 1024px) {
    .auth-container {
        max-width: 700px;
    }
    
    .auth-content {
        max-width: 500px;
    }
}

/* Effets de hover supplémentaires */
.btn-success:active,
.btn-secondary:active {
    transform: translateY(-1px);
}

.success-message:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(40, 167, 69, 0.2);
}
</style>
{% endblock %}

{% block body %}
<div class="auth-container">
    <div class="auth-card">
        <div class="auth-content">
            <div class="success-container">
                <!-- Animation de succès -->
                <div class="success-icon">
                    <svg class="checkmark" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 52 52">
                        <circle class="checkmark__circle" cx="26" cy="26" r="25" fill="none"/>
                        <path class="checkmark__check" fill="none" d="M14.1 27.2l7.1 7.2 16.7-16.8"/>
                    </svg>
                </div>

                <div class="success-message">
                    <h3>
                        Réinitialisation réussie !
                    </h3>
                    <p>
                        Votre mot de passe a été réinitialisé avec succès.<br>
                        Vous pouvez maintenant vous connecter avec votre nouveau mot de passe.
                    </p>
                </div>

                <div class="success-actions">
                    <a href="{{ path('app_login') }}" class="btn-success">
                        <i class="bi bi-box-arrow-in-right"></i>
                        &nbsp;Se connecter
                    </a>
                </div>

                <div class="security-tip">
                    <small>
                        <i class="bi bi-shield-check"></i>
                        <strong>Conseil de sécurité :</strong> Utilisez un mot de passe unique que vous n'utilisez nulle part ailleurs.
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // Animation supplémentaire pour le succès
    const successMessage = document.querySelector('.success-message');
    if (successMessage) {
        setTimeout(() => {
            successMessage.style.transform = 'translateY(-5px) scale(1.02)';
            setTimeout(() => {
                successMessage.style.transform = 'translateY(0) scale(1)';
            }, 300);
        }, 1000);
    }
});
</script>
{% endblock %}