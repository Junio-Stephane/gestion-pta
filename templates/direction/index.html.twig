/* Responsive pour mobile - Priorité au dropdown */
@media (max-width: 768px) {
    .actions-container {
        flex-direction: row;
        gap: 0.3rem;
        min-height: auto;
        width: 100%;
        justify-content: center;
        flex-wrap: wrap;
    }
    
    .btn {
        min-width: 70px;
        padding: 0.2rem 0.4rem;
        font-size: 0.65rem;
    }
    
    /* Dropdown spécifique pour mobile */
