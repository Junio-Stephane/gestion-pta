        position: static; /* Important pour le responsive */
    }
    
    .dropdown .btn {
        min-width: 70px;
        font-size: 0.65rem;
        padding: 0.2rem 0.4rem;
    }
    
    .dropdown-menu {
        position: absolute;
        left: 50% !important;
        transform: translateX(-50%) !important;
        min-width: 180px;
        z-index: 1050;
    }
    
    /* Ajustement spécifique pour la colonne Actions */
