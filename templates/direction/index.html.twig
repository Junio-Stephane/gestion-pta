    width: 32px;
    height: 32px;
    background: linear-gradient(135deg, #964ee3 0%, #75165f 100%);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-weight: 600;
    font-size: 0.75rem;
}

.user-info-cell {
    display: flex;
    align-items: center;
    gap: 0.75rem;
}

/* Badge désactivé pour les personnels */
.badge-desactive {
    background: #e5e7eb;
    color: #6b7280;
    padding: 0.25rem 0.5rem;
    border-radius: 6px;
    font-size: 0.7rem;
    margin-left: 0.5rem;
}

/* Options désactivées dans les selects */
.option-desactive {
    color: #63676dff;
    font-style: italic;
}

/* Styles pour la colonne email fixe */
.table-directions th:nth-child(5),
.table-directions td:nth-child(5) {
    width: 200px !important;
    min-width: 200px !important;
    max-width: 200px !important;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

/* Styles pour les colonnes Attribution et Statut */
.table-directions th:nth-child(6),
.table-directions td:nth-child(6),
.table-directions th:nth-child(7),
.table-directions td:nth-child(7) {
    width: 120px;
    min-width: 120px;
    white-space: normal;
    word-wrap: break-word;
}

/* Ajustement pour la colonne Actions */
.table-directions th:nth-child(8),
.table-directions td:nth-child(8) {
    width: 220px;
    min-width: 220px;
    max-width: 220px;
}

/* Style spécifique pour les badges d'attribution et statut */
.attribution-badge, .status-badge {
    display: inline-block;
    text-align: center;
    padding: 0.4rem 0.6rem;
    border-radius: 20px;
    font-size: 0.7rem;
    font-weight: 600;
    line-height: 1.2;
    white-space: normal;
    word-break: break-word;
    max-width: 100%;
}

/* Badge spécifique pour "Non défini" */
.attribution-badge {
    background: #6b7280 !important;
    color: white !important;
}

/* Hover effect pour voir l'email complet */
.table-directions td:nth-child(5):hover {
    overflow: visible;
    white-space: normal;
    background: #f8f9fa;
    z-index: 1;
    position: relative;
}

/* Styles pour les filtres et la recherche */
.filters-container {
    background: #f3f3fbff;
    border-radius: 8px;
    padding: 1.5rem;
    margin-bottom: 1rem;
    border: 1px solid #e5e7eb;
    box-shadow: rgba(0, 0, 0, 0.12) 0px 1px 3px, rgba(0, 0, 0, 0.13) 0px 1px 2px;
}

.filter-row {
    display: flex;
    gap: 1rem;
    align-items: end;
    flex-wrap: wrap;
}

.filter-group {
    flex: 1;
    min-width: 200px;
}

.search-group {
    flex: 2;
    min-width: 300px;
}

.filter-group label,
.search-group label {
    font-weight: 500;
    color: #374151;
    margin-bottom: 0.5rem;
    display: block;
    font-size: 0.875rem;
}

.filter-group .form-control,
.filter-group .form-select,
.search-group .form-control {
    padding: 0.4rem 0.75rem;
    height: 38px;
    font-size: 0.85rem;
    line-height: 1.3;
}

.filter-actions {
    display: flex;
    gap: 0.5rem;
}

/* Pagination compacte */
.pagination-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 1rem;
    padding: 0.75rem 0;
    border-top: 1px solid #e5e7eb;
}

.pagination-info {
    color: #6b7280;
    font-size: 0.8rem;
}

.pagination {
    margin: 0;
    gap: 0.25rem;
}

.page-item .page-link {
    padding: 0.3rem 0.5rem;
    border: 1px solid #d1d5db;
    color: #374151;
    background: white;
    font-size: 0.8rem;
    min-width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    border-radius: 6px;
}

/* Réduire encore plus pour les boutons précédent/suivant */
.page-item .page-link i {
    font-size: 0.7rem;
}

/* États */
.page-item.active .page-link {
    background: linear-gradient(135deg, #964ee3 0%, #8b1970ff 100%);    border-color: #964ee3;
    color: white;
}

.page-item.disabled .page-link {
    color: #9ca3af;
    background: #f9fafb;
    cursor: not-allowed;
}

.page-link:hover:not(.disabled) {
    background: #f3f4f6;
    color: #1f2937;
}

/* Ajoutez ceci dans votre section CSS */
#nouvelleDirectionMutation:disabled {
    background-color: #f8f9fa;
    color: #6c757d;
    cursor: default;
}

#nouvelleDirectionMutation option:disabled {
    color: #6c757d;
    font-style: italic;
}

/* Style pour le bouton désactivé */
#submitMutation:disabled {
    background: linear-gradient(135deg, #6b7280 0%, #4b5563 100%);
    color: #d1d5db;
    border-color: #6b7280;
    cursor: default;
}

/* Position fixe pour les alertes */
.fixed-alert-container {
    position: fixed;
    top: 100px;
    right: 20px;
    z-index: 9999;
    max-width: 400px;
    animation: slideInRight 0.3s ease-out;
}

@keyframes slideInRight {
    from {
        transform: translateX(100%);
        opacity: 0;
    }
    to {
        transform: translateX(0);
        opacity: 1;
    }
}

.alert-success-fixed {
    background: linear-gradient(135deg, #10b981 0%, #059669 100%);
    color: white;
    border: none;
    border-radius: 10px;
    padding: 1rem 1.25rem;
    box-shadow: 0 8px 25px rgba(16, 185, 129, 0.3);
    border-left: 4px solid #047857;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    animation: fadeIn 0.3s ease-out;
}

.alert-danger-fixed {
    background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
    color: white;
    border: none;
    border-radius: 10px;
    padding: 1rem 1.25rem;
    box-shadow: 0 8px 25px rgba(239, 68, 68, 0.3);
    border-left: 4px solid #b91c1c;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    animation: fadeIn 0.3s ease-out;
}

.alert-success-fixed i,
.alert-danger-fixed i {
    font-size: 1.2rem;
}

.alert-close-btn {
    background: none;
    border: none;
    color: white;
    opacity: 0.8;
    padding: 0.25rem;
    margin-left: auto;
    cursor: pointer;
    transition: opacity 0.2s ease;
}

.alert-close-btn:hover {
    opacity: 1;
}

@keyframes fadeIn {
    from {
        opacity: 0;
        transform: translateY(-10px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

@keyframes fadeOut {
    from {
        opacity: 1;
        transform: translateX(0);
    }
    to {
        opacity: 0;
        transform: translateX(100%);
    }
}

/* Responsive adjustments */
@media (max-width: 768px) {
    .table-directions th:nth-child(5),
    .table-directions td:nth-child(5) {
        width: 150px !important;
        min-width: 150px !important;
        max-width: 150px !important;
    }
    
    .table-directions th:nth-child(6),
    .table-directions td:nth-child(6),
    .table-directions th:nth-child(7),
    .table-directions td:nth-child(7) {
        width: 100px;
        min-width: 100px;
    }
    
    .attribution-badge, .status-badge {
        font-size: 0.65rem;
        padding: 0.3rem 0.5rem;
    }

    .filter-row {
        flex-direction: column;
    }

    .filter-group,
    .search-group {
        min-width: 100%;
    }

    .filter-actions {
        width: 100%;
        justify-content: flex-end;
    }

    .pagination-container {
        flex-direction: column;
        gap: 1rem;
        text-align: center;
    }
}

/* Responsive */
@media (max-width: 768px) {
    .directions-container {
        padding: 1rem;
    }
    
    .table-directions {
        font-size: 0.875rem;
    }
    
    .table-directions th,
    .table-directions td {
        padding: 0.75rem 0.5rem;
    }
    
    .actions-container {
        flex-direction: column;
        gap: 0.25rem;
        min-height: auto;
        width: 100%;
    }
    
    .btn {
        width: 100%;
        justify-content: center;
        min-width: auto;
    }
    
    .table-directions th:nth-child(8),
    .table-directions td:nth-child(8) {
        width: 200px;
        min-width: 200px;
        max-width: 200px;
    }
    
    .modal-content {
        margin: 10% auto;
        width: 95%;
    }
    
    .section-header {
        flex-direction: column;
        gap: 1rem;
        align-items: flex-start;
    }
}
</style>
{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    <div id="fixedAlertContainer" class="fixed-alert-container"></div>
    <!-- En-tête -->
    <div class="directions-container">
        <div class="section-header">
            <div>
                <h1 class="section-title">
                    <i class="bi bi-building"></i>
                    Liste des Directions
                </h1>
                <p class="text-muted mb-0">Gérez les directions et leurs directeurs</p>
            </div>
            <button class="btnG btn-primary btn-lg" data-bs-toggle="modal" data-bs-target="#addDirectionModal">
                <i class="bi bi-plus-circle me-2"></i>
                Ajouter une direction
            </button>
        </div>

        <!-- Filtres et recherche -->
        <div class="filters-container">
            <div class="filter-row">
                <div class="filter-group">
                    <label for="statutFilter">Filtrer par statut</label>
                    <select class="form-select" id="statutFilter">
                        <option value="">Tous les statuts</option>
                        <option value="ACTIVE">Active</option>
                        <option value="EN_ATTENTE">En attente</option>
                        <option value="DESACTIVEE">Désactivée</option>
                    </select>
                </div>
                
                <div class="filter-group">
                    <label for="attributionFilter">Filtrer par attribution</label>
                    <select class="form-select" id="attributionFilter">
                        <option value="">Toutes les attributions</option>
                        <option value="AVEC_DIRECTEUR">Avec directeur</option>
                        <option value="SANS_DIRECTEUR">Sans directeur</option>
                    </select>
                </div>
                
                <div class="search-group">
                    <label for="searchInput">Recherche</label>
                    <input type="text" class="form-control" id="searchInput" 
                           placeholder="Rechercher par nom, email, matricule ou code direction...">
                </div>
                
                <div class="filter-actions">
                    <button type="button" class="btnG btn-secondary btn-sm" id="resetFilters">
                        <i class="bi bi-arrow-clockwise"></i>
                        Réinitialiser
                    </button>
                </div>
            </div>
        </div>

        <!-- Tableau des directions -->
       <div class="table-responsive">
            <table class="table-directions">
                <thead>
                    <tr>
                        <th>CODE</th>
                        <th>NOM DE LA DIRECTION</th>
                        <th>DIRECTEUR</th>
                        <th>IMMATRICULE</th>
                        <th>EMAIL</th>
                        <th>ATTRIBUTION</th>
                        <th>STATUT</th>
                        <th style="text-align: center;">ACTIONS</th>
                    </tr>
                </thead>
                <tbody id="directionsTableBody">
                    <!-- Les données seront chargées via JavaScript -->
                    <tr>
                        <td colspan="8" class="text-center py-4">
                            <div class="loading-spinner me-2"></div>
                            Chargement des directions...
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        <div class="pagination-container">
            <div class="pagination-info" id="paginationInfo">
                Affichage de 0 à 0 sur 0 directions
            </div>
            <nav>
                <ul class="pagination" id="pagination">
                    <!-- La pagination sera générée via JavaScript -->
                </ul>
            </nav>
        </div>
    </div>
</div>

<!-- Modal Ajouter Direction -->
<div class="modal fade" id="addDirectionModal" tabindex="-1" aria-labelledby="addDirectionModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-building-add"></i>
                    Nouvelle Direction
                </h5>
                <button type="button" class="btn-close-custom" data-bs-dismiss="modal" aria-label="Close">
                    <i class="bi bi-x"></i>
                </button>
            </div>
            <div class="modal-body">
                <form id="addDirectionForm">
                    <div class="consigne">
                        <h5><i class="bi bi-info-circle"></i> Information</h5>
                        <p>Les champs marqués d'un * sont obligatoires. Vous pourrez assigner un directeur plus tard si nécessaire.</p>
                    </div>

                    <div class="form-group">
                        <label for="codeDirection" class="form-label">Code Direction *</label>
                        <input type="text" class="form-control" id="codeDirection" name="codeDirection" required
                               placeholder="Ex: DIR001" maxlength="20">
                        <!-- Message d'erreur pour le code -->
                        <div class="invalid-feedback" id="codeDirectionError"></div>
                    </div>

                    <div class="form-group">
                        <label for="nomDirection" class="form-label">Nom de la Direction *</label>
                        <input type="text" class="form-control" id="nomDirection" name="nomDirection" required
                               placeholder="Ex: Direction des Ressources Humaines" maxlength="50">
                        <!-- Message d'erreur pour le nom -->
                        <div class="invalid-feedback" id="nomDirectionError"></div>
                    </div>

                    <div class="form-group">
    <label for="personnel" class="form-label">Directeur</label>
    <select class="form-select search-select" id="personnel" name="personnel">
        <option value="">Sélectionnez un directeur</option>
    </select>
    <div class="invalid-feedback" id="personnelError"></div>
</div>
                    
                    <div class="modal-footer">
                        <button type="button" class="btnG btn-secondary" data-bs-dismiss="modal">Annuler</button>
                        <button type="submit" class="btnG btn-primary" id="submitAddDirection">
                            <i class="bi bi-check-circle me-2"></i>
                            Créer la direction
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Modal Modifier Direction -->
<div class="modal fade" id="modifierDirectionModal" tabindex="-1" aria-labelledby="modifierDirectionModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-pencil-square"></i>
                    Modifier la Direction
                </h5>
                <button type="button" class="btn-close-custom" data-bs-dismiss="modal" aria-label="Close">
                    <i class="bi bi-x"></i>
                </button>
            </div>
            <div class="modal-body">
                <form id="modifierDirectionForm">
                    <div class="consigne">
                        <h5><i class="bi bi-info-circle"></i> Information</h5>
                        <p>Modifiez le nom de la direction et/ou changez le directeur. Sélectionnez "Aucun directeur" pour désaffecter le directeur.</p>
                    </div>

                    <input type="hidden" id="modifierDirectionCode" name="codeDirection">
                    
                    <div class="form-group">
                        <label for="modifierCodeDirection" class="form-label">Code Direction</label>
                        <input type="text" class="form-control" id="modifierCodeDirection" readonly>
                        {# <div class="form-text">Le code direction ne peut pas être modifié</div> #}
                    </div>

                    <div class="form-group">
                        <label for="modifierNomDirection" class="form-label">Nom de la Direction *</label>
                        <input type="text" class="form-control" id="modifierNomDirection" name="nomDirection" required
                               placeholder="Ex: Direction des Ressources Humaines" maxlength="50">
                        <!-- Message d'erreur pour le nom -->
                        <div class="invalid-feedback" id="modifierNomDirectionError"></div>
                    </div>

                    <div class="form-group">
    <label for="modifierDirecteur" class="form-label">Directeur</label>
    <select class="form-select search-select" id="modifierDirecteur" name="personnel">
        <option value="">Aucun directeur</option>
    </select>
    <div class="invalid-feedback" id="modifierDirecteurError"></div>
</div>
                    
                    <div class="modal-footer">
                        <button type="button" class="btnG btn-secondary" data-bs-dismiss="modal">Annuler</button>
                        <button type="submit" class="btnG btn-primary" id="submitModifierDirection">
                            <i class="bi bi-check-circle me-2"></i>
                            Enregistrer les modifications
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Modal Mutation -->
<div class="modal fade" id="mutationModal" tabindex="-1" aria-labelledby="mutationModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-people"></i>
                    Mutation de Directeur
                </h5>
                <button type="button" class="btn-close-custom" data-bs-dismiss="modal" aria-label="Close">
                    <i class="bi bi-x"></i>
                </button>
            </div>
            <div class="modal-body">
                <form id="mutationForm">
                    <div class="consigne consigne-warning">
                        <h5><i class="bi bi-exclamation-triangle"></i> Attention</h5>
                        <p>Cette action va réaffecter le directeur vers la nouvelle direction selectionnée et mettre son ancienne direction en attente de nouveau directeur.</p>
                    </div>
                    
                    <input type="hidden" id="directeurImMutation" name="directeur">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="directeurMutation" class="form-label">Directeur à muter *</label>
                                <input type="text" class="form-control" id="directeurMutation" readonly>
                                {# <small class="form-text text-muted">Directeur sélectionné</small> #}
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
    <label for="nouvelleDirectionMutation" class="form-label">Nouvelle Direction *</label>
    <select class="form-select search-select" id="nouvelleDirectionMutation" name="nouvelleDirection" required>
        <option value="">Chargement des directions...</option>
    </select>
</div>
                        </div>
                    </div>
                    
                    <div class="modal-footer">
                        <button type="button" class="btnG btn-secondary" data-bs-dismiss="modal">Annuler</button>
                        <button type="submit" class="btnG btn-primary" id="submitMutation">
                            <i class="bi bi-check-circle me-2"></i>
                            Confirmer la réaffectation
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Modal Confirmation Désactivation -->
<div class="modal fade" id="confirmationDesactivationModal" tabindex="-1" aria-labelledby="confirmationDesactivationModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-exclamation-triangle"></i>
                    Confirmation de désactivation
                </h5>
                <button type="button" class="btn-close-custom" data-bs-dismiss="modal" aria-label="Close">
                    <i class="bi bi-x"></i>
                </button>
            </div>
            <div class="modal-body">
                <div class="consigneD consigne-danger">
                    <h5><i class="bi bi-x-circle"></i> Désactivation</h5>
                    <p id="confirmationDesactivationMessage">
                        Êtes-vous sûr de vouloir désactiver cette direction ? Cette action désactivera également tous les services et personnels associés.
                    </p>
                </div>
                <div class="mt-3">
                    <small class="text-muted">Direction concernée :</small>
                    <span id="directionNomDesactivation" class="fw-bold mb-1"></span>
                </div>
                <div>
                    <small class="text-muted">Code :</small>
                    <span id="directionCodeDesactivation" class="fw-bold mb-1"></span>
                </div>
                {# <div id="desactivationDetails" class="mt-3">
                    <small class="text-muted">
                        <i class="bi bi-info-circle"></i>
                        Cette action est réversible. La direction pourra être réactivée ultérieurement.
                    </small>
                </div> #}
            </div>
            <div class="modal-footer">
                <button type="button" class="btnG btn-secondary" data-bs-dismiss="modal">
                    Annuler
                </button>
                <button type="button" class="btnG btn-dangerG" id="confirmDesactiverDirection">
                    <i class="bi bi-x-circle me-2"></i>
                    Confirmer la désactivation
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Activation -->
<div class="modal fade" id="activationModal" tabindex="-1" aria-labelledby="activationModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-check-circle"></i>
                    Activation de Direction
                </h5>
                <button type="button" class="btn-close-custom" data-bs-dismiss="modal" aria-label="Close">
                    <i class="bi bi-x"></i>
                </button>
            </div>
            <div class="modal-body">
                <form id="activationForm">
                    <div class="consigne consigne-success">
                        <h5><i class="bi bi-check-circle"></i> Activation</h5>
                        <p>Vous allez réactiver cette direction. Choisissez comment gérer le directeur.</p>
                    </div>

                    <input type="hidden" id="activationDirectionCode" name="codeDirection">
                    
                    <div class="form-group">
                        <label class="form-label">Direction</label>
                        <input type="text" class="form-control" id="activationDirectionNom" readonly>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Ancien directeur</label>
                        <input type="text" class="form-control" id="activationAncienDirecteur" readonly>
                        <div class="form-text" id="activationDirecteurInfo"></div>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Options d'activation</label>
                        <div class="mt-2">
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="radio" name="activationOption" id="garderDirecteur" value="garder" checked>
                                <label class="form-check-label" for="garderDirecteur">
                                    Garder l'ancien directeur
                                </label>
                                <div class="form-text">Réactiver l'ancien directeur et le réassigner à cette direction</div>
                            </div>
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="radio" name="activationOption" id="choisirDirecteur" value="choisir">
                                <label class="form-check-label" for="choisirDirecteur">
                                    Choisir un nouveau directeur
                                </label>
                                <div class="form-text">Sélectionner un nouveau directeur parmi les personnels disponibles</div>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="activationOption" id="aucunDirecteur" value="aucun">
                                <label class="form-check-label" for="aucunDirecteur">
                                    Aucun directeur pour le moment
                                </label>
                                <div class="form-text">Activer la direction sans directeur (en attente)</div>
                            </div>
                        </div>
                    </div>

                    <div class="form-group" id="nouveauDirecteurGroup" style="display: none;">
    <label for="activationNouveauDirecteur" class="form-label">Nouveau Directeur</label>
    <select class="form-select search-select" id="activationNouveauDirecteur" name="nouveauDirecteur">
        <option value="">Sélectionnez un directeur</option>
    </select>
</div>
                    
                    <div class="modal-footer">
                        <button type="button" class="btnG btn-secondary" data-bs-dismiss="modal">Annuler</button>
                        <button type="submit" class="btnG btn-successG" id="submitActivation">
                            <i class="bi bi-check-circle me-2"></i>
                            Activer la direction
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script>
class DirectionManager {
    constructor() {
        this.currentPage = 1;
        this.itemsPerPage = 5;
        this.totalItems = 0;
        this.allDirections = [];
        this.filteredDirections = [];
        this.currentFilters = {
            statut: '',
            attribution: '',
            search: ''
        };
        this.init();
        this.currentDirectionCode = null;
        this.currentDirecteurInfo = null;
    }

// Dans la classe DirectionManager, remplacez les méthodes initSelect2 et loadPersonnelsActifs

initSelect2() {
    // Fonction d'initialisation générique pour Select2
    const initSelect = (selector, options = {}) => {
        const defaultOptions = {
            theme: 'bootstrap-5',
            width: '100%',
            placeholder: 'Rechercher...',
            allowClear: true,
            dropdownParent: $(selector).closest('.modal').length ? $(selector).closest('.modal') : $(document.body),
            language: {
                noResults: () => "Aucun résultat trouvé",
                searching: () => "Recherche en cours..."
            }
        };
        
        return $(selector).select2({ ...defaultOptions, ...options });
    };

    // Initialiser tous les selects
    this.selects = {
        personnel: initSelect('#personnel'),
        modifierDirecteur: initSelect('#modifierDirecteur', { placeholder: 'Rechercher un directeur...' }),
        activationNouveauDirecteur: initSelect('#activationNouveauDirecteur', { placeholder: 'Rechercher un nouveau directeur...' }),
        nouvelleDirectionMutation: initSelect('#nouvelleDirectionMutation', { placeholder: 'Rechercher une direction...' })
    };

    // Gérer la fermeture des modaux
    $('.modal').on('hidden.bs.modal', () => {
        Object.values(this.selects).forEach(select => {
            if (select && $.fn.select2) {
                select.select2('close');
            }
        });
    });

    // Réinitialiser quand le modal s'ouvre
    $('.modal').on('show.bs.modal', () => {
        setTimeout(() => {
            Object.values(this.selects).forEach(select => {
                if (select && $.fn.select2) {
                    select.trigger('change.select2');
                }
            });
        }, 100);
    });

    console.log('✅ Select2 initialisé sur tous les selects');
}

async loadPersonnelsActifs() {
    try {
        const response = await fetch('/admin/directions/api/personnels-selections');
        const data = await response.json();
        
        if (data.success) {
            const select = this.selects.personnel;
            if (!select) return;
            
            // Vider et réinitialiser
            select.empty();
            select.append('<option value=""></option>');
            
            // Ajouter l'option "Aucun directeur"
            select.append('<option value="AUCUN">Aucun directeur</option>');
            
            data.personnels.forEach(personnel => {
                const desactive = personnel.StatutPer === 'DESACTIVE';
                let suffix = '';
                
                if (desactive) {
                    if (personnel.FonctionPer === 'Directeur') {
                        suffix = ' (Directeur désactivé)';
                    } else if (personnel.FonctionPer === 'Chef_service') {
                        suffix = ' (Chef désactivé)';
                    } else {
                        suffix = ' (Agent désactivé)';
                    }
                }
                
                const optionText = `${personnel.NomPer} ${personnel.PrenomPer} - ${personnel.ImPer}${suffix}`;
                const option = new Option(optionText, personnel.ImPer, false, false);
                
                if (desactive) {
                    $(option).addClass('option-desactive');
                }
                
                select.append(option);
            });
            
            // Mettre à jour Select2
            select.trigger('change.select2');
        }
    } catch (error) {
        console.error('Erreur chargement personnels actifs:', error);
    }
}

