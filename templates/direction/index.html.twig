async loadDirectionsEnAttente() {
    try {
        const response = await fetch('/admin/directions/api/directions-en-attente');
        const data = await response.json();

        if (data.success) {
            const select = this.selects.nouvelleDirectionMutation;
            if (!select) return;
            
            select.empty();
            
            if (data.directions && data.directions.length > 0) {
                select.append('<option value=""></option>');
                
                data.directions.forEach(direction => {
                    const optionText = `${direction.nomDirection} (${direction.CodeDirection})`;
                    const option = new Option(optionText, direction.CodeDirection, false, false);
                    select.append(option);
                });
                
                select.prop('disabled', false);
            } else {
                select.append('<option value="">Aucune direction disponible</option>');
                select.prop('disabled', true);
            }
            
            select.trigger('change.select2');
        }
    } catch (error) {
        console.error('Erreur chargement directions en attente:', error);
        
        const select = this.selects.nouvelleDirectionMutation;
        if (select) {
            select.empty();
            select.append('<option value="">Aucune direction disponible</option>');
            select.prop('disabled', true);
            select.trigger('change.select2');
        }
    }
}

// Modifiez la méthode init() pour inclure initSelect2
init() {
    this.loadDirections();
    this.setupEventListeners();
    this.setupModalResetListeners();
    this.initSelect2(); // Initialiser Select2 avant de charger les données
    this.loadPersonnelsActifs();
}

    async loadDirections() {
        try {
            const response = await fetch('/admin/directions/api/list');
            const data = await response.json();
            
            if (data.success) {
                this.allDirections = data.directions;
                this.applyFilters();
            } else {
                this.showError(data.message);
            }
        } catch (error) {
            console.error('Erreur chargement directions:', error);
            this.showError('Erreur lors du chargement des directions');
        }
    }

    applyFilters() {
        let filtered = [...this.allDirections];

        // Filtre par statut
        if (this.currentFilters.statut) {
            filtered = filtered.filter(direction => 
                direction.statutDirection === this.currentFilters.statut
            );
        }

        // Filtre par attribution
        if (this.currentFilters.attribution) {
            if (this.currentFilters.attribution === 'AVEC_DIRECTEUR') {
                filtered = filtered.filter(direction => direction.personnel !== null);
            } else if (this.currentFilters.attribution === 'SANS_DIRECTEUR') {
                filtered = filtered.filter(direction => direction.personnel === null);
            }
        }

        // Filtre par recherche
        if (this.currentFilters.search) {
            const searchTerm = this.currentFilters.search.toLowerCase();
            filtered = filtered.filter(direction => {
                const directeur = direction.personnel;
                return (
                    direction.CodeDirection.toLowerCase().includes(searchTerm) ||
                    direction.nomDirection.toLowerCase().includes(searchTerm) ||
                    (directeur && (
                        directeur.NomPer.toLowerCase().includes(searchTerm) ||
                        directeur.PrenomPer.toLowerCase().includes(searchTerm) ||
                        (directeur.EmailPer && directeur.EmailPer.toLowerCase().includes(searchTerm)) ||
                        (directeur.ImPer && directeur.ImPer.toLowerCase().includes(searchTerm))
                    ))
                );
            });
        }

        this.filteredDirections = filtered;
        this.totalItems = filtered.length;
        this.currentPage = 1;
        this.renderDirections();
        this.renderPagination();
    }

    getPaginatedDirections() {
        const startIndex = (this.currentPage - 1) * this.itemsPerPage;
        const endIndex = startIndex + this.itemsPerPage;
        return this.filteredDirections.slice(startIndex, endIndex);
    }

    renderDirections() {
        const directions = this.getPaginatedDirections();
        const tbody = document.getElementById('directionsTableBody');
        
        if (!directions || directions.length === 0) {
            tbody.innerHTML = `
                <tr>
                    <td colspan="8" class="text-center py-4 text-muted">
                        <i class="bi bi-building-x" style="font-size: 2rem;"></i>
                        <p class="mt-2">Aucune direction trouvée</p>
                        ${this.hasActiveFilters() ? 
                            '<p class="text-sm">Essayez de modifier vos critères de recherche</p>' : 
                            ''
                        }
                    </td>
                </tr>
            `;
            return;
        }

        

        tbody.innerHTML = directions.map(direction => {
            const directeur = direction.personnel;
            const nomDirecteur = directeur ? 
                `${this.escapeHtml(directeur.NomPer)} ${this.escapeHtml(directeur.PrenomPer)}` : 
                'Aucun directeur';

            const fonctionDirecteur = directeur ? directeur.FonctionPer : null;
            const estDesactivee = direction.statutDirection === 'DESACTIVEE';
            const directeurDesactive = directeur && directeur.StatutPer === 'DESACTIVE';
            const rowClass = estDesactivee ? 'direction-desactivee' : '';
            
            
            const statutBadge = estDesactivee ? 
                '<span class="status-badge status-desactive">Désactivée</span>' :
                (direction.statutDirection === 'ACTIVE' ? 
                    '<span class="status-badge status-active">Active</span>' : 
                    '<span class="status-badge status-waiting">En attente</span>'
                );
            
            const fonctionBadge = directeur ? 
                `<span class="status-badge ${directeurDesactive ? 'role-badge-desactive' : 'role-badge'}">
                    ${this.capitalizeFirstLetter(fonctionDirecteur)}${directeurDesactive ? '' : ''}
                </span>` : 
                '<span class="status-badge" style="background: #6b7280; color: white;">Non défini</span>';

            return `
                <tr class="direction-item ${rowClass}" id="direction-${direction.CodeDirection}">
                    <td style="width: 50px;"><strong>${direction.CodeDirection}</strong></td>
                    <td style="width: 150px;">${this.escapeHtml(direction.nomDirection)}</td>
                    <td>
                        ${directeur ? 
                            `<div class="user-info-cell">
                                <div>${nomDirecteur}</div>
                            </div>` : 
                            '<span class="text-muted">Aucun directeur</span>'
                        }
                    </td>
                    <td>${directeur ? (directeur.ImPer || 'Aucun') : 'Aucun'}</td>
                    <td style="width: 50px !important;">${directeur ? (directeur.EmailPer || 'Aucun') : 'Aucun'}</td>
                    <td style="width: 120px;">
                        ${fonctionBadge}
                    </td>
                    <td style="width: 120px;">
                        ${statutBadge}
                    </td>
                    <td>
                        <div>
                            ${!estDesactivee ? 
                                (directeur ? 
                                    `<div class="dropdown">
                                        <button class="btn btn-warning dropdown-toggle" type="button" 
                                            data-bs-toggle="dropdown" aria-expanded="false">
                                            <i class="bi bi-pencil"></i>
                                            Modifier
                                        </button>
                                        <ul class="dropdown-menu">
                                            <li>
                                                <a class="dropdown-item" href="#" 
                                                   onclick="directionManager.openModifierDirectionModal(
                                                       '${direction.CodeDirection}', 
                                                       '${this.escapeHtml(direction.nomDirection)}', 
                                                       '${directeur.ImPer}', 
                                                       '${this.escapeHtml(nomDirecteur)}'
                                                   )">
                                                    <i class="bi bi-pencil-square me-2"></i>
                                                    Modifier la direction
                                                </a>
                                            </li>
                                            <li>
                                                <a class="dropdown-item" href="#" 
                                                   onclick="directionManager.openMutationModal(
                                                       '${direction.CodeDirection}', 
                                                       '${this.escapeHtml(direction.nomDirection)}', 
                                                       '${directeur.ImPer}', 
                                                       '${this.escapeHtml(nomDirecteur)}'
                                                   )">
                                                    <i class="bi bi-people me-2"></i>
                                                    Réaffecter le directeur
                                                </a>
                                            </li>
                                        </ul>
                                    </div>` :
                                    `<button type="button" class="btn btn-warning"
                                        onclick="directionManager.openModifierDirectionModal(
                                            '${direction.CodeDirection}', 
                                            '${this.escapeHtml(direction.nomDirection)}', 
                                            null, 
                                            'Aucun directeur'
                                        )">
                                        <i class="bi bi-pencil"></i>
                                        Modifier
                                    </button>`
                                ) :
                                `<button type="button" class="btn btn-warning" disabled>
                                    <i class="bi bi-pencil"></i>
                                    Modifier
                                </button>`
                            }
                            
                            ${estDesactivee ? 
                                `<button type="button" class="btn btn-success"
                                    onclick="directionManager.openActivationModal(
                                        '${direction.CodeDirection}', 
                                        '${this.escapeHtml(direction.nomDirection)}',
                                        '${directeur ? this.escapeHtml(nomDirecteur) : 'Aucun directeur'}',
                                        '${directeur ? directeur.ImPer : ''}'
                                    )">
                                    <i class="bi bi-check-circle"></i>
                                    Activer
                                </button>` :
                                `<button type="button" class="btn btn-danger" 
                                    onclick="directionManager.openConfirmationDesactivationModal(
                                        '${direction.CodeDirection}', 
                                        '${this.escapeHtml(direction.nomDirection)}'
                                    )">
                                    <i class="bi bi-x-circle"></i>
                                    Désactiver
                                </button>`
                                
                            }
                        </div>
                    </td>
                </tr>
            `;
        }).join('');
    }

    renderPagination() {
        const totalPages = Math.ceil(this.totalItems / this.itemsPerPage);
        const paginationElement = document.getElementById('pagination');
        const paginationInfoElement = document.getElementById('paginationInfo');

        const startItem = (this.currentPage - 1) * this.itemsPerPage + 1;
        const endItem = Math.min(this.currentPage * this.itemsPerPage, this.totalItems);
        
        paginationInfoElement.textContent = 
            `Affichage de ${startItem} à ${endItem} sur ${this.totalItems} direction${this.totalItems !== 1 ? 's' : ''}`;

        let paginationHTML = '';

        paginationHTML += `
            <li class="page-item ${this.currentPage === 1 ? 'disabled' : ''}">
                <a class="page-link" href="#" onclick="directionManager.changePage(${this.currentPage - 1})">
                    <i class="bi bi-chevron-left"></i>
                </a>
            </li>
        `;

        for (let i = 1; i <= totalPages; i++) {
            if (i === 1 || i === totalPages || (i >= this.currentPage - 1 && i <= this.currentPage + 1)) {
                paginationHTML += `
                    <li class="page-item ${i === this.currentPage ? 'active' : ''}">
                        <a class="page-link" href="#" onclick="directionManager.changePage(${i})">${i}</a>
                    </li>
                `;
            } else if (i === this.currentPage - 2 || i === this.currentPage + 2) {
                paginationHTML += `<li class="page-item disabled"><span class="page-link">...</span></li>`;
            }
        }

        paginationHTML += `
            <li class="page-item ${this.currentPage === totalPages ? 'disabled' : ''}">
                <a class="page-link" href="#" onclick="directionManager.changePage(${this.currentPage + 1})">
                    <i class="bi bi-chevron-right"></i>
                </a>
            </li>
        `;

        paginationElement.innerHTML = paginationHTML;
    }

    changePage(page) {
        if (page < 1 || page > Math.ceil(this.totalItems / this.itemsPerPage)) {
            return;
        }
        this.currentPage = page;
        this.renderDirections();
        this.renderPagination();
        
        document.querySelector('.table-responsive').scrollIntoView({ 
            behavior: 'smooth', 
            block: 'start' 
        });
    }

    hasActiveFilters() {
        return this.currentFilters.statut || this.currentFilters.attribution || this.currentFilters.search;
    }

    escapeHtml(unsafe) {
        if (!unsafe) return '';
        return unsafe
            .replace(/&/g, "&amp;")
            .replace(/</g, "&lt;")
            .replace(/>/g, "&gt;")
            .replace(/"/g, "&quot;")
            .replace(/'/g, "&#039;");
    }

    setupEventListeners() {
        // Formulaire ajout direction
        document.getElementById('addDirectionForm').addEventListener('submit', (e) => {
            e.preventDefault();
            this.ajouterDirection();
        });

        // Filtres
        document.getElementById('statutFilter').addEventListener('change', (e) => {
            this.currentFilters.statut = e.target.value;
            this.applyFilters();
        });

        document.getElementById('attributionFilter').addEventListener('change', (e) => {
            this.currentFilters.attribution = e.target.value;
            this.applyFilters();
        });

        document.getElementById('searchInput').addEventListener('input', (e) => {
            this.currentFilters.search = e.target.value;
            clearTimeout(this.searchTimeout);
            this.searchTimeout = setTimeout(() => {
                this.applyFilters();
            }, 300);
        });

        document.getElementById('resetFilters').addEventListener('click', () => {
            this.resetFilters();
        });

        // Formulaire modifier direction
        document.getElementById('modifierDirectionForm').addEventListener('submit', (e) => {
            e.preventDefault();
            this.modifierDirection();
        });

        // Formulaire activation
        document.getElementById('activationForm').addEventListener('submit', (e) => {
            e.preventDefault();
            this.activerDirection();
        });

        // Formulaire mutation
        document.getElementById('mutationForm').addEventListener('submit', (e) => {
            e.preventDefault();
            this.effectuerMutation();
        });

        // Confirmation désactivation
        document.getElementById('confirmDesactiverDirection').addEventListener('click', () => {
            this.confirmDesactiverDirection();
        });

        // Gestion des options d'activation
        document.querySelectorAll('input[name="activationOption"]').forEach(radio => {
            radio.addEventListener('change', (e) => {
                this.toggleNouveauDirecteurGroup(e.target.value);
            });
        });

        // Charger les personnels quand les modaux s'ouvrent
        document.getElementById('addDirectionModal').addEventListener('show.bs.modal', () => {
            this.clearModalErrors('add');
            this.loadPersonnelsActifs();
        });
        
        document.getElementById('modifierDirectionModal').addEventListener('show.bs.modal', () => {
            this.clearModalErrors('modify');
            this.loadPersonnelsPourModification().then(() => {
                if (this.currentDirecteurInfo && this.currentDirecteurInfo.im) {
                    const select = document.getElementById('modifierDirecteur');
                    
                    // Vérifier si l'option existe déjà
                    const optionExists = Array.from(select.options).some(option => 
                        option.value === this.currentDirecteurInfo.im
                    );
                    
                    if (!optionExists) {
                        // Ajouter l'option sans le suffixe "(Directeur actuel)"
                        select.innerHTML += `<option value="${this.currentDirecteurInfo.im}" selected>${this.currentDirecteurInfo.nom}</option>`;
                    } else {
                        select.value = this.currentDirecteurInfo.im;
                    }
                }
                this.currentDirecteurInfo = null;
            });
        });

        document.getElementById('activationModal').addEventListener('show.bs.modal', () => {
            this.loadPersonnelsPourActivation();
        });

        // Effacer les erreurs quand l'utilisateur tape dans les champs
        document.getElementById('codeDirection')?.addEventListener('input', () => {
            this.clearFieldError('codeDirection');
        });
        
        document.getElementById('nomDirection')?.addEventListener('input', () => {
            this.clearFieldError('nomDirection');
        });

        document.getElementById('personnel')?.addEventListener('change', () => {
            this.clearFieldError('personnel');
        });

        document.getElementById('modifierNomDirection')?.addEventListener('input', () => {
            this.clearFieldError('modifierNomDirection');
        });

        document.getElementById('modifierDirecteur')?.addEventListener('change', () => {
            this.clearFieldError('modifierDirecteur');
        });
    }

    setupModalResetListeners() {
    // Modal d'ajout
    document.getElementById('addDirectionModal').addEventListener('hidden.bs.modal', () => {
        const form = document.getElementById('addDirectionForm');
        form.reset();
        this.clearModalErrors('add');
        
        // Réinitialiser l'état du bouton
        const submitBtn = document.getElementById('submitAddDirection');
        submitBtn.disabled = false;
        submitBtn.innerHTML = '<i class="bi bi-check-circle me-2"></i> Créer la direction';
    });
    
    // Modal de modification
    document.getElementById('modifierDirectionModal').addEventListener('hidden.bs.modal', () => {
        const form = document.getElementById('modifierDirectionForm');
        form.reset();
        this.clearModalErrors('modify');
        
        // Réinitialiser le select
        const select = document.getElementById('modifierDirecteur');
        select.innerHTML = '<option value="">Aucun directeur</option>';
        
        // Réinitialiser l'état du bouton
        const submitBtn = document.getElementById('submitModifierDirection');
        submitBtn.disabled = false;
        submitBtn.innerHTML = '<i class="bi bi-check-circle me-2"></i> Enregistrer les modifications';
        
        this.currentDirecteurInfo = null;
    });
    
    // Modal de mutation
    document.getElementById('mutationModal').addEventListener('hidden.bs.modal', () => {
        const form = document.getElementById('mutationForm');
        form.reset();
        
        // Réinitialiser le select
        const directionsSelect = document.getElementById('nouvelleDirectionMutation');
        directionsSelect.innerHTML = '<option value="">Chargement des directions...</option>';
        directionsSelect.disabled = false;
        
        // Réactiver le bouton
        const submitBtn = document.getElementById('submitMutation');
        submitBtn.disabled = false;
        submitBtn.innerHTML = '<i class="bi bi-check-circle me-2"></i> Confirmer la réaffectation';
    });
    
    // Modal de confirmation de désactivation
    document.getElementById('confirmationDesactivationModal').addEventListener('hidden.bs.modal', () => {
        // Réinitialiser le bouton
        const confirmBtn = document.getElementById('confirmDesactiverDirection');
        confirmBtn.innerHTML = '<i class="bi bi-x-circle me-2"></i> Confirmer la désactivation';
        confirmBtn.disabled = false;
        
        this.currentDirectionCode = null;
    });
    
    // Modal d'activation
    document.getElementById('activationModal').addEventListener('hidden.bs.modal', () => {
        const form = document.getElementById('activationForm');
        form.reset();
        
        // Réinitialiser les options
        document.getElementById('garderDirecteur').checked = true;
        document.getElementById('garderDirecteur').disabled = false;
        document.querySelector('label[for="garderDirecteur"]').innerHTML = 'Garder l\'ancien directeur';
        
        document.getElementById('choisirDirecteur').disabled = false;
        document.querySelector('label[for="choisirDirecteur"]').innerHTML = 'Choisir un nouveau directeur';
        
        this.toggleNouveauDirecteurGroup('garder');
        
        // Réinitialiser le select
        const select = document.getElementById('activationNouveauDirecteur');
        select.innerHTML = '<option value="">Sélectionnez un directeur</option>';
        select.disabled = false;
        
        // Réinitialiser l'état du bouton
        const submitBtn = document.getElementById('submitActivation');
        submitBtn.disabled = false;
        submitBtn.innerHTML = '<i class="bi bi-check-circle me-2"></i> Activer la direction';
    });
}

    resetFilters() {
        document.getElementById('statutFilter').value = '';
        document.getElementById('attributionFilter').value = '';
        document.getElementById('searchInput').value = '';

        const resetBtn = document.getElementById('resetFilters');
        const originalText = resetBtn.innerHTML;
        resetBtn.innerHTML = '<i class="bi bi-check"></i> Réinitialisé !';
        resetBtn.style.background = '#10b981';
        
        setTimeout(() => {
            resetBtn.innerHTML = originalText;
            resetBtn.style.background = '';
        }, 1500);
        
        this.currentFilters = {
            statut: '',
            attribution: '',
            search: ''
        };
        
        this.applyFilters();
    }

    capitalizeFirstLetter(string) {
        if (!string) return '';
        return string.charAt(0).toUpperCase() + string.slice(1);
    }

    showMultipleErrors(errors) {
        Object.keys(errors).forEach(fieldKey => {
            const errorMessage = errors[fieldKey];
            
            const fieldMapping = {
                'codeDirection': 'codeDirection',
                'nomDirection': 'nomDirection',
                'personnel': 'personnel'
            };
            
            const modifierFieldMapping = {
                'nomDirection': 'modifierNomDirection',
                'personnel': 'modifierDirecteur'
            };
            
            const addModal = document.getElementById('addDirectionModal');
            const modifyModal = document.getElementById('modifierDirectionModal');
            
            if (addModal && addModal.classList.contains('show')) {
                if (fieldMapping[fieldKey]) {
                    this.showFieldError(fieldMapping[fieldKey], errorMessage);
                }
            } else if (modifyModal && modifyModal.classList.contains('show')) {
                if (modifierFieldMapping[fieldKey]) {
                    this.showFieldError(modifierFieldMapping[fieldKey], errorMessage);
                }
            }
        });
    }

    showFieldError(fieldId, errorMessage) {
        const field = document.getElementById(fieldId);
        const errorElement = document.getElementById(fieldId + 'Error');
        
        if (field && errorElement) {
            field.classList.add('is-invalid');
            errorElement.textContent = errorMessage;
            errorElement.style.display = 'block';
        }
    }

    clearFieldError(fieldId) {
        const field = document.getElementById(fieldId);
        const errorElement = document.getElementById(fieldId + 'Error');
        
        if (field) {
            field.classList.remove('is-invalid');
        }
        if (errorElement) {
            errorElement.textContent = '';
            errorElement.style.display = 'none';
        }
    }

    clearModalErrors(modalType) {
        if (modalType === 'add') {
            this.clearFieldError('codeDirection');
            this.clearFieldError('nomDirection');
            this.clearFieldError('personnel');
        } else if (modalType === 'modify') {
            this.clearFieldError('modifierNomDirection');
            this.clearFieldError('modifierDirecteur');
        }
    }

