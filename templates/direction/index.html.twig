    }
    
    /* Pour les très petits écrans */
    @media (max-width: 576px) {
        .actions-container {
            flex-direction: column;
            gap: 0.2rem;
        }
        
        .dropdown-menu {
            position: fixed;
            top: 50% !important;
            left: 50% !important;
            transform: translate(-50%, -50%) !important;
            width: 90%;
            max-width: 250px;
        }
        
