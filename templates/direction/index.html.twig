/* Dropdown responsive */
.dropdown {
    display: inline-flex;
    position: relative;
}

.dropdown-menu {
    min-width: 200px;
    border-radius: 8px;
    border: 1px solid #e5e7eb;
    box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    background: #fffdf5ff;
