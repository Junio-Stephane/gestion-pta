    async loadPersonnelsPourModification() {
    try {
        const response = await fetch('/admin/directions/api/personnels-selections');
        const data = await response.json();
        
        if (data.success) {
            const select = this.selects.modifierDirecteur;
            if (!select) return;
            
            select.empty();
            select.append('<option value=""></option>');
            
            // Ajouter l'option "Aucun directeur"
            select.append('<option value="AUCUN">Aucun directeur</option>');
            
            data.personnels.forEach(personnel => {
                const desactive = personnel.StatutPer === 'DESACTIVE';
                let suffix = '';
                
                if (desactive) {
                    if (personnel.FonctionPer === 'Directeur') {
                        suffix = ' (Directeur désactivé)';
                    } else if (personnel.FonctionPer === 'Chef_service') {
                        suffix = ' (Chef désactivé)';
                    } else {
                        suffix = ' (Agent désactivé)';
                    }
                }
                
                const optionText = `${personnel.NomPer} ${personnel.PrenomPer} - ${personnel.ImPer}${suffix}`;
                const option = new Option(optionText, personnel.ImPer, false, false);
                
                if (desactive) {
                    $(option).addClass('option-desactive');
                }
                
                select.append(option);
            });
            
            // Mettre à jour Select2
            select.trigger('change.select2');
            
            // Sélectionner le directeur actuel si existe
            if (this.currentDirecteurInfo && this.currentDirecteurInfo.im) {
                select.val(this.currentDirecteurInfo.im).trigger('change');
            } else if (this.currentDirecteurInfo && this.currentDirecteurInfo.nom === 'Aucun directeur') {
                // Si aucun directeur, sélectionner l'option "Aucun directeur"
                select.val('AUCUN').trigger('change');
            }
        }
    } catch (error) {
        console.error('Erreur chargement personnels:', error);
    }
}

async loadPersonnelsPourActivation() {
    try {
        const directionCode = document.getElementById('activationDirectionCode').value;
        const response = await fetch(`/admin/directions/api/personnels-pour-activation?directionCode=${directionCode}`);
        const data = await response.json();
        
        if (data.success) {
            const select = this.selects.activationNouveauDirecteur;
            if (!select) return;
            
            const ancienDirecteurIm = data.ancienDirecteurIm;
            
            select.empty();
            select.append('<option value=""></option>');
            
            
            if (data.personnels && data.personnels.length > 0) {
                data.personnels.forEach(personnel => {
                    // Exclure l'ancien directeur de la liste des nouveaux
                    if (personnel.ImPer === ancienDirecteurIm) return;
                    
                    const desactive = personnel.StatutPer === 'DESACTIVE';
                    let suffix = '';
                    
                    if (desactive) {
                        if (personnel.FonctionPer === 'Directeur') {
                            suffix = ' (Directeur désactivé)';
                        } else if (personnel.FonctionPer === 'Chef_service') {
                            suffix = ' (Chef désactivé)';
                        } else {
                            suffix = ' (Agent désactivé)';
                        }
                    }
                    
                    const optionText = `${personnel.NomPer} ${personnel.PrenomPer} - ${personnel.ImPer}${suffix}`;
                    const option = new Option(optionText, personnel.ImPer, false, false);
                    
                    if (desactive) {
                        $(option).addClass('option-desactive');
                    }
                    
                    select.append(option);
                });
                
                // Activer/désactiver selon le nombre d'options
                if (select.find('option').length <= 2) { // +1 pour l'option "Aucun directeur"
                    select.prop('disabled', true);
                    document.getElementById('choisirDirecteur').disabled = true;
                    
                    if (document.getElementById('garderDirecteur').disabled) {
                        document.getElementById('aucunDirecteur').checked = true;
                        this.toggleNouveauDirecteurGroup('aucun');
                    }
                } else {
                    select.prop('disabled', false);
                    document.getElementById('choisirDirecteur').disabled = false;
                }
            } else {
                select.append('<option value="">Aucun directeur disponible</option>');
                select.prop('disabled', true);
                document.getElementById('choisirDirecteur').disabled = true;
                document.getElementById('aucunDirecteur').checked = true;
                this.toggleNouveauDirecteurGroup('aucun');
            }
            
            select.trigger('change.select2');
        }
    } catch (error) {
        console.error('Erreur chargement personnels pour activation:', error);
    }
}
    
    async ajouterDirection() {
        const form = document.getElementById('addDirectionForm');
        const submitBtn = document.getElementById('submitAddDirection');
        const originalText = submitBtn.innerHTML;

        try {
            this.clearModalErrors('add');
            
            submitBtn.innerHTML = '<div class="loading-spinner me-2"></div> Création...';
            submitBtn.disabled = true;

            const formData = new FormData(form);
            const data = {
                codeDirection: formData.get('codeDirection'),
                nomDirection: formData.get('nomDirection'),
                personnel: formData.get('personnel') || null
            };

            const response = await fetch('/admin/directions/api/create', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify(data)
            });

            const result = await response.json();

            if (result.success) {
                this.showSuccess(result.message);
                bootstrap.Modal.getInstance(document.getElementById('addDirectionModal')).hide();
                form.reset();
                this.loadDirections();
            } else {
                if (result.errors) {
                    this.showMultipleErrors(result.errors);
                } else {
                    this.showError(result.message);
                }
            }
        } catch (error) {
            console.error('Erreur création direction:', error);
            this.showError('Erreur lors de la création de la direction');
        } finally {
            submitBtn.innerHTML = originalText;
            submitBtn.disabled = false;
        }
    }

    async modifierDirection() {
        const form = document.getElementById('modifierDirectionForm');
        const submitBtn = document.getElementById('submitModifierDirection');
        const originalText = submitBtn.innerHTML;

        try {
            this.clearModalErrors('modify');
            
            submitBtn.innerHTML = '<div class="loading-spinner me-2"></div> Modification...';
            submitBtn.disabled = true;

            const formData = new FormData(form);
            const data = {
                nomDirection: formData.get('nomDirection'),
                personnel: formData.get('personnel') || null
            };

            const directionCode = formData.get('codeDirection');
            const response = await fetch(`/admin/directions/api/${directionCode}/modifier`, {
                method: 'PUT',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify(data)
            });

            const result = await response.json();

            if (result.success) {
                this.showSuccess(result.message);
                bootstrap.Modal.getInstance(document.getElementById('modifierDirectionModal')).hide();
                this.loadDirections();
            } else {
                if (result.errors) {
                    this.showMultipleErrors(result.errors);
                } else {
                    this.showError(result.message);
                }
            }
        } catch (error) {
            console.error('Erreur modification direction:', error);
            this.showError('Erreur lors de la modification de la direction');
        } finally {
            submitBtn.innerHTML = originalText;
            submitBtn.disabled = false;
        }
    }

    openModifierDirectionModal(codeDirection, nomDirection, directeurIm, directeurNom) {
        document.getElementById('modifierDirectionCode').value = codeDirection;
        document.getElementById('modifierCodeDirection').value = codeDirection;
        document.getElementById('modifierNomDirection').value = nomDirection;
        
        const modalElement = document.getElementById('modifierDirectionModal');
        const modal = new bootstrap.Modal(modalElement);
        
        // Stocker les infos du directeur actuel
        this.currentDirecteurInfo = {
            im: directeurIm,
            nom: directeurNom
        };
        
        modal.show();
    }

    async loadDirectionsEnAttente() {
    try {
        const response = await fetch('/admin/directions/api/directions-en-attente');
        const data = await response.json();

        if (data.success) {
            const directionsSelect = document.getElementById('nouvelleDirectionMutation');
            
            // Réinitialiser le select
            directionsSelect.innerHTML = '';
            
            if (data.directions && data.directions.length > 0) {
                // Ajouter une option par défaut
                directionsSelect.innerHTML += '<option value="">Sélectionnez une direction</option>';
                
                // Ajouter les directions disponibles
                data.directions.forEach(direction => {
                    directionsSelect.innerHTML += `<option value="${direction.CodeDirection}">${direction.nomDirection}</option>`;
                });
            } else {
                // Si aucune direction n'est disponible, afficher l'option "Aucune direction disponible"
                directionsSelect.innerHTML = '<option value="">Aucune direction disponible</option>';
                directionsSelect.disabled = true;
            }
        }
    } catch (error) {
        console.error('Erreur chargement directions en attente:', error);
        
        // En cas d'erreur, afficher aussi l'option
        const directionsSelect = document.getElementById('nouvelleDirectionMutation');
        directionsSelect.innerHTML = '<option value="">Aucune direction disponible</option>';
        directionsSelect.disabled = true;
        
        this.showError('Erreur lors du chargement des directions');
    }
}

    openMutationModal(directionCode, directionNom, directeurIm, directeurNom) {
    try {
        document.getElementById('directeurImMutation').value = directeurIm;
        document.getElementById('directeurMutation').value = directeurNom;
        
        this.loadDirectionsEnAttente().then(() => {
            const directionsSelect = document.getElementById('nouvelleDirectionMutation');
            
            // Si le select est désactivé (pas de directions disponibles), désactiver aussi le bouton de soumission
            if (directionsSelect.disabled) {
                const submitBtn = document.getElementById('submitMutation');
                submitBtn.disabled = true;
                submitBtn.innerHTML = '<i class="bi bi-exclamation-circle me-2"></i> Aucune direction disponible';
            }
            
            const modal = new bootstrap.Modal(document.getElementById('mutationModal'));
            modal.show();
        });
        
    } catch (error) {
        console.error('Erreur ouverture modal mutation:', error);
        this.showError('Erreur lors de l\'ouverture du modal');
    }
}

    openConfirmationDesactivationModal(codeDirection, nomDirection) {
    this.currentDirectionCode = codeDirection;
    
    document.getElementById('directionNomDesactivation').textContent = nomDirection;
    document.getElementById('directionCodeDesactivation').textContent = codeDirection;
    
    // Réinitialiser le bouton de confirmation
    const confirmBtn = document.getElementById('confirmDesactiverDirection');
    confirmBtn.innerHTML = '<i class="bi bi-x-circle me-2"></i> Confirmer la désactivation';
    confirmBtn.disabled = false;
    
    const modal = new bootstrap.Modal(document.getElementById('confirmationDesactivationModal'));
    modal.show();
}

    async confirmDesactiverDirection() {
    if (!this.currentDirectionCode) return;

    try {
        const modal = bootstrap.Modal.getInstance(document.getElementById('confirmationDesactivationModal'));
        
        // Mettre le spinner sur le bouton de confirmation du modal
        const confirmBtn = document.getElementById('confirmDesactiverDirection');
        const originalBtnText = confirmBtn.innerHTML;
        confirmBtn.innerHTML = '<div class="loading-spinner me-2"></div> Désactivation...';
        confirmBtn.disabled = true;

        const response = await fetch(`/admin/directions/api/${this.currentDirectionCode}/desactiver`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            }
        });

        const result = await response.json();

        if (result.success) {
            modal.hide();
            this.showSuccess(result.message);
            this.loadDirections();
        } else {
            this.showError(result.message);
            // Réinitialiser le bouton en cas d'erreur
            confirmBtn.innerHTML = originalBtnText;
            confirmBtn.disabled = false;
        }
    } catch (error) {
        console.error('Erreur désactivation:', error);
        this.showError('Erreur lors de la désactivation');
        // Réinitialiser le bouton en cas d'erreur
        const confirmBtn = document.getElementById('confirmDesactiverDirection');
        confirmBtn.innerHTML = '<i class="bi bi-x-circle me-2"></i> Confirmer la désactivation';
        confirmBtn.disabled = false;
    } finally {
        this.currentDirectionCode = null;
    }
}

    openActivationModal(codeDirection, nomDirection, ancienDirecteurNom, ancienDirecteurIm) {
    this.currentDirectionCode = codeDirection;
    
    document.getElementById('activationDirectionCode').value = codeDirection;
    document.getElementById('activationDirectionNom').value = nomDirection;
    document.getElementById('activationAncienDirecteur').value = ancienDirecteurNom;
    
    const directeurInfo = document.getElementById('activationDirecteurInfo');
    const garderDirecteurRadio = document.getElementById('garderDirecteur');
    const garderDirecteurLabel = document.querySelector('label[for="garderDirecteur"]');
    const choisirDirecteurRadio = document.getElementById('choisirDirecteur');

    if (ancienDirecteurIm && ancienDirecteurIm !== '') {
        directeurInfo.textContent = 'Cet ancien directeur sera réactivé si vous choisissez de le garder.';
        directeurInfo.className = 'form-text text-primary';
        garderDirecteurRadio.disabled = false;
        garderDirecteurLabel.innerHTML = 'Garder l\'ancien directeur';
        garderDirecteurRadio.checked = true; // Option par défaut quand disponible
    } else {
        directeurInfo.textContent = 'Aucun ancien directeur trouvé pour cette direction.';
        directeurInfo.className = 'form-text text-primary';
        garderDirecteurLabel.innerHTML = 'Garder l\'ancien directeur <span class="text-muted">(non disponible)</span>';
        garderDirecteurRadio.disabled = true;
        garderDirecteurRadio.checked = false;
        
        // Passer à l'option suivante disponible
        if (!choisirDirecteurRadio.disabled) {
            choisirDirecteurRadio.checked = true;
        } else {
            document.getElementById('aucunDirecteur').checked = true;
        }
    }

    // Charger les personnels après avoir configuré les options
    this.loadPersonnelsPourActivation().then(() => {
        this.toggleNouveauDirecteurGroup(document.querySelector('input[name="activationOption"]:checked').value);
    });
    
    const modal = new bootstrap.Modal(document.getElementById('activationModal'));
    modal.show();
}

    toggleNouveauDirecteurGroup(option) {
        const nouveauDirecteurGroup = document.getElementById('nouveauDirecteurGroup');
        if (option === 'choisir') {
            nouveauDirecteurGroup.style.display = 'block';
        } else {
            nouveauDirecteurGroup.style.display = 'none';
        }
    }

    async activerDirection() {
        const form = document.getElementById('activationForm');
        const submitBtn = document.getElementById('submitActivation');
        const originalText = submitBtn.innerHTML;

        try {
            submitBtn.innerHTML = '<div class="loading-spinner me-2"></div> Activation...';
            submitBtn.disabled = true;

            const activationOption = document.querySelector('input[name="activationOption"]:checked').value;
            const data = {
                garderDirecteur: activationOption === 'garder',
                nouveauDirecteur: activationOption === 'choisir' ? document.getElementById('activationNouveauDirecteur').value : null
            };

            const directionCode = document.getElementById('activationDirectionCode').value;
            const response = await fetch(`/admin/directions/api/${directionCode}/activer`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify(data)
            });

            const result = await response.json();

            if (result.success) {
                this.showSuccess(result.message);
                bootstrap.Modal.getInstance(document.getElementById('activationModal')).hide();
                this.loadDirections();
            } else {
                this.showError(result.message);
            }
        } catch (error) {
            console.error('Erreur activation:', error);
            this.showError('Erreur lors de l\'activation de la direction');
        } finally {
            submitBtn.innerHTML = originalText;
            submitBtn.disabled = false;
        }
    }

    async effectuerMutation() {
    const form = document.getElementById('mutationForm');
    const submitBtn = document.getElementById('submitMutation');
    const originalText = submitBtn.innerHTML;
    
    const nouvelleDirectionSelect = document.getElementById('nouvelleDirectionMutation');
    
    // Vérifier si le select est désactivé ou vide
    if (nouvelleDirectionSelect.disabled || !nouvelleDirectionSelect.value) {
        this.showError('Aucune direction disponible pour la mutation');
        return;
    }

    try {
        submitBtn.innerHTML = '<div class="loading-spinner me-2"></div> Mutation...';
        submitBtn.disabled = true;

        const formData = new FormData(form);
        const data = {
            directeur: document.getElementById('directeurImMutation').value,
            nouvelleDirection: formData.get('nouvelleDirection')
        };

        const response = await fetch('/admin/directions/api/mutation', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify(data)
        });

        const result = await response.json();

        if (result.success) {
            this.showSuccess(result.message);
            bootstrap.Modal.getInstance(document.getElementById('mutationModal')).hide();
            this.loadDirections();
        } else {
            this.showError(result.message);
        }
    } catch (error) {
        console.error('Erreur mutation:', error);
        this.showError('Erreur lors de la mutation');
    } finally {
        submitBtn.innerHTML = originalText;
        submitBtn.disabled = false;
    }
}

