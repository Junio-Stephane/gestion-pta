<style>
.filters-container .select2-container--bootstrap-5 .select2-selection {
    min-height: 36px !important;
    height: 36px !important;
    padding: 0.375rem !important;
    font-size: 0.85rem !important;
}

.filters-container .select2-container--bootstrap-5 .select2-selection--single {
    height: 36px !important;
}

.filters-container .select2-container--bootstrap-5 .select2-selection--single .select2-selection__rendered {
    line-height: 20px !important;
    padding-left: 0.5rem !important;
    font-size: 0.85rem !important;
}

.filters-container .select2-container--bootstrap-5 .select2-selection--single .select2-selection__arrow {
    height: 34px !important;
    right: 0.5rem !important;
}

.filters-container .select2-container--bootstrap-5 .select2-dropdown {
    font-size: 0.85rem !important;
}

.filters-container .select2-container--bootstrap-5 .select2-results__option {
    padding: 0.4rem 0.6rem !important;
    font-size: 0.85rem !important;
    min-height: 34px !important;
}

/* Style spécifique pour le filtre de direction */
#directionFilter + .select2 .select2-selection {
    min-height: 36px !important;
    height: 36px !important;
}

/* Style pour les selects dans les modaux (garder la taille normale) */
.modal .select2-container--bootstrap-5 .select2-selection {
    min-height: 45px !important;
    height: 45px !important;
}

.select2-container--bootstrap-5 .select2-selection {
    min-height: 47px !important;
    height: 47px !important;
    padding: 0.675rem !important;
    border: 1px solid #d1d5db !important;
    border-radius: 6px !important;
    font-size: 0.9rem !important;
    line-height: 1.5 !important;
    background-color: white !important;
    transition: all 0.3s ease !important;
}

.select2-container--bootstrap-5 .select2-selection--single {
    height: 38px !important;
}

.select2-container--bootstrap-5 .select2-selection--single .select2-selection__rendered {
    line-height: 24px !important;
    padding-left: 0.75rem !important;
    padding-right: 2.5rem !important;
    color: #374151 !important;
}

.select2-container--bootstrap-5 .select2-selection--single .select2-selection__arrow {
    height: 36px !important;
    right: 0.5rem !important;
}

/* Style au survol (hover) */
.select2-container--bootstrap-5 .select2-selection:hover {
    border-color: #964ee3 !important;
    box-shadow: 0 0 0 3px rgba(150, 78, 227, 0.1) !important;
}

/* Style au focus */
.select2-container--bootstrap-5.select2-container--focus .select2-selection,
.select2-container--bootstrap-5.select2-container--open .select2-selection {
    border-color: #964ee3 !important;
    box-shadow: 0 0 0 3px rgba(150, 78, 227, 0.1) !important;
    outline: none !important;
}

/* Style pour le dropdown */
.select2-container--bootstrap-5 .select2-dropdown {
    border: 1px solid #d1d5db !important;
    border-radius: 6px !important;
    box-shadow: 0 4px 6px rgba(0,0,0,0.1) !important;
    background-color: white !important;
}

/* Champ de recherche dans le dropdown */
.select2-container--bootstrap-5 .select2-search--dropdown .select2-search__field {
    border: 1px solid #d1d5db !important;
    border-radius: 4px !important;
    padding: 0.375rem 0.75rem !important;
    font-size: 0.9rem !important;
    height: 38px !important;
}

.select2-container--bootstrap-5 .select2-search--dropdown .select2-search__field:focus {
    border-color: #964ee3 !important;
    box-shadow: 0 0 0 3px rgba(150, 78, 227, 0.1) !important;
    outline: none !important;
}

/* Options dans le dropdown */
.select2-container--bootstrap-5 .select2-results__option {
    padding: 0.5rem 0.75rem !important;
    font-size: 0.9rem !important;
    min-height: 38px !important;
    display: flex !important;
    align-items: center !important;
}

/* Option sélectionnée */
.select2-container--bootstrap-5 .select2-results__option--selected {
    background-color: #f3f4f6 !important;
    color: #374151 !important;
}

/* Option au survol/surbrillance */
.select2-container--bootstrap-5 .select2-results__option--highlighted.select2-results__option--selectable {
    background-color: #3f7ee3 !important;
    color: white !important;
}

/* Options désactivées */
.select2-container--bootstrap-5 .select2-results__option.option-desactive {
    color: #6b7280 !important;
    font-style: italic !important;
    background-color: #f9fafb !important;
}

.select2-container--bootstrap-5 .select2-results__option.option-desactive.select2-results__option--highlighted {
    background-color: #f3f4f6 !important;
    color: #6b7280 !important;
}

/* Style pour les sélects dans les modaux (z-index corrigé) */
.modal .select2-container {
    z-index: 1060 !important;
}

.modal .select2-dropdown {
    z-index: 1061 !important;
}

/* Style pour le placeholder */
.select2-container--bootstrap-5 .select2-selection--single .select2-selection__placeholder {
    color: #6b7280 !important;
    font-size: 0.9rem !important;
}

/* Style pour les sélects désactivés */
.select2-container--bootstrap-5 .select2-selection--single[aria-disabled="true"] {
    background-color: #f1f3f6 !important;
    border-color: #ced1d6 !important;
    color: #626771 !important;
    cursor: default !important;
}

/* Style pour le clear button */
.select2-container--bootstrap-5 .select2-selection--single .select2-selection__clear {
    height: 36px !important;
    padding: 0 0.5rem !important;
    color: #6b7280 !important;
    font-size: 1.2rem !important;
}

.select2-container--bootstrap-5 .select2-selection--single .select2-selection__clear:hover {
    color: #ef4444 !important;
}

/* Responsive adjustments */
@media (max-width: 768px) {
    .select2-container--bootstrap-5 .select2-selection {
        min-height: 36px !important;
        height: 36px !important;
        font-size: 0.85rem !important;
    }
    
    .select2-container--bootstrap-5 .select2-selection--single {
        height: 36px !important;
    }
    
    .select2-container--bootstrap-5 .select2-selection--single .select2-selection__rendered {
        padding-left: 0.5rem !important;
        font-size: 0.85rem !important;
    }
    
    .select2-container--bootstrap-5 .select2-results__option {
        font-size: 0.85rem !important;
        min-height: 36px !important;
    }
}
    /* [Tous les styles CSS précédents restent identiques] */
    .rapport-container {
