    }

    @media (max-width: 768px) {
        .projet-title-section {
            flex-direction: column;
            align-items: flex-start;
        }
        
        .projet-meta-primary {
            justify-content: flex-start;
        }
        
        .info-grid {
            grid-template-columns: 1fr;
        }
        
        .stats-row {
            grid-template-columns: repeat(2, 1fr);
        }
        
        .export-buttons {
            flex-direction: column;
        }
        
        .btn-export {
            min-width: 100%;
        }
    }
</style>
{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    <div class="rapport-container">
        <div class="section-header">
            <div>
                <h1 class="section-title">
                    <i class="bi bi-graph-up"></i>
                    Rapport des Projets
                </h1>
                <p class="text-muted mb-0">Générez des rapports détaillés par direction</p>
            </div>
        </div>

        <!-- Instructions de sélection -->
        <div class="selection-instructions" id="selectionInstructions">
            <div class="instructions-title">
                <i class="bi bi-info-circle"></i>
                Instructions
            </div>
            <div class="instructions-content">
                <p class="mb-2">Veuillez sélectionner une direction dans la liste déroulante ci-dessous pour générer le rapport correspondant.</p>
                <p class="mb-0">Le rapport inclura tous les services, projets et tâches associés à la direction sélectionnée.</p>
            </div>
        </div>

        

        <!-- Sélection de la direction -->
<div class="selection-container">
    <div class="row">
        <div class="col-md-6">
            <div class="form-group">
                <label for="directionSelect" class="form-label">Sélectionnez une direction</label>
                <select class="form-select search-select" id="directionSelect" style="width: 100%" data-allow-clear="true">
                    <option value="">Chargement des directions...</option>
                </select>
            </div>
        </div>
        <div class="col-md-6">
            <div class="form-group">
                <label class="form-label">Date du rapport</label>
                <input type="text" class="form-control" id="dateRapport" readonly 
                       value="{{ "now"|date("d/m/Y") }}">
            </div>
        </div>
    </div>
</div>

        <div id="rapportResume" style="display: none;">
            <div class="section-header">
                <h2 class="section-title">
                    <i class="bi bi-file-text"></i>
                    Résumé du rapport
                </h2>
            </div>
        </div>

        <!-- Aperçu du rapport -->
        <div id="rapportPreview" style="display: none;">
            <div class="preview-container">
                <div id="previewContent">
                    <!-- Le contenu sera généré dynamiquement -->
                </div>
            </div>

            <!-- Boutons d'export -->
            <div class="export-buttons">
                <button class="btn-export btn-pdf" id="exportPdf" disabled>
                    <i class="bi bi-file-pdf"></i>
                    Exporter en PDF
                </button>
                {# <button class="btn-export btn-excel" id="exportExcel" disabled>
                    <i class="bi bi-file-spreadsheet"></i>
                    Exporter en Excel
                </button> #}
            </div>
        </div>

        <!-- État vide -->
        <div id="emptyState" class="empty-state">
            <i class="bi bi-clipboard-data"></i>
            <h4>Aucune direction sélectionnée</h4>
            <p class="text-muted">Veuillez sélectionner une direction pour générer le rapport</p>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.28/jspdf.plugin.autotable.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>

<script>

class RapportManager {
    constructor() {
        this.selectedDirection = null;
        this.directionData = null;
        this.select2Instance = null;
        this.isHandlingChange = false;
        this.init();
    }

    init() {
        this.loadDirections();
        this.setupEventListeners();
    }

    setupEventListeners() {
        // Gérer l'export PDF
        const exportPdf = document.getElementById('exportPdf');
        if (exportPdf) {
            exportPdf.addEventListener('click', () => {
                this.exportToPDF();
            });
        }
    }

    async loadDirections() {
        try {
            const response = await fetch('/api/rapport-directions-actives');
            const data = await response.json();
            
            if (data.success) {
                this.populateDirectionSelect(data.directions);
                this.initSelect2(); // Initialiser Select2 après le chargement
            } else {
                this.showError('Erreur lors du chargement des directions');
            }
        } catch (error) {
            console.error('Erreur chargement directions:', error);
            this.showError('Erreur de connexion au serveur');
        }
    }

    populateDirectionSelect(directions) {
        const select = document.getElementById('directionSelect');
        if (!select) return;
        
        // Créer les options avec une option vide par défaut avec valeur "aucun"
        let options = '<option value="aucun">Sélectionnez une direction</option>';
        
        directions.forEach(direction => {
            options += `<option value="${direction.CodeDirection}">${direction.CodeDirection} - ${direction.nomDirection}</option>`;
        });
        
        select.innerHTML = options;
    }

    initSelect2() {
        const directionSelect = document.getElementById('directionSelect');
        if (directionSelect && !this.select2Instance) {
            this.select2Instance = $(directionSelect).select2({
                theme: 'bootstrap-5',
                width: '100%',
                placeholder: 'Sélectionnez une direction',
                allowClear: true,
                language: {
                    noResults: () => "Aucune direction trouvée",
                    searching: () => "Recherche en cours..."
                }
            }).on('select2:opening', function () {
                // S'assurer que le dropdown s'affiche correctement
                setTimeout(() => {
                    $('.select2-dropdown').css('z-index', '1060');
                }, 10);
            });

            // Gérer l'événement change
            this.select2Instance.on('change', (e) => {
                const selectedValue = this.select2Instance.val();
                console.log('Select2 change event - Value:', selectedValue);
                
                // Si la valeur est "aucun" ou vide (désélection avec le "x"), réinitialiser
                if (!selectedValue || selectedValue === '' || selectedValue === 'aucun') {
                    console.log('Valeur "aucun" ou vide détectée - Réinitialisation du rapport');
                    this.resetRapport();
                } else {
                    this.handleDirectionChange(selectedValue);
                }
            });

            // Gérer aussi l'événement select2:clear
            this.select2Instance.on('select2:clear', () => {
                console.log('Select2 clear event triggered - Réinitialisation du rapport');
                this.resetRapport();
            });
        }
    }

    async handleDirectionChange(directionCode) {
        console.log('handleDirectionChange appelé avec:', directionCode);
        
        // Vérifier si la valeur est "aucun" ou vide
        if (!directionCode || directionCode === '' || directionCode === 'aucun') {
            this.resetRapport();
            return;
        }

        this.showLoading();
        
        // Désactiver temporairement le select pendant le chargement
        if (this.select2Instance) {
            this.select2Instance.prop('disabled', true);
        }
        
        try {
            const response = await fetch(`/api/rapport/direction/${directionCode}`);
            const data = await response.json();
            
            if (data.success) {
                this.directionData = data.direction;
                this.selectedDirection = directionCode;
                this.renderPreview();
                this.enableExportButtons();
                this.hideInstructions();
            } else {
                this.showError(data.message);
                this.resetRapport();
            }
        } catch (error) {
            console.error('Erreur chargement données direction:', error);
            this.showError('Erreur lors du chargement des données');
            this.resetRapport();
        } finally {
            // Réactiver le select après chargement
            if (this.select2Instance) {
                this.select2Instance.prop('disabled', false);
            }
        }
    }

    renderPreview() {
        const preview = document.getElementById('rapportPreview');
        const resume = document.getElementById('rapportResume');
        const emptyState = document.getElementById('emptyState');
        const previewContent = document.getElementById('previewContent');
        
        // Cacher le résumé
        if (resume) resume.style.display = 'none';
        
        // Afficher l'aperçu et cacher l'état vide
        if (preview) preview.style.display = 'block';
        if (emptyState) emptyState.style.display = 'none';
        
        if (previewContent) {
            previewContent.innerHTML = this.generatePreviewHTML();
        }
    }

    generatePreviewHTML() {
        if (!this.directionData) return '';

        const direction = this.directionData;
        const dateRapport = document.getElementById('dateRapport')?.value || new Date().toLocaleDateString('fr-FR');

        let html = `
            <div class="direction-header">
                <div class="logo-header">
                    <div class="logo-placeholder">
                        <img src="{{ asset('images/logo2.png') }}" alt="MIC Logo" class="nav-logo">
                    </div>
                    <div class="header-text">
                        <h2 class="mb-1">MINISTÈRE DE L'INDUSTRIE ET DU COMMERCE</h2>
                        <h4 class="mb-1">Direction: ${this.escapeHtml(direction.nomDirection)} (n°: ${this.escapeHtml(direction.CodeDirection)})</h4>
                        ${direction.statutDirection !== 'ACTIVE' ? 
                            `<span class="status-badge status-desactive">
                                <i class="bi bi-pause-circle"></i> Direction Désactivée
                            </span>` : ''
                        }
                    </div>
                </div>
                <p class="mb-0">Rapport des Projets et Tâches - Généré le ${dateRapport}</p>
            </div>
        `;

        // Statistiques générales
        const stats = this.calculateStatistics();
        html += this.generateStatsHTML(stats);

        // Services et projets
        if (direction.services && direction.services.length > 0) {
            direction.services.forEach(service => {
                html += this.generateServiceHTML(service);
            });
        } else {
            html += `
                <div class="alert alert-info">
                    <i class="bi bi-info-circle"></i>
                    Aucun service trouvé pour cette direction
                </div>
            `;
        }

        return html;
    }

    hidePreview() {
        const preview = document.getElementById('rapportPreview');
        const resume = document.getElementById('rapportResume');
        const emptyState = document.getElementById('emptyState');
        
        if (preview) preview.style.display = 'none';
        if (resume) resume.style.display = 'none';
        if (emptyState) emptyState.style.display = 'block';
        
        this.disableExportButtons();
        this.showInstructions();
    }

    hideInstructions() {
        const instructions = document.getElementById('selectionInstructions');
        if (instructions) {
            instructions.style.display = 'none';
        }
    }

    showInstructions() {
        const instructions = document.getElementById('selectionInstructions');
        if (instructions) {
            instructions.style.display = 'block';
        }
    }

    showLoading() {
        const previewContent = document.getElementById('previewContent');
        if (previewContent) {
            previewContent.innerHTML = `
                <div class="text-center py-4">
                    <div class="loading-spinner me-2"></div>
                    Chargement des données...
                </div>
            `;
        }
    }

    enableExportButtons() {
        const exportPdfBtn = document.getElementById('exportPdf');
        if (exportPdfBtn) {
            exportPdfBtn.disabled = false;
        }
    }

    disableExportButtons() {
        const exportPdfBtn = document.getElementById('exportPdf');
        if (exportPdfBtn) {
            exportPdfBtn.disabled = true;
        }
    }

    resetRapport() {
        console.log('resetRapport appelé');
        
        // Réinitialiser l'aperçu
        this.hidePreview();
        
        // Réinitialiser les données
        this.selectedDirection = null;
        this.directionData = null;
        
        // Remettre la valeur du select à "aucun"
        if (this.select2Instance) {
            this.select2Instance.val('aucun').trigger('change');
        }
        
        console.log('Rapport réinitialisé - valeur remise à "aucun"');
    }

    escapeHtml(text) {
        const div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
    }

    calculateStatistics() {
        if (!this.directionData || !this.directionData.services) {
            return {
                totalServices: 0,
                totalProjets: 0,
                totalTaches: 0,
                budgetTotal: 0,
                avancementMoyen: 0,
                servicesActifs: 0,
                servicesDesactives: 0,
                projetsActifs: 0,
                projetsSuspendus: 0
            };
        }

        let totalProjets = 0;
        let totalTaches = 0;
        let budgetTotal = 0;
        let totalAvancement = 0;
        let projetsAvecAvancement = 0;
        let servicesActifs = 0;
        let servicesDesactives = 0;
        let projetsActifs = 0;
        let projetsSuspendus = 0;

        this.directionData.services.forEach(service => {
            if (service.statutService === 'ACTIF') {
                servicesActifs++;
            } else if (service.statutService === 'DESACTIVE') {
                servicesDesactives++;
            }

            if (service.projets) {
                totalProjets += service.projets.length;
                
                service.projets.forEach(projet => {
                    budgetTotal += parseFloat(projet.budgetPro) || 0;
                    
                    if (projet.StatutPro === 'Suspendu') {
                        projetsSuspendus++;
                    } else {
                        projetsActifs++;
                    }
                    
                    if (projet.taches) {
                        totalTaches += projet.taches.length;
                    }
                    
                    if (projet.avancementPro !== null && projet.avancementPro !== undefined) {
                        totalAvancement += projet.avancementPro;
                        projetsAvecAvancement++;
                    }
                });
            }
        });

        const avancementMoyen = projetsAvecAvancement > 0 ? 
            Math.round(totalAvancement / projetsAvecAvancement) : 0;

        return {
            totalServices: this.directionData.services.length,
            totalProjets: totalProjets,
            totalTaches: totalTaches,
            budgetTotal: budgetTotal,
            avancementMoyen: avancementMoyen,
            servicesActifs: servicesActifs,
            servicesDesactives: servicesDesactives,
            projetsActifs: projetsActifs,
            projetsSuspendus: projetsSuspendus
        };
    }

    generateStatsHTML(stats) {
        return `
            <div class="stats-row">
                <div class="stat-card">
                    <div class="stat-value">${stats.totalServices}</div>
                    <div class="stat-label">Services Total</div>
                    <div class="stat-subtext">
                        <span class="text-success">${stats.servicesActifs} actifs</span>
                        ${stats.servicesDesactives > 0 ? 
                            `<span class="text-muted"> • ${stats.servicesDesactives} désactivés</span>` : ''
                        }
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-value">${stats.totalProjets}</div>
                    <div class="stat-label">Projets Total</div>
                    <div class="stat-subtext">
                        <span class="text-success">${stats.projetsActifs} actifs</span>
                        ${stats.projetsSuspendus > 0 ? 
                            `<span class="text-muted"> • ${stats.projetsSuspendus} suspendus</span>` : ''
                        }
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-value">${stats.totalTaches}</div>
                    <div class="stat-label">Tâches Total</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value">${this.formatBudget(stats.budgetTotal)}</div>
                    <div class="stat-label">Budget Total (Ar)</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value">${stats.avancementMoyen}%</div>
                    <div class="stat-label">Avancement Moyen</div>
                </div>
            </div>
        `;
    }

    generateServiceHTML(service) {
        const projetsCount = service.projets ? service.projets.length : 0;
        const tachesCount = service.projets ? service.projets.reduce((total, projet) => 
            total + (projet.taches ? projet.taches.length : 0), 0) : 0;

        const isServiceDesactive = service.statutService === 'DESACTIVE';
        const serviceClass = isServiceDesactive ? 'service-desactive grised' : '';
        const serviceHeaderClass = isServiceDesactive ? 'service-header-desactive' : '';

        let html = `
            <div class="service-section ${serviceClass}">
                <div class="service-header ${serviceHeaderClass}">
                    <div>
                        <i class="bi bi-diagram-3 me-2"></i>
                        ${this.escapeHtml(service.nomService)} (n°: ${this.escapeHtml(service.CodeService)})
                        ${isServiceDesactive ? 
                            '<span class="status-badge status-desactive ms-2"><i class="bi bi-pause-circle"></i> Service Désactivé</span>' : 
                            (service.statutService === 'EN_ATTENTE' ? 
                                '<span class="status-badge status-suspendu ms-2"><i class="bi bi-clock"></i> En Attente</span>' : '')
                        }
                    </div>
                    <div class="service-stats">
                        ${projetsCount} projet(s) • ${tachesCount} tâche(s)
                    </div>
                </div>
        `;

        if (service.projets && service.projets.length > 0) {
            service.projets.forEach(projet => {
                html += this.generateProjetHTML(projet, isServiceDesactive);
            });
        } else {
            html += `
                <div class="projet-table-container ${isServiceDesactive ? 'grised' : ''}">
                    <div class="projet-header ${isServiceDesactive ? 'projet-header-suspendu' : ''}">
                        <div class="projet-title-section">
                            <div class="projet-title">Aucun projet</div>
                        </div>
                    </div>
                </div>
            `;
        }

        html += `</div>`;
        return html;
    }

    generateProjetHTML(projet, isServiceDesactive = false) {
        const isProjetSuspendu = projet.StatutPro === 'Suspendu';
        const statutClass = this.getStatutClass(projet.StatutPro);
        const avancement = projet.avancementPro || 0;
        const tachesCount = projet.taches ? projet.taches.length : 0;
        
        const projetContainerClass = isProjetSuspendu || isServiceDesactive ? 'projet-suspendu grised' : '';
        const projetHeaderClass = isProjetSuspendu || isServiceDesactive ? 'projet-header-suspendu' : '';
        
        let html = `
            <div class="projet-table-container ${projetContainerClass}">
                <div class="projet-header ${projetHeaderClass}">
                    <div class="projet-main-info">
                        <div class="projet-title-section">
                            <div class="projet-title">${this.escapeHtml(projet.titrePro)}</div>
                            <div class="projet-meta-primary">
                                <div class="meta-item">
                                    <i class="bi bi-hash icon-small"></i>
                                    <strong>N°:</strong> ${this.escapeHtml(projet.numProjet)}
                                </div>
                                <div class="meta-item">
                                    <i class="bi bi-list-task icon-small"></i>
                                    <strong>Tâches:</strong> ${tachesCount}
                                </div>
                                <div class="meta-item">
                                    <span class="status-badge ${statutClass}">
                                        <i class="bi bi-circle-fill" style="font-size: 0.4rem;"></i>
                                        ${projet.StatutPro}
                                    </span>
                                </div>
                            </div>
                        </div>
                        
                        <div class="projet-details-compact">
                            <!-- Description et Commentaire sur la même ligne -->
                            <div class="description-commentaire-row">
                                <!-- Description -->
                                <div class="info-container ${isProjetSuspendu || isServiceDesactive ? 'grised' : ''}">
                                    <div class="info-header">
                                        <i class="bi bi-text-paragraph icon-small"></i>
                                        <h4 class="info-title">Description du Projet</h4>
                                    </div>
                                    <div class="info-content">
                                        <div class="info-value">
                                            ${projet.descriptionPro ? this.escapeHtml(projet.descriptionPro) : 'Aucune description fournie'}
                                        </div>
                                    </div>
                                </div>

                                <!-- Commentaire -->
                                <div class="info-container ${isProjetSuspendu || isServiceDesactive ? 'grised' : ''}" 
                                     style="${projet.commentairePro ? 'background: #fefce8; border-color: #fef08a;' : ''}">
                                    <div class="info-header">
                                        <i class="bi bi-chat-left-text icon-small"></i>
                                        <h4 class="info-title" style="${projet.commentairePro ? 'color: #854d0e;' : ''}">Commentaire</h4>
                                    </div>
                                    <div class="info-content">
                                        <div class="info-value" style="${projet.commentairePro ? 'color: #a16207;' : ''}">
                                            ${projet.commentairePro ? this.escapeHtml(projet.commentairePro) : 'Aucun commentaire'}
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Informations Générales -->
                            <div class="info-container ${isProjetSuspendu || isServiceDesactive ? 'grised' : ''}">
                                <div class="info-header">
                                    <i class="bi bi-info-circle icon-small"></i>
                                    <h4 class="info-title">Informations Générales</h4>
                                </div>
                                <div class="info-grid">
                                    <div class="info-item">
                                        <span class="info-label">
                                            <i class="bi bi-calendar-range icon-small"></i>
                                            Date de Début
                                        </span>
                                        <span class="info-value">
                                            ${this.formatDate(projet.dateDebutPro)}
                                        </span>
                                    </div>
                                    <div class="info-item">
                                        <span class="info-label">
                                            <i class="bi bi-calendar-check icon-small"></i>
                                            Date de Fin
                                        </span>
                                        <span class="info-value">
                                            ${projet.dateFinPro ? this.formatDate(projet.dateFinPro) : 'Non définie'}
                                        </span>
                                    </div>
                                    <div class="info-item">
                                        <span class="info-label">
                                            <i class="bi bi-cash-coin icon-small"></i>
                                            Budget Alloué
                                        </span>
                                        <span class="info-value budget">
                                            ${this.formatBudget(projet.budgetPro)} Ar
                                        </span>
                                    </div>
                                </div>
                            </div>

                            <!-- Avancement -->
                            <div class="info-container ${isProjetSuspendu || isServiceDesactive ? 'grised' : ''}">
                                <div class="info-header">
                                    <i class="bi bi-graph-up icon-small"></i>
                                    <h4 class="info-title">État d'Avancement</h4>
                                </div>
                                <div class="info-content">
                                    <div class="info-item">
                                        <span class="info-label">
                                            <i class="bi bi-speedometer2 icon-small"></i>
                                            Progression Globale
                                        </span>
                                        <div class="info-value">
                                            <div class="progress-container">
                                                <div class="progress-info">
                                                    <span class="progress-percent">${avancement}%</span>
                                                </div>
                                                <div class="progress-bar">
                                                    <div class="progress-fill" style="width: ${avancement}%"></div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Équipe -->
                            <div class="info-container ${isProjetSuspendu || isServiceDesactive ? 'grised' : ''}">
                                <div class="info-header">
                                    <i class="bi bi-people icon-small"></i>
                                    <h4 class="info-title">Équipe du Projet</h4>
                                </div>
                                <div class="info-grid">
                                    ${projet.createur ? `
                                        <div class="info-item">
                                            <span class="info-label">
                                                <i class="bi bi-person-plus icon-small"></i>
                                                Créateur
                                            </span>
                                            <div class="createur-section ${isProjetSuspendu || isServiceDesactive ? 'grised' : ''}">
                                                <div class="createur-content">
                                                    ${this.escapeHtml(projet.createur.NomPer)} ${projet.createur.PrenomPer ? this.escapeHtml(projet.createur.PrenomPer) : ''}
                                                    ${projet.createur.ImPer ? `(IM: ${this.escapeHtml(projet.createur.ImPer)})` : ''}
                                                </div>
                                            </div>
                                        </div>
                                    ` : ''}

                                    <div class="info-item">
                                        <span class="info-label">
                                            <i class="bi bi-person-gear icon-small"></i>
                                            Responsables
                                        </span>
                                        <div class="responsables-compact-section ${isProjetSuspendu || isServiceDesactive ? 'grised' : ''}">
                                            ${projet.personnels && projet.personnels.length > 0 ? `
                                                <div class="responsables-list-compact">
                                                    ${projet.personnels.map(personnel => `
                                                        <div class="responsable-item-compact ${isProjetSuspendu || isServiceDesactive ? 'grised' : ''}">
                                                            <div class="responsable-nom">
                                                                ${this.escapeHtml(personnel.NomPer)} ${personnel.PrenomPer ? this.escapeHtml(personnel.PrenomPer) : ''}
                                                            </div>
                                                            <div class="responsable-details">
                                                                ${personnel.ImPer ? `IM: ${this.escapeHtml(personnel.ImPer)}` : ''}
                                                                ${personnel.EmailPer ? ` • ${this.escapeHtml(personnel.EmailPer)}` : ''}
                                                            </div>
                                                        </div>
                                                    `).join('')}
                                                </div>
                                            ` : `
                                                <div class="no-responsables-compact">
                                                    <i class="bi bi-person-x icon-small"></i>
                                                    Aucun responsable assigné
                                                </div>
                                            `}
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
        `;

        // Tâches du projet
        html += this.generateTachesHTML(projet.taches, isProjetSuspendu || isServiceDesactive);

        html += `</div>`; // Fermeture du projet-table-container
        return html;
    }

    generateTachesHTML(taches, isParentSuspendu = false) {
        let html = `
            <div style="padding: 1.25rem;">
                <h5 style="margin-bottom: 1rem; color: #374151; display: flex; align-items: center; gap: 0.5rem; font-size: 1.1rem;">
                    <i class="bi bi-list-task"></i>
                    Liste des Tâches
                    ${isParentSuspendu ? '<span class="status-badge status-desactive ms-2"><small>Projet Suspendu/Service Désactivé</small></span>' : ''}
                </h5>
                <table class="taches-table">
                    <thead>
                        <tr>
                            <th style="width: 70px;">#</th>
                            <th style="width: 180px;">Titre</th>
                            <th>Description</th>
                            <th class="tache-commentaire-cell">Commentaire</th>
                            <th style="width: 140px;">Période</th>
                            <th style="width: 110px;">Avancement</th>
                            <th style="width: 90px;">Statut</th>
                        </tr>
                    </thead>
                    <tbody>
        `;

        if (taches && taches.length > 0) {
            taches.forEach(tache => {
                const isTacheSuspendue = tache.statutTache === 'Suspendu';
                const statutClass = this.getStatutClass(tache.statutTache);
                const avancement = tache.avancementTache || 0;
                
                const tacheRowClass = isTacheSuspendue || isParentSuspendu ? 'tache-suspendue grised' : '';
                
                html += `
                    <tr class="${tacheRowClass}">
                        <td><strong>${tache.numTache}</strong></td>
                        <td>${this.escapeHtml(tache.titreTache)}</td>
                        <td>
                            <div class="text-preview ${!tache.descriptionTache ? 'empty' : ''}">
                                ${tache.descriptionTache ? this.escapeHtml(tache.descriptionTache) : 'Aucune description'}
                            </div>
                        </td>
                        <td class="tache-commentaire-cell">
                            <div class="tache-commentaire ${!tache.commentaireTache ? 'empty' : ''} ${isTacheSuspendue || isParentSuspendu ? 'grised' : ''}" 
                                 onclick="this.classList.toggle('expanded')">
                                ${tache.commentaireTache ? this.escapeHtml(tache.commentaireTache) : 'Aucun commentaire'}
                            </div>
                        </td>
                        <td>
                            <div>
                                <div><small><strong>Début:</strong> ${this.formatDate(tache.dateDebutTache)}</small></div>
                                <div><small><strong>Fin:</strong> ${tache.dateFinTache ? this.formatDate(tache.dateFinTache) : '-'}</small></div>
                            </div>
                        </td>
                        <td>
                            <div>
                                <span style="font-size: 0.8rem;">${avancement}%</span>
                                <div class="progress-bar">
                                    <div class="progress-fill" style="width: ${avancement}%"></div>
                                </div>
                            </div>
                        </td>
                        <td><span class="status-badge ${statutClass}">${tache.statutTache}</span></td>
                    </tr>
                `;
            });
        } else {
            const noTachesClass = isParentSuspendu ? 'grised' : '';
            html += `
                <tr>
                    <td colspan="7" class="no-taches-row ${noTachesClass}">
                        <i class="bi bi-list-task me-2"></i>
                        Aucune tâche définie pour ce projet
                    </td>
                </tr>
            `;
        }

        html += `
                    </tbody>
                </table>
            </div>
        `;
        return html;
    }

    formatDate(dateString) {
        if (!dateString) return 'N/A';
        try {
            const date = new Date(dateString);
            return date.toLocaleDateString('fr-FR');
        } catch (error) {
            return 'N/A';
        }
    }

    formatBudget(budget) {
        if (!budget) return '0';
        const amount = parseFloat(budget);
        return amount.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ' ');
    }

    getStatutClass(statut) {
        const classes = {
            'Débuté': 'status-debute',
            'En cours': 'status-encours',
            'Terminé': 'status-termine',
            'Suspendu': 'status-suspendu',
            'DESACTIVE': 'status-desactive'
        };
        return classes[statut] || 'status-debute';
    }

    showError(message) {
        const alert = document.createElement('div');
        alert.className = 'alert alert-danger alert-dismissible fade show';
        alert.innerHTML = `
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            ${this.escapeHtml(message)}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        `;
        
        const container = document.querySelector('.rapport-container');
        if (container) {
            container.insertBefore(alert, container.firstChild);
            
            setTimeout(() => {
                if (alert.parentNode) {
                    alert.classList.remove('show');
                    setTimeout(() => {
                        if (alert.parentNode) {
                            alert.parentNode.removeChild(alert);
                        }
                    }, 150);
                }
            }, 5000);
        }
    }

    exportToPDF() {
        if (!this.directionData) {
            this.showError('Aucune donnée à exporter');
            return;
        }

        const { jsPDF } = window.jspdf;
        const doc = new jsPDF('p', 'mm', 'a4');
        const dateRapport = document.getElementById('dateRapport')?.value || new Date().toLocaleDateString('fr-FR');
        const direction = this.directionData;

        // Fonctions utilitaires
        const ensureString = (value) => {
            if (value === null || value === undefined) return '';
            if (typeof value === 'number') return value.toString();
            if (typeof value === 'boolean') return value ? 'Oui' : 'Non';
            return String(value);
        };

        const safeText = (text, x, y, options = {}) => {
            try {
                const safeText = ensureString(text);
                doc.text(safeText, x, y, options);
            } catch (error) {
                console.error('Erreur lors de l\'ajout du texte:', text, error);
                doc.text('Erreur', x, y, options);
            }
        };

        const addMultilineText = (text, x, y, maxWidth, lineHeight = 4, fontSize = 6) => {
            doc.setFontSize(fontSize);
            const lines = doc.splitTextToSize(ensureString(text), maxWidth);
            safeText(lines, x, y);
            return lines.length * lineHeight;
        };

        const checkNewPage = (neededSpace = 20) => {
            if (yPosition > 280 - neededSpace) {
                doc.addPage();
                yPosition = 20;
                return true;
            }
            return false;
        };

        const addVerticalSpace = (space = 5) => {
            yPosition += space;
        };

        // Couleurs
        const colors = {
            primary: [150, 78, 227],
            secondary: [117, 22, 95],
            blue: [59, 130, 246],
            gray: [107, 114, 128],
            lightGray: [243, 244, 246],
            darkGray: [55, 65, 81],
            border: [229, 231, 235]
        };

        let yPosition = 10;

        // ==================== EN-TÊTE DU DOCUMENT ====================
        const drawHeader = () => {
            // Bannière principale
            doc.setFillColor(colors.primary[0], colors.primary[1], colors.primary[2]);
            doc.roundedRect(10, yPosition, 190, 25, 3, 3, 'F');
            
            // Logo et texte de l'en-tête
            doc.setFontSize(16);
            doc.setFont('helvetica', 'bold');
            doc.setTextColor(255, 255, 255);
            safeText('MINISTÈRE DE L\'INDUSTRIE ET DU COMMERCE', 105, yPosition + 10, { align: 'center' });

            doc.setFontSize(10);
            safeText(`Direction: ${ensureString(direction.nomDirection)} (n°: ${ensureString(direction.CodeDirection)})`, 105, yPosition + 16, { align: 'center' });
            
            if (direction.statutDirection !== 'ACTIVE') {
                doc.setFontSize(8);
                doc.setTextColor(255, 255, 255, 128);
                safeText('(Direction Désactivée)', 105, yPosition + 20, { align: 'center' });
            }

            yPosition += 30;

            // Date du rapport
            doc.setFontSize(9);
            doc.setTextColor(colors.gray[0], colors.gray[1], colors.gray[2]);
            safeText(`Rapport généré le ${dateRapport}`, 105, yPosition, { align: 'center' });
            
            yPosition += 15;
        };

        // ==================== STATISTIQUES ====================
        const drawStatistics = () => {
            const stats = this.calculateStatistics();
            
            // Titre section
            doc.setFontSize(12);
            doc.setFont('helvetica', 'bold');
            doc.setTextColor(colors.darkGray[0], colors.darkGray[1], colors.darkGray[2]);
            safeText('RÉSUMÉ DU RAPPORT', 105, yPosition, { align: 'center' });
            yPosition += 8;

            // Cartes de statistiques
            const statCards = [
                { 
                    value: ensureString(stats.totalServices), 
                    label: 'Services Total' 
                },
                { 
                    value: ensureString(stats.totalProjets), 
                    label: 'Projets Total' 
                },
                { 
                    value: ensureString(stats.totalTaches), 
                    label: 'Tâches Total' 
                },
                { 
                    value: this.formatBudget(stats.budgetTotal), 
                    label: 'Budget Total' 
                },
                { 
                    value: `${ensureString(stats.avancementMoyen)}%`, 
                    label: 'Avancement Moyen' 
                }
            ];

            const cardWidth = 36;
            const cardHeight = 18;
            const horizontalSpacing = 2;
            const startX = 10;
            
            statCards.forEach((card, index) => {
                const x = startX + index * (cardWidth + horizontalSpacing);
                const y = yPosition;

                // Fond de la carte
                doc.setFillColor(255, 255, 255);
                doc.setDrawColor(colors.border[0], colors.border[1], colors.border[2]);
                doc.setLineWidth(0.3);
                doc.roundedRect(x, y, cardWidth, cardHeight, 2, 2, 'FD');
                
                // Valeur
                doc.setFontSize(10);
                doc.setFont('helvetica', 'bold');
                doc.setTextColor(colors.primary[0], colors.primary[1], colors.primary[2]);
                safeText(ensureString(card.value), x + cardWidth/2, y + 7, { align: 'center' });
                
                // Label
                doc.setFontSize(7);
                doc.setFont('helvetica', 'normal');
                doc.setTextColor(colors.darkGray[0], colors.darkGray[1], colors.darkGray[2]);
                safeText(card.label, x + cardWidth/2, y + 12, { align: 'center' });
            });

            yPosition += 25;
        };

        // ==================== SERVICES ET PROJETS ====================
        const drawServicesAndProjects = () => {
            if (!direction.services || direction.services.length === 0) {
                doc.setFontSize(10);
                doc.setFont('helvetica', 'italic');
                doc.setTextColor(colors.gray[0], colors.gray[1], colors.gray[2]);
                safeText('Aucun service trouvé pour cette direction', 15, yPosition);
                yPosition += 10;
                return;
            }

            direction.services.forEach(service => {
                checkNewPage(40);
                drawServiceHeader(service);
                
                if (service.projets && service.projets.length > 0) {
                    service.projets.forEach(projet => {
                        checkNewPage(80);
                        drawProject(projet, service.statutService === 'DESACTIVE');
                        addVerticalSpace(15); // Espace entre projets
                    });
                } else {
                    drawNoProjects();
                }
                addVerticalSpace(20); // Espace après un service
            });
        };

        const drawServiceHeader = (service) => {
            const isServiceDesactive = service.statutService === 'DESACTIVE';
            const serviceHeaderColor = isServiceDesactive ? colors.gray : colors.blue;

            // En-tête du service
            doc.setFillColor(serviceHeaderColor[0], serviceHeaderColor[1], serviceHeaderColor[2]);
            doc.roundedRect(10, yPosition, 190, 8, 2, 2, 'F');
            
            // Texte du service
            doc.setFontSize(10);
            doc.setFont('helvetica', 'bold');
            doc.setTextColor(255, 255, 255);
            
            let serviceText = `${ensureString(service.nomService)} (n°: ${ensureString(service.CodeService)})`;
            if (isServiceDesactive) serviceText += ' [DÉSACTIVÉ]';
            
            safeText(serviceText, 15, yPosition + 5);
            
            yPosition += 12;
            addVerticalSpace(5); // Espace après l'en-tête du service
        };

        const drawProject = (projet, isServiceDesactive) => {
            const isProjetSuspendu = projet.StatutPro === 'Suspendu';
            
            // Titre du projet avec fond
            doc.setFillColor(248, 250, 252);
            doc.roundedRect(10, yPosition, 190, 8, 1, 1, 'F');
            
            doc.setFontSize(10);
            doc.setFont('helvetica', 'bold');
            const textColor = isProjetSuspendu || isServiceDesactive ? colors.gray : colors.darkGray;
            doc.setTextColor(textColor[0], textColor[1], textColor[2]);
            
            let projetText = `${ensureString(projet.titrePro)}`;
            if (isProjetSuspendu) projetText += ' [SUSPENDU]';
            
            safeText(projetText, 15, yPosition + 5);
            
            // Informations rapides
            doc.setFontSize(7);
            doc.setFont('helvetica', 'normal');
            safeText(`N°: ${ensureString(projet.numProjet)} | Tâches: ${projet.taches ? ensureString(projet.taches.length) : '0'} | Statut: ${ensureString(projet.StatutPro)}`, 185, yPosition + 5, { align: 'right' });
            
            yPosition += 12;
            addVerticalSpace(8);

            // Détails du projet en colonnes
            drawProjectDetails(projet, isProjetSuspendu, isServiceDesactive);
        };

        const drawProjectDetails = (projet, isProjetSuspendu, isServiceDesactive) => {
            const startY = yPosition;

            // === COLONNE GAUCHE ===
            let leftY = startY;

            // Description
            doc.setFontSize(8);
            doc.setFont('helvetica', 'bold');
            doc.setTextColor(colors.primary[0], colors.primary[1], colors.primary[2]);
            safeText('DESCRIPTION', 15, leftY);
            leftY += 5;
            
            doc.setFontSize(7);
            doc.setFont('helvetica', 'normal');
            doc.setTextColor(colors.darkGray[0], colors.darkGray[1], colors.darkGray[2]);
            const description = ensureString(projet.descriptionPro || 'Aucune description fournie');
            const descHeight = addMultilineText(description, 15, leftY, 85, 3.5);
            
            leftY += descHeight + 10;

            // Informations générales
            doc.setFontSize(8);
            doc.setFont('helvetica', 'bold');
            doc.setTextColor(colors.primary[0], colors.primary[1], colors.primary[2]);
            safeText('INFORMATIONS', 15, leftY);
            leftY += 5;
            
            doc.setFontSize(7);
            doc.setFont('helvetica', 'normal');
            doc.setTextColor(colors.darkGray[0], colors.darkGray[1], colors.darkGray[2]);
            
            safeText(`Début: ${this.formatDate(projet.dateDebutPro)}`, 15, leftY);
            leftY += 4.5;
            
            if (projet.dateFinPro) {
                safeText(`Fin: ${this.formatDate(projet.dateFinPro)}`, 15, leftY);
                leftY += 4.5;
            }
            
            safeText(`Budget: ${this.formatBudget(projet.budgetPro)} Ar`, 15, leftY);
            leftY += 4.5;

            // Avancement (juste le pourcentage - sans barre de progression)
            const avancement = projet.avancementPro || 0;
            safeText(`Avancement: ${avancement}%`, 15, leftY);
            leftY += 8; // Réduit l'espace puisque pas de barre

            // === COLONNE DROITE ===
            const rightColX = 110;
            let rightY = startY;

            // Commentaire
            doc.setFontSize(8);
            doc.setFont('helvetica', 'bold');
            doc.setTextColor(colors.primary[0], colors.primary[1], colors.primary[2]);
            safeText('COMMENTAIRE', rightColX, rightY);
            rightY += 5;
            
            doc.setFontSize(7);
            doc.setFont('helvetica', 'normal');
            const commentColor = projet.commentairePro ? [161, 98, 7] : colors.gray;
            doc.setTextColor(commentColor[0], commentColor[1], commentColor[2]);
            const commentaire = ensureString(projet.commentairePro || 'Aucun commentaire');
            const commentHeight = addMultilineText(commentaire, rightColX, rightY, 85, 3.5);
            
            rightY += commentHeight + 12;

            // Équipe
            doc.setFontSize(8);
            doc.setFont('helvetica', 'bold');
            doc.setTextColor(colors.primary[0], colors.primary[1], colors.primary[2]);
            safeText('ÉQUIPE', rightColX, rightY);
            rightY += 5;

            doc.setFontSize(7);
            doc.setFont('helvetica', 'normal');
            doc.setTextColor(colors.darkGray[0], colors.darkGray[1], colors.darkGray[2]);
            
            // Créateur
            if (projet.createur) {
                safeText('Créateur:', rightColX, rightY);
                doc.setFont('helvetica', 'bold');
                safeText(`${ensureString(projet.createur.NomPer)} ${ensureString(projet.createur.PrenomPer || '')}`, rightColX + 18, rightY);
                rightY += 4;
                
                if (projet.createur.ImPer) {
                    doc.setFont('helvetica', 'normal');
                    doc.setFontSize(6);
                    safeText(`IM: ${ensureString(projet.createur.ImPer)}`, rightColX + 18, rightY);
                    rightY += 4;
                }
                doc.setFontSize(7);
            }

            rightY += 3;

            // Responsables
            if (projet.personnels && projet.personnels.length > 0) {
                doc.setFont('helvetica', 'normal');
                safeText('Responsables:', rightColX, rightY);
                rightY += 4;
                
                projet.personnels.forEach((personnel) => {
                    if (rightY > 250) {
                        rightY += 4;
                        return;
                    }
                    
                    doc.setFont('helvetica', 'bold');
                    safeText(`• ${ensureString(personnel.NomPer)} ${ensureString(personnel.PrenomPer || '')}`, rightColX + 5, rightY);
                    
                    if (personnel.ImPer) {
                        doc.setFont('helvetica', 'normal');
                        doc.setFontSize(6);
                        safeText(`(IM: ${ensureString(personnel.ImPer)})`, rightColX + 60, rightY);
                        doc.setFontSize(7);
                    }
                    
                    rightY += 4.5;
                });
            } else {
                safeText('Aucun responsable assigné', rightColX, rightY);
                rightY += 4;
            }

            // Prendre la plus grande hauteur des deux colonnes
            yPosition = Math.max(leftY, rightY) + 8;

            // Tâches
            checkNewPage(40);
            drawProjectTasks(projet.taches, isProjetSuspendu || isServiceDesactive);
        };

        const drawProjectTasks = (taches, isParentInactive) => {
            // Ligne de séparation
            doc.setDrawColor(colors.border[0], colors.border[1], colors.border[2]);
            doc.line(10, yPosition, 200, yPosition);
            yPosition += 10;

            // Titre section tâches
            doc.setFontSize(9);
            doc.setFont('helvetica', 'bold');
            doc.setTextColor(colors.primary[0], colors.primary[1], colors.primary[2]);
            safeText('TÂCHES DU PROJET', 15, yPosition);
            yPosition += 8;

            // En-tête du tableau
            doc.setFillColor(248, 250, 252);
            doc.rect(10, yPosition, 190, 6, 'F');
            doc.setDrawColor(colors.border[0], colors.border[1], colors.border[2]);
            doc.setLineWidth(0.3);
            
            // Bordures verticales
            doc.line(20, yPosition, 20, yPosition + 6);  // #
            doc.line(50, yPosition, 50, yPosition + 6);  // Tâche (plus large)
            doc.line(120, yPosition, 120, yPosition + 6); // Description
            doc.line(150, yPosition, 150, yPosition + 6); // Commentaire
            doc.line(165, yPosition, 165, yPosition + 6); // Avanc.
            doc.line(180, yPosition, 180, yPosition + 6); // Statut
            
            doc.setFontSize(7);
            doc.setFont('helvetica', 'bold');
            doc.setTextColor(colors.darkGray[0], colors.darkGray[1], colors.darkGray[2]);
            
            // En-têtes de colonnes
            safeText('#', 15, yPosition + 4);
            safeText('TÂCHE', 35, yPosition + 4);
            safeText('DESCRIPTION', 85, yPosition + 4);
            safeText('COMMENTAIRE', 135, yPosition + 4);
            safeText('AVANC.', 157, yPosition + 4);
            safeText('STATUT', 172, yPosition + 4);
            
            yPosition += 7;

            // Lignes des tâches
            if (taches && taches.length > 0) {
                taches.forEach((tache, index) => {
                    checkNewPage(20); // Plus d'espace pour le texte multiligne

                    const isTacheSuspendue = tache.statutTache === 'Suspendu';
                    const textColor = isTacheSuspendue || isParentInactive ? colors.gray : colors.darkGray;

                    // Fond alterné pour les lignes
                    if (index % 2 === 0) {
                        doc.setFillColor(253, 253, 254);
                        doc.rect(10, yPosition, 190, 10, 'F'); // Hauteur augmentée
                    }

                    // Numéro de tâche
                    doc.setFontSize(6);
                    doc.setFont('helvetica', 'bold');
                    doc.setTextColor(textColor[0], textColor[1], textColor[2]);
                    safeText(ensureString(tache.numTache), 15, yPosition + 4);
                    
                    // Titre de la tâche (nom complet avec retour à la ligne)
                    const titre = ensureString(tache.titreTache);
                    doc.setFont('helvetica', 'normal');
                    doc.setFontSize(6);
                    const titreLines = doc.splitTextToSize(titre, 40); // Largeur limitée à 40mm
                    safeText(titreLines, 25, yPosition + 4);
                    
                    // Description
                    const description = ensureString(tache.descriptionTache || '---');
                    const descLines = doc.splitTextToSize(description, 50); // Largeur limitée à 50mm
                    safeText(descLines, 55, yPosition + 4);
                    
                    // Commentaire
                    const commentaireTache = ensureString(tache.commentaireTache || '---');
                    const commentColorTache = tache.commentaireTache ? [161, 98, 7] : colors.gray;
                    doc.setTextColor(commentColorTache[0], commentColorTache[1], commentColorTache[2]);
                    const commentLines = doc.splitTextToSize(commentaireTache, 25); // Largeur limitée à 25mm
                    safeText(commentLines, 125, yPosition + 4);
                    doc.setTextColor(textColor[0], textColor[1], textColor[2]);
                    
                    // Avancement (juste le pourcentage)
                    const tacheAvancement = tache.avancementTache || 0;
                    safeText(`${ensureString(tacheAvancement)}%`, 157, yPosition + 4);
                    
                    // Statut
                    safeText(ensureString(tache.statutTache), 172, yPosition + 4);
                    
                    // Ligne séparatrice
                    doc.setDrawColor(colors.border[0], colors.border[1], colors.border[2]);
                    doc.line(10, yPosition + 10, 200, yPosition + 10);
                    
                    yPosition += 12; // Plus d'espace entre les lignes pour le texte multiligne
                });
            } else {
                // Aucune tâche
                doc.setFillColor(255, 255, 255);
                doc.rect(10, yPosition, 190, 8, 'F');
                
                doc.setFontSize(7);
                doc.setFont('helvetica', 'italic');
                doc.setTextColor(colors.gray[0], colors.gray[1], colors.gray[2]);
                safeText('Aucune tâche définie pour ce projet', 105, yPosition + 5, { align: 'center' });
                
                doc.setDrawColor(colors.border[0], colors.border[1], colors.border[2]);
                doc.line(10, yPosition + 8, 200, yPosition + 8);
                
                yPosition += 10;
            }

            yPosition += 10;
        };

        const drawNoProjects = () => {
            doc.setFontSize(8);
            doc.setFont('helvetica', 'italic');
            doc.setTextColor(colors.gray[0], colors.gray[1], colors.gray[2]);
            safeText('Aucun projet dans ce service', 15, yPosition);
            yPosition += 12;
        };

        // ==================== PIED DE PAGE ====================
        const drawFooter = () => {
            const pageCount = doc.internal.getNumberOfPages();
            for (let i = 1; i <= pageCount; i++) {
                doc.setPage(i);
                doc.setFontSize(7);
                doc.setFont('helvetica', 'normal');
                doc.setTextColor(colors.gray[0], colors.gray[1], colors.gray[2]);
                safeText(`Page ${i}/${pageCount}`, 105, 287, { align: 'center' });
                safeText(`Rapport généré le ${dateRapport} - Ministère de l'Industrie et du Commerce`, 105, 290, { align: 'center' });
            }
        };

        // ==================== EXÉCUTION PRINCIPALE ====================
        try {
            drawHeader();
            drawStatistics();
            drawServicesAndProjects();
            drawFooter();

            // Sauvegarder le PDF
            doc.save(`Rapport PTA - ${direction.nomDirection} - ${dateRapport.replace(/\//g, '-')}.pdf`);
            
        } catch (error) {
            console.error('Erreur lors de la génération du PDF:', error);
            this.showError('Erreur lors de la génération du PDF');
        }
    }
}

// Initialisation
document.addEventListener('DOMContentLoaded', function() {
    window.rapportManager = new RapportManager();
    
    // Forcer le bon rendu de Select2 après chargement
    setTimeout(() => {
        const directionSelect = document.getElementById('directionSelect');
        if (directionSelect && directionSelect.innerHTML.includes('Chargement')) {
            // Si le select montre encore "Chargement", on le met à jour avec la valeur "aucun"
            directionSelect.innerHTML = '<option value="aucun">Sélectionnez une direction</option>';
            if (window.rapportManager && window.rapportManager.select2Instance) {
                window.rapportManager.select2Instance.destroy();
                window.rapportManager.initSelect2();
            }
        }
    }, 1000);
});
</script>
{% endblock %}